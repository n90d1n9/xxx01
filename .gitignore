# -------------------------------------------------------------------------
# Monorepo / Multi-App Flutter Core Glob Patterns
# -------------------------------------------------------------------------

# Tooling artifacts (Applies to root and all child apps)
**/**/develop-log.json
**/.pub-cache/
**/.pub/
**/build/
**/.dart_tool/

# Flutter/Dart web dependencies
**/.packages
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/generated_plugin_registrant.dart

# Symbol artifacts
**/*.jmpl
**/*.js.deps
**/*.js.manifest
**/*.js.sourcemap

# -------------------------------------------------------------------------
# Android Child Apps
# -------------------------------------------------------------------------
**/android/**.iml
**/android/.gradle/
**/android/local.properties
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/generated_gradle_redirect.gradle
**/android/app/src/main/res/generated/

# -------------------------------------------------------------------------
# iOS/macOS Child Apps
# -------------------------------------------------------------------------
**/ios/.generated/
**/ios/Flutter/ephemeral/
**/ios/Flutter/Flutter Xcode Generated File/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/**.moved-aside
**/ios/**.mode1v3
**/ios/**.mode2v3
**/ios/**.perspectivev3
**/ios/**/*sync/
**/ios/**/.generated/

# CocoaPods - Ignore Pods folders inside any iOS/macOS directory
**/Pods/
**/.symlinks/
**/xcuserdata/
**/*.xcworkspace/
**/*.xcuserdata/
**/DerivedData/

# -------------------------------------------------------------------------
# Windows/Linux Child Apps
# -------------------------------------------------------------------------
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/

# -------------------------------------------------------------------------
# IDEs and System Files (Universal)
# -------------------------------------------------------------------------
# VS Code
**/.vscode/

# IntelliJ / Android Studio
**/.idea/
**/*.iml
**/*.ipr
**/*.iws

# Operating System Files
**/.DS_Store
**/Thumbs.db

# -------------------------------------------------------------------------
# Rust (Cargo) Child Projects
# -------------------------------------------------------------------------
**/target/
**/*.rs.bk