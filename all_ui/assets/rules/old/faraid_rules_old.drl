rule "Ahli Waris Transgender dalam Faraid"
    salience 40
    agenda-group "special-cases"
    when
        $deceased: FamilyMember(relationName == "deceased")
        $transgenderHeir: FamilyMember(isTransgender == true, isDeceased == false)
    then
        // Dalam Faraid, gender asli (saat lahir) yang digunakan
        executionLog.add("Ahli waris transgender - menggunakan gender asli untuk perhitungan Faraid");
        // Implementasi tergantung pendekatan fiqih yang digunakan
end

// ============================================================================
## KASUS WARIS BERSAMA (JOINT INHERITANCE)
// ============================================================================

rule "Beberapa Orang Meninggal Bersamaan"
    salience 35
    agenda-group "joint-inheritance"
    when
        $deceased1: FamilyMember(relationName == "deceased")
        $deceased2: FamilyMember(relationName == "deceased")
        eval($deceased1.deathDate == $deceased2.deathDate && $deceased1.id != $deceased2.id)
    then
        // Kasus meninggal bersama (seperti dalam kecelakaan)
        executionLog.add("Kasus meninggal bersama terdeteksi - perlu penanganan khusus");
        // Dalam fiqih, ini disebut "al-muwafaqah" atau "al-muharabah"
end

// ============================================================================
## ATURAN MADZHAB UNTUK KASUS KOMPLEKS
// ============================================================================

rule "Madzhab Maliki - Saudara Seibu dengan Ibu"
    salience 30
    agenda-group "school-specific"
    activation-group "maliki-complex"
    when
        calculationMethod == "Maliki"
        $deceased: FamilyMember(relationName == "deceased")
        $mother: FamilyMember(relationName == "mother", isDeceased == false)
        $uterineSibling: FamilyMember(relationName in ("brother", "sister"), maternal == true, isDeceased == false)
    then
        // Dalam Maliki, saudara seibu terhalang oleh ibu
        shares.put($uterineSibling.id, 0.0);
        reasons.put($uterineSibling.id, "Saudara seibu terhalang oleh ibu (Madzhab Maliki)");
        executionLog.add("Madzhab Maliki: Saudara seibu terhalang oleh ibu");
end

rule "Madzhab Syafii - Cucu Perempuan dengan Anak Perempuan"
    salience 30
    agenda-group "school-specific"
    activation-group "syafii-complex"
    when
        calculationMethod == "Syafii"
        $deceased: FamilyMember(relationName == "deceased")
        $daughter: FamilyMember(relationName == "daughter", isDeceased == false)
        $granddaughter: FamilyMember(relationName == "granddaughter", isDeceased == false)
    then
        // Dalam Syafii, cucu perempuan terhalang oleh anak perempuan
        shares.put($granddaughter.id, 0.0);
        reasons.put($granddaughter.id, "Cucu perempuan terhalang oleh anak perempuan (Madzhab Syafii)");
        executionLog.add("Madzhab Syafii: Cucu perempuan terhalang oleh anak perempuan");
end

rule "Madzhab Hanbali - Paman dengan Saudara"
    salience 30
    agenda-group "school-specific"
    activation-group "hanbali-complex"
    when
        calculationMethod == "Hanbali"
        $deceased: FamilyMember(relationName == "deceased")
        not exists FamilyMember(relationName in ("son", "daughter", "father", "mother"), isDeceased == false)
        $sister: FamilyMember(relationName == "sister", isDeceased == false)
        $uncle: FamilyMember(relationName == "uncle", isDeceased == false)
    then
        // Dalam Hanbali, paman dan saudara perempuan berbagi
        shares.put($sister.id, 0.5);
        shares.put($uncle.id, 0.5);
        reasons.put($sister.id, "Saudara perempuan mendapatkan 1/2 (Madzhab Hanbali)");
        reasons.put($uncle.id, "Paman mendapatkan 1/2 sebagai 'asabah (Madzhab Hanbali)");
        executionLog.add("Madzhab Hanbali: Saudara perempuan dan paman berbagi sama");
end

// ============================================================================
## VALIDASI TAMBAHAN UNTUK KASUS KOMPLEKS
// ============================================================================

rule "Validasi Keluarga Besar dengan Banyak Ahli Waris"
    salience 20
    agenda-group "validation"
    when
        $deceased: FamilyMember(relationName == "deceased")
        $allHeirs: List(size > 10) from collect(FamilyMember(relationName != "deceased", isDeceased == false))
    then
        executionLog.add("Keluarga besar terdeteksi dengan " + $allHeirs.size() + " ahli waris");
        validationErrors.add("Keluarga besar kompleks - disarankan konsultasi dengan ahli Faraid");
end

rule "Deteksi Konflik Bagian Warisan"
    salience 15
    agenda-group "validation"
    when
        $deceased: FamilyMember(relationName == "deceased")
        $totalShares: Double() from accumulate($s: FamilyMember(relationName != "deceased", isDeceased == false), sum($s.faraidShare))
        eval($totalShares > 1.0)
    then
        validationErrors.add("Total bagian warisan melebihi 1.0 (" + $totalShares + ") - perlu penyesuaian");
        executionLog.add("Konflik bagian warisan terdeteksi: total = " + $totalShares);
end

// ============================================================================
## ATURAN PENYESUAIAN UNTUK KASUS KOMPLEKS
// ============================================================================

rule "Penyesuaian Bagian untuk Kasus 'Awl"
    salience 10
    agenda-group "adjustments"
    when
        $deceased: FamilyMember(relationName == "deceased")
        $totalShares: Double() from accumulate($s: FamilyMember(relationName != "deceased", isDeceased == false), sum($s.faraidShare))
        eval($totalShares > 1.0)
    then
        // Lakukan 'awl (pengurangan proporsional)
        for (Object heir : collect(FamilyMember(relationName != "deceased", isDeceased == false))) {
            FamilyMember h = (FamilyMember) heir;
            Double adjustedShare = h.faraidShare / $totalShares;
            shares.put(h.id, adjustedShare);
            reasons.put(h.id, "Bagian disesuaikan secara proporsional karena 'awl");
        }
        executionLog.add("Penyesuaian 'awl diterapkan: dari " + $totalShares + " menjadi 1.0");
end

rule "Penyesuaian Bagian untuk Kasus Radd"
    salience 10
    agenda-group "adjustments"
    when
        $deceased: FamilyMember(relationName == "deceased")
        $totalShares: Double() from accumulate($s: FamilyMember(relationName != "deceased", isDeceased == false), sum($s.faraidShare))
        eval($totalShares < 1.0)
        not exists FamilyMember(relationName == "son", isDeceased == false)
        not exists FamilyMember(relationName == "father", isDeceased == false)
        not exists FamilyMember(relationName == "brother", isDeceased == false)
    then
        // Lakukan radd (pengembalian proporsional kepada ahli waris)
        for (Object heir : collect(FamilyMember(relationName != "deceased", isDeceased == false))) {
            FamilyMember h = (FamilyMember) heir;
            Double adjustedShare = h.faraidShare / $totalShares;
            shares.put(h.id, adjustedShare);
            reasons.put(h.id, "Bagian ditambah secara proporsional karena radd");
        }
        executionLog.add("Penyesuaian radd diterapkan: dari " + $totalShares + " menjadi 1.0");
end