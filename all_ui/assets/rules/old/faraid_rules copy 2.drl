package com.estate.faraid

global Map shares;
global Map reasons;
global List executionLog;
global Double remainingShare;
global Double totalEstate;
global String calculationMethod;

// -----------------------------------------------------------------------------
// FIXED SHARES (no-loop + guarded assignments)
// -----------------------------------------------------------------------------

rule "Husband With Children"
salience 200
agenda-group "fixed-shares"
no-loop true
when
    FamilyMember(relationName == "deceased", genderName == "female")
    $h: FamilyMember(relationName == "spouse", genderName == "male", isDeceased == false)
    exists FamilyMember(relationName in ("son","daughter"), isDeceased == false)
then
    if (!shares.containsKey($h.id)) {
        shares.put($h.id, 0.25);
        reasons.put($h.id, "Suami mendapat 1/4 (ada anak) - QS 4:12");
        executionLog.add("Husband gets 1/4");
    }
end

rule "Husband No Child"
salience 200
agenda-group "fixed-shares"
no-loop true
when
    FamilyMember(relationName == "deceased", genderName == "female")
    $h: FamilyMember(relationName == "spouse", genderName == "male", isDeceased == false)
    not FamilyMember(relationName in ("son","daughter"), isDeceased == false)
then
    if (!shares.containsKey($h.id)) {
        shares.put($h.id, 0.5);
        reasons.put($h.id, "Suami mendapat 1/2 (tanpa anak) - QS 4:12");
        executionLog.add("Husband gets 1/2");
    }
end

rule "Wife With Children"
salience 100
agenda-group "fixed-shares"
when
    $w : FamilyMember(relationName == "wife")
    $d : FamilyMember(relationName == "deceased")
    $children : List() from collect(
        FamilyMember(relationName == "son" || relationName == "daughter")
    )
    eval($children.size() > 0)
    eval(!shares.containsKey($w.id))
then
    shares.put($w.id, 0.125);
    reasons.put($w.id, "Wife share (1/8 with children)");
end

rule "Wife Without Children"
salience 200
agenda-group "fixed-shares"
no-loop true
when
    FamilyMember(relationName == "deceased", genderName == "male")
    $w: FamilyMember(relationName == "spouse", genderName == "female", isDeceased == false)
    not FamilyMember(relationName in ("son","daughter"), isDeceased == false)
then
    if (!shares.containsKey($w.id)) {
        shares.put($w.id, 0.25);
        reasons.put($w.id, "Istri mendapat 1/4 (tanpa anak) - QS 4:12");
        executionLog.add("Wife gets 1/4");
    }
end

rule "Mother With Children or Siblings"
salience 190
agenda-group "fixed-shares"
no-loop true
when
    $m: FamilyMember(relationName == "mother", isDeceased == false)
    (
        exists FamilyMember(relationName in ("son","daughter"), isDeceased == false)
        or exists FamilyMember(relationName in ("brother","sister"), isDeceased == false)
    )
then
    if (!shares.containsKey($m.id)) {
        shares.put($m.id, 1.0/6.0);
        reasons.put($m.id, "Ibu mendapat 1/6 - QS 4:11");
        executionLog.add("Mother gets 1/6");
    }
end

rule "Mother No Children No Siblings"
salience 190
agenda-group "fixed-shares"
no-loop true
when
    $m: FamilyMember(relationName == "mother", isDeceased == false)
    not FamilyMember(relationName in ("son","daughter"), isDeceased == false)
    not FamilyMember(relationName in ("brother","sister"), isDeceased == false)
then
    if (!shares.containsKey($m.id)) {
        shares.put($m.id, 1.0/3.0);
        reasons.put($m.id, "Ibu mendapat 1/3 - QS 4:11");
        executionLog.add("Mother gets 1/3");
    }
end

rule "Father With Children"
salience 180
agenda-group "fixed-shares"
no-loop true
when
    $f: FamilyMember(relationName == "father", isDeceased == false)
    exists FamilyMember(relationName in ("son","daughter"), isDeceased == false)
then
    if (!shares.containsKey($f.id)) {
        shares.put($f.id, 1.0/6.0);
        reasons.put($f.id, "Ayah mendapat 1/6 (ada anak) - QS 4:11");
        executionLog.add("Father gets 1/6");
    }
end

rule "Single Daughter Only"
salience 170
agenda-group "fixed-shares"
no-loop true
when
    $d: FamilyMember(relationName == "daughter", isDeceased == false)
    not FamilyMember(relationName == "son", isDeceased == false)
    // ensure there's not a second daughter (engine lacking collect->simple guard)
    not ( FamilyMember(relationName == "daughter", isDeceased == false) and eval(true) )
then
    if (!shares.containsKey($d.id)) {
        shares.put($d.id, 0.5);
        reasons.put($d.id, "Anak perempuan tunggal mendapat 1/2 - QS 4:11");
        executionLog.add("Single daughter gets 1/2");
    }
end

rule "Multiple Daughters Only"
salience 170
agenda-group "fixed-shares"
no-loop true
when
    exists FamilyMember(relationName == "daughter", isDeceased == false)
    exists ( FamilyMember(relationName == "daughter", isDeceased == false) and eval(true) )
    not FamilyMember(relationName == "son", isDeceased == false)
then
    // The programmatic residual rule will compute the split for multiple daughters,
    // but we add a log entry here to indicate detection.
    executionLog.add("Multiple daughters detected (2+), will share 2/3");
end

// -----------------------------------------------------------------------------
// RESIDUAL CALCULATION
// -----------------------------------------------------------------------------

rule "Calculate Remaining Share"
salience -10
agenda-group "residual-calculation"
when
    eval(!internalFlags.containsKey("remainingCalculated"))
then
    double used = 0.0;
    for (String key : shares.keySet()) {
        used += shares.get(key);
    }

    double rem = 1.0 - used;
    if (rem < 0) rem = 0;

    remainingShare.put("value", rem);
    internalFlags.put("remainingCalculated", true);
end

// -----------------------------------------------------------------------------
// CHILDREN RESIDUAL (simple DRL fallback; robust allocation performed in Dart)
// -----------------------------------------------------------------------------

rule "Children Residual (indicator)"
salience -50
agenda-group "residual-distribution"
when
    $children : List() from collect(
        FamilyMember(relationName == "son" || relationName == "daughter")
    )
    eval($children.size() > 0)
    eval(!internalFlags.containsKey("childrenDistributed"))
    $rem : Double() from remainingShare.get("value")
then
    double boys = 0;
    double girls = 0;

    for (Object o : $children) {
        FamilyMember c = (FamilyMember)o;
        if (c.getRelationName().equals("son")) boys++;
        if (c.getRelationName().equals("daughter")) girls++;
    }

    double totalParts = boys * 2 + girls * 1;
    if (totalParts == 0) totalParts = 1;

    for (Object o : $children) {
        FamilyMember c = (FamilyMember)o;

        double part = c.getRelationName().equals("son") ? 2 : 1;
        double share = $rem * (part / totalParts);

        shares.put(c.getId(), share);
        reasons.put(c.getId(), "Residual share for children");
    }

    internalFlags.put("childrenDistributed", true);
end

rule "Father Takes Residual"
salience 80
agenda-group "residual-distribution"
no-loop true
when
    $f: FamilyMember(relationName == "father", isDeceased == false)
    not FamilyMember(relationName in ("son","daughter"), isDeceased == false)
    eval(remainingShare > 0.000001)
then
    if (!shares.containsKey($f.id)) {
        Object o = shares.get($f.id);
        double old = 0.0;
        if (o instanceof Number) old = ((Number)o).doubleValue();
        shares.put($f.id, old + remainingShare);
        reasons.put($f.id, "Ayah mengambil sisa sebagai asabah");
        executionLog.add("Father gets residual");
    }
    remainingShare = 0.0;
end

// -----------------------------------------------------------------------------
// VALIDATION: AWL & RADD (only when NO children exist)
// -----------------------------------------------------------------------------

rule "Apply Awl"
salience 60
agenda-group "validation"
no-loop true
when
    not exists FamilyMember(relationName in ("son","daughter"), isDeceased == false)
    FamilyMember(relationName == "deceased")
then
    Double total = 0.0;
    for (Object v : shares.values()) {
        if (v instanceof Number)
            total = total + ((Number)v).doubleValue();
    }
    if (total > 1.000001) {
        for (Object k : shares.keySet()) {
            Object old = shares.get(k);
            if (old instanceof Number) {
                double adj = ((Number)old).doubleValue() / total;
                shares.put(k, adj);
                reasons.put(k, "Dikenakan 'awl (pengurangan proporsional)");
            }
        }
        executionLog.add("Applied AWL");
    }
end

rule "Apply Radd"
salience 60
agenda-group "validation"
no-loop true
when
    not exists FamilyMember(relationName in ("son","daughter"), isDeceased == false)
    FamilyMember(relationName == "deceased")
    eval(remainingShare > 0.0001)
then
    Double total = 0.0;
    for (Object v : shares.values()) {
        if (v instanceof Number) total = total + ((Number)v).doubleValue();
    }
    if (total > 0) {
        for (Object k : shares.keySet()) {
            double base = ((Number)shares.get(k)).doubleValue();
            double addition = base / total * remainingShare;
            shares.put(k, base + addition);
            reasons.put(k, "Dikenakan radd (penambahan proporsional)");
        }
        remainingShare = 0.0;
        executionLog.add("Applied RADD");
    }
end

// -----------------------------------------------------------------------------
// COMPLETION
// -----------------------------------------------------------------------------
rule "Finish"
salience 1
agenda-group "completion"
no-loop true
when
    FamilyMember(relationName == "deceased")
then
    executionLog.add("Faraid calculation completed.");
end
