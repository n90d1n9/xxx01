  Future<void> initializeModel() async {
    // Load pre-trained TensorFlow Lite model
    _interpreter = await Interpreter.fromAsset('service_health_predictor.tflite');
  }

  Future<ServicePrediction> predictServiceHealth(
    List<double> historicalMetrics
  ) async {
    // Prepare input tensor
    var input = Float32List.fromList(historicalMetrics);
    var output = Float32List(2); // [health_score, failure_probability]

    // Run inference
    _interpreter.run(input, output);

    return ServicePrediction(
      healthScore: output[0],
      failureProbability: output[1]
    );
  }

