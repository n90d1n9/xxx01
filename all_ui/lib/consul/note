        providers: [
          Provider.value(value: configManager),
          Provider.value(value: healthMonitor),
          Provider.value(value: autoRegistrar),
          Provider.value(value: performanceTracker),
          // Add other providers
        ],
        child: ConsulServiceDiscoveryApp(),
      ),
    ),
  );
}

