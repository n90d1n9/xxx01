class MultiClusterManager {
  final Map<String, ClusterConfiguration> _clusters = {};

  void registerCluster(ClusterConfiguration cluster) {
    _clusters[cluster.clusterId] = cluster;
  }

  Future<List<ServiceMetadata>> discoverServicesAcrossClusters() async {
    final List<ServiceMetadata> globalServices = [];

    for (var cluster in _clusters.values) {
      final clusterServices = await _fetchClusterServices(cluster);
      globalServices.addAll(clusterServices);
    }

    return globalServices;
  }

