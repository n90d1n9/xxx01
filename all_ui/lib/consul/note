// models/service_model.dart
import 'package:freezed_annotation/freezed_annotation.dart';
import 'package:flutter/foundation.dart';

part 'service_model.freezed.dart';
part 'service_model.g.dart';

@freezed
class ServiceEntry with _$ServiceEntry {
  const factory ServiceEntry({
    required String serviceName,
    required String nodeAddress,
    required int port,
    @Default(false) bool isHealthy,
    @Default({}) Map<String, String> tags,
  }) = _ServiceEntry;

  factory ServiceEntry.fromJson(Map<String, dynamic> json) => _$ServiceEntryFromJson(json);
}

// providers/consul_provider.dart
import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:dio/dio.dart';
import '../models/service_model.dart';

class ConsulService {
  final Dio _dio;

  ConsulService(this._dio);

  Future<List<ServiceEntry>> fetchServices() async {
    try {
      final response = await _dio.get('/v1/catalog/services');
      final serviceNames = (response.data as Map<String, dynamic>).keys.toList();
      
      List<ServiceEntry> services = [];
      for (var serviceName in serviceNames) {
        final serviceResponse = await _dio.get('/v1/catalog/service/$serviceName');
        services.addAll(
          (serviceResponse.data as List)
            .map((service) => ServiceEntry.fromJson(service))
            .toList()
        );
      }
      
      return services;
    } catch (e) {
      throw Exception('Failed to fetch services: $e');
    }
  }

  Future<void> registerService(ServiceEntry service) async {
    try {
      await _dio.put('/v1/agent/service/register', data: {
        'Name': service.serviceName,
        'Address': service.nodeAddress,
        'Port': service.port,
        'Tags': service.tags,
      });
    } catch (e) {
      throw Exception('Failed to register service: $e');
    }
  }
}

// providers/consul_provider.dart continued
final dioProvider = Provider<Dio>((ref) {
  return Dio(BaseOptions(
    baseUrl: 'http://localhost:8500', // Default Consul URL
    connectTimeout: const Duration(seconds: 5),
    receiveTimeout: const Duration(seconds: 5),
  ));
});

final consulServiceProvider = Provider<ConsulService>((ref) {
  final dio = ref.watch(dioProvider);
  return ConsulService(dio);
});

final servicesProvider = StateNotifierProvider<ServicesNotifier, List<ServiceEntry>>((ref) {
  final consulService = ref.watch(consulServiceProvider);
  return ServicesNotifier(consulService);
});

class ServicesNotifier extends StateNotifier<List<ServiceEntry>> {
  final ConsulService _consulService;

  ServicesNotifier(this._consulService) : super([]);

  Future<void> fetchServices() async {
    try {
      state = await _consulService.fetchServices();
    } catch (e) {
      state = [];
      // Consider adding error handling mechanism
    }
  }

  Future<void> registerService(ServiceEntry service) async {
    try {
      await _consulService.registerService(service);
      await fetchServices(); // Refresh the list after registration
    } catch (e) {
      // Consider adding error handling mechanism
    }
  }
}



// screens/service_discovery_screen.dart
import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import '../providers/consul_provider.dart';
import '../models/service_model.dart';

class ServiceDiscoveryScreen extends ConsumerStatefulWidget {
  const ServiceDiscoveryScreen({Key? key}) : super(key: key);

  @override
  _ServiceDiscoveryScreenState createState() => _ServiceDiscoveryScreenState();
}

class _ServiceDiscoveryScreenState extends ConsumerState<ServiceDiscoveryScreen> {
  final _formKey = GlobalKey<FormState>();
  final _serviceNameController = TextEditingController();
  final _addressController = TextEditingController();
  final _portController = TextEditingController();

  @override
  void initState() {
    super.initState();
    // Fetch services when the screen initializes
    WidgetsBinding.instance.addPostFrameCallback((_) {
      ref.read(servicesProvider.notifier).fetchServices();
    });
  }

  void _showRegisterServiceBottomSheet() {
    showModalBottomSheet(
      context: context,
      isScrollControlled: true,
      builder: (context) => Padding(
        padding: EdgeInsets.only(
          bottom: MediaQuery.of(context).viewInsets.bottom,
          top: 20,
          left: 20,
          right: 20,
        ),
        child: Form(
          key: _formKey,
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              Text(
                'Register New Service',
                style: Theme.of(context).textTheme.headlineSmall,
              ),
              const SizedBox(height: 20),
              TextFormField(
                controller: _serviceNameController,
                decoration: const InputDecoration(
                  labelText: 'Service Name',
                  border: OutlineInputBorder(),
                ),
                validator: (value) => 
                  value == null || value.isEmpty ? 'Please enter service name' : null,
              ),
              const SizedBox(height: 15),
              TextFormField(
                controller: _addressController,
                decoration: const InputDecoration(
                  labelText: 'Node Address',
                  border: OutlineInputBorder(),
                ),
                validator: (value) => 
                  value == null || value.isEmpty ? 'Please enter node address' : null,
              ),
              const SizedBox(height: 15),
              TextFormField(
                controller: _portController,
                decoration: const InputDecoration(
                  labelText: 'Port',
                  border: OutlineInputBorder(),
                ),
                keyboardType: TextInputType.number,
                validator: (value) => 
                  value == null || value.isEmpty ? 'Please enter port' : null,
              ),
              const SizedBox(height: 20),
              ElevatedButton(
                onPressed: () {
                  if (_formKey.currentState!.validate()) {
                    final service = ServiceEntry(
                      serviceName: _serviceNameController.text,
                      nodeAddress: _addressController.text,
                      port: int.parse(_portController.text),
                      isHealthy: true,
                      tags: {'managed-by-app': 'true'},
                    );
                    
                    ref.read(servicesProvider.notifier)
                      .registerService(service)
                      .then((_) {
                        Navigator.of(context).pop();
                        ScaffoldMessenger.of(context).showSnackBar(
                          const SnackBar(content: Text('Service Registered Successfully'))
                        );
                      });
                  }
                },
                child: const Text('Register Service'),
              ),
              const SizedBox(height: 20),
            ],
          ),
        ),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    final services = ref.watch(servicesProvider);

    return Scaffold(
      appBar: AppBar(
        title: const Text('Consul Service Discovery'),
        actions: [
          IconButton(
            icon: const Icon(Icons.refresh),
            onPressed: () => ref.read(servicesProvider.notifier).fetchServices(),
          ),
        ],
      ),
      body: services.isEmpty
        ? const Center(child: CircularProgressIndicator())
        : ListView.builder(
            itemCount: services.length,
            itemBuilder: (context, index) {
              final service = services[index];
              return Card(
                margin: const EdgeInsets.symmetric(horizontal: 10, vertical: 5),
                child: ListTile(
                  title: Text(
                    service.serviceName,
                    style: Theme.of(context).textTheme.titleMedium,
                  ),
                  subtitle: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      Text('Address: ${service.nodeAddress}:${service.port}'),
                      Text(
                        'Status: ${service.isHealthy ? 'Healthy' : 'Unhealthy'}',
                        style: TextStyle(
                          color: service.isHealthy ? Colors.green : Colors.red,
                        ),
                      ),
                    ],
                  ),
                  trailing: service.tags.isNotEmpty
                    ? Chip(
                        label: Text(service.tags.keys.first),
                        backgroundColor: Colors.blue.shade100,
                      )
                    : null,
                ),
              );
            },
          ),
      floatingActionButton: FloatingActionButton(
        onPressed: _showRegisterServiceBottomSheet,
        child: const Icon(Icons.add),
      ),
    );
  }

  @override
  void dispose() {
    _serviceNameController.dispose();
    _addressController.dispose();
    _portController.dispose();
    super.dispose();
  }
}


