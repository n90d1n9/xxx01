}


// lib/core/di/service_locator.dart
import 'package:get_it/get_it.dart';
import 'package:dio/dio.dart';

class ServiceLocator {
  static final GetIt _getIt = GetIt.instance;

  static void setup() {
    // Dio Configuration with Advanced Interceptors
    _getIt.registerLazySingleton<Dio>(() {
      final dio = Dio(BaseOptions(
        baseUrl: 'http://localhost:8500',
        connectTimeout: const Duration(seconds: 10),
        receiveTimeout: const Duration(seconds: 10),
      ));

      // Add Interceptors
      dio.interceptors.addAll([
        LoggingInterceptor(),
        RetryInterceptor(
          dio: dio,
          retries: 3,
          retryDelays: [
            const Duration(seconds: 1),
            const Duration(seconds: 3),
            const Duration(seconds: 5),
          ],
        ),
      ]);

      return dio;
    });

    // Repositories
    _getIt.registerLazySingleton<ConsulRepository>(
      () => ConsulRepositoryImpl(_getIt<Dio>())
    );

    // Add more dependencies as needed
  }

  // Helper method to get dependencies
  static T get<T extends Object>() => _getIt<T>();
}

// Configuration Management
class AppConfig {
  static const String consulBaseUrl = 'http://localhost:8500';
  static const int connectTimeout = 10000;
  static const int receiveTimeout = 10000;
  
  // Environment-specific configurations
  static Map<String, dynamic> getEnvironmentConfig(String env) {
    switch (env) {
      case 'development':
        return {
          'baseUrl': 'http://localhost:8500',
          'logLevel': LogLevel.debug,
        };
      case 'production':
        return {
          'baseUrl': 'https://consul.production.com',
          'logLevel': LogLevel.error,
        };
      default:
        return {};
    }
  }
}


// lib/services/health_monitoring_service.dart
import 'dart:async';
import 'package:dio/dio.dart';
import 'package:rxdart/rxdart.dart';

class ServiceHealthMonitor {
  final Dio _dio;
  final _healthSubject = BehaviorSubject<Map<String, ServiceHealthStatus>>();

  ServiceHealthMonitor(this._dio);

  Stream<Map<String, ServiceHealthStatus>> get healthStream => _healthSubject.stream;

  // Continuous health checking
  Timer? _healthCheckTimer;

  void startContinuousMonitoring(List<String> services, {Duration interval = const Duration(minutes: 1)}) {
    _healthCheckTimer = Timer.periodic(interval, (_) => checkServicesHealth(services));
  }

  Future<void> checkServicesHealth(List<String> services) async {
    final healthStatuses = <String, ServiceHealthStatus>{};

    for (var service in services) {
      try {
        final startTime = DateTime.now();
        final response = await _dio.get('/v1/health/service/$service');
        final endTime = DateTime.now();

        final health = _evaluateServiceHealth(response.data, startTime, endTime);
        healthStatuses[service] = health;
      } catch (e) {
        healthStatuses[service] = ServiceHealthStatus(
          isHealthy: false,
          lastChecked: DateTime.now(),
          errorMessage: e.toString(),
        );
      }
    }

    _healthSubject.add(healthStatuses);
  }

  ServiceHealthStatus _evaluateServiceHealth(
    dynamic serviceData, 
    DateTime startTime, 
    DateTime endTime
  ) {
    final responseTime = endTime.difference(startTime).inMilliseconds;
    
    return ServiceHealthStatus(
      isHealthy: true,
      lastChecked: DateTime.now(),
      responseTime: responseTime,
      checks: {
        'availability': true,
        'responseTime': responseTime < 500, // < 500ms is considered good
      },
    );
  }

  void dispose() {
    _healthCheckTimer?.cancel();
    _healthSubject.close();
  }
}

class ServiceHealthStatus {
  final bool isHealthy;
  final DateTime lastChecked;
  final int? responseTime;
  final String? errorMessage;
  final Map<String, bool>? checks;

  ServiceHealthStatus({
    required this.isHealthy,
    required this.lastChecked,
    this.responseTime,
    this.errorMessage,
    this.checks,
  });
}


// lib/services/service_auto_registrar.dart
import 'dart:io';
import 'package:dio/dio.dart';
import 'package:network_info_plus/network_info_plus.dart';

class ServiceAutoRegistrar {
  final Dio _dio;
  final NetworkInfo _networkInfo;

  ServiceAutoRegistrar(this._dio, this._networkInfo);

  Future<void> autoRegisterService({
    required String serviceName,
    int? port,
    List<String> tags = const [],
  }) async {
    // Automatically detect network and system details
    final ipAddress = await _networkInfo.getWifiIP();
    final hostname = Platform.localHostname;
    
    // Generate unique service ID
    final serviceId = _generateServiceId(serviceName, ipAddress);

    // Prepare registration payload
    final registrationPayload = {
      'ID': serviceId,
      'Name': serviceName,
      'Address': ipAddress,
      'Port': port ?? _findAvailablePort(),
      'Tags': [
        ...tags,
        'auto-registered',
        'platform:${Platform.operatingSystem}',
      ],
      'Check': {
        'HTTP': 'http://$ipAddress:${port ?? _findAvailablePort()}/health',
        'Interval': '10s',
        'Timeout': '5s',
      },
    };

    try {
      await _dio.put('/v1/agent/service/register', data: registrationPayload);
      print('Service $serviceName auto-registered successfully');
    } catch (e) {
      print('Failed to auto-register service: $e');
    }
  }

  // Find an available port
  int _findAvailablePort() {
    // Implement port availability check
    return 8080; // Placeholder
  }

  // Generate a unique service ID
  String _generateServiceId(String serviceName, String? ipAddress) {
    final timestamp = DateTime.now().millisecondsSinceEpoch;
    return '$serviceName-${ipAddress ?? 'unknown'}-$timestamp';
  }

  // Automated deregistration
  Future<void> deregisterService(String serviceId) async {
    try {
      await _dio.put('/v1/agent/service/deregister/$serviceId');
      print('Service $serviceId deregistered successfully');
    } catch (e) {
      print('Failed to deregister service: $e');
    }
  }
}

// lib/models/service_dependency.dart
import 'package:graph/graph.dart';

class ServiceDependencyGraph {
  final DiGraph<String> _dependencyGraph = DiGraph<String>();
  
  // Add a service dependency
  void addDependency(String sourceService, String targetService) {
    _dependencyGraph.addEdge(sourceService, targetService);
  }

  // Remove a service dependency
  void removeDependency(String sourceService, String targetService) {
    _dependencyGraph.removeEdge(sourceService, targetService);
  }

  // Get direct dependencies of a service
  List<String> getDirectDependencies(String service) {
    return _dependencyGraph.successors(service).toList();
  }

  // Get services that depend on a given service
  List<String> getServiceDependents(String service) {
    return _dependencyGraph.predecessors(service).toList();
  }

  // Find all transitive dependencies
  List<String> getTransitiveDependencies(String service) {
    final visited = <String>{};
    final dependencies = <String>[];

    void traverse(String currentService) {
      for (var dependency in _dependencyGraph.successors(currentService)) {
        if (!visited.contains(dependency)) {
          visited.add(dependency);
          dependencies.add(dependency);
          traverse(dependency);
        }
      }
    }

    traverse(service);
    return dependencies;
  }

  // Detect circular dependencies
  bool hasCircularDependency() {
    for (var service in _dependencyGraph.vertices) {
      if (_hasCircularPath(service)) {
        return true;
      }
    }
    return false;
  }

  bool _hasCircularPath(String service) {
    final visited = <String>{};
    final path = <String>{};

    bool dfs(String currentService) {
      visited.add(currentService);
      path.add(currentService);

      for (var dependency in _dependencyGraph.successors(currentService)) {
        if (path.contains(dependency)) {
          return true;
        }
        if (!visited.contains(dependency)) {
          if (dfs(dependency)) {
            return true;
          }
        }
      }

      path.remove(currentService);
      return false;
    }

    return dfs(service);
  }

  // Visualize dependency graph (could be expanded to generate GraphViz DOT)
  String generateDependencyVisualization() {
    final buffer = StringBuffer();
    buffer.writeln('digraph ServiceDependencies {');
    
    for (var vertex in _dependencyGraph.vertices) {
      for (var dependency in _dependencyGraph.successors(vertex)) {
        buffer.writeln('  "$vertex" -> "$dependency";');
      }
    }
    
    buffer.writeln('}');
    return buffer.toString();
  }
}

// lib/services/performance_metrics_tracker.dart
import 'dart:async';
import 'package:collection/collection.dart';

class PerformanceMetricsTracker {
  // Metrics storage
  final _serviceMetrics = <String, ServicePerformanceMetrics>{};
  
  // Streams for real-time metrics
  final _metricsStreamController = StreamController<Map<String, ServicePerformanceMetrics>>.broadcast();
  
  Stream<Map<String, ServicePerformanceMetrics>> get metricsStream => _metricsStreamController.stream;

  // Track request performance
  void trackRequestPerformance(
    String serviceName, {
    required Duration duration,
    bool isSuccess = true,
  }) {
    if (!_serviceMetrics.containsKey(serviceName)) {
      _serviceMetrics[serviceName] = ServicePerformanceMetrics(serviceName);
    }

    _serviceMetrics[serviceName]!.addRequestMetric(
      duration: duration,
      isSuccess: isSuccess,
    );

    _metricsStreamController.add(_serviceMetrics);
  }

  // Aggregate performance summary
  ServicePerformanceSummary getPerformanceSummary(String serviceName) {
    final metrics = _serviceMetrics[serviceName];
    if (metrics == null) {
      return ServicePerformanceSummary.empty(serviceName);
    }

    return ServicePerformanceSummary(
      serviceName: serviceName,
      totalRequests: metrics.totalRequests,
      successRate: metrics.successRate,
      averageResponseTime: metrics.averageResponseTime,
      p95ResponseTime: metrics.p95ResponseTime,
    );
  }

  void dispose() {
    _metricsStreamController.close();
  }
}

class ServicePerformanceMetrics {
  final String serviceName;
  final List<Duration> _responseTimes = [];
  final List<bool> _requestStatuses = [];

  ServicePerformanceMetrics(this.serviceName);

  void addRequestMetric({
    required Duration duration,
    required bool isSuccess,
  }) {
    _responseTimes.add(duration);
    _requestStatuses.add(isSuccess);
  }

  int get totalRequests => _responseTimes.length;
  
  double get successRate {
    if (_requestStatuses.isEmpty) return 0.0;
    return _requestStatuses.where((status) => status).length / _requestStatuses.length;
  }

  Duration get averageResponseTime {
    if (_responseTimes.isEmpty) return Duration.zero;
    return Duration(
      microseconds: (_responseTimes.map((d) => d.inMicroseconds).sum / _responseTimes.length).round(),
    );
  }

  Duration get p95ResponseTime {
    if (_responseTimes.isEmpty) return Duration.zero;
    final sortedTimes = List<Duration>.from(_responseTimes)..sort();
    final index = (sortedTimes.length * 0.95).floor();
    return sortedTimes[index];
  }
}

class ServicePerformanceSummary {
  final String serviceName;
  final int totalRequests;
  final double successRate;
  final Duration averageResponseTime;
  final Duration p95ResponseTime;

  ServicePerformanceSummary({
    required this.serviceName,
    required this.totalRequests,
    required this.successRate,
    required this.averageResponseTime,
    required this.p95ResponseTime,
  });

  factory ServicePerformanceSummary.empty(String serviceName) {
    return ServicePerformanceSummary(
      serviceName: serviceName,
      totalRequests: 0,
      successRate: 0.0,
      averageResponseTime: Duration.zero,
      p95ResponseTime: Duration.zero,
    );
  }

  Map<String, dynamic> toJson() => {
    'serviceName': serviceName,
    'totalRequests': totalRequests,
    'successRate': successRate,
    'averageResponseTime': averageResponseTime.inMilliseconds,
    'p95ResponseTime': p95ResponseTime.inMilliseconds,
  };
}


// lib/services/config_management.dart
import 'dart:convert';
import 'package:flutter_secure_storage/flutter_secure_storage.dart';
import 'package:rxdart/rxdart.dart';

class CentralizedConfigManager {
  final FlutterSecureStorage _secureStorage;
  
  // Configuration streams for real-time updates
  final _configSubject = BehaviorSubject<Map<String, dynamic>>();
  
  CentralizedConfigManager(this._secureStorage) {
    // Load initial configuration
    _loadSavedConfigurations();
  }

  Stream<Map<String, dynamic>> get configStream => _configSubject.stream;

  // Load saved configurations
  Future<void> _loadSavedConfigurations() async {
    final savedConfig = await _secureStorage.read(key: 'app_configuration');
    if (savedConfig != null) {
      _configSubject.add(json.decode(savedConfig));
    }
  }

  // Update configuration
  Future<void> updateConfiguration(Map<String, dynamic> newConfig) async {
    // Merge with existing configuration
    final currentConfig = _configSubject.valueOrNull ?? {};
    final mergedConfig = {
      ...currentConfig,
      ...newConfig,
    };

    // Save to secure storage
    await _secureStorage.write(
      key: 'app_configuration', 
      value: json.encode(mergedConfig)
    );

    // Update stream
    _configSubject.add(mergedConfig);
  }

  // Get specific configuration value
  dynamic getConfigValue(String key, {dynamic defaultValue}) {
    final currentConfig = _configSubject.valueOrNull ?? {};
    return currentConfig[key] ?? defaultValue;
  }

  // Environment-specific configurations
  Future<void> setEnvironment(String environment) async {
    final environmentConfigs = {
      'development': {
        'consulUrl': 'http://localhost:8500',
        'logLevel': 'DEBUG',
        'featureFlags': {
          'enableAutoRegistration': true,
          'enableHealthMonitoring': true,
        }
      },
      'production': {
        'consulUrl': 'https://consul.production.com',
        'logLevel': 'ERROR',
        'featureFlags': {
          'enableAutoRegistration': false,
          'enableHealthMonitoring': true,
        }
      }
    };

    await updateConfiguration(
      environmentConfigs[environment] ?? {}
    );
  }

  // Dynamic feature flag management
  bool isFeatureEnabled(String featureName) {
    final featureFlags = getConfigValue('featureFlags', defaultValue: {});
    return featureFlags[featureName] ?? false;
  }

  void dispose() {
    _configSubject.close();
  }
}

// Usage Example
class AppConfigKeys {
  static const consulUrl = 'consulUrl';
  static const logLevel = 'logLevel';
  static const featureFlags = 'featureFlags';
}


