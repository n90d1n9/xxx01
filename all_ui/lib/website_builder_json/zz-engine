/// Lazy loading for heavy components
class LazyLoadedComponent extends StatefulWidget {
  final Component component;
  final SchemaEngine engine;

  const LazyLoadedComponent({
    Key? key,
    required this.component,
    required this.engine,
  }) : super(key: key);

  @override
  State<LazyLoadedComponent> createState() => _LazyLoadedComponentState();
}

class _LazyLoadedComponentState extends State<LazyLoadedComponent> {
  bool _isVisible = false;

  @override
  Widget build(BuildContext context) {
    return VisibilityDetector(
      key: Key(widget.component.id),
      onVisibilityChanged: (info) {
        if (info.visibleFraction > 0 && !_isVisible) {
          setState(() => _isVisible = true);
        }
      },
      child: _isVisible
          ? widget.engine.renderComponent(widget.component)
          : const SizedBox(height: 200),
    );
  }
}

