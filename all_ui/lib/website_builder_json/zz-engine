class CarouselRenderer extends ComponentRenderer {
  @override
  Widget render(Component component, SchemaEngine engine) {
    final props = component.props ?? {};
    final autoPlay = props['autoPlay'] ?? false;
    final interval = props['interval'] ?? 3000;

    return PageView.builder(
      itemCount: component.children?.length ?? 0,
      itemBuilder: (context, index) {
        return engine.renderComponent(component.children![index]);
      },
    );
  }
}

class AccordionRenderer extends ComponentRenderer {
  @override
  Widget render(Component component, SchemaEngine engine) {
    return ExpansionTile(
      title: Text(component.props?['title'] ?? 'Accordion'),
      children: component.children?.map((c) => engine.renderComponent(c)).toList() ?? [],
    );
  }
}

class TabsRenderer extends ComponentRenderer {
  @override
  Widget render(Component component, SchemaEngine engine) {
    final tabs = component.props?['tabs'] as List? ?? [];
    
    return DefaultTabController(
      length: tabs.length,
      child: Column(
        children: [
          TabBar(
            tabs: tabs.map((tab) => Tab(text: tab['label'])).toList(),
          ),
          Expanded(
            child: TabBarView(
              children: tabs.map((tab) {
                final content = tab['content'] as Component?;
                return content != null ? engine.renderComponent(content) : const SizedBox();
              }).toList(),
            ),
          ),
        ],
      ),
    );
  }
}

class CardRenderer extends ComponentRenderer {
  @override
  Widget render(Component component, SchemaEngine engine) {
    return Card(
      elevation: component.props?['elevation']?.toDouble() ?? 2.0,
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: component.children?.map((c) => engine.renderComponent(c)).toList() ?? [],
        ),
      ),
    );
  }
}

