/// Form state management
class FormStateManager {
  final Map<String, dynamic> _formData = {};
  final Map<String, String?> _errors = {};

  dynamic getValue(String key) => _formData[key];
  
  void setValue(String key, dynamic value) {
    _formData[key] = value;
  }

  void setError(String key, String? error) {
    _errors[key] = error;
  }

  String? getError(String key) => _errors[key];

  Map<String, dynamic> getData() => Map.from(_formData);

  bool validate(List<ValidationRule> rules, String fieldName) {
    final value = _formData[fieldName];
    
    for (final rule in rules) {
      switch (rule.type) {
        case 'required':
          if (value == null || value.toString().isEmpty) {
            setError(fieldName, rule.message ?? 'This field is required');
            return false;
          }
          break;
        case 'email':
          if (value != null && !_isValidEmail(value.toString())) {
            setError(fieldName, rule.message ?? 'Invalid email address');
            return false;
          }
          break;
        case 'minLength':
          if (value != null && value.toString().length < (rule.value as int)) {
            setError(fieldName, rule.message ?? 'Minimum length is ${rule.value}');
            return false;
          }
          break;
        case 'maxLength':
          if (value != null && value.toString().length > (rule.value as int)) {
            setError(fieldName, rule.message ?? 'Maximum length is ${rule.value}');
            return false;
          }
          break;
      }
    }
    
    setError(fieldName, null);
    return true;
  }

  bool _isValidEmail(String email) {
    return RegExp(r'^[\w-\.]+@([\w-]+\.)+[\w-]{2,4}).hasMatch(email);
  }

  void clear() {
    _formData.clear();
    _errors.clear();
  }
}

/// Data binding helper
class DataBinding {
  static dynamic resolveValue(String path, Map<String, dynamic> data) {
    final parts = path.split('.');
    dynamic current = data;
    
    for (final part in parts) {
      if (current is Map) {
        current = current[part];
      } else {
        return null;
      }
    }
    
    return current;
  }

  static void setValue(String path, dynamic value, Map<String, dynamic> data) {
    final parts = path.split('.');
    Map<String, dynamic> current = data;
    
    for (int i = 0; i < parts.length - 1; i++) {
      if (!current.containsKey(parts[i])) {
        current[parts[i]] = <String, dynamic>{};
      }
      current = current[parts[i]] as Map<String, dynamic>;
    }
    
    current[parts.last] = value;
  }
}

