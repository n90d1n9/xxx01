class _ContentTab extends ConsumerWidget {
  final Component component;

  const _ContentTab({required this.component});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    return ListView(
      padding: const EdgeInsets.all(16),
      children: [
        ...._buildContentFields(component.type, component.props ?? {}, ref),
      ],
    );
  }

  List<Widget> _buildContentFields(
    String type,
    Map<String, dynamic> props,
    WidgetRef ref,
  ) {
    switch (type) {
      case 'text':
      case 'heading':
        return [
          _PropertyLabel('Content'),
          TextField(
            controller: TextEditingController(text: props['content'] ?? ''),
            decoration: const InputDecoration(
              border: OutlineInputBorder(),
              hintText: 'Enter text...',
            ),
            maxLines: 3,
            onChanged: (value) => _updateProp(ref, 'content', value),
          ),
          const SizedBox(height: 16),
          _PropertyLabel('Tag'),
          DropdownButtonFormField<String>(
            value: props['tag'] ?? 'p',
            decoration: const InputDecoration(border: OutlineInputBorder()),
            items: const [
              DropdownMenuItem(value: 'p', child: Text('Paragraph')),
              DropdownMenuItem(value: 'h1', child: Text('H1')),
              DropdownMenuItem(value: 'h2', child: Text('H2')),
              DropdownMenuItem(value: 'h3', child: Text('H3')),
              DropdownMenuItem(value: 'h4', child: Text('H4')),
              DropdownMenuItem(value: 'span', child: Text('Span')),
            ],
            onChanged: (value) => _updateProp(ref, 'tag', value),
          ),
        ];
      case 'image':
        return [
          _PropertyLabel('Image URL'),
          TextField(
            controller: TextEditingController(text: props['src'] ?? ''),
            decoration: const InputDecoration(
              border: OutlineInputBorder(),
              hintText: 'https://...',
            ),
            onChanged: (value) => _updateProp(ref, 'src', value),
          ),
          const SizedBox(height: 16),
          _PropertyLabel('Alt Text'),
          TextField(
            controller: TextEditingController(text: props['alt'] ?? ''),
            decoration: const InputDecoration(
              border: OutlineInputBorder(),
              hintText: 'Image description',
            ),
            onChanged: (value) => _updateProp(ref, 'alt', value),
          ),
          const SizedBox(height: 16),
          _PropertyLabel('Fit'),
          DropdownButtonFormField<String>(
            value: props['fit'] ?? 'cover',
            decoration: const InputDecoration(border: OutlineInputBorder()),
            items: const [
              DropdownMenuItem(value: 'cover', child: Text('Cover')),
              DropdownMenuItem(value: 'contain', child: Text('Contain')),
              DropdownMenuItem(value: 'fill', child: Text('Fill')),
              DropdownMenuItem(value: 'fitWidth', child: Text('Fit Width')),
              DropdownMenuItem(value: 'fitHeight', child: Text('Fit Height')),
            ],
            onChanged: (value) => _updateProp(ref, 'fit', value),
          ),
        ];
      case 'button':
        return [
          _PropertyLabel('Button Text'),
          TextField(
            controller: TextEditingController(text: props['text'] ?? ''),
            decoration: const InputDecoration(
              border: OutlineInputBorder(),
              hintText: 'Button text',
            ),
            onChanged: (value) => _updateProp(ref, 'text', value),
          ),
          const SizedBox(height: 16),
          _PropertyLabel('Variant'),
          SegmentedButton<String>(
            segments: const [
              ButtonSegment(value: 'contained', label: Text('Contained')),
              ButtonSegment(value: 'outlined', label: Text('Outlined')),
              ButtonSegment(value: 'text', label: Text('Text')),
            ],
            selected: {props['variant'] ?? 'contained'},
            onSelectionChanged: (set) => _updateProp(ref, 'variant', set.first),
          ),
        ];
      default:
        return [
          Text(
            'No content properties available',
            style: TextStyle(color: Colors.grey[600]),
          ),
        ];
    }
  }

  void _updateProp(WidgetRef ref, String key, dynamic value) {
    final updatedProps = {...component.props ?? {}, key: value};
    final updated = component.copyWith(props: updatedProps);
    ref.read(builderStateProvider.notifier).updateComponent(component.id, updated);
  }
}

class _StyleTab extends ConsumerWidget {
  final Component component;

  const _StyleTab({required this.component});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final styles = component.styles ?? Styles();

    return ListView(
      padding: const EdgeInsets.all(16),
      children: [
        _StyleSection(
          title: 'Layout',
          children: [
            _DimensionField(
              label: 'Width',
              value: styles.dimensions?.width,
              onChanged: (value) => _updateDimension(ref, 'width', value),
            ),
            _DimensionField(
              label: 'Height',
              value: styles.dimensions?.height,
              onChanged: (value) => _updateDimension(ref, 'height', value),
            ),
          ],
        ),
        _StyleSection(
          title: 'Spacing',
          children: [
            _SpacingField(
              label: 'Padding',
              spacing: styles.padding,
              onChanged: (spacing) => _updateSpacing(ref, 'padding', spacing),
            ),
            _SpacingField(
              label: 'Margin',
              spacing: styles.margin,
              onChanged: (spacing) => _updateSpacing(ref, 'margin', spacing),
            ),
          ],
        ),
        _StyleSection(
          title: 'Background',
          children: [
            _ColorField(
              label: 'Color',
              value: styles.background?.color,
              onChanged: (color) => _updateBackgroundColor(ref, color),
            ),
          ],
        ),
        _StyleSection(
          title: 'Border',
          children: [
            _BorderRadiusField(
              radius: styles.border?.radius,
              onChanged: (radius) => _updateBorderRadius(ref, radius),
            ),
            _ColorField(
              label: 'Border Color',
              value: styles.border?.color,
              onChanged: (color) => _updateBorderColor(ref, color),
            ),
          ],
        ),
        _StyleSection(
          title: 'Typography',
          children: [
            _FontSizeField(
              value: styles.typography?.fontSize,
              onChanged: (size) => _updateFontSize(ref, size),
            ),
            _FontWeightField(
              value: styles.typography?.fontWeight,
              onChanged: (weight) => _updateFontWeight(ref, weight),
            ),
            _ColorField(
              label: 'Text Color',
              value: styles.typography?.color,
              onChanged: (color) => _updateTextColor(ref, color),
            ),
          ],
        ),
      ],
    );
  }

  void _updateDimension(WidgetRef ref, String key, String? value) {
    final currentDimensions = component.styles?.dimensions ?? Dimensions();
    final updated = key == 'width'
        ? currentDimensions.copyWith(width: value)
        : currentDimensions.copyWith(height: value);
    
    final updatedStyles = (component.styles ?? Styles()).copyWith(dimensions: updated);
    final updatedComponent = component.copyWith(styles: updatedStyles);
    ref.read(builderStateProvider.notifier).updateComponent(component.id, updatedComponent);
  }

  void _updateSpacing(WidgetRef ref, String type, Spacing spacing) {
    final updatedStyles = type == 'padding'
        ? (component.styles ?? Styles()).copyWith(padding: spacing)
        : (component.styles ?? Styles()).copyWith(margin: spacing);
    
    final updatedComponent = component.copyWith(styles: updatedStyles);
    ref.read(builderStateProvider.notifier).updateComponent(component.id, updatedComponent);
  }

  void _updateBackgroundColor(WidgetRef ref, String color) {
    final background = Background(color: color);
    final updatedStyles = (component.styles ?? Styles()).copyWith(background: background);
    final updatedComponent = component.copyWith(styles: updatedStyles);
    ref.read(builderStateProvider.notifier).updateComponent(component.id, updatedComponent);
  }

  void _updateBorderRadius(WidgetRef ref, BorderRadius radius) {
