  const _DraggableComponent({
    required this.icon,
    required this.label,
    required this.type,
  });

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    return Draggable<ComponentDragData>(
      data: ComponentDragData(type: type),
      feedback: Material(
        elevation: 4,
        borderRadius: BorderRadius.circular(8),
        child: Container(
          padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
          decoration: BoxDecoration(
            color: Colors.blue,
            borderRadius: BorderRadius.circular(8),
          ),
          child: Row(
            mainAxisSize: MainAxisSize.min,
            children: [
              Icon(icon, color: Colors.white, size: 20),
              const SizedBox(width: 8),
              Text(
                label,
                style: const TextStyle(color: Colors.white, fontWeight: FontWeight.w500),
              ),
            ],
          ),
        ),
      ),
      child: InkWell(
        onTap: () {
          // Quick add component
          _addComponent(ref, type);
        },
        borderRadius: BorderRadius.circular(8),
        child: Container(
          margin: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
          padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 10),
          decoration: BoxDecoration(
            border: Border.all(color: Colors.grey[300]!),
            borderRadius: BorderRadius.circular(8),
          ),
          child: Row(
            children: [
              Icon(icon, size: 20, color: Colors.grey[700]),
              const SizedBox(width: 12),
              Text(
                label,
                style: TextStyle(
                  fontSize: 14,
                  color: Colors.grey[800],
                  fontWeight: FontWeight.w500,
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }

  void _addComponent(WidgetRef ref, String type) {
    final component = _createComponent(type);
    ref.read(builderStateProvider.notifier).addComponent(component);
  }

  Component _createComponent(String type) {
    final id = 'comp-${DateTime.now().millisecondsSinceEpoch}';
    
    switch (type) {
      case 'text':
        return Component(
          id: id,
          type: 'text',
          props: {'content': 'Sample text', 'tag': 'p'},
        );
      case 'heading':
        return Component(
          id: id,
          type: 'text',
          props: {'content': 'Heading', 'tag': 'h2'},
        );
      case 'image':
        return Component(
          id: id,
          type: 'image',
          props: {
            'src': 'https://via.placeholder.com/400x300',
            'alt': 'Placeholder image',
          },
        );
      case 'button':
        return Component(
          id: id,
          type: 'button',
          props: {'text': 'Click me', 'variant': 'contained'},
        );
      case 'container':
        return Component(
          id: id,
          type: 'container',
          children: [],
        );
      default:
        return Component(
          id: id,
          type: type,
          props: {},
        );
    }
  }
}

