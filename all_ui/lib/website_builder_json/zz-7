    required this.isSelected,
  });

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    return GestureDetector(
      onTap: () => ref.read(builderStateProvider.notifier).selectSection(section),
      child: DragTarget<ComponentDragData>(
        onAccept: (data) {
          // Add component to this section
          final component = _createComponent(data.type);
          ref.read(builderStateProvider.notifier).addComponent(
            component,
            targetSection: section,
          );
        },
        builder: (context, candidateData, rejectedData) {
          final isHovering = candidateData.isNotEmpty;
          
          return Container(
            decoration: BoxDecoration(
              border: Border.all(
                color: isSelected
                    ? Colors.blue
                    : isHovering
                        ? Colors.blue.withOpacity(0.5)
                        : Colors.transparent,
                width: 2,
              ),
              color: isHovering ? Colors.blue.withOpacity(0.05) : null,
            ),
            child: Stack(
              children: [
                Padding(
                  padding: const EdgeInsets.all(16),
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.stretch,
                    children: section.components.map((component) {
                      return _BuilderComponent(component: component);
                    }).toList(),
                  ),
                ),
                if (isSelected)
                  Positioned(
                    top: 8,
                    right: 8,
                    child: Container(
                      padding: const EdgeInsets.symmetric(
                        horizontal: 8,
                        vertical: 4,
                      ),
                      decoration: BoxDecoration(
                        color: Colors.blue,
                        borderRadius: BorderRadius.circular(4),
                      ),
                      child: Row(
                        mainAxisSize: MainAxisSize.min,
                        children: [
                          Text(
                            section.type.toUpperCase(),
                            style: const TextStyle(
                              color: Colors.white,
                              fontSize: 11,
                              fontWeight: FontWeight.bold,
                            ),
                          ),
                          const SizedBox(width: 8),
                          IconButton(
                            icon: const Icon(Icons.settings, size: 16),
                            color: Colors.white,
                            padding: EdgeInsets.zero,
                            constraints: const BoxConstraints(),
                            onPressed: () {
                              // Open section settings
                            },
                          ),
                        ],
                      ),
                    ),
                  ),
              ],
            ),
          );
        },
      ),
    );
  }

  Component _createComponent(String type) {
    final id = 'comp-${DateTime.now().millisecondsSinceEpoch}';
    return Component(id: id, type: type, props: {});
  }
}

class _BuilderComponent extends ConsumerWidget {
  final Component component;

  const _BuilderComponent({required this.component});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final isSelected = ref.watch(builderStateProvider).selectedComponent?.id == component.id;

    return GestureDetector(
      onTap: () => ref.read(builderStateProvider.notifier).selectComponent(component),
      child: Container(
        margin: const EdgeInsets.symmetric(vertical: 4),
        decoration: BoxDecoration(
          border: Border.all(
            color: isSelected ? Colors.blue : Colors.transparent,
            width: 2,
          ),
          borderRadius: BorderRadius.circular(4),
        ),
        child: Stack(
          children: [
            SchemaEngine(context: context).renderComponent(component),
            if (isSelected)
              Positioned.fill(
                child: Container(
                  decoration: BoxDecoration(
                    color: Colors.blue.withOpacity(0.1),
                    borderRadius: BorderRadius.circular(4),
                  ),
                ),
              ),
            if (isSelected)
              Positioned(
                top: 4,
                right: 4,
                child: Row(
                  mainAxisSize: MainAxisSize.min,
                  children: [
                    _ComponentActionButton(
                      icon: Icons.edit,
                      onPressed: () {
                        // Edit component
                      },
                    ),
                    _ComponentActionButton(
                      icon: Icons.content_copy,
                      onPressed: () {
                        // Duplicate component
                      },
                    ),
                    _ComponentActionButton(
                      icon: Icons.delete,
                      onPressed: () {
                        ref.read(builderStateProvider.notifier).deleteComponent(component.id);
                      },
                    ),
                  ],
                ),
              ),
          ],
        ),
      ),
    );
  }
}

