                    fontSize: 16,
                    color: Colors.grey[600],
                  ),
                ),
              ],
            ),
          ),
        );
      },
    );
  }

  Widget _buildPageCanvas(Page page, WidgetRef ref) {
    return SingleChildScrollView(
      child: Column(
        children: [
          ...page.sections.map((section) => _BuilderSection(
            section: section,
            isSelected: state.selectedSection?.id == section.id,
