// ==================== Plugin Manager ====================

class PluginManager {
  static final PluginManager _instance = PluginManager._internal();
  factory PluginManager() => _instance;
  PluginManager._internal();

  final Map<String, BuilderPlugin> _plugins = {};
  final List<String> _enabledPlugins = [];

  void registerPlugin(BuilderPlugin plugin) {
    _plugins[plugin.id] = plugin;
  }

  void enablePlugin(String pluginId, BuildContext context) {
    if (_plugins.containsKey(pluginId) && !_enabledPlugins.contains(pluginId)) {
      _plugins[pluginId]!.initialize(context);
      _enabledPlugins.add(pluginId);
    }
  }

  void disablePlugin(String pluginId) {
    if (_enabledPlugins.contains(pluginId)) {
      _plugins[pluginId]!.dispose();
      _enabledPlugins.remove(pluginId);
    }
  }

  List<BuilderPlugin> get availablePlugins => _plugins.values.toList();
  List<BuilderPlugin> get enabledPlugins =>
      _enabledPlugins.map((id) => _plugins[id]!).toList();

  List<ToolbarAction> getAllToolbarActions() {
    return enabledPlugins
        .where((p) => p.toolbarActions != null)
        .expand((p) => p.toolbarActions!)
        .toList();
  }

  Map<String, ComponentRenderer> getAllCustomRenderers() {
    final renderers = <String, ComponentRenderer>{};
    for (final plugin in enabledPlugins) {
      if (plugin.customRenderers != null) {
        renderers.addAll(plugin.customRenderers!);
      }
    }
    return renderers;
  }
}

