class BuilderStateNotifier extends StateNotifier<BuilderState> {
  BuilderStateNotifier() : super(BuilderState()) {
    _initializeNewProject();
  }

  void _initializeNewProject() {
    final website = WebsiteDocument(
      id: 'website-${DateTime.now().millisecondsSinceEpoch}',
      version: '1.0.0',
      metadata: WebsiteMetadata(
        name: 'New Website',
        createdAt: DateTime.now(),
        updatedAt: DateTime.now(),
      ),
      pages: [
        Page(
          id: 'page-home',
          name: 'Home',
          path: '/',
          sections: [],
        ),
      ],
    );

    state = state.copyWith(
      website: website,
      currentPage: website.pages.first,
    );
  }

  void selectSection(Section section) {
    state = state.copyWith(
      selectedSection: section,
      selectedComponent: null,
    );
  }

  void selectComponent(Component component) {
    state = state.copyWith(selectedComponent: component);
  }

  void addSection(Section section) {
    if (state.currentPage == null) return;

    final updatedPage = _updatePage(
      state.currentPage!,
      (page) => page.copyWith(
        sections: [...page.sections, section],
      ),
    );

    _updateCurrentPage(updatedPage);
  }

  void addComponent(Component component, {Section? targetSection}) {
    final section = targetSection ?? state.selectedSection;
    if (section == null) return;

    final updatedSection = section.copyWith(
      components: [...section.components, component],
    );

    _updateSection(section.id, updatedSection);
  }

  void updateComponent(String componentId, Component updated) {
    if (state.currentPage == null) return;

    final updatedPage = _updateComponentInPage(
      state.currentPage!,
      componentId,
      updated,
    );

    _updateCurrentPage(updatedPage);
  }

  void deleteComponent(String componentId) {
    if (state.currentPage == null) return;

    final updatedPage = _deleteComponentFromPage(
      state.currentPage!,
      componentId,
    );

    _updateCurrentPage(updatedPage);
    state = state.copyWith(selectedComponent: null);
  }

  void moveComponent(String componentId, int newIndex, {String? newSectionId}) {
    // Implementation for drag-and-drop reordering
    if (state.currentPage == null) return;

    // Find the component and remove it
    Component? movedComponent;
    final updatedPage = _removeComponentFromPage(
      state.currentPage!,
      componentId,
      (component) => movedComponent = component,
    );

    if (movedComponent == null) return;

    // Add to new position
    final finalPage = _insertComponentInPage(
      updatedPage,
      movedComponent!,
      newIndex,
      newSectionId,
    );

    _updateCurrentPage(finalPage);
  }

  void togglePreviewMode() {
    state = state.copyWith(isPreviewMode: !state.isPreviewMode);
  }

  void _updateCurrentPage(Page page) {
    if (state.website == null) return;

    final pages = state.website!.pages.map((p) {
      return p.id == page.id ? page : p;
    }).toList();

    final updatedWebsite = state.website!.copyWith(pages: pages);

    state = state.copyWith(
      website: updatedWebsite,
      currentPage: page,
    );
  }

  void _updateSection(String sectionId, Section updated) {
    if (state.currentPage == null) return;

    final updatedPage = _updatePage(
      state.currentPage!,
      (page) => page.copyWith(
        sections: page.sections.map((s) {
          return s.id == sectionId ? updated : s;
        }).toList(),
      ),
    );

    _updateCurrentPage(updatedPage);
  }

  Page _updatePage(Page page, Page Function(Page) updater) {
    return updater(page);
  }

  Page _updateComponentInPage(Page page, String componentId, Component updated) {
    return page.copyWith(
      sections: page.sections.map((section) {
        return section.copyWith(
          components: _updateComponentInList(
            section.components,
            componentId,
            updated,
          ),
        );
      }).toList(),
    );
  }

  List<Component> _updateComponentInList(
    List<Component> components,
    String componentId,
    Component updated,
  ) {
    return components.map((component) {
      if (component.id == componentId) {
        return updated;
      } else if (component.children != null) {
        return component.copyWith(
          children: _updateComponentInList(
            component.children!,
            componentId,
            updated,
          ),
        );
      }
      return component;
    }).toList();
  }

  Page _deleteComponentFromPage(Page page, String componentId) {
    return page.copyWith(
      sections: page.sections.map((section) {
        return section.copyWith(
          components: _removeComponentFromList(section.components, componentId),
        );
      }).toList(),
    );
  }

  List<Component> _removeComponentFromList(
    List<Component> components,
    String componentId,
  ) {
    return components.where((c) => c.id != componentId).map((component) {
      if (component.children != null) {
        return component.copyWith(
          children: _removeComponentFromList(component.children!, componentId),
        );
      }
      return component;
    }).toList();
  }

  Page _removeComponentFromPage(
    Page page,
    String componentId,
    void Function(Component) onFound,
  ) {
    return page.copyWith(
      sections: page.sections.map((section) {
        return section.copyWith(
          components: _findAndRemoveComponent(
            section.components,
            componentId,
            onFound,
          ),
        );
      }).toList(),
    );
  }

  List<Component> _findAndRemoveComponent(
    List<Component> components,
    String componentId,
    void Function(Component) onFound,
  ) {
    final result = <Component>[];
    for (final component in components) {
      if (component.id == componentId) {
        onFound(component);
      } else {
        if (component.children != null) {
          result.add(component.copyWith(
            children: _findAndRemoveComponent(
              component.children!,
              componentId,
              onFound,
            ),
          ));
        } else {
          result.add(component);
        }
      }
    }
    return result;
  }

  Page _insertComponentInPage(
    Page page,
    Component component,
    int index,
    String? sectionId,
  ) {
    return page.copyWith(
      sections: page.sections.map((section) {
        if (sectionId == null || section.id == sectionId) {
          final components = [...section.components];
          components.insert(index.clamp(0, components.length), component);
          return section.copyWith(components: components);
        }
        return section;
      }).toList(),
    );
  }
}

