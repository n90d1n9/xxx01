                      ),
                      const SizedBox(height: 8),
                      Text(
                        plugin.description,
                        style: TextStyle(
                          color: Colors.grey[600],
                          fontSize: 14,
                        ),
                      ),
                    ],
                  ),
                ),
                const SizedBox(width: 16),
                ElevatedButton(
                  onPressed: () {
                    setState(() {
                      if (isEnabled) {
                        _pluginManager.disablePlugin(plugin.id);
                      } else {
                        _pluginManager.enablePlugin(plugin.id, context);
                      }
                    });
                  },
                  style: ElevatedButton.styleFrom(
                    backgroundColor: isEnabled ? Colors.red : Colors.blue,
                  ),
                  child: Text(isEnabled ? 'Disable' : 'Enable'),
                ),
