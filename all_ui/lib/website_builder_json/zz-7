  Widget _buildCodeView(BuilderState state) {
    if (state.website == null) {
      return const Center(child: Text('No content to display'));
    }

    final jsonString = jsonEncode(state.website!.toJson());
    final prettyJson = const JsonEncoder.withIndent('  ').convert(
      jsonDecode(jsonString),
    );

    return DefaultTabController(
      length: 3,
      child: Column(
        children: [
          const TabBar(
            tabs: [
              Tab(text: 'JSON'),
              Tab(text: 'HTML'),
              Tab(text: 'React'),
            ],
          ),
          Expanded(
            child: TabBarView(
              children: [
                _CodeTab(code: prettyJson, language: 'json'),
                _CodeTab(
                  code: HTMLExporter.generateHTML(
                    BuilderProject(
                      name: state.website!.metadata.name,
                      pages: state.website!.pages,
                    ),
                  ),
                  language: 'html',
                ),
                _CodeTab(code: _generateReactCode(state.website!), language: 'jsx'),
              ],
            ),
          ),
        ],
      ),
    );
  }

  String _generateReactCode(WebsiteDocument website) {
    return '''
import React from 'react';

function App() {
  return (
    <div className="app">
      <h1>${website.metadata.name}</h1>
      {/* Generated React components */}
    </div>
  );
}

export default App;
''';
  }
}

