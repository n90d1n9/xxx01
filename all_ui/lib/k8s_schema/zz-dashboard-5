                  context,
                  ref,
                  icon: Icons.security,
                  label: 'RBAC',
                  view: DashboardView.rbac,
                  isSelected: currentView == DashboardView.rbac,
                ),
                _buildNavItem(
                  context,
                  ref,
                  icon: Icons.attach_money,
                  label: 'Costs',
                  view: DashboardView.costs,
                  isSelected: currentView == DashboardView.costs,
