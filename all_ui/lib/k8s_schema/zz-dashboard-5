// ============================================================================
// Models
// ============================================================================

enum DashboardView {
  overview,
  workloads,
  networking,
  storage,
  configuration,
  rbac,
  events,
  nodes,
  costs,
}

enum PodStatus { running, pending, failed, succeeded, unknown }
enum ClusterStatus { healthy, warning, error, unknown }

class ClusterInfo {
  final String id;
  final String name;
  final String endpoint;
  final String region;
  final String provider;
  final String version;
  final ClusterStatus status;
  final int nodes;
  final int namespaces;

  ClusterInfo({
    required this.id,
    required this.name,
    required this.endpoint,
    required this.region,
    required this.provider,
    required this.version,
    required this.status,
    required this.nodes,
    required this.namespaces,
  });
}

class PodInfo {
  final String name;
  final String namespace;
  final PodStatus status;
  final int readyContainers;
  final int totalContainers;
  final int restarts;
  final String age;
  final String node;
  final String cpu;
  final String memory;
  final Map<String, String> labels;

  PodInfo({
    required this.name,
    required this.namespace,
    required this.status,
    required this.readyContainers,
    required this.totalContainers,
    required this.restarts,
    required this.age,
    required this.node,
    required this.cpu,
    required this.memory,
    required this.labels,
  });
}

class DeploymentInfo {
  final String name;
  final String namespace;
  final String ready;
  final int upToDate;
  final int available;
  final String age;
  final String strategy;

  DeploymentInfo({
    required this.name,
    required this.namespace,
    required this.ready,
    required this.upToDate,
    required this.available,
    required this.age,
    required this.strategy,
  });
}

class ServiceInfo {
  final String name;
  final String namespace;
  final String type;
  final String clusterIP;
  final String externalIP;
  final String ports;
  final String age;

  ServiceInfo({
    required this.name,
    required this.namespace,
    required this.type,
    required this.clusterIP,
    required this.externalIP,
    required this.ports,
    required this.age,
  });
}

class NodeInfo {
  final String name;
  final String status;
  final String roles;
  final String age;
  final String version;
  final String cpuCapacity;
  final String memoryCapacity;
  final String cpuUsage;
  final String memoryUsage;
  final String pods;

  NodeInfo({
    required this.name,
    required this.status,
    required this.roles,
    required this.age,
    required this.version,
    required this.cpuCapacity,
    required this.memoryCapacity,
    required this.cpuUsage,
    required this.memoryUsage,
    required this.pods,
  });
}

class NamespaceInfo {
  final String name;
  final String status;
  final String age;
  final int pods;
  final int deployments;
  final int services;

  NamespaceInfo({
    required this.name,
    required this.status,
    required this.age,
    required this.pods,
    required this.deployments,
    required this.services,
  });
}

class ResourceDetail {
  final String name;
  final String type;
  final String namespace;

  ResourceDetail({
    required this.name,
    required this.type,
    required this.namespace,
  });
}

class CostTracking {
  final double currentMonthCost;
  final double previousMonthCost;
  final double projectedCost;
  final Map<String, double> breakdown;
  final List<double> dailyCosts;

  CostTracking({
    required this.currentMonthCost,
    required this.previousMonthCost,
    required this.projectedCost,
    required this.breakdown,
    required this.dailyCosts,
  });

  double get changePercentage => 
      ((currentMonthCost - previousMonthCost) / previousMonthCost) * 100;
}

// ============================================================================
// Main Dashboard Screen
// ============================================================================

class DashboardScreen extends ConsumerWidget {
  const DashboardScreen({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final currentView = ref.watch(currentViewProvider);
    final currentNamespace = ref.watch(currentNamespaceProvider);
    final showDetailDrawer = ref.watch(showDetailDrawerProvider);
    final showFilterPanel = ref.watch(showFilterPanelProvider);
    final showNotificationCenter = ref.watch(showNotificationCenterProvider);

    return Scaffold(
      body: Stack(
        children: [
          Row(
            children: [
              // Sidebar Navigation
              const NavigationSidebar(),
              
              // Main Content Area
              Expanded(
                child: Column(
                  children: [
                    // Top Bar
                    TopBar(
                      currentNamespace: currentNamespace,
                      onNamespaceChanged: (ns) =>
                          ref.read(currentNamespaceProvider.notifier).state = ns,
                      onSearchTap: () => _showSearch(context),
                      onNotificationTap: () => ref
                          .read(showNotificationCenterProvider.notifier)
                          .state = !showNotificationCenter,
                    ),
                    
                    // Content
                    Expanded(
                      child: _buildContent(currentView, ref),
                    ),
                  ],
                ),
              ),
              
              // Filter Panel
              if (showFilterPanel)
                FilterPanel(
                  onClose: () => ref.read(showFilterPanelProvider.notifier).state = false,
                  onApply: () {
                    ref.read(showFilterPanelProvider.notifier).state = false;
                    // Apply filters
                  },
                ),
              
              // Detail Drawer
              if (showDetailDrawer != null)
                ResourceDetailDrawer(
                  resourceName: showDetailDrawer.name,
                  resourceType: showDetailDrawer.type,
                  namespace: showDetailDrawer.namespace,
                  onClose: () => ref.read(showDetailDrawerProvider.notifier).state = null,
                ),
              
              // Notification Center
              if (showNotificationCenter)
                NotificationCenter(
                  onClose: () => ref.read(showNotificationCenterProvider.notifier).state = false,
                ),
            ],
          ),
          
          // Cluster Selector FAB
          Positioned(
            right: 24,
            bottom: 24,
            child: FloatingActionButton.extended(
              onPressed: () => _showClusterSelector(context, ref),
              icon: const Icon(Icons.cloud),
              label: Text(ref.watch(selectedClusterProvider)?.name ?? 'Select Cluster'),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildContent(DashboardView view, WidgetRef ref) {
    switch (view) {
      case DashboardView.overview:
        return const EnhancedOverviewView();
      case DashboardView.workloads:
        return const WorkloadsView();
      case DashboardView.networking:
        return const NetworkingView();
      case DashboardView.storage:
        return const StorageView();
      case DashboardView.configuration:
        return const ConfigurationView();
      case DashboardView.rbac:
        return const RBACView();
      case DashboardView.events:
        return const EventsView();
      case DashboardView.nodes:
        return const NodesView();
      case DashboardView.costs:
        return const CostsView();
    }
  }

  void _showSearch(BuildContext context) {
    showDialog(
      context: context,
      builder: (context) => const SearchDialog(),
    );
  }

  void _showClusterSelector(BuildContext context, WidgetRef ref) {
    showDialog(
      context: context,
      builder: (context) => ClusterSelectorDialog(
        onClusterSelected: (cluster) {
          ref.read(selectedClusterProvider.notifier).state = cluster;
          Navigator.of(context).pop();
        },
      ),
    );
  }
}

