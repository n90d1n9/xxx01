// ============================================================================
// Models
// ============================================================================

enum DashboardView {
  overview,
  workloads,
  networking,
  storage,
  configuration,
  rbac,
  events,
}

enum PodStatus { running, pending, failed, succeeded, unknown }

class PodInfo {
  final String name;
  final String namespace;
  final PodStatus status;
  final int readyContainers;
  final int totalContainers;
  final int restarts;
  final String age;
  final String node;

  PodInfo({
    required this.name,
    required this.namespace,
    required this.status,
    required this.readyContainers,
    required this.totalContainers,
    required this.restarts,
    required this.age,
    required this.node,
  });
}

class DeploymentInfo {
  final String name;
  final String namespace;
  final String ready;
  final int upToDate;
  final int available;
  final String age;

  DeploymentInfo({
    required this.name,
    required this.namespace,
    required this.ready,
    required this.upToDate,
    required this.available,
    required this.age,
  });
}

class ServiceInfo {
  final String name;
  final String namespace;
  final String type;
  final String clusterIP;
  final String externalIP;
  final String ports;
  final String age;

  ServiceInfo({
    required this.name,
    required this.namespace,
    required this.type,
    required this.clusterIP,
    required this.externalIP,
    required this.ports,
    required this.age,
  });
}

