  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final pods = ref.watch(podsProvider);
    final deployments = ref.watch(deploymentsProvider);
    final services = ref.watch(servicesProvider);

    final runningPods = pods.where((p) => p.status == PodStatus.running).length;
    final pendingPods = pods.where((p) => p.status == PodStatus.pending).length;
    final failedPods = pods.where((p) => p.status == PodStatus.failed).length;

    return SingleChildScrollView(
      padding: const EdgeInsets.all(24),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Text(
            'Cluster Overview',
            style: Theme.of(context).textTheme.headlineMedium?.copyWith(
                  fontWeight: FontWeight.bold,
                ),
          ),
          const SizedBox(height: 24),
          
          // Stats Cards
          GridView.count(
            shrinkWrap: true,
            physics: const NeverScrollableScrollPhysics(),
            crossAxisCount: 4,
            crossAxisSpacing: 16,
            mainAxisSpacing: 16,
            childAspectRatio: 2,
            children: [
              _buildStatCard(
                context,
                icon: Icons.podcasts,
                title: 'Pods',
                value: pods.length.toString(),
                subtitle: '$runningPods running, $pendingPods pending',
                color: Colors.blue,
              ),
              _buildStatCard(
                context,
                icon: Icons.deploy_outlined,
                title: 'Deployments',
                value: deployments.length.toString(),
                subtitle: 'All healthy',
                color: Colors.green,
              ),
              _buildStatCard(
                context,
                icon: Icons.dns_outlined,
                title: 'Services',
                value: services.length.toString(),
                subtitle: 'Active endpoints',
                color: Colors.purple,
              ),
              _buildStatCard(
                context,
                icon: Icons.error_outline,
                title: 'Issues',
                value: failedPods.toString(),
                subtitle: 'Requires attention',
                color: Colors.red,
              ),
            ],
          ),
          
          const SizedBox(height: 32),
          
          // Recent Resources
          Row(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Expanded(
                child: _buildRecentPodsCard(context, pods),
              ),
              const SizedBox(width: 16),
              Expanded(
                child: _buildRecentDeploymentsCard(context, deployments),
              ),
            ],
          ),
        ],
      ),
    );
  }

