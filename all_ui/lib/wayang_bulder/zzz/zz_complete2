class PluginDefinitionNotifier extends StateNotifier<PluginDefinition?> {
  PluginDefinitionNotifier() : super(null);

  void createNew(String name, String version, String description, String author, String category) {
    state = PluginDefinition(
      id: name.toLowerCase().replaceAll(' ', '-'),
      name: name,
      version: version,
      description: description,
      author: author,
      category: category,
      tags: [],
      nodes: [],
      createdAt: DateTime.now(),
    );
  }

  void updateMetadata({
    String? name,
    String? version,
    String? description,
    String? author,
    String? category,
    List<String>? tags,
  }) {
    if (state == null) return;
    state = state!.copyWith(
      name: name,
      version: version,
      description: description,
      author: author,
      category: category,
      tags: tags,
      updatedAt: DateTime.now(),
    );
  }

  void addNode(NodeDefinition node) {
    if (state == null) return;
    state = state!.copyWith(
      nodes: [...state!.nodes, node],
      updatedAt: DateTime.now(),
    );
  }

  void updateNode(String nodeId, NodeDefinition updatedNode) {
    if (state == null) return;
    final nodes = state!.nodes.map((n) => n.id == nodeId ? updatedNode : n).toList();
    state = state!.copyWith(nodes: nodes, updatedAt: DateTime.now());
  }

  void deleteNode(String nodeId) {
    if (state == null) return;
    state = state!.copyWith(
      nodes: state!.nodes.where((n) => n.id != nodeId).toList(),
      updatedAt: DateTime.now(),
    );
  }

  void addTag(String tag) {
    if (state == null) return;
    if (!state!.tags.contains(tag)) {
      state = state!.copyWith(
        tags: [...state!.tags, tag],
        updatedAt: DateTime.now(),
      );
    }
  }

  void removeTag(String tag) {
    if (state == null) return;
    state = state!.copyWith(
      tags: state!.tags.where((t) => t != tag).toList(),
      updatedAt: DateTime.now(),
    );
  }

  void loadFromJson(Map<String, dynamic> json) {
    state = PluginDefinition.fromJson(json);
  }

  void clear() {
    state = null;
  }
}

