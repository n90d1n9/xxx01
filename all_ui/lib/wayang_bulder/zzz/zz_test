class TestRunnerWidget extends ConsumerStatefulWidget {
  final WorkflowData workflow;

  const TestRunnerWidget({Key? key, required this.workflow}) : super(key: key);

  @override
  ConsumerState<TestRunnerWidget> createState() => _TestRunnerWidgetState();
}

class _TestRunnerWidgetState extends ConsumerState<TestRunnerWidget> {
  List<TestCase> testCases = [];
  TestSuiteResult? lastResult;
  bool isRunning = false;

  @override
  Widget build(BuildContext context) {
    return Container(
      padding: const EdgeInsets.all(16),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              const Text(
                'Test Suite',
                style: TextStyle(
                  color: Colors.white,
                  fontSize: 18,
                  fontWeight: FontWeight.bold,
                ),
              ),
              const Spacer(),
              ElevatedButton.icon(
                onPressed: isRunning ? null : _addTestCase,
                icon: const Icon(Icons.add),
                label: const Text('Add Test'),
              ),
              const SizedBox(width: 8),
              ElevatedButton.icon(
                onPressed: isRunning ? null : _runTests,
                icon: const Icon(Icons.play_arrow),
                label: const Text('Run All'),
                style: ElevatedButton.styleFrom(backgroundColor: Colors.green),
              ),
            ],
          ),
          const SizedBox(height: 16),
          if (lastResult != null) _buildTestResults(),
          const SizedBox(height: 16),
          Expanded(
            child: testCases.isEmpty
                ? _buildEmptyState()
                : _buildTestList(),
          ),
        ],
      ),
    );
  }

  Widget _buildTestResults() {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: lastResult!.failed == 0 ? Colors.green.withValues(alpha: 0.2) : Colors.red.withValues(alpha: 0.2),
        borderRadius: BorderRadius.circular(8),
        border: Border.all(
          color: lastResult!.failed == 0 ? Colors.green : Colors.red,
        ),
      ),
      child: Row(
        children: [
          Icon(
            lastResult!.failed == 0 ? Icons.check_circle : Icons.error,
            color: lastResult!.failed == 0 ? Colors.green : Colors.red,
          ),
          const SizedBox(width: 12),
          Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Text(
                '${lastResult!.passed}/${lastResult!.totalTests} tests passed',
                style: const TextStyle(color: Colors.white, fontWeight: FontWeight.bold),
              ),
              Text(
                'Duration: ${lastResult!.duration.inMilliseconds}ms',
                style: const TextStyle(color: Colors.white70, fontSize: 12),
              ),
            ],
          ),
          const Spacer(),
          Text(
            '${lastResult!.passRate.toStringAsFixed(1)}%',
            style: const TextStyle(
              color: Colors.white,
              fontSize: 24,
              fontWeight: FontWeight.bold,
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildEmptyState() {
    return Center(
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          Icon(Icons.science, size: 64, color: Colors.white.withValues(alpha: 0.3)),
          const SizedBox(height: 16),
          Text(
            'No tests yet',
            style: TextStyle(color: Colors.white.withValues(alpha: 0.5), fontSize: 16),
          ),
          const SizedBox(height: 8),
          TextButton(
            onPressed: _addTestCase,
            child: const Text('Create your first test'),
          ),
        ],
      ),
    );
  }

  Widget _buildTestList() {
    return ListView.builder(
      itemCount: testCases.length,
      itemBuilder: (context, index) {
        final testCase = testCases[index];
        final result = lastResult?.results.firstWhere(
          (r) => r.testCase.id == testCase.id,
          orElse: () => lastResult!.results.first,
        );

        return Card(
          color: const Color(0xFF2D2D2D),
          child: ListTile(
            leading: result != null
                ? Icon(
                    result.passed ? Icons.check_circle : Icons.error,
                    color: result.passed ? Colors.green : Colors.red,
                  )
                : const Icon(Icons.circle_outlined, color: Colors.white54),
            title: Text(testCase.name, style: const TextStyle(color: Colors.white)),
            subtitle: Text(
              testCase.description,
              style: const TextStyle(color: Colors.white70, fontSize: 12),
            ),
            trailing: Row(
              mainAxisSize: MainAxisSize.min,
              children: [
                IconButton(
                  icon: const Icon(Icons.play_arrow, color: Colors.blue),
                  onPressed: () => _runSingleTest(testCase),
                ),
                IconButton(
                  icon: const Icon(Icons.delete, color: Colors.red),
                  onPressed: () => _deleteTest(testCase),
                ),
              ],
            ),
          ),
        );
      },
    );
  }

  void _addTestCase() {
    final testCase = TestCase(
      id: DateTime.now().millisecondsSinceEpoch.toString(),
      name: 'Test ${testCases.length + 1}',
      description: 'Test description',
      input: {'test': 'data'},
      assertions: [
        Assertion(
          id: '1',
          path: 'output.result',
          type: AssertionType.notNull,
        ),
      ],
    );

    setState(() {
      testCases.add(testCase);
    });
  }

  Future<void> _runTests() async {
    setState(() {
      isRunning = true;
    });

    final tester = WorkflowTester(
      workflow: widget.workflow,
      testCases: testCases,
    );

    final result = await tester.runAllTests();

    setState(() {
      lastResult = result;
      isRunning = false;
    });
  }

  Future<void> _runSingleTest(TestCase testCase) async {
    setState(() {
      isRunning = true;
    });

    final tester = WorkflowTester(
      workflow: widget.workflow,
      testCases: [testCase],
    );

    final result = await tester.runTest(testCase);

    setState(() {
      isRunning = false;
    });

    // Show result dialog
  }

  void _deleteTest(TestCase testCase) {
    setState(() {
      testCases.removeWhere((t) => t.id == testCase.id);
    });
  }
}

// ==================== MOCK DATA GENERATOR ====================

class MockDataGenerator {
  static Map<String, dynamic> generateMockData(String nodeType) {
    switch (nodeType) {
      case 'webhook':
        return {
          'method': 'POST',
          'path': '/webhook',
          'body': {'event': 'test', 'data': 'mock data'},
          'headers': {'Content-Type': 'application/json'},
        };
      case 'llm':
        return {
          'prompt': 'This is a test prompt',
          'response': 'This is a mock AI response',
          'tokens': 50,
        };
      case 'api':
        return {
          'statusCode': 200,
          'data': {'success': true, 'message': 'Mock API response'},
        };
      default:
        return {'mock': true, 'type': nodeType};
    }
  }

  static Map<String, dynamic> generateRandomData(PortType portType) {
    switch (portType) {
      case PortType.string:
        return {'value': 'random_string_${DateTime.now().millisecondsSinceEpoch}'};
      case PortType.number:
        return {'value': (DateTime.now().millisecondsSinceEpoch % 1000).toDouble()};
      case PortType.boolean:
        return {'value': DateTime.now().millisecondsSinceEpoch % 2 == 0};
      case PortType.array:
        return {'value': [1, 2, 3, 'test']};
      case PortType.object:
        return {'value': {'key1': 'value1', 'key2': 42}};
      default:
        return {'value': 'any type data'};
    }
  }
}

// Required stub classes
enum PortType { string, number, boolean, object, array, any }
class WorkflowData {
  final String id;
  final List<NodeData> nodes;
  final List<ConnectionData> connections;
  WorkflowData({required this.id, required this.nodes, required this.connections});
}
class NodeData {
  final String id;
  final String type;
  final String label;
  final Map<String, dynamic> config;
  NodeData({required this.id, required this.type, required this.label, required this.config});
}
class ConnectionData {
  final String sourceNodeId;
  final String targetNodeId;
  final String sourcePortId;
  final String targetPortId;
  ConnectionData({required this.sourceNodeId, required this.targetNodeId, required this.sourcePortId, required this.targetPortId});
}
class WorkflowExecutor {
