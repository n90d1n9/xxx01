// ==================== EXAMPLE USAGE ====================

void exampleUsage() async {
  final registry = PluginRegistry();

  // Register a plugin
  final myPlugin = ExamplePlugin();
  await registry.registerPlugin(myPlugin);

  // Get an executor
  final executor = registry.getExecutor('example_node');

  // Execute a node
  if (executor != null) {
    final context = NodeExecutionContext(
      nodeId: 'node-1',
      workflowId: 'workflow-1',
      executionId: 'exec-1',
      inputs: {'data': 'test'},
      config: {},
      secrets: {},
      variables: {},
    );

    final result = await executor.execute(context);
    print('Execution result: ${result.status}');
  }
}

// Example plugin implementation
class ExamplePlugin implements NodePlugin {
  @override
  PluginMetadata get metadata => PluginMetadata(
        id: 'example-plugin',
        name: 'Example Plugin',
        version: '1.0.0',
        description: 'An example plugin',
        author: 'Developer',
        tags: ['example'],
        capabilities: PluginCapabilities(),
        createdAt: DateTime.now(),
      );

  @override
  Future<void> initialize(PluginContext context) async {
    context.logger.info('Example plugin initialized');
  }

  @override
  Future<void> dispose() async {
    // Cleanup
  }

  @override
  List<NodeExecutor> getExecutors() {
    return [ExampleExecutor()];
  }
}

class ExampleExecutor implements NodeExecutor {
  @override
  String get nodeType => 'example_node';

  @override
  NodeSchema get schema => NodeSchema(
        name: 'Example Node',
        description: 'An example node executor',
        category: 'Example',
        icon: Icons.star,
        color: Colors.blue,
        inputs: [
          PortSchema(
            id: 'input',
            name: 'Input',
            description: 'Input data',
            type: PortType.any,
          ),
        ],
        outputs: [
          PortSchema(
            id: 'output',
            name: 'Output',
            description: 'Output data',
            type: PortType.any,
          ),
        ],
      );

  @override
  Future<NodeExecutionResult> execute(NodeExecutionContext context) async {
    final startTime = DateTime.now();

    try {
      // Your execution logic here
      final output = {'result': 'success', 'data': context.inputs['data']};

      return NodeExecutionResult.success(
        context.nodeId,
        output,
        DateTime.now().difference(startTime),
      );
    } catch (e) {
      return NodeExecutionResult.failure(
        context.nodeId,
        e.toString(),
        DateTime.now().difference(startTime),
      );
    }
  }
}


