class RedisExecutor implements NodeExecutor {
  @override
  Future<Map<String, dynamic>> execute(
    NodeExecutionContext context,
    Map<String, dynamic> config,
    Map<String, dynamic> inputs,
  ) async {
    final url = context.secrets['REDIS_URL'];
    final operation = config['operation'] ?? 'GET';
    final key = inputs['key'] ?? '';
    final value = inputs['value'];

    await Future.delayed(const Duration(milliseconds: 50));

    if (operation == 'GET') {
      return {'value': 'cached_value', 'exists': true};
    } else if (operation == 'SET') {
      return {'success': true, 'key': key};
    }

    return {'success': true};
  }

  @override
  Map<String, dynamic> getSchema() => {
        'inputs': [
          {'name': 'key', 'type': 'string', 'required': true},
          {'name': 'value', 'type': 'any', 'required': false},
        ],
        'outputs': [
          {'name': 'value', 'type': 'any'},
        ],
      };

  @override
  List<String> getRequiredSecrets() => ['REDIS_URL'];
}

