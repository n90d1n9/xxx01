// ========== WORKFLOW MODELS ==========
class WorkflowNode {
  final String id;
  final String name;
  final String type;
  final Offset position;
  final Map<String, dynamic> config;
  final List<String> inputs;
  final List<String> outputs;
  final NodeStatus status;
  final String? error;

  WorkflowNode({
    required this.id,
    required this.name,
    required this.type,
    required this.position,
    this.config = const {},
    this.inputs = const [],
    this.outputs = const [],
    this.status = NodeStatus.idle,
    this.error,
  });

  WorkflowNode copyWith({
    String? name,
    Offset? position,
    Map<String, dynamic>? config,
    List<String>? inputs,
    List<String>? outputs,
    NodeStatus? status,
    String? error,
  }) {
    return WorkflowNode(
      id: id,
      name: name ?? this.name,
      type: type,
      position: position ?? this.position,
      config: config ?? this.config,
      inputs: inputs ?? this.inputs,
      outputs: outputs ?? this.outputs,
      status: status ?? this.status,
      error: error ?? this.error,
    );
  }
}

enum NodeStatus { idle, running, success, error, warning }

class WorkflowConnection {
  final String id;
  final String sourceNodeId;
  final String targetNodeId;
  final String sourcePort;
  final String targetPort;
  final ConnectionStatus status;

  WorkflowConnection({
    required this.id,
    required this.sourceNodeId,
    required this.targetNodeId,
    this.sourcePort = 'output',
    this.targetPort = 'input',
    this.status = ConnectionStatus.idle,
  });

  WorkflowConnection copyWith({
    ConnectionStatus? status,
  }) {
    return WorkflowConnection(
      id: id,
      sourceNodeId: sourceNodeId,
      targetNodeId: targetNodeId,
      sourcePort: sourcePort,
      targetPort: targetPort,
      status: status ?? this.status,
    );
  }
}

enum ConnectionStatus { idle, active, completed }

class Workflow {
  final String id;
  final String name;
  final Map<String, WorkflowNode> nodes;
  final Map<String, WorkflowConnection> connections;
  final WorkflowStatus status;
  final DateTime? lastRun;

  Workflow({
    required this.id,
    required this.name,
    this.nodes = const {},
    this.connections = const {},
    this.status = WorkflowStatus.draft,
    this.lastRun,
  });

  Workflow copyWith({
    String? name,
    Map<String, WorkflowNode>? nodes,
    Map<String, WorkflowConnection>? connections,
    WorkflowStatus? status,
    DateTime? lastRun,
  }) {
    return Workflow(
      id: id,
      name: name ?? this.name,
      nodes: nodes ?? this.nodes,
      connections: connections ?? this.connections,
      status: status ?? this.status,
      lastRun: lastRun ?? this.lastRun,
    );
  }
}

enum WorkflowStatus { draft, testing, running, paused, completed, failed }

// ========== TEST EXECUTION MODELS ==========
class TestExecution {
  final String id;
  final String workflowId;
  final DateTime startTime;
  final DateTime? endTime;
  final TestStatus status;
  final Map<String, dynamic> input;
  final Map<String, dynamic>? output;
  final List<ExecutionStep> steps;
  final Map<String, dynamic> metrics;

  TestExecution({
    required this.id,
    required this.workflowId,
    required this.startTime,
    this.endTime,
    required this.status,
    required this.input,
    this.output,
    this.steps = const [],
    this.metrics = const {},
  });

  TestExecution copyWith({
    DateTime? endTime,
    TestStatus? status,
    Map<String, dynamic>? output,
    List<ExecutionStep>? steps,
    Map<String, dynamic>? metrics,
  }) {
    return TestExecution(
      id: id,
      workflowId: workflowId,
      startTime: startTime,
      endTime: endTime ?? this.endTime,
      status: status ?? this.status,
      input: input,
      output: output ?? this.output,
      steps: steps ?? this.steps,
      metrics: metrics ?? this.metrics,
    );
  }
}

enum TestStatus { running, completed, failed, cancelled }

class ExecutionStep {
  final String nodeId;
  final String nodeName;
  final DateTime startTime;
  final DateTime? endTime;
  final StepStatus status;
  final Map<String, dynamic>? input;
  final Map<String, dynamic>? output;
  final String? error;
  final int tokensUsed;
  final double cost;

  ExecutionStep({
    required this.nodeId,
    required this.nodeName,
    required this.startTime,
    this.endTime,
    required this.status,
    this.input,
    this.output,
    this.error,
    this.tokensUsed = 0,
    this.cost = 0.0,
  });
}

enum StepStatus { pending, running, completed, failed, skipped }

// ========== STATE MANAGEMENT ==========
class WorkflowState {
  final Workflow? currentWorkflow;
  final String? selectedNodeId;
  final bool isConnecting;
  final String? connectingFromNodeId;
  final Offset canvasOffset;
  final double canvasScale;

  WorkflowState({
    this.currentWorkflow,
    this.selectedNodeId,
    this.isConnecting = false,
    this.connectingFromNodeId,
    this.canvasOffset = Offset.zero,
    this.canvasScale = 1.0,
  });

  WorkflowState copyWith({
    Workflow? currentWorkflow,
    String? selectedNodeId,
    bool? isConnecting,
    String? connectingFromNodeId,
    Offset? canvasOffset,
    double? canvasScale,
  }) {
    return WorkflowState(
      currentWorkflow: currentWorkflow ?? this.currentWorkflow,
      selectedNodeId: selectedNodeId ?? this.selectedNodeId,
      isConnecting: isConnecting ?? this.isConnecting,
      connectingFromNodeId: connectingFromNodeId ?? this.connectingFromNodeId,
      canvasOffset: canvasOffset ?? this.canvasOffset,
      canvasScale: canvasScale ?? this.canvasScale,
    );
  }
}

class WorkflowNotifier extends StateNotifier<WorkflowState> {
  WorkflowNotifier() : super(WorkflowState());

  void createWorkflow(String name) {
    final workflow = Workflow(
      id: 'wf_${DateTime.now().millisecondsSinceEpoch}',
      name: name,
    );
    state = state.copyWith(currentWorkflow: workflow);
  }

  void addNode(String type, Offset position) {
    if (state.currentWorkflow == null) return;

    final nodeId = 'node_${DateTime.now().millisecondsSinceEpoch}';
    final node = WorkflowNode(
      id: nodeId,
      name: '$type Agent',
      type: type,
      position: position,
    );

    final updatedNodes = Map<String, WorkflowNode>.from(state.currentWorkflow!.nodes);
    updatedNodes[nodeId] = node;

    state = state.copyWith(
      currentWorkflow: state.currentWorkflow!.copyWith(nodes: updatedNodes),
    );
  }

  void updateNodePosition(String nodeId, Offset position) {
    if (state.currentWorkflow == null) return;

    final node = state.currentWorkflow!.nodes[nodeId];
    if (node == null) return;

    final updatedNodes = Map<String, WorkflowNode>.from(state.currentWorkflow!.nodes);
    updatedNodes[nodeId] = node.copyWith(position: position);

    state = state.copyWith(
      currentWorkflow: state.currentWorkflow!.copyWith(nodes: updatedNodes),
    );
  }

  void selectNode(String? nodeId) {
    state = state.copyWith(selectedNodeId: nodeId);
  }

  void startConnection(String nodeId) {
    state = state.copyWith(
      isConnecting: true,
      connectingFromNodeId: nodeId,
    );
  }

  void completeConnection(String targetNodeId) {
    if (state.connectingFromNodeId == null || !state.isConnecting) return;
    if (state.connectingFromNodeId == targetNodeId) {
      cancelConnection();
      return;
    }

    final connectionId = 'conn_${DateTime.now().millisecondsSinceEpoch}';
    final connection = WorkflowConnection(
      id: connectionId,
      sourceNodeId: state.connectingFromNodeId!,
      targetNodeId: targetNodeId,
    );

    final updatedConnections = Map<String, WorkflowConnection>.from(
      state.currentWorkflow!.connections,
    );
    updatedConnections[connectionId] = connection;

    state = state.copyWith(
      currentWorkflow: state.currentWorkflow!.copyWith(connections: updatedConnections),
      isConnecting: false,
      connectingFromNodeId: null,
    );
  }

  void cancelConnection() {
    state = state.copyWith(
      isConnecting: false,
      connectingFromNodeId: null,
    );
  }

  void deleteNode(String nodeId) {
    if (state.currentWorkflow == null) return;

    final updatedNodes = Map<String, WorkflowNode>.from(state.currentWorkflow!.nodes);
    updatedNodes.remove(nodeId);

    // Remove connections to/from this node
    final updatedConnections = Map<String, WorkflowConnection>.from(
      state.currentWorkflow!.connections,
    );
    updatedConnections.removeWhere(
      (key, conn) => conn.sourceNodeId == nodeId || conn.targetNodeId == nodeId,
    );

    state = state.copyWith(
      currentWorkflow: state.currentWorkflow!.copyWith(
        nodes: updatedNodes,
        connections: updatedConnections,
      ),
      selectedNodeId: state.selectedNodeId == nodeId ? null : state.selectedNodeId,
    );
  }

  void deleteConnection(String connectionId) {
    if (state.currentWorkflow == null) return;

    final updatedConnections = Map<String, WorkflowConnection>.from(
      state.currentWorkflow!.connections,
    );
    updatedConnections.remove(connectionId);

    state = state.copyWith(
      currentWorkflow: state.currentWorkflow!.copyWith(connections: updatedConnections),
    );
  }

  void updateCanvasTransform(Offset offset, double scale) {
    state = state.copyWith(
      canvasOffset: offset,
      canvasScale: scale,
    );
  }
}

final workflowProvider = StateNotifierProvider<WorkflowNotifier, WorkflowState>((ref) {
  return WorkflowNotifier();
});

// Test execution state
class TestExecutionNotifier extends StateNotifier<TestExecution?> {
  TestExecutionNotifier() : super(null);

  void startTest(String workflowId, Map<String, dynamic> input) {
    state = TestExecution(
      id: 'test_${DateTime.now().millisecondsSinceEpoch}',
      workflowId: workflowId,
      startTime: DateTime.now(),
      status: TestStatus.running,
      input: input,
    );

    // Simulate test execution
    _simulateExecution();
  }

  Future<void> _simulateExecution() async {
    await Future.delayed(const Duration(seconds: 1));
    
    if (state == null) return;

    final steps = [
      ExecutionStep(
        nodeId: 'node_1',
        nodeName: 'Planning Agent',
        startTime: DateTime.now(),
        endTime: DateTime.now().add(const Duration(milliseconds: 500)),
        status: StepStatus.completed,
        input: state!.input,
        output: {'plan': 'Step-by-step plan generated'},
        tokensUsed: 150,
        cost: 0.003,
      ),
      ExecutionStep(
        nodeId: 'node_2',
        nodeName: 'Tool Agent',
        startTime: DateTime.now().add(const Duration(milliseconds: 500)),
        endTime: DateTime.now().add(const Duration(seconds: 1)),
        status: StepStatus.completed,
        input: {'plan': 'Step-by-step plan generated'},
        output: {'result': 'Task completed successfully'},
        tokensUsed: 200,
        cost: 0.004,
      ),
    ];

    state = state!.copyWith(
      endTime: DateTime.now(),
      status: TestStatus.completed,
      steps: steps,
      output: {'result': 'Task completed successfully'},
      metrics: {
        'totalTokens': 350,
        'totalCost': 0.007,
        'duration': 1.0,
      },
    );
  }

  void stopTest() {
    if (state == null) return;
    state = state!.copyWith(
      endTime: DateTime.now(),
      status: TestStatus.cancelled,
    );
  }

  void clearTest() {
    state = null;
  }
}

final testExecutionProvider = StateNotifierProvider<TestExecutionNotifier, TestExecution?>((ref) {
  return TestExecutionNotifier();
});

