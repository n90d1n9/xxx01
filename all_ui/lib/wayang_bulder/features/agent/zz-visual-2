// ========== UNDO/REDO SYSTEM ==========
class HistoryEntry<T> {
  final T state;
  final String action;
  final DateTime timestamp;

  HistoryEntry({
    required this.state,
    required this.action,
    required this.timestamp,
  });
}

class UndoRedoManager<T> {
  final LinkedList<HistoryEntry<T>> _history = LinkedList();
  int _currentIndex = -1;
  final int maxHistorySize;

  UndoRedoManager({this.maxHistorySize = 50});

  void push(T state, String action) {
    // Remove any states after current index (redo stack)
    while (_currentIndex < _history.length - 1 && _history.isNotEmpty) {
      _history.removeLast();
    }

    // Add new state
    _history.add(HistoryEntry(
      state: state,
      action: action,
      timestamp: DateTime.now(),
    ));
    _currentIndex++;

    // Limit history size
    while (_history.length > maxHistorySize) {
      _history.removeAt(0);
      _currentIndex--;
    }
  }

  T? undo() {
    if (!canUndo) return null;
    _currentIndex--;
    return _history.elementAt(_currentIndex);
  }

  T? redo() {
    if (!canRedo) return null;
    _currentIndex++;
    return _history.elementAt(_currentIndex);
  }

  bool get canUndo => _currentIndex > 0;
  bool get canRedo => _currentIndex < _history.length - 1;

  T? get current => _currentIndex >= 0 ? _history.elementAt(_currentIndex) : null;

  List<HistoryEntry<T>> get historyList => _history.toList();

  void clear() {
    _history.clear();
    _currentIndex = -1;
  }
}

// Workflow History State
class WorkflowHistoryState {
  final UndoRedoManager<Map<String, dynamic>> manager;

  WorkflowHistoryState() : manager = UndoRedoManager(maxHistorySize: 100);
}

class WorkflowHistoryNotifier extends StateNotifier<WorkflowHistoryState> {
  WorkflowHistoryNotifier() : super(WorkflowHistoryState());

  void saveState(Map<String, dynamic> workflowState, String action) {
    state.manager.push(workflowState, action);
    state = WorkflowHistoryState()..manager;
  }

  Map<String, dynamic>? undo() {
    return state.manager.undo();
  }

  Map<String, dynamic>? redo() {
    return state.manager.redo();
  }

  bool get canUndo => state.manager.canUndo;
  bool get canRedo => state.manager.canRedo;
}

final workflowHistoryProvider =
    StateNotifierProvider<WorkflowHistoryNotifier, WorkflowHistoryState>((ref) {
  return WorkflowHistoryNotifier();
});

