// ========== AUTO-SAVE FUNCTIONALITY ==========
class AutoSaveManager {
  Timer? _saveTimer;
  final Duration saveInterval;
  final Function(Map<String, dynamic>) onSave;

  AutoSaveManager({
    this.saveInterval = const Duration(seconds: 30),
    required this.onSave,
  });

  void scheduleAutoSave(Map<String, dynamic> data) {
    _saveTimer?.cancel();
    _saveTimer = Timer(saveInterval, () => onSave(data));
  }

  void forceSave(Map<String, dynamic> data) {
    _saveTimer?.cancel();
    onSave(data);
  }

  void dispose() {
    _saveTimer?.cancel();
  }
}

// ========== VERSION CONTROL ==========
class ConfigVersion {
  final String id;
  final DateTime timestamp;
  final String author;
  final String message;
  final Map<String, dynamic> configuration;
  final List<String> changes;

  ConfigVersion({
    required this.id,
    required this.timestamp,
    required this.author,
    required this.message,
    required this.configuration,
    this.changes = const [],
  });
}

class VersionControlState {
  final List<ConfigVersion> versions;
  final String? currentVersionId;

  VersionControlState({
    this.versions = const [],
    this.currentVersionId,
  });

  VersionControlState copyWith({
    List<ConfigVersion>? versions,
    String? currentVersionId,
  }) {
    return VersionControlState(
      versions: versions ?? this.versions,
      currentVersionId: currentVersionId ?? this.currentVersionId,
    );
  }
}

class VersionControlNotifier extends StateNotifier<VersionControlState> {
  VersionControlNotifier() : super(VersionControlState());

  void commit(Map<String, dynamic> config, String message, String author) {
    final version = ConfigVersion(
      id: 'v${DateTime.now().millisecondsSinceEpoch}',
      timestamp: DateTime.now(),
      author: author,
      message: message,
      configuration: config,
      changes: _calculateChanges(config),
    );

    state = state.copyWith(
      versions: [...state.versions, version],
      currentVersionId: version.id,
    );
  }

  void checkout(String versionId) {
    state = state.copyWith(currentVersionId: versionId);
  }

  List<String> _calculateChanges(Map<String, dynamic> config) {
    // Calculate diff from previous version
    return ['Configuration updated'];
  }
}

final versionControlProvider =
    StateNotifierProvider<VersionControlNotifier, VersionControlState>((ref) {
  return VersionControlNotifier();
});

