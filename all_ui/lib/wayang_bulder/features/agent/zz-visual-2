// Undo/Redo Toolbar
class UndoRedoToolbar extends ConsumerWidget {
  const UndoRedoToolbar({Key? key}) : super(key: key);

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final historyState = ref.watch(workflowHistoryProvider);

    return Row(
      children: [
        IconButton(
          icon: const Icon(Icons.undo),
          onPressed: historyState.manager.canUndo
              ? () {
                  final previousState = ref.read(workflowHistoryProvider.notifier).undo();
                  if (previousState != null) {
                    // Apply previous state to workflow
                    ScaffoldMessenger.of(context).showSnackBar(
                      const SnackBar(content: Text('Undone')),
                    );
                  }
                }
              : null,
          tooltip: 'Undo',
        ),
        IconButton(
          icon: const Icon(Icons.redo),
          onPressed: historyState.manager.canRedo
              ? () {
                  final nextState = ref.read(workflowHistoryProvider.notifier).redo();
                  if (nextState != null) {
                    // Apply next state to workflow
                    ScaffoldMessenger.of(context).showSnackBar(
                      const SnackBar(content: Text('Redone')),
                    );
                  }
                }
              : null,
          tooltip: 'Redo',
        ),
        const VerticalDivider(),
        TextButton.icon(
          onPressed: () => _showHistoryDialog(context, historyState),
          icon: const Icon(Icons.history),
          label: const Text('History'),
        ),
      ],
    );
  }

  void _showHistoryDialog(BuildContext context, WorkflowHistoryState historyState) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Action History'),
        content: SizedBox(
          width: 400,
          height: 500,
          child: historyState.manager.historyList.isEmpty
              ? const Center(child: Text('No history available'))
              : ListView.builder(
                  itemCount: historyState.manager.historyList.length,
                  itemBuilder: (context, index) {
                    final entry = historyState.manager.historyList[index];
                    return ListTile(
                      leading: const Icon(Icons.history),
                      title: Text(entry.action),
                      subtitle: Text(
                        '${entry.timestamp.hour}:${entry.timestamp.minute}:${entry.timestamp.second}',
                      ),
                      trailing: index == historyState.manager._currentIndex
                          ? const Icon(Icons.arrow_forward, color: Colors.blue)
                          : null,
                    );
                  },
                ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Close'),
          ),
        ],
      ),
    );
  }
}

