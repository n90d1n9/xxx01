// ========== COST CALCULATOR ==========
class CostEstimate {
  final String modelName;
  final int inputTokens;
  final int outputTokens;
  final double inputCostPerToken;
  final double outputCostPerToken;
  final int expectedCalls;

  CostEstimate({
    required this.modelName,
    required this.inputTokens,
    required this.outputTokens,
    required this.inputCostPerToken,
    required this.outputCostPerToken,
    this.expectedCalls = 1,
  });

  double get costPerCall {
    return (inputTokens * inputCostPerToken) + (outputTokens * outputCostPerToken);
  }

  double get totalCost => costPerCall * expectedCalls;
}

class AgentCostConfig {
  final String agentType;
  final String model;
  final int averageInputTokens;
  final int averageOutputTokens;
  final int callsPerDay;

  AgentCostConfig({
    required this.agentType,
    required this.model,
    this.averageInputTokens = 500,
    this.averageOutputTokens = 200,
    this.callsPerDay = 100,
  });
}

class CostCalculatorState {
  final List<AgentCostConfig> agents;
  final Map<String, double> modelPricing;

  CostCalculatorState({
    this.agents = const [],
    Map<String, double>? modelPricing,
  }) : modelPricing = modelPricing ?? _defaultModelPricing;

  static final Map<String, double> _defaultModelPricing = {
    'gpt-4-input': 0.00003,
    'gpt-4-output': 0.00006,
    'gpt-3.5-turbo-input': 0.0000015,
    'gpt-3.5-turbo-output': 0.000002,
    'claude-3-opus-input': 0.000015,
    'claude-3-opus-output': 0.000075,
    'claude-3-sonnet-input': 0.000003,
    'claude-3-sonnet-output': 0.000015,
  };

  CostCalculatorState copyWith({
    List<AgentCostConfig>? agents,
    Map<String, double>? modelPricing,
  }) {
    return CostCalculatorState(
      agents: agents ?? this.agents,
      modelPricing: modelPricing ?? this.modelPricing,
    );
  }

  double calculateDailyCost() {
    double total = 0.0;
    for (final agent in agents) {
      final inputCost = modelPricing['${agent.model}-input'] ?? 0.0;
      final outputCost = modelPricing['${agent.model}-output'] ?? 0.0;
      
      final costPerCall = (agent.averageInputTokens * inputCost) +
          (agent.averageOutputTokens * outputCost);
      
      total += costPerCall * agent.callsPerDay;
    }
    return total;
  }

  double calculateMonthlyCost() => calculateDailyCost() * 30;
  double calculateYearlyCost() => calculateDailyCost() * 365;
}

class CostCalculatorNotifier extends StateNotifier<CostCalculatorState> {
  CostCalculatorNotifier() : super(CostCalculatorState());

  void addAgent(AgentCostConfig agent) {
    state = state.copyWith(agents: [...state.agents, agent]);
  }

  void removeAgent(int index) {
    final agents = List<AgentCostConfig>.from(state.agents);
    agents.removeAt(index);
    state = state.copyWith(agents: agents);
  }

  void updateAgent(int index, AgentCostConfig agent) {
    final agents = List<AgentCostConfig>.from(state.agents);
    agents[index] = agent;
    state = state.copyWith(agents: agents);
  }
}

final costCalculatorProvider =
    StateNotifierProvider<CostCalculatorNotifier, CostCalculatorState>((ref) {
  return CostCalculatorNotifier();
});

