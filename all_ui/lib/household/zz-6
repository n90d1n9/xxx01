    state = [
      for (final cat in state)
        if (cat.name == name) cat.copyWith(budget: budget) else cat,
    ];
    await storage.saveBudget(state);
  }

  Future<void> addExpense(String category, double amount) async {
    state = [
      for (final cat in state)
        if (cat.name == category)
          cat.copyWith(spent: cat.spent + amount)
        else
          cat,
    ];
    await storage.saveBudget(state);
  }

