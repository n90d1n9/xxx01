class BudgetCategory {
  final String name;
  final double budget;
  final double spent;
  final IconData icon;
  final Color color;

  BudgetCategory({
    required this.name,
    required this.budget,
    required this.spent,
    required this.icon,
    required this.color,
  });

  Map<String, dynamic> toJson() => {
        'name': name,
        'budget': budget,
        'spent': spent,
      };

  factory BudgetCategory.fromJson(Map<String, dynamic> json) {
    final categoryConfig = _getCategoryConfig(json['name']);
    return BudgetCategory(
      name: json['name'],
      budget: json['budget'],
      spent: json['spent'],
      icon: categoryConfig['icon'],
      color: categoryConfig['color'],
    );
  }

  static Map<String, dynamic> _getCategoryConfig(String name) {
    switch (name) {
      case 'Groceries':
        return {'icon': Icons.shopping_basket, 'color': Colors.green};
      case 'Utilities':
        return {'icon': Icons.electrical_services, 'color': Colors.blue};
      case 'Entertainment':
        return {'icon': Icons.movie, 'color': Colors.purple};
      case 'Transportation':
        return {'icon': Icons.directions_car, 'color': Colors.orange};
      case 'Healthcare':
        return {'icon': Icons.medical_services, 'color': Colors.red};
      case 'Education':
        return {'icon': Icons.school, 'color': Colors.indigo};
      default:
        return {'icon': Icons.more_horiz, 'color': Colors.grey};
    }
  }

  BudgetCategory copyWith({String? name, double? budget, double? spent}) {
    return BudgetCategory(
      name: name ?? this.name,
      budget: budget ?? this.budget,
      spent: spent ?? this.spent,
      icon: icon,
      color: color,
    );
  }
}

