                  child: Text(
                    currentSlide.title ?? 'Slide ${presentation.currentSlideIndex + 1}',
                    style: const TextStyle(
                      fontSize: 48,
                      fontWeight: FontWeight.bold,
                      color: Colors.black87,
                    ),
                    textAlign: TextAlign.center,
                  ),
                ),
              ),
            ),
            // Live cursors
            ...presentation.collaborators
                .where((u) => u.isOnline && u.id != '1' && u.cursorPosition != null)
                .map((user) => LiveCursor(user: user)),
            // Comment markers
            ...currentSlide.comments
                .where((c) => !c.isResolved && c.position != null)
                .map((comment) => CommentMarker(comment: comment)),
          ],
        ),
      ),
    );
  }
}

