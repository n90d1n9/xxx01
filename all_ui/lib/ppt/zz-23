      ),
      CollaborativeUser(
        id: '3',
        name: 'Michael Rodriguez',
        email: 'michael.r@example.com',
        cursorColor: const Color(0xFFEC4899),
        role: UserRole.editor,
        lastActive: DateTime.now().subtract(const Duration(minutes: 5)),
        isOnline: true,
        currentSlideId: null,
        cursorPosition: const Offset(680, 450),
      ),
      CollaborativeUser(
        id: '4',
        name: 'Emma Watson',
        email: 'emma.w@example.com',
        cursorColor: const Color(0xFFF59E0B),
        role: UserRole.commenter,
        lastActive: DateTime.now().subtract(const Duration(hours: 1)),
        isOnline: false,
      ),
    ];
  }

  static List<ActivityLog> _generateSampleActivity() {
    return [
      ActivityLog(
        id: '1',
        userId: '2',
        userName: 'Sarah Chen',
        type: ActivityType.edit,
        description: 'Updated slide title',
        timestamp: DateTime.now().subtract(const Duration(minutes: 2)),
        slideId: 'slide1',
      ),
      ActivityLog(
        id: '2',
        userId: '3',
        userName: 'Michael Rodriguez',
        type: ActivityType.add,
        description: 'Added new chart component',
        timestamp: DateTime.now().subtract(const Duration(minutes: 5)),
        slideId: 'slide2',
      ),
      ActivityLog(
        id: '3',
        userId: '2',
        userName: 'Sarah Chen',
        type: ActivityType.comment,
        description: 'Left a comment on slide 3',
        timestamp: DateTime.now().subtract(const Duration(minutes: 8)),
        slideId: 'slide3',
      ),
    ];
  }

  void setCurrentSlide(int index) {
    if (index >= 0 && index < state.slides.length) {
      state = state.copyWith(currentSlideIndex: index);
      _logActivity(ActivityType.edit, 'Navigated to slide ${index + 1}');
    }
  }

  void addComment(Comment comment) {
    state = state.copyWith(
      allComments: [...state.allComments, comment],
      lastModified: DateTime.now(),
    );
    _logActivity(ActivityType.comment, 'Added a comment');
  }

  void resolveComment(String commentId) {
    final updatedComments = state.allComments.map((c) =>
      c.id == commentId ? c.copyWith(isResolved: true) : c
    ).toList();
    state = state.copyWith(allComments: updatedComments);
    _logActivity(ActivityType.edit, 'Resolved a comment');
  }

  void addReplyToComment(String commentId, CommentReply reply) {
    final updatedComments = state.allComments.map((c) {
      if (c.id == commentId) {
        return c.copyWith(replies: [...c.replies, reply]);
      }
      return c;
    }).toList();
    state = state.copyWith(allComments: updatedComments);
  }

  void updateCollaboratorCursor(String userId, Offset position, String? slideId) {
    final updatedCollaborators = state.collaborators.map((user) {
      if (user.id == userId) {
        return user.copyWith(
          cursorPosition: position,
          currentSlideId: slideId,
          lastActive: DateTime.now(),
        );
      }
      return user;
    }).toList();
    state = state.copyWith(collaborators: updatedCollaborators);
  }

  void updateUserRole(String userId, UserRole newRole) {
    final updatedCollaborators = state.collaborators.map((user) {
      if (user.id == userId) {
        return user.copyWith(role: newRole);
      }
      return user;
    }).toList();
    state = state.copyWith(collaborators: updatedCollaborators);
  }

  void _logActivity(ActivityType type, String description) {
    final log = ActivityLog(
      id: const Uuid().v4(),
      userId: '1',
      userName: 'Current User',
      type: type,
      description: description,
      timestamp: DateTime.now(),
    );
    state = state.copyWith(
      activityLogs: [log, ...state.activityLogs],
      lastModified: DateTime.now(),
      lastModifiedBy: 'Current User',
    );
  }
}

