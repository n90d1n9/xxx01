// ==================== MODELS ====================

enum UserRole { owner, editor, commenter, viewer }
enum ActivityType { edit, comment, add, delete, move, resize, styleChange }
enum SlideTheme { minimal, modern, bold, dark, colorful }
enum ComponentType { text, image, shape }

class SlideComponent {
  final String id;
  final ComponentType type;
  final Offset position;
  final Size size;
  final String content;
  final Color? color;
  final double fontSize;

  SlideComponent({
    required this.id,
    required this.type,
    required this.position,
    required this.size,
    this.content = '',
    this.color,
    this.fontSize = 16,
  });

  SlideComponent copyWith({
    Offset? position,
    Size? size,
    String? content,
    Color? color,
    double? fontSize,
  }) {
    return SlideComponent(
      id: id,
      type: type,
      position: position ?? this.position,
      size: size ?? this.size,
      content: content ?? this.content,
      color: color ?? this.color,
      fontSize: fontSize ?? this.fontSize,
    );
  }
}

class CollaborativeUser {
  final String id;
  final String name;
  final String email;
  final Color cursorColor;
  final UserRole role;
  final DateTime lastActive;
  final bool isOnline;
  final Offset? cursorPosition;
  final bool isPresenting;
  final int? currentSlideIndex;

  CollaborativeUser({
    required this.id,
    required this.name,
    required this.email,
    required this.cursorColor,
    this.role = UserRole.editor,
    required this.lastActive,
    this.isOnline = true,
    this.cursorPosition,
    this.isPresenting = false,
    this.currentSlideIndex,
  });

  CollaborativeUser copyWith({
    DateTime? lastActive,
    bool? isOnline,
    Offset? cursorPosition,
    UserRole? role,
    bool? isPresenting,
    int? currentSlideIndex,
  }) {
    return CollaborativeUser(
      id: id,
      name: name,
      email: email,
      cursorColor: cursorColor,
      role: role ?? this.role,
      lastActive: lastActive ?? this.lastActive,
      isOnline: isOnline ?? this.isOnline,
      cursorPosition: cursorPosition ?? this.cursorPosition,
      isPresenting: isPresenting ?? this.isPresenting,
      currentSlideIndex: currentSlideIndex ?? this.currentSlideIndex,
    );
  }

  String get initials {
    final parts = name.split(' ');
    if (parts.length >= 2) {
      return '${parts[0][0]}${parts[1][0]}'.toUpperCase();
    }
    return name.substring(0, math.min(2, name.length)).toUpperCase();
  }
}

