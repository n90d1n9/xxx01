                  onPressed: _saveText,
                  style: ElevatedButton.styleFrom(
                    backgroundColor: const Color(0xFF3B82F6),
                  ),
                  child: const Text('Save'),
                ),
              ],
            ),
          ],
        ),
      ),
    );
  }

  void _showColorPicker() {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        backgroundColor: const Color(0xFF1E293B),
        title: const Text('Choose Color', style: TextStyle(color: Colors.white)),
        content: Wrap(
          spacing: 8,
          runSpacing: 8,
          children: [
            Colors.black87,
            Colors.white,
            const Color(0xFF3B82F6),
            const Color(0xFF10B981),
            const Color(0xFFF59E0B),
            const Color(0xFFEF4444),
            const Color(0xFF8B5CF6),
            const Color(0xFFEC4899),
          ].map((color) {
            return GestureDetector(
              onTap: () {
                setState(() => _textColor = color);
                Navigator.pop(context);
              },
              child: Container(
                width: 48,
                height: 48,
                decoration: BoxDecoration(
                  color: color,
                  borderRadius: BorderRadius.circular(8),
                  border: Border.all(color: Colors.white24, width: 2),
                ),
              ),
            );
          }).toList(),
        ),
      ),
    );
  }

  void _saveText() {
    if (_controller.text.isNotEmpty) {
      if (widget.component != null) {
        ref.read(presentationProvider.notifier).updateComponent(
              widget.slideIndex,
              widget.component!.id,
              widget.component!.copyWith(
                content: _controller.text,
                fontSize: _fontSize,
                color: _textColor,
              ),
            );
      } else {
        final component = SlideComponent(
          id: const Uuid().v4(),
          type: ComponentType.text,
          position: const Offset(400, 300),
          size: const Size(400, 100),
          content: _controller.text,
          fontSize: _fontSize,
          color: _textColor,
        );
        ref
            .read(presentationProvider.notifier)
            .addComponentToSlide(widget.slideIndex, component);
      }
      Navigator.pop(context);
    }
  }
}

