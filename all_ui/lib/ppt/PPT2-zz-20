  void saveToHistory() {
    ref.read(historyProvider.notifier).pushState(state);
  }

  void setCurrentSlide(int index) {
    if (index >= 0 && index < state.slides.length) {
      state = state.copyWith(currentSlideIndex: index);
      _logActivity(ActivityType.edit, 'Navigated to slide ${index + 1}');
    }
  }

  void addSlide() {
    saveToHistory();
    final newSlide = Slide(
      id: const Uuid().v4(),
      title: 'New Slide ${state.slides.length + 1}',
      theme: SlideTheme.minimal,
    );
    state = state.copyWith(
      slides: [...state.slides, newSlide],
      lastModified: DateTime.now(),
    );
    _logActivity(ActivityType.add, 'Added new slide');
  }

  void deleteSlide(int index) {
    if (state.slides.length > 1) {
      saveToHistory();
      final updatedSlides = List<Slide>.from(state.slides)..removeAt(index);
      state = state.copyWith(
        slides: updatedSlides,
        currentSlideIndex:
            math.min(state.currentSlideIndex, updatedSlides.length - 1),
        lastModified: DateTime.now(),
      );
      _logActivity(ActivityType.delete, 'Deleted slide ${index + 1}');
    }
  }

  void updateSlideTitle(int index, String title) {
    saveToHistory();
    final updatedSlides = List<Slide>.from(state.slides);
    updatedSlides[index] = updatedSlides[index].copyWith(title: title);
    state = state.copyWith(
      slides: updatedSlides,
      lastModified: DateTime.now(),
    );
    _logActivity(ActivityType.edit, 'Updated slide title');
  }

  void updateSlideTheme(int index, SlideTheme theme) {
    saveToHistory();
    final updatedSlides = List<Slide>.from(state.slides);
    updatedSlides[index] = updatedSlides[index].copyWith(theme: theme);
    state = state.copyWith(
      slides: updatedSlides,
      lastModified: DateTime.now(),
    );
    _logActivity(ActivityType.styleChange, 'Changed slide theme');
  }

  void addComponentToSlide(int slideIndex, SlideComponent component) {
    saveToHistory();
    final updatedSlides = List<Slide>.from(state.slides);
    final slide = updatedSlides[slideIndex];
    updatedSlides[slideIndex] = slide.copyWith(
      components: [...slide.components, component],
    );
    state = state.copyWith(
      slides: updatedSlides,
      lastModified: DateTime.now(),
    );
    _logActivity(ActivityType.add, 'Added component to slide');
  }

  void updateComponent(
      int slideIndex, String componentId, SlideComponent updatedComponent) {
    saveToHistory();
    final updatedSlides = List<Slide>.from(state.slides);
    final slide = updatedSlides[slideIndex];
    final components = slide.components.map((c) {
      return c.id == componentId ? updatedComponent : c;
    }).toList();
    updatedSlides[slideIndex] = slide.copyWith(components: components);
    state = state.copyWith(
      slides: updatedSlides,
      lastModified: DateTime.now(),
    );
  }

  void deleteComponent(int slideIndex, String componentId) {
    saveToHistory();
    final updatedSlides = List<Slide>.from(state.slides);
    final slide = updatedSlides[slideIndex];
    final components =
        slide.components.where((c) => c.id != componentId).toList();
    updatedSlides[slideIndex] = slide.copyWith(components: components);
    state = state.copyWith(
      slides: updatedSlides,
      lastModified: DateTime.now(),
    );
    _logActivity(ActivityType.delete, 'Deleted component');
  }

  void addComment(Comment comment) {
    state = state.copyWith(
      allComments: [...state.allComments, comment],
      lastModified: DateTime.now(),
    );
    _logActivity(ActivityType.comment, 'Added a comment');
  }

  void resolveComment(String commentId) {
    final updatedComments = state.allComments
        .map((c) => c.id == commentId ? c.copyWith(isResolved: true) : c)
        .toList();
    state = state.copyWith(allComments: updatedComments);
    _logActivity(ActivityType.edit, 'Resolved a comment');
  }

  void updateCollaboratorCursor(String userId, Offset position) {
    final updatedCollaborators = state.collaborators.map((user) {
      if (user.id == userId) {
        return user.copyWith(
          cursorPosition: position,
          lastActive: DateTime.now(),
        );
      }
      return user;
    }).toList();
    state = state.copyWith(collaborators: updatedCollaborators);
  }

  void startPresentation(String userId) {
    final updatedCollaborators = state.collaborators.map((user) {
      if (user.id == userId) {
        return user.copyWith(isPresenting: true);
      }
      return user.copyWith(isPresenting: false);
    }).toList();
    
    state = state.copyWith(
      isPresentationMode: true,
      presenterId: userId,
      collaborators: updatedCollaborators,
    );
    _logActivity(ActivityType.edit, 'Started presentation');
  }

  void endPresentation() {
    final updatedCollaborators = state.collaborators
        .map((user) => user.copyWith(isPresenting: false))
        .toList();
    
    state = state.copyWith(
      isPresentationMode: false,
      presenterId: null,
      collaborators: updatedCollaborators,
    );
    _logActivity(ActivityType.edit, 'Ended presentation');
  }

  void syncSlideForViewer(int slideIndex) {
    if (state.isPresentationMode) {
      setCurrentSlide(slideIndex);
    }
  }

  void _logActivity(ActivityType type, String description) {
    final log = ActivityLog(
      id: const Uuid().v4(),
      userId: '1',
      userName: 'Current User',
      type: type,
      description: description,
      timestamp: DateTime.now(),
    );
    state = state.copyWith(
      activityLogs: [log, ...state.activityLogs],
      lastModified: DateTime.now(),
    );
  }
}

final historyProvider =
    StateNotifierProvider<HistoryNotifier, PresentationHistory>((ref) {
  return HistoryNotifier();
});

class HistoryNotifier extends StateNotifier<PresentationHistory> {
  HistoryNotifier() : super(PresentationHistory());

  void pushState(Presentation presentation) {
    state = state.copyWith(
      undoStack: [...state.undoStack, presentation].take(50).toList(),
      redoStack: [],
    );
  }

  Presentation? undo() {
    if (state.undoStack.isNotEmpty) {
      final previous = state.undoStack.last;
      state = state.copyWith(
        undoStack: state.undoStack.sublist(0, state.undoStack.length - 1),
      );
      return previous;
    }
    return null;
  }

  Presentation? redo() {
    if (state.redoStack.isNotEmpty) {
      final next = state.redoStack.last;
      state = state.copyWith(
        redoStack: state.redoStack.sublist(0, state.redoStack.length - 1),
      );
      return next;
    }
    return null;
  }
}

final canUndoProvider = Provider<bool>((ref) {
  return ref.watch(historyProvider).undoStack.isNotEmpty;
});

final canRedoProvider = Provider<bool>((ref) {
  return ref.watch(historyProvider).redoStack.isNotEmpty;
});

