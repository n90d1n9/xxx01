  void _launchStandardMode(BuildContext context) {
    Navigator.pop(context);
    ref.read(presentationProvider.notifier).startPresentation('1');
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (context) => const SyncedCollaborativePresentationMode(),
      ),
    ).then((_) {
      ref.read(presentationProvider.notifier).endPresentation();
    });
  }

  void _launchPresenterView(BuildContext context) {
    Navigator.pop(context);
    ref.read(presentationProvider.notifier).startPresentation('1');
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (context) => const PresenterViewMode(),
      ),
    ).then((_) {
      ref.read(presentationProvider.notifier).endPresentation();
    });
  }

  void _launchDrawingMode(BuildContext context) {
    Navigator.pop(context);
    ref.read(presentationProvider.notifier).startPresentation('1');
    ref.read(slideSyncProvider.notifier).startPresenting();
    
    // Show drawing tips
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(
        content: Row(
          children: [
            Icon(Icons.draw, color: Colors.white),
            SizedBox(width: 12),
            Expanded(
              child: Text('Click the pen icon to start drawing!'),
            ),
          ],
        ),
        backgroundColor: Color(0xFF10B981),
        duration: Duration(seconds: 3),
      ),
    );
    
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (context) => const PresentationModeWithDrawing(),
      ),
    ).then((_) {
      ref.read(slideSyncProvider.notifier).stopPresenting();
      ref.read(presentationProvider.notifier).endPresentation();
      ref.read(drawingProvider.notifier).clearDrawings();
    });
  }

  void _launchDualDisplay(BuildContext context) {
    Navigator.pop(context);
    ref.read(presentationProvider.notifier).startPresentation('1');
