// ==================== DRAGGABLE COMPONENT ====================

class DraggableComponent extends StatefulWidget {
  final SlideComponent component;
  final bool isSelected;
  final VoidCallback onTap;
  final Function(Offset) onPositionChanged;
  final VoidCallback onDelete;

  const DraggableComponent({
    super.key,
    required this.component,
    required this.isSelected,
    required this.onTap,
    required this.onPositionChanged,
    required this.onDelete,
  });

  @override
  State<DraggableComponent> createState() => _DraggableComponentState();
}

class _DraggableComponentState extends State<DraggableComponent> {
  bool _isHovered = false;

  @override
  Widget build(BuildContext context) {
    return Positioned(
      left: widget.component.position.dx,
      top: widget.component.position.dy,
      child: GestureDetector(
        onTap: widget.onTap,
        onPanUpdate: (details) {
          widget.onPositionChanged(
            widget.component.position + details.delta,
          );
        },
        child: MouseRegion(
          onEnter: (_) => setState(() => _isHovered = true),
          onExit: (_) => setState(() => _isHovered = false),
          child: Container(
            width: widget.component.size.width,
            height: widget.component.size.height,
            decoration: BoxDecoration(
              border: _isHovered || widget.isSelected
                  ? Border.all(color: const Color(0xFF3B82F6), width: 2)
                  : null,
            ),
            child: Stack(
              children: [
                _buildComponentContent(),
                if (_isHovered || widget.isSelected)
                  Positioned(
                    right: -8,
                    top: -8,
                    child: GestureDetector(
                      onTap: widget.onDelete,
                      child: Container(
                        padding: const EdgeInsets.all(4),
                        decoration: const BoxDecoration(
                          color: Color(0xFFEF4444),
                          shape: BoxShape.circle,
                        ),
                        child: const Icon(Icons.close,
                            color: Colors.white, size: 12),
                      ),
                    ),
                  ),
              ],
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildComponentContent() {
    switch (widget.component.type) {
      case ComponentType.text:
        return Container(
          alignment: Alignment.center,
          child: Text(
            widget.component.content,
            style: TextStyle(
              fontSize: widget.component.fontSize,
              fontWeight: FontWeight.w600,
              color: widget.component.color ?? Colors.black87,
            ),
          ),
        );
      case ComponentType.shape:
        return Container(
          decoration: BoxDecoration(
            color: widget.component.color ?? const Color(0xFF3B82F6),
            borderRadius: BorderRadius.circular(8),
          ),
        );
      case ComponentType.image:
        return Container(
          decoration: BoxDecoration(
            color: Colors.grey[300],
            borderRadius: BorderRadius.circular(8),
          ),
          child: const Icon(Icons.image, size: 48, color: Colors.grey),
        );
    }
  }
}

