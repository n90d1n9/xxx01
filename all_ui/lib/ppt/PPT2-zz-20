    this.allStrokes = const [],
    this.activeStrokes = const {},
    this.allowCollaborativeDrawing = true,
    this.allowedDrawers = const {},
  });

  CollaborativeDrawingState copyWith({
    Map<String, DrawingState>? userDrawingStates,
    List<CollaborativeDrawingStroke>? allStrokes,
    Map<String, List<DrawingPoint>>? activeStrokes,
    bool? allowCollaborativeDrawing,
    Set<String>? allowedDrawers,
  }) {
    return CollaborativeDrawingState(
      userDrawingStates: userDrawingStates ?? this.userDrawingStates,
      allStrokes: allStrokes ?? this.allStrokes,
      activeStrokes: activeStrokes ?? this.activeStrokes,
      allowCollaborativeDrawing:
          allowCollaborativeDrawing ?? this.allowCollaborativeDrawing,
      allowedDrawers: allowedDrawers ?? this.allowedDrawers,
    );
  }
}

// ==================== COLLABORATIVE DRAWING PROVIDER ====================

final collaborativeDrawingProvider =
    StateNotifierProvider<CollaborativeDrawingNotifier, CollaborativeDrawingState>(
        (ref) {
  return CollaborativeDrawingNotifier(ref);
});

class CollaborativeDrawingNotifier extends StateNotifier<CollaborativeDrawingState> {
  final Ref ref;

  CollaborativeDrawingNotifier(this.ref) : super(CollaborativeDrawingState());

  void setAllowCollaborativeDrawing(bool allow) {
    state = state.copyWith(allowCollaborativeDrawing: allow);
  }

  void grantDrawingPermission(String userId) {
    final updatedDrawers = Set<String>.from(state.allowedDrawers)..add(userId);
    state = state.copyWith(allowedDrawers: updatedDrawers);
  }

  void revokeDrawingPermission(String userId) {
    final updatedDrawers = Set<String>.from(state.allowedDrawers)..remove(userId);
    state = state.copyWith(allowedDrawers: updatedDrawers);
  }

  bool canUserDraw(String userId) {
    if (!state.allowCollaborativeDrawing) return userId == '1'; // Only presenter
    return state.allowedDrawers.isEmpty || state.allowedDrawers.contains(userId);
  }

  void startCollaborativeDrawing(String userId, Offset position, Color color, double width) {
    if (!canUserDraw(userId)) return;

    final newPoint = DrawingPoint(
      position: position,
      color: color,
      strokeWidth: width,
      timestamp: DateTime.now(),
    );

    final updatedActive = Map<String, List<DrawingPoint>>.from(state.activeStrokes);
    updatedActive[userId] = [newPoint];

    state = state.copyWith(activeStrokes: updatedActive);
  }

  void updateCollaborativeDrawing(String userId, Offset position) {
    if (!canUserDraw(userId)) return;
    
    final currentPoints = state.activeStrokes[userId];
    if (currentPoints == null || currentPoints.isEmpty) return;

    final newPoint = DrawingPoint(
      position: position,
      color: currentPoints.first.color,
      strokeWidth: currentPoints.first.strokeWidth,
      timestamp: DateTime.now(),
    );

    final updatedActive = Map<String, List<DrawingPoint>>.from(state.activeStrokes);
    updatedActive[userId] = [...currentPoints, newPoint];

    state = state.copyWith(activeStrokes: updatedActive);
  }

  void endCollaborativeDrawing(String userId, String userName) {
    final points = state.activeStrokes[userId];
    if (points == null || points.isEmpty) return;

    final stroke = CollaborativeDrawingStroke(
      id: const Uuid().v4(),
      points: points,
      color: points.first.color,
      strokeWidth: points.first.strokeWidth,
      userId: userId,
      userName: userName,
      timestamp: DateTime.now(),
      isComplete: true,
    );

    final updatedActive = Map<String, List<DrawingPoint>>.from(state.activeStrokes);
    updatedActive.remove(userId);

    state = state.copyWith(
      allStrokes: [...state.allStrokes, stroke],
      activeStrokes: updatedActive,
    );
  }

  void clearAllDrawings() {
    state = state.copyWith(
      allStrokes: [],
      activeStrokes: {},
    );
  }

  void undoLastStrokeByUser(String userId) {
    final userStrokes =
        state.allStrokes.where((s) => s.userId == userId).toList();
    if (userStrokes.isEmpty) return;

    final lastStroke = userStrokes.last;
    final updatedStrokes =
        state.allStrokes.where((s) => s.id != lastStroke.id).toList();

    state = state.copyWith(allStrokes: updatedStrokes);
  }

  void simulateCollaboratorDrawing() {
    // Simulate other users drawing occasionally
    final random = math.Random();
    final presentation = ref.read(presentationProvider);
    
    for (var user in presentation.collaborators) {
      if (user.id != '1' && user.isOnline && random.nextDouble() > 0.95) {
        final x = 400 + random.nextDouble() * 800;
        final y = 200 + random.nextDouble() * 400;
        
        startCollaborativeDrawing(
          user.id,
          Offset(x, y),
          user.cursorColor,
          3.0,
        );
        
        // Add a few points
        for (int i = 0; i < 5; i++) {
          final nextX = x + random.nextDouble() * 50 - 25;
          final nextY = y + random.nextDouble() * 50 - 25;
          updateCollaborativeDrawing(user.id, Offset(nextX, nextY));
        }
        
        endCollaborativeDrawing(user.id, user.name);
      }
    }
  }
}

