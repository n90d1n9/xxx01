// ==================== MULTI-MONITOR DETECTION SERVICE ====================

class MultiMonitorService {
  static List<DisplayInfo> _displays = [];
  static bool _initialized = false;

  static Future<void> initialize() async {
    if (_initialized) return;
    
    try {
      // In a real implementation with screen_retriever package:
      // final displays = await screenRetriever.getAllDisplays();
      
      // For now, simulate multi-monitor setup
      _displays = [
        DisplayInfo(
          id: 0,
          name: 'Primary Display',
          bounds: const Rect.fromLTWH(0, 0, 1920, 1080),
          isPrimary: true,
        ),
        DisplayInfo(
          id: 1,
          name: 'Secondary Display',
          bounds: const Rect.fromLTWH(1920, 0, 1920, 1080),
          isPrimary: false,
        ),
      ];
      _initialized = true;
    } catch (e) {
      // Single monitor fallback
      _displays = [
        DisplayInfo(
          id: 0,
          name: 'Primary Display',
          bounds: const Rect.fromLTWH(0, 0, 1920, 1080),
          isPrimary: true,
        ),
      ];
      _initialized = true;
    }
  }

  static Future<List<DisplayInfo>> getDisplays() async {
    await initialize();
    return _displays;
  }

  static bool get hasMultipleDisplays => _displays.length > 1;

  static DisplayInfo? get primaryDisplay =>
      _displays.where((d) => d.isPrimary).firstOrNull ?? _displays.firstOrNull;

  static DisplayInfo? get secondaryDisplay =>
      _displays.where((d) => !d.isPrimary).firstOrNull;
}

class DisplayInfo {
  final int id;
  final String name;
  final Rect bounds;
  final bool isPrimary;

  DisplayInfo({
    required this.id,
    required this.name,
    required this.bounds,
    required this.isPrimary,
  });

  @override
  String toString() => '$name (${bounds.width.toInt()}x${bounds.height.toInt()})';
}

