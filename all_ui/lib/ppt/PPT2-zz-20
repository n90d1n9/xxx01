// ==================== THEME PROVIDER ====================

final presentationThemeProvider =
    StateNotifierProvider<PresentationThemeNotifier, PresentationThemeData>(
        (ref) {
  return PresentationThemeNotifier();
});

class PresentationThemeNotifier extends StateNotifier<PresentationThemeData> {
  PresentationThemeNotifier() : super(BuiltInThemes.modern);

  void setTheme(PresentationThemeData theme) {
    state = theme;
  }

  void updateTheme(PresentationThemeData Function(PresentationThemeData) update) {
    state = update(state);
  }

  void resetToDefault() {
    state = BuiltInThemes.modern;
  }
}

