class PresentationModeWithDrawing extends ConsumerStatefulWidget {
  const PresentationModeWithDrawing({super.key});

  @override
  ConsumerState<PresentationModeWithDrawing> createState() =>
      _PresentationModeWithDrawingState();
}

class _PresentationModeWithDrawingState
    extends ConsumerState<PresentationModeWithDrawing> {
  final Map<String, Offset> _presentationPointers = {};
  Timer? _pointerTimer;
  final _focusNode = FocusNode();

  @override
  void initState() {
    super.initState();
    _startPointerSimulation();
  }

  @override
  void dispose() {
    _pointerTimer?.cancel();
    _focusNode.dispose();
    super.dispose();
  }

  void _startPointerSimulation() {
    _pointerTimer = Timer.periodic(const Duration(milliseconds: 100), (timer) {
      if (mounted) {
        setState(() {
          final presentation = ref.read(presentationProvider);
          for (var user in presentation.collaborators) {
            if (user.id != '1' && user.isOnline) {
              final random = math.Random();
              final x = 400 + random.nextDouble() * 800;
              final y = 200 + random.nextDouble() * 400;
              _presentationPointers[user.id] = Offset(x, y);
            }
          }
        });
      }
    });
  }

  void _handleKeyPress(KeyEvent event) {
    if (event is KeyDownEvent) {
      final presentation = ref.read(presentationProvider);

      if (event.logicalKey == LogicalKeyboardKey.arrowRight ||
          event.logicalKey == LogicalKeyboardKey.space) {
        if (presentation.currentSlideIndex < presentation.slides.length - 1) {
          ref
              .read(slideSyncProvider.notifier)
              .updateSlide(presentation.currentSlideIndex + 1);
        }
      } else if (event.logicalKey == LogicalKeyboardKey.arrowLeft) {
        if (presentation.currentSlideIndex > 0) {
          ref
              .read(slideSyncProvider.notifier)
              .updateSlide(presentation.currentSlideIndex - 1);
        }
      } else if (event.logicalKey == LogicalKeyboardKey.escape) {
        ref.read(slideSyncProvider.notifier).stopPresenting();
        Navigator.pop(context);
      }
    }
  }

  @override
  Widget build(BuildContext context) {
    final presentation = ref.watch(presentationProvider);
    final syncState = ref.watch(slideSyncProvider);
    final drawingState = ref.watch(drawingProvider);
    final currentSlide = presentation.slides[presentation.currentSlideIndex];
    final presenter = presentation.presenter;

    return KeyboardListener(
      focusNode: _focusNode,
      autofocus: true,
      onKeyEvent: _handleKeyPress,
      child: Scaffold(
        backgroundColor: Colors.black,
        body: Stack(
          children: [
            // Main presentation area with drawing overlay
            Center(
              child: AspectRatio(
                aspectRatio: 16 / 9,
                child: DrawingCanvasOverlay(
                  enabled: true,
                  child: Container(
                    color: currentSlide.getThemeBackground(),
                    child: Stack(
                      children: [
                        // Slide content
                        Center(
                          child: Padding(
                            padding: const EdgeInsets.all(48),
                            child: Text(
                              currentSlide.title ?? 'Slide ${presentation.currentSlideIndex + 1}',
                              style: TextStyle(
                                fontSize: 64,
                                fontWeight: FontWeight.bold,
                                color: currentSlide.getThemeTextColor(),
                              ),
                              textAlign: TextAlign.center,
                            ),
                          ),
                        ),
                        // Components
                        ...currentSlide.components.map((component) {
                          return Positioned(
                            left: component.position.dx,
                            top: component.position.dy,
                            child: SizedBox(
                              width: component.size.width,
                              height: component.size.height,
                              child: _buildComponentContent(component),
                            ),
                          );
                        }),
                        // Collaborative pointers
                        ..._presentationPointers.entries.map((entry) {
                          final user = presentation.collaborators
                              .where((u) => u.id == entry.key)
                              .firstOrNull;
                          if (user == null) return const SizedBox.shrink();

                          return PresentationPointer(
                            position: entry.value,
                            user: user,
                          );
                        }),
                      ],
                    ),
                  ),
                ),
              ),
            ),

            // Drawing toolbar
            if (drawingState.showDrawingPanel)
              const Positioned(
                left: 24,
                top: 80,
                child: DrawingToolbar(),
              ),

            // Drawing toggle button
            Positioned(
              left: 24,
              top: 24,
              child: Row(
                children: [
                  const DrawingToggleButton(),
                  if (drawingState.strokes.isNotEmpty) ...[
                    const SizedBox(width: 12),
                    Container(
                      padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                      decoration: BoxDecoration(
                        color: Colors.black.withOpacity(0.7),
                        borderRadius: BorderRadius.circular(12),
                      ),
                      child: Text(
                        '${drawingState.strokes.length} drawing${drawingState.strokes.length > 1 ? 's' : ''}',
                        style: const TextStyle(
                          color: Colors.white70,
                          fontSize: 12,
                          fontWeight: FontWeight.w600,
                        ),
                      ),
                    ),
                  ],
                ],
              ),
            ),

            // Sync indicator
            Positioned(
              top: 24,
              right: 24,
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.end,
                children: [
                  const ScreenMirroringIndicator(isMainDisplay: false),
                  const SizedBox(height: 8),
                  Container(
                    padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                    decoration: BoxDecoration(
                      color: Colors.black.withOpacity(0.7),
                      borderRadius: BorderRadius.circular(12),
                    ),
                    child: Row(
                      mainAxisSize: MainAxisSize.min,
                      children: [
                        Container(
                          width: 8,
                          height: 8,
                          decoration: BoxDecoration(
                            color: syncState.isPresenting
                                ? const Color(0xFF10B981)
                                : Colors.grey,
                            shape: BoxShape.circle,
                          ),
                        ),
                        const SizedBox(width: 8),
                        Text(
                          syncState.isPresenting ? 'SYNCED' : 'NOT SYNCED',
                          style: TextStyle(
                            color: syncState.isPresenting
                                ? const Color(0xFF10B981)
                                : Colors.grey,
                            fontSize: 11,
                            fontWeight: FontWeight.bold,
                          ),
                        ),
                      ],
                    ),
                  ),
                ],
              ),
            ),

            // Presenter indicator
            if (presenter != null)
              Positioned(
                top: 100,
                right: 24,
                child: Container(
                  padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
                  decoration: BoxDecoration(
                    color: Colors.black.withOpacity(0.7),
                    borderRadius: BorderRadius.circular(20),
                    border: Border.all(color: presenter.cursorColor, width: 2),
                  ),
                  child: Row(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      CircleAvatar(
                        radius: 12,
                        backgroundColor: presenter.cursorColor,
                        child: Text(
                          presenter.initials,
                          style: const TextStyle(
                            fontSize: 10,
                            fontWeight: FontWeight.bold,
                          ),
                        ),
                      ),
                      const SizedBox(width: 8),
                      Text(
                        '${presenter.name} is presenting',
                        style: const TextStyle(
                          color: Colors.white,
                          fontSize: 14,
                          fontWeight: FontWeight.w600,
                        ),
                      ),
                    ],
                  ),
                ),
              ),

            // Viewers panel
            Positioned(
              bottom: 100,
              right: 24,
              child: ViewersPanel(),
            ),

            // Bottom controls
            Positioned(
              bottom: 32,
              left: 0,
              right: 0,
              child: Center(
                child: Container(
                  padding: const EdgeInsets.symmetric(horizontal: 24, vertical: 12),
                  decoration: BoxDecoration(
                    color: Colors.black.withOpacity(0.7),
                    borderRadius: BorderRadius.circular(24),
                  ),
                  child: Row(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      IconButton(
                        icon: const Icon(Icons.arrow_back, color: Colors.white),
                        onPressed: presentation.currentSlideIndex > 0
                            ? () {
                                ref
                                    .read(slideSyncProvider.notifier)
                                    .updateSlide(presentation.currentSlideIndex - 1);
                              }
                            : null,
                      ),
                      Text(
                        '${presentation.currentSlideIndex + 1} / ${presentation.slides.length}',
                        style: const TextStyle(color: Colors.white),
                      ),
                      IconButton(
                        icon: const Icon(Icons.arrow_forward, color: Colors.white),
                        onPressed:
                            presentation.currentSlideIndex < presentation.slides.length - 1
                                ? () {
                                    ref
                                        .read(slideSyncProvider.notifier)
                                        .updateSlide(presentation.currentSlideIndex + 1);
                                  }
                                : null,
                      ),
                      const SizedBox(width: 16),
                      IconButton(
                        icon: const Icon(Icons.chat, color: Colors.white),
                        tooltip: 'Open Chat',
                        onPressed: () {
                          showDialog(
                            context: context,
                            builder: (context) => const PresentationChatDialog(),
                          );
                        },
                      ),
                      const SizedBox(width: 16),
                      IconButton(
                        icon: const Icon(Icons.close, color: Colors.white),
                        onPressed: () {
                          ref.read(slideSyncProvider.notifier).stopPresenting();
                          Navigator.pop(context);
                        },
                      ),
                    ],
                  ),
                ),
              ),
            ),

            // Live comments overlay
            const LiveCommentsOverlay(),
          ],
        ),
      ),
    );
  }

  Widget _buildComponentContent(SlideComponent component) {
    switch (component.type) {
      case ComponentType.text:
        return Text(
          component.content,
          style: TextStyle(
            fontSize: component.fontSize,
            fontWeight: FontWeight.w600,
            color: component.color ?? Colors.black87,
          ),
        );
      case ComponentType.shape:
        return Container(
          decoration: BoxDecoration(
            color: component.color ?? const Color(0xFF3B82F6),
            borderRadius: BorderRadius.circular(8),
          ),
        );
      case ComponentType.image:
        return Container(
          decoration: BoxDecoration(
            color: Colors.grey[300],
            borderRadius: BorderRadius.circular(8),
          ),
          child: const Icon(Icons.image, size: 48, color: Colors.grey),
        );
    }
  }
}

