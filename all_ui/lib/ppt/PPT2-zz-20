// ==================== MASTER SLIDE PREVIEW PAINTER ====================

class MasterSlidePreviewPainter extends CustomPainter {
  final MasterSlide masterSlide;

  MasterSlidePreviewPainter({required this.masterSlide});

  @override
  void paint(Canvas canvas, Size size) {
    final scale = size.width / 1200;

    for (final element in masterSlide.elements) {
      final scaledRect = Rect.fromLTWH(
        element.bounds.left * scale,
        element.bounds.top * scale,
        element.bounds.width * scale,
        element.bounds.height * scale,
      );

      // Draw element box
      final paint = Paint()
        ..color = element.type == 'title'
            ? const Color(0xFF3B82F6).withOpacity(0.2)
            : const Color(0xFF64748B).withOpacity(0.2)
        ..style = PaintingStyle.fill;

      canvas.drawRRect(
        RRect.fromRectAndRadius(scaledRect, const Radius.circular(4)),
        paint,
      );

      // Draw border
      final borderPaint = Paint()
        ..color = element.type == 'title'
            ? const Color(0xFF3B82F6)
            : const Color(0xFF64748B)
        ..style = PaintingStyle.stroke
        ..strokeWidth = 1;

      canvas.drawRRect(
        RRect.fromRectAndRadius(scaledRect, const Radius.circular(4)),
        borderPaint,
      );

      // Draw placeholder text
      final textPainter = TextPainter(
        text: TextSpan(
          text: element.placeholder ?? element.type,
          style: TextStyle(
            color: element.type == 'title'
                ? const Color(0xFF3B82F6)
                : const Color(0xFF64748B),
            fontSize: (element.textStyle?.fontSize ?? 16) * scale * 0.3,
          ),
        ),
        textDirection: TextDirection.ltr,
      );

      textPainter.layout(maxWidth: scaledRect.width - 8);
      textPainter.paint(
        canvas,
        Offset(
          scaledRect.left + 4,
          scaledRect.top + (scaledRect.height - textPainter.height) / 2,
        ),
      );
    }
  }

  @override
  bool shouldRepaint(MasterSlidePreviewPainter oldDelegate) =>
      oldDelegate.masterSlide != masterSlide;
}

