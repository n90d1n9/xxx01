class _ColorSection extends StatelessWidget {
  final String title;
  final List<_ColorOption> colors;

  const _ColorSection({required this.title, required this.colors});

  @override
  Widget build(BuildContext context) {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text(
          title,
          style: const TextStyle(
            color: Colors.white,
            fontSize: 16,
            fontWeight: FontWeight.bold,
          ),
        ),
        const SizedBox(height: 12),
        ...colors.map((option) => Padding(
              padding: const EdgeInsets.only(bottom: 12),
              child: Row(
                children: [
                  SizedBox(
                    width: 100,
                    child: Text(
                      option.label,
                      style: const TextStyle(color: Colors.white70),
                    ),
                  ),
                  GestureDetector(
                    onTap: () => _showColorPicker(context, option),
                    child: Container(
                      width: 48,
                      height: 48,
                      decoration: BoxDecoration(
                        color: option.color,
                        borderRadius: BorderRadius.circular(8),
                        border: Border.all(color: Colors.white24, width: 2),
                      ),
                    ),
                  ),
                  const SizedBox(width: 12),
                  Text(
                    '#${option.color.value.toRadixString(16).substring(2).toUpperCase()}',
                    style: const TextStyle(
                      color: Colors.white54,
                      fontFamily: 'monospace',
                    ),
                  ),
                ],
              ),
            )),
      ],
    );
  }

  void _showColorPicker(BuildContext context, _ColorOption option) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        backgroundColor: const Color(0xFF1E293B),
        title: Text('Choose ${option.label} Color',
            style: const TextStyle(color: Colors.white)),
        content: Wrap(
          spacing: 8,
          runSpacing: 8,
          children: [
            const Color(0xFF3B82F6),
            const Color(0xFF10B981),
            const Color(0xFFF59E0B),
            const Color(0xFFEF4444),
            const Color(0xFF8B5CF6),
            const Color(0xFFEC4899),
            const Color(0xFF06B6D4),
            const Color(0xFF84CC16),
            const Color(0xFF1E293B),
            Colors.white,
          ].map((color) {
            return GestureDetector(
              onTap: () {
                option.onChanged(color);
                Navigator.pop(context);
              },
              child: Container(
                width: 48,
                height: 48,
                decoration: BoxDecoration(
                  color: color,
                  borderRadius: BorderRadius.circular(8),
                  border: Border.all(color: Colors.white24, width: 2),
                ),
              ),
            );
          }).toList(),
        ),
      ),
    );
  }
}

class _ColorOption {
  final String label;
  final Color color;
  final Function(Color) onChanged;

  _ColorOption(this.label, this.color, this.onChanged);
}

