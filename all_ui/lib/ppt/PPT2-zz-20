    this.redoStack = const [],
  });

  PresentationHistory copyWith({
    List<Presentation>? undoStack,
    List<Presentation>? redoStack,
  }) {
    return PresentationHistory(
      undoStack: undoStack ?? this.undoStack,
      redoStack: redoStack ?? this.redoStack,
    );
  }
}

class Presentation {
  final String id;
  final String title;
  final List<Slide> slides;
  final int currentSlideIndex;
  final List<CollaborativeUser> collaborators;
  final List<Comment> allComments;
  final List<ActivityLog> activityLogs;
  final DateTime lastModified;
  final bool isPresentationMode;
  final String? presenterId;

  Presentation({
    required this.id,
    required this.title,
    required this.slides,
    this.currentSlideIndex = 0,
    this.collaborators = const [],
    this.allComments = const [],
    this.activityLogs = const [],
    required this.lastModified,
    this.isPresentationMode = false,
    this.presenterId,
  });

  Presentation copyWith({
    String? title,
    List<Slide>? slides,
    int? currentSlideIndex,
    List<CollaborativeUser>? collaborators,
    List<Comment>? allComments,
    List<ActivityLog>? activityLogs,
    DateTime? lastModified,
    bool? isPresentationMode,
    String? presenterId,
  }) {
    return Presentation(
      id: id,
      title: title ?? this.title,
      slides: slides ?? this.slides,
      currentSlideIndex: currentSlideIndex ?? this.currentSlideIndex,
      collaborators: collaborators ?? this.collaborators,
      allComments: allComments ?? this.allComments,
      activityLogs: activityLogs ?? this.activityLogs,
      lastModified: lastModified ?? this.lastModified,
      isPresentationMode: isPresentationMode ?? this.isPresentationMode,
      presenterId: presenterId ?? this.presenterId,
    );
  }

  int get unresolvedCommentCount =>
      allComments.where((c) => !c.isResolved).length;

  CollaborativeUser? get presenter =>
      collaborators.where((u) => u.id == presenterId).firstOrNull;
}

