class DrawingPoint {
  final Offset position;
  final Color color;
  final double strokeWidth;
  final DateTime timestamp;

  DrawingPoint({
    required this.position,
    required this.color,
    required this.strokeWidth,
    required this.timestamp,
  });
}

class DrawingStroke {
  final String id;
  final List<DrawingPoint> points;
  final Color color;
  final double strokeWidth;
  final String userId;
  final String userName;

  DrawingStroke({
    required this.id,
    required this.points,
    required this.color,
    required this.strokeWidth,
    required this.userId,
    required this.userName,
  });
}

enum DrawingTool { pen, highlighter, eraser, laser }

class DrawingState {
  final bool isDrawing;
  final DrawingTool currentTool;
  final Color currentColor;
  final double strokeWidth;
  final List<DrawingStroke> strokes;
  final List<DrawingPoint> currentPoints;
  final bool showDrawingPanel;

  DrawingState({
    this.isDrawing = false,
    this.currentTool = DrawingTool.pen,
    this.currentColor = Colors.red,
    this.strokeWidth = 3.0,
    this.strokes = const [],
    this.currentPoints = const [],
    this.showDrawingPanel = false,
  });

  DrawingState copyWith({
    bool? isDrawing,
    DrawingTool? currentTool,
    Color? currentColor,
    double? strokeWidth,
    List<DrawingStroke>? strokes,
    List<DrawingPoint>? currentPoints,
    bool? showDrawingPanel,
  }) {
    return DrawingState(
      isDrawing: isDrawing ?? this.isDrawing,
      currentTool: currentTool ?? this.currentTool,
      currentColor: currentColor ?? this.currentColor,
      strokeWidth: strokeWidth ?? this.strokeWidth,
      strokes: strokes ?? this.strokes,
      currentPoints: currentPoints ?? this.currentPoints,
      showDrawingPanel: showDrawingPanel ?? this.showDrawingPanel,
    );
  }
}

// ==================== DRAWING PROVIDER ====================

final drawingProvider = StateNotifierProvider<DrawingNotifier, DrawingState>((ref) {
  return DrawingNotifier();
});

class DrawingNotifier extends StateNotifier<DrawingState> {
  DrawingNotifier() : super(DrawingState());

  void setTool(DrawingTool tool) {
    state = state.copyWith(currentTool: tool);
  }

  void setColor(Color color) {
    state = state.copyWith(currentColor: color);
  }

  void setStrokeWidth(double width) {
    state = state.copyWith(strokeWidth: width);
  }

  void startDrawing(Offset position) {
    if (state.currentTool == DrawingTool.laser) {
      // Laser pointer doesn't draw strokes
      return;
    }

    state = state.copyWith(
      isDrawing: true,
      currentPoints: [
        DrawingPoint(
          position: position,
          color: state.currentColor,
          strokeWidth: state.strokeWidth,
          timestamp: DateTime.now(),
        ),
      ],
    );
  }

  void updateDrawing(Offset position) {
    if (!state.isDrawing) return;

    state = state.copyWith(
      currentPoints: [
        ...state.currentPoints,
        DrawingPoint(
          position: position,
          color: state.currentColor,
          strokeWidth: state.strokeWidth,
          timestamp: DateTime.now(),
        ),
      ],
    );
  }

  void endDrawing() {
    if (!state.isDrawing || state.currentPoints.isEmpty) return;

    final stroke = DrawingStroke(
      id: const Uuid().v4(),
      points: state.currentPoints,
      color: state.currentColor,
      strokeWidth: state.strokeWidth,
      userId: '1',
      userName: 'Current User',
    );

    state = state.copyWith(
      isDrawing: false,
      strokes: [...state.strokes, stroke],
      currentPoints: [],
    );
  }

  void clearDrawings() {
    state = state.copyWith(
      strokes: [],
      currentPoints: [],
    );
  }

  void undoLastStroke() {
    if (state.strokes.isEmpty) return;
    state = state.copyWith(
      strokes: state.strokes.sublist(0, state.strokes.length - 1),
    );
  }

  void toggleDrawingPanel() {
    state = state.copyWith(showDrawingPanel: !state.showDrawingPanel);
  }
}

