class UndoRedoButtons extends ConsumerWidget {
  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final canUndo = ref.watch(canUndoProvider);
    final canRedo = ref.watch(canRedoProvider);

    return Row(
      children: [
        IconButton(
          icon: const Icon(Icons.undo, size: 20),
          color: canUndo ? Colors.white70 : Colors.white24,
          onPressed: canUndo
              ? () {
                  final previous = ref.read(historyProvider.notifier).undo();
                  if (previous != null) {
                    ref.read(presentationProvider.notifier).state = previous;
                  }
                }
              : null,
          tooltip: 'Undo (Ctrl+Z)',
        ),
        IconButton(
          icon: const Icon(Icons.redo, size: 20),
          color: canRedo ? Colors.white70 : Colors.white24,
          onPressed: canRedo
              ? () {
                  final next = ref.read(historyProvider.notifier).redo();
                  if (next != null) {
                    ref.read(presentationProvider.notifier).state = next;
                  }
                }
              : null,
          tooltip: 'Redo (Ctrl+Y)',
        ),
      ],
    );
  }
}

