class CollaborativeDrawingCanvas extends ConsumerStatefulWidget {
  final Widget child;
  final bool enabled;
  final String currentUserId;

  const CollaborativeDrawingCanvas({
    super.key,
    required this.child,
    this.enabled = true,
    this.currentUserId = '1',
  });

  @override
  ConsumerState<CollaborativeDrawingCanvas> createState() =>
      _CollaborativeDrawingCanvasState();
}

class _CollaborativeDrawingCanvasState
    extends ConsumerState<CollaborativeDrawingCanvas> {
  Offset? _laserPosition;
  Timer? _laserTimer;

  @override
  void dispose() {
    _laserTimer?.cancel();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final drawingState = ref.watch(drawingProvider);
    final collaborativeState = ref.watch(collaborativeDrawingProvider);
    final canDraw = collaborativeState.allowCollaborativeDrawing ||
        widget.currentUserId == '1';

    return Stack(
      children: [
        widget.child,
        if (widget.enabled)
          Positioned.fill(
            child: GestureDetector(
              onPanStart: canDraw
                  ? (details) {
                      if (drawingState.currentTool == DrawingTool.laser) {
                        setState(() => _laserPosition = details.localPosition);
                        _startLaserFade();
                      } else {
                        ref.read(collaborativeDrawingProvider.notifier).startCollaborativeDrawing(
                              widget.currentUserId,
                              details.localPosition,
                              drawingState.currentColor,
                              drawingState.strokeWidth,
                            );
                      }
                    }
                  : null,
              onPanUpdate: canDraw
                  ? (details) {
                      if (drawingState.currentTool == DrawingTool.laser) {
                        setState(() => _laserPosition = details.localPosition);
                        _startLaserFade();
                      } else {
                        ref.read(collaborativeDrawingProvider.notifier).updateCollaborativeDrawing(
                              widget.currentUserId,
                              details.localPosition,
                            );
                      }
                    }
                  : null,
              onPanEnd: canDraw
                  ? (details) {
                      if (drawingState.currentTool != DrawingTool.laser) {
                        final presentation = ref.read(presentationProvider);
                        final currentUser = presentation.collaborators
                            .where((u) => u.id == widget.currentUserId)
                            .firstOrNull;
                        ref.read(collaborativeDrawingProvider.notifier).endCollaborativeDrawing(
                              widget.currentUserId,
                              currentUser?.name ?? 'User',
                            );
                      }
                    }
                  : null,
              child: CustomPaint(
                painter: CollaborativeDrawingPainter(
                  allStrokes: collaborativeState.allStrokes,
                  activeStrokes: collaborativeState.activeStrokes,
                  currentTool: drawingState.currentTool,
                  laserPosition: _laserPosition,
                  presentation: ref.watch(presentationProvider),
                ),
              ),
            ),
          ),
      ],
    );
  }

  void _startLaserFade() {
    _laserTimer?.cancel();
    _laserTimer = Timer(const Duration(milliseconds: 500), () {
      if (mounted) {
        setState(() => _laserPosition = null);
      }
    });
  }
}

// ==================== COLLABORATIVE DRAWING PAINTER ====================

class CollaborativeDrawingPainter extends CustomPainter {
  final List<CollaborativeDrawingStroke> allStrokes;
  final Map<String, List<DrawingPoint>> activeStrokes;
  final DrawingTool currentTool;
  final Offset? laserPosition;
  final Presentation presentation;

  CollaborativeDrawingPainter({
    required this.allStrokes,
    required this.activeStrokes,
    required this.currentTool,
    this.laserPosition,
    required this.presentation,
  });

  @override
  void paint(Canvas canvas, Size size) {
    // Draw completed strokes
    for (final stroke in allStrokes) {
      _drawStroke(canvas, stroke.points, stroke.color, stroke.strokeWidth);
      
      // Draw user label for recent strokes
      if (stroke.points.isNotEmpty &&
          DateTime.now().difference(stroke.timestamp).inSeconds < 3) {
        _drawUserLabel(canvas, stroke);
      }
    }

    // Draw active strokes being drawn by other users
    for (final entry in activeStrokes.entries) {
      final userId = entry.key;
      final points = entry.value;
      
      if (points.isNotEmpty) {
        _drawStroke(canvas, points, points.first.color, points.first.strokeWidth);
        
        // Show who is drawing
        final user = presentation.collaborators
            .where((u) => u.id == userId)
            .firstOrNull;
        if (user != null) {
          _drawActiveDrawingIndicator(canvas, points.last.position, user);
        }
      }
    }

    // Draw laser pointer
    if (laserPosition != null) {
      _drawLaserPointer(canvas, laserPosition!);
    }
  }

  void _drawStroke(
      Canvas canvas, List<DrawingPoint> points, Color color, double width) {
    if (points.length < 2) return;

    final paint = Paint()
      ..color = color
      ..strokeWidth = width
      ..strokeCap = StrokeCap.round
      ..strokeJoin = StrokeJoin.round
      ..style = PaintingStyle.stroke;

    final path = Path();
    path.moveTo(points.first.position.dx, points.first.position.dy);

    for (int i = 1; i < points.length; i++) {
      final p1 = points[i - 1].position;
      final p2 = points[i].position;

      final midPoint = Offset(
        (p1.dx + p2.dx) / 2,
        (p1.dy + p2.dy) / 2,
      );
      path.quadraticBezierTo(p1.dx, p1.dy, midPoint.dx, midPoint.dy);
    }

    canvas.drawPath(path, paint);
  }

  void _drawUserLabel(Canvas canvas, CollaborativeDrawingStroke stroke) {
    if (stroke.points.isEmpty) return;

    final lastPoint = stroke.points.last.position;
    final user = presentation.collaborators
        .where((u) => u.id == stroke.userId)
        .firstOrNull;
    
    if (user == null) return;

    final textPainter = TextPainter(
      text: TextSpan(
        text: user.name.split(' ').first,
        style: TextStyle(
          color: Colors.white,
          fontSize: 10,
          fontWeight: FontWeight.bold,
          shadows: [
            Shadow(
              color: Colors.black.withOpacity(0.5),
              blurRadius: 4,
            ),
          ],
        ),
      ),
      textDirection: TextDirection.ltr,
    );

    textPainter.layout();

    final labelOffset = Offset(
      lastPoint.dx + 10,
      lastPoint.dy - 20,
    );

    // Draw background
    final backgroundRect = Rect.fromLTWH(
      labelOffset.dx - 4,
      labelOffset.dy - 2,
      textPainter.width + 8,
      textPainter.height + 4,
    );

    canvas.drawRRect(
      RRect.fromRectAndRadius(backgroundRect, const Radius.circular(4)),
      Paint()..color = stroke.color.withOpacity(0.9),
    );

    textPainter.paint(canvas, labelOffset);
  }

  void _drawActiveDrawingIndicator(
      Canvas canvas, Offset position, CollaborativeUser user) {
    // Draw pulsing circle around active drawing
    final paint = Paint()
      ..color = user.cursorColor.withOpacity(0.3)
      ..style = PaintingStyle.fill;

    canvas.drawCircle(position, 8, paint);

    // Draw solid center
    canvas.drawCircle(
      position,
      4,
      Paint()..color = user.cursorColor,
    );
  }

  void _drawLaserPointer(Canvas canvas, Offset position) {
    // Draw laser pointer with glow effect
    final paint = Paint()
      ..color = Colors.red
      ..style = PaintingStyle.fill;

    // Outer glow
    canvas.drawCircle(
      position,
      12,
      Paint()
        ..color = Colors.red.withOpacity(0.3)
        ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 8),
    );

    // Inner circle
    canvas.drawCircle(position, 6, paint);

    // Center dot
    canvas.drawCircle(
      position,
      2,
      Paint()..color = Colors.white,
    );
  }

  @override
  bool shouldRepaint(CollaborativeDrawingPainter oldDelegate) {
    return oldDelegate.allStrokes != allStrokes ||
        oldDelegate.activeStrokes != activeStrokes ||
        oldDelegate.laserPosition != laserPosition;
  }
}

