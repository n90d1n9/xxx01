class Slide {
  final String id;
  final String? title;
  final Color? backgroundColor;
  final SlideTheme theme;
  final List<SlideComponent> components;

  Slide({
    required this.id,
    this.title,
    this.backgroundColor,
    this.theme = SlideTheme.minimal,
    this.components = const [],
  });

  Slide copyWith({
    String? title,
    Color? backgroundColor,
    SlideTheme? theme,
    List<SlideComponent>? components,
  }) {
    return Slide(
      id: id,
      title: title ?? this.title,
      backgroundColor: backgroundColor ?? this.backgroundColor,
      theme: theme ?? this.theme,
      components: components ?? this.components,
    );
  }

  Color getThemeBackground() {
    switch (theme) {
      case SlideTheme.minimal:
        return Colors.white;
      case SlideTheme.modern:
        return const Color(0xFFF8FAFC);
      case SlideTheme.bold:
        return const Color(0xFF1E293B);
      case SlideTheme.dark:
        return const Color(0xFF0F172A);
      case SlideTheme.colorful:
        return const Color(0xFFFEF3C7);
    }
  }

  Color getThemeTextColor() {
    switch (theme) {
      case SlideTheme.minimal:
      case SlideTheme.modern:
      case SlideTheme.colorful:
        return Colors.black87;
      case SlideTheme.bold:
      case SlideTheme.dark:
        return Colors.white;
    }
  }
}

