// ==================== SLIDE TRANSITIONS ====================

enum SlideTransition {
  none,
  fade,
  slide,
  zoom,
  flip,
  cube,
  dissolve,
  push,
}

class TransitionSettings {
  final SlideTransition type;
  final Duration duration;
  final Curve curve;

  const TransitionSettings({
    this.type = SlideTransition.fade,
    this.duration = const Duration(milliseconds: 500),
    this.curve = Curves.easeInOut,
  });
}

// ==================== SLIDE TRANSITION PROVIDER ====================

final slideTransitionProvider = StateProvider<TransitionSettings>((ref) {
  return const TransitionSettings();
});

final presentationZoomProvider = StateProvider<double>((ref) => 1.0);

// ==================== ANIMATED SLIDE TRANSITION ====================

class AnimatedSlideTransition extends ConsumerStatefulWidget {
  final Widget child;
  final int slideIndex;

  const AnimatedSlideTransition({
    super.key,
    required this.child,
    required this.slideIndex,
  });

  @override
  ConsumerState<AnimatedSlideTransition> createState() =>
      _AnimatedSlideTransitionState();
}

class _AnimatedSlideTransitionState
    extends ConsumerState<AnimatedSlideTransition>
    with SingleTickerProviderStateMixin {
  late AnimationController _controller;
  late Animation<double> _animation;
  int _previousSlideIndex = 0;

  @override
  void initState() {
    super.initState();
    _previousSlideIndex = widget.slideIndex;
    _controller = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 500),
    );
    _animation = CurvedAnimation(
      parent: _controller,
      curve: Curves.easeInOut,
    );
    _controller.forward();
  }

  @override
  void didUpdateWidget(AnimatedSlideTransition oldWidget) {
    super.didUpdateWidget(oldWidget);
    if (oldWidget.slideIndex != widget.slideIndex) {
      _previousSlideIndex = oldWidget.slideIndex;
      _controller.reset();
      _controller.forward();
    }
  }

  @override
  void dispose() {
    _controller.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final transitionSettings = ref.watch(slideTransitionProvider);
    final isForward = widget.slideIndex > _previousSlideIndex;

    return AnimatedBuilder(
      animation: _animation,
      builder: (context, child) {
        switch (transitionSettings.type) {
          case SlideTransition.fade:
            return FadeTransition(
              opacity: _animation,
              child: widget.child,
            );
          case SlideTransition.slide:
            return SlideTransition(
              position: Tween<Offset>(
                begin: Offset(isForward ? 1.0 : -1.0, 0.0),
                end: Offset.zero,
              ).animate(_animation),
              child: widget.child,
            );
          case SlideTransition.zoom:
            return ScaleTransition(
              scale: Tween<double>(begin: 0.8, end: 1.0).animate(_animation),
              child: FadeTransition(
                opacity: _animation,
                child: widget.child,
              ),
            );
          case SlideTransition.flip:
            return Transform(
              transform: Matrix4.identity()
                ..setEntry(3, 2, 0.001)
                ..rotateY((1.0 - _animation.value) * math.pi / 2),
              alignment: Alignment.center,
              child: _animation.value > 0.5
                  ? widget.child
                  : Container(color: Colors.black),
            );
          case SlideTransition.cube:
            return Transform(
              transform: Matrix4.identity()
                ..setEntry(3, 2, 0.001)
                ..rotateY(_animation.value * math.pi / 2 * (isForward ? -1 : 1)),
              alignment: isForward ? Alignment.centerLeft : Alignment.centerRight,
              child: widget.child,
            );
          case SlideTransition.dissolve:
            return FadeTransition(
              opacity: _animation,
              child: Transform.scale(
                scale: 1.0 + (1.0 - _animation.value) * 0.05,
                child: widget.child,
              ),
            );
          case SlideTransition.push:
            return SlideTransition(
              position: Tween<Offset>(
                begin: Offset(0.0, isForward ? 1.0 : -1.0),
                end: Offset.zero,
              ).animate(_animation),
              child: widget.child,
            );
          case SlideTransition.none:
            return widget.child;
        }
      },
    );
  }
}

