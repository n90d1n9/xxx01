class CollaborativeEditor extends ConsumerStatefulWidget {
  const CollaborativeEditor({super.key});

  @override
  ConsumerState<CollaborativeEditor> createState() =>
      _CollaborativeEditorState();
}

class _CollaborativeEditorState extends ConsumerState<CollaborativeEditor> {
  Timer? _cursorUpdateTimer;
  final _focusNode = FocusNode();

  @override
  void initState() {
    super.initState();
    _startCursorSimulation();
  }

  @override
  void dispose() {
    _cursorUpdateTimer?.cancel();
    _focusNode.dispose();
    super.dispose();
  }

  void _startCursorSimulation() {
    _cursorUpdateTimer =
        Timer.periodic(const Duration(milliseconds: 500), (timer) {
      final presentation = ref.read(presentationProvider);
      for (var user in presentation.collaborators) {
        if (user.id != '1' && user.isOnline) {
          final newX = (user.cursorPosition?.dx ?? 400) +
              (math.Random().nextDouble() - 0.5) * 30;
          final newY = (user.cursorPosition?.dy ?? 400) +
              (math.Random().nextDouble() - 0.5) * 30;
          ref.read(presentationProvider.notifier).updateCollaboratorCursor(
                user.id,
                Offset(newX.clamp(100.0, 1100.0), newY.clamp(100.0, 600.0)),
              );
        }
      }
    });
  }

  void _handleKeyPress(KeyEvent event) {
    if (event is KeyDownEvent) {
      final presentation = ref.read(presentationProvider);
      
      // Arrow keys for navigation
      if (event.logicalKey == LogicalKeyboardKey.arrowRight) {
        if (presentation.currentSlideIndex < presentation.slides.length - 1) {
          ref
              .read(presentationProvider.notifier)
              .setCurrentSlide(presentation.currentSlideIndex + 1);
        }
      } else if (event.logicalKey == LogicalKeyboardKey.arrowLeft) {
        if (presentation.currentSlideIndex > 0) {
          ref
              .read(presentationProvider.notifier)
              .setCurrentSlide(presentation.currentSlideIndex - 1);
        }
      }
      
      // Undo/Redo
      else if (event.logicalKey == LogicalKeyboardKey.keyZ &&
          (event.control || event.meta)) {
        final previous = ref.read(historyProvider.notifier).undo();
        if (previous != null) {
          ref.read(presentationProvider.notifier).state = previous;
        }
      } else if (event.logicalKey == LogicalKeyboardKey.keyY &&
          (event.control || event.meta)) {
        final next = ref.read(historyProvider.notifier).redo();
        if (next != null) {
          ref.read(presentationProvider.notifier).state = next;
        }
      }
      
      // F5 for presentation
      else if (event.logicalKey == LogicalKeyboardKey.f5) {
        _startPresentation();
      }
    }
  }

  void _startPresentation() {
    ref.read(presentationProvider.notifier).startPresentation('1');
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (context) => const CollaborativePresentationMode(),
      ),
    ).then((_) {
      ref.read(presentationProvider.notifier).endPresentation();
    });
  }

  @override
  Widget build(BuildContext context) {
    final presentation = ref.watch(presentationProvider);
    final showComments = ref.watch(showCommentsPanel);
    final showActivity = ref.watch(showActivityFeed);
    final showChat = ref.watch(showChatPanel);

    return KeyboardListener(
      focusNode: _focusNode,
      autofocus: true,
      onKeyEvent: _handleKeyPress,
      child: Scaffold(
        backgroundColor: const Color(0xFF0F172A),
        appBar: AppBar(
          backgroundColor: const Color(0xFF1E293B),
          elevation: 0,
          title: Row(
            children: [
              Container(
                padding: const EdgeInsets.all(8),
                decoration: BoxDecoration(
                  gradient: const LinearGradient(
                    colors: [Color(0xFF3B82F6), Color(0xFF8B5CF6)],
                  ),
                  borderRadius: BorderRadius.circular(8),
                ),
                child: const Icon(Icons.people, size: 20),
              ),
              const SizedBox(width: 12),
              Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(presentation.title,
                      style: const TextStyle(fontSize: 16)),
                  Text(
                    'Last edited ${_timeAgo(presentation.lastModified)}',
                    style: const TextStyle(fontSize: 11, color: Colors.white54),
                  ),
                ],
              ),
            ],
          ),
          actions: [
            UndoRedoButtons(),
            const SizedBox(width: 8),
            IconButton(
              icon: Badge(
                label: Text('${presentation.unresolvedCommentCount}'),
                isLabelVisible: presentation.unresolvedCommentCount > 0,
                child: const Icon(Icons.comment),
              ),
              onPressed: () {
                ref.read(showCommentsPanel.notifier).state = !showComments;
                ref.read(showActivityFeed.notifier).state = false;
                ref.read(showChatPanel.notifier).state = false;
              },
            ),
            IconButton(
              icon: const Icon(Icons.activity_zone),
              onPressed: () {
                ref.read(showActivityFeed.notifier).state = !showActivity;
                ref.read(showCommentsPanel.notifier).state = false;
                ref.read(showChatPanel.notifier).state = false;
              },
            ),
            IconButton(
              icon: const Icon(Icons.chat),
              onPressed: () {
                ref.read(showChatPanel.notifier).state = !showChat;
                ref.read(showCommentsPanel.notifier).state = false;
                ref.read(showActivityFeed.notifier).state = false;
              },
            ),
            const SizedBox(width: 8),
            const CollaboratorsAvatarStack(),
            const SizedBox(width: 16),
          ],
        ),
        body: Stack(
          children: [
            Row(
              children: [
                const SlideNavigator(),
                Expanded(
                  child: Column(
                    children: [
                      const Toolbar(),
                      Expanded(child: CollaborativeCanvas()),
                    ],
                  ),
                ),
              ],
            ),
            if (showComments) const CommentsPanel(),
            if (showActivity) const ActivityFeedPanel(),
            if (showChat) const ChatPanel(),
          ],
        ),
      ),
    );
  }

  String _timeAgo(DateTime time) {
    final diff = DateTime.now().difference(time);
    if (diff.inSeconds < 60) return 'just now';
    if (diff.inMinutes < 60) return '${diff.inMinutes}m ago';
    if (diff.inHours < 24) return '${diff.inHours}h ago';
    return '${diff.inDays}d ago';
  }
}

