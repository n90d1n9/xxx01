// ==================== SLIDE SYNCHRONIZATION PROVIDER ====================

final slideSyncProvider = StateNotifierProvider<SlideSyncNotifier, SlideSyncState>((ref) {
  return SlideSyncNotifier(ref);
});

class SlideSyncState {
  final int currentSlide;
  final bool isPresenting;
  final DateTime lastUpdate;
  final Map<String, int> viewerSlides; // userId -> slideIndex

  SlideSyncState({
    this.currentSlide = 0,
    this.isPresenting = false,
    required this.lastUpdate,
    this.viewerSlides = const {},
  });

  SlideSyncState copyWith({
    int? currentSlide,
    bool? isPresenting,
    DateTime? lastUpdate,
    Map<String, int>? viewerSlides,
  }) {
    return SlideSyncState(
      currentSlide: currentSlide ?? this.currentSlide,
      isPresenting: isPresenting ?? this.isPresenting,
      lastUpdate: lastUpdate ?? this.lastUpdate,
      viewerSlides: viewerSlides ?? this.viewerSlides,
    );
  }
}

class SlideSyncNotifier extends StateNotifier<SlideSyncState> {
  final Ref ref;

  SlideSyncNotifier(this.ref)
      : super(SlideSyncState(lastUpdate: DateTime.now()));

  void updateSlide(int slideIndex) {
    state = state.copyWith(
      currentSlide: slideIndex,
      lastUpdate: DateTime.now(),
    );
    // Update main presentation
    ref.read(presentationProvider.notifier).setCurrentSlide(slideIndex);
  }

  void startPresenting() {
    state = state.copyWith(
      isPresenting: true,
      lastUpdate: DateTime.now(),
    );
  }

  void stopPresenting() {
    state = state.copyWith(
      isPresenting: false,
      lastUpdate: DateTime.now(),
    );
  }

  void updateViewerSlide(String userId, int slideIndex) {
    final updatedViewers = Map<String, int>.from(state.viewerSlides);
    updatedViewers[userId] = slideIndex;
    state = state.copyWith(
      viewerSlides: updatedViewers,
      lastUpdate: DateTime.now(),
    );
  }
}

// ==================== EXTENDED COLLABORATIVE PRESENTATION WITH SYNC ====================

class SyncedCollaborativePresentationMode extends ConsumerStatefulWidget {
  const SyncedCollaborativePresentationMode({super.key});

  @override
  ConsumerState<SyncedCollaborativePresentationMode> createState() =>
      _SyncedCollaborativePresentationModeState();
}

class _SyncedCollaborativePresentationModeState
    extends ConsumerState<SyncedCollaborativePresentationMode> {
  final Map<String, Offset> _presentationPointers = {};
  Timer? _pointerTimer;
  final _focusNode = FocusNode();

  @override
  void initState() {
    super.initState();
    _startPointerSimulation();
  }

  @override
  void dispose() {
    _pointerTimer?.cancel();
    _focusNode.dispose();
    super.dispose();
  }

  void _startPointerSimulation() {
    _pointerTimer = Timer.periodic(const Duration(milliseconds: 100), (timer) {
      if (mounted) {
        setState(() {
          final presentation = ref.read(presentationProvider);
          for (var user in presentation.collaborators) {
            if (user.id != '1' && user.isOnline) {
              final random = math.Random();
              final x = 400 + random.nextDouble() * 800;
              final y = 200 + random.nextDouble() * 400;
              _presentationPointers[user.id] = Offset(x, y);
            }
          }
        });
      }
    });
  }

  void _handleKeyPress(KeyEvent event) {
    if (event is KeyDownEvent) {
      final presentation = ref.read(presentationProvider);

      if (event.logicalKey == LogicalKeyboardKey.arrowRight ||
          event.logicalKey == LogicalKeyboardKey.space) {
        if (presentation.currentSlideIndex < presentation.slides.length - 1) {
          ref
              .read(slideSyncProvider.notifier)
              .updateSlide(presentation.currentSlideIndex + 1);
        }
      } else if (event.logicalKey == LogicalKeyboardKey.arrowLeft) {
        if (presentation.currentSlideIndex > 0) {
          ref
              .read(slideSyncProvider.notifier)
              .updateSlide(presentation.currentSlideIndex - 1);
        }
      } else if (event.logicalKey == LogicalKeyboardKey.escape) {
        ref.read(slideSyncProvider.notifier).stopPresenting();
        Navigator.pop(context);
      }
    }
  }

  @override
  Widget build(BuildContext context) {
    final presentation = ref.watch(presentationProvider);
    final syncState = ref.watch(slideSyncProvider);
    final currentSlide = presentation.slides[presentation.currentSlideIndex];
    final presenter = presentation.presenter;

    return KeyboardListener(
      focusNode: _focusNode,
      autofocus: true,
      onKeyEvent: _handleKeyPress,
      child: Scaffold(
        backgroundColor: Colors.black,
        body: Stack(
          children: [
            // Main presentation area
            Center(
              child: AspectRatio(
                aspectRatio: 16 / 9,
                child: Container(
                  color: currentSlide.getThemeBackground(),
                  child: Stack(
                    children: [
                      // Slide content
                      Center(
                        child: Padding(
                          padding: const EdgeInsets.all(48),
                          child: Column(
                            mainAxisAlignment: MainAxisAlignment.center,
                            children: [
                              if (currentSlide.title != null)
                                Text(
                                  currentSlide.title!,
                                  style: TextStyle(
                                    fontSize: 64,
                                    fontWeight: FontWeight.bold,
                                    color: currentSlide.getThemeTextColor(),
                                  ),
                                  textAlign: TextAlign.center,
                                ),
                            ],
                          ),
                        ),
                      ),
                      // Components
                      ...currentSlide.components.map((component) {
                        return Positioned(
                          left: component.position.dx,
                          top: component.position.dy,
                          child: SizedBox(
                            width: component.size.width,
                            height: component.size.height,
                            child: _buildComponentContent(component),
                          ),
                        );
                      }),
                      // Collaborative pointers
                      ..._presentationPointers.entries.map((entry) {
                        final user = presentation.collaborators
                            .where((u) => u.id == entry.key)
                            .firstOrNull;
                        if (user == null) return const SizedBox.shrink();

                        return PresentationPointer(
                          position: entry.value,
                          user: user,
                        );
                      }),
                    ],
                  ),
                ),
              ),
            ),

            // Sync indicator
            Positioned(
              top: 16,
              left: 16,
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  const ScreenMirroringIndicator(isMainDisplay: false),
                  const SizedBox(height: 8),
                  Container(
                    padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                    decoration: BoxDecoration(
                      color: Colors.black.withOpacity(0.7),
                      borderRadius: BorderRadius.circular(12),
                    ),
                    child: Row(
                      mainAxisSize: MainAxisSize.min,
                      children: [
                        Container(
                          width: 8,
                          height: 8,
                          decoration: BoxDecoration(
                            color: syncState.isPresenting
                                ? const Color(0xFF10B981)
                                : Colors.grey,
                            shape: BoxShape.circle,
                          ),
                        ),
                        const SizedBox(width: 8),
                        Text(
                          syncState.isPresenting ? 'SYNCED' : 'NOT SYNCED',
                          style: TextStyle(
                            color: syncState.isPresenting
                                ? const Color(0xFF10B981)
                                : Colors.grey,
                            fontSize: 11,
