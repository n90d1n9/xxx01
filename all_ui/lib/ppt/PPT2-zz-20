// ==================== UPDATE PRESENTATION MODE WITH COLLABORATIVE DRAWING ====================

class CollaborativePresentationModeWithDrawing extends ConsumerStatefulWidget {
  const CollaborativePresentationModeWithDrawing({super.key});

  @override
  ConsumerState<CollaborativePresentationModeWithDrawing> createState() =>
      _CollaborativePresentationModeWithDrawingState();
}

class _CollaborativePresentationModeWithDrawingState
    extends ConsumerState<CollaborativePresentationModeWithDrawing> {
  final Map<String, Offset> _presentationPointers = {};
  Timer? _pointerTimer;
  Timer? _drawingSimTimer;
  final _focusNode = FocusNode();

  @override
  void initState() {
    super.initState();
    _startPointerSimulation();
    _startDrawingSimulation();
  }

  @override
  void dispose() {
    _pointerTimer?.cancel();
    _drawingSimTimer?.cancel();
    _focusNode.dispose();
    super.dispose();
  }

  void _startPointerSimulation() {
    _pointerTimer = Timer.periodic(const Duration(milliseconds: 100), (timer) {
      if (mounted) {
        setState(() {
          final presentation = ref.read(presentationProvider);
          for (var user in presentation.collaborators) {
            if (user.id != '1' && user.isOnline) {
              final random = math.Random();
