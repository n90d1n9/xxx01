// ============================================================================

class EnhancedDocumentEditorScreen extends ConsumerStatefulWidget {
  const EnhancedDocumentEditorScreen({Key? key}) : super(key: key);

  @override
  ConsumerState<EnhancedDocumentEditorScreen> createState() => 
      _EnhancedDocumentEditorScreenState();
}

class _EnhancedDocumentEditorScreenState 
    extends ConsumerState<EnhancedDocumentEditorScreen> {

  void _handleKeyEvent(KeyEvent event) {
    
  }



  @override
  Widget build(BuildContext context) {
    final docState = ref.watch(documentControllerProvider);
    final toolbarVisible = ref.watch(toolbarVisibilityProvider);
    final layoutMode = ref.watch(layoutModeProvider);
    final stats = ref.watch(wordCountProvider);
    final showCommandPalette = ref.watch(commandPaletteProvider);

    _titleController.value = TextEditingValue(
      text: docState.title,
      selection: _titleController.selection,
    );

    return KeyboardListener(
      focusNode: FocusNode(),
      onKeyEvent: _handleKeyEvent,
      child: Scaffold(
        appBar: layoutMode != LayoutMode.focus 
            ? EnhancedAppBar(titleController: _titleController)
            : null,
        body: Stack(
          children: [
            Column(
              children: [
                // Toolbar
                if (toolbarVisible && layoutMode != LayoutMode.focus)
                  CustomToolbar(controller: docState.controller),
                // Editor with ruler
                Expanded(
                  child: EnhancedEditorLayout(
                    controller: docState.controller,
                    focusNode: _focusNode,
                    scrollController: _scrollController,
                  ),
                ),
                // Status bar
                if (layoutMode != LayoutMode.focus)
                  StatusBar(stats: stats, lastModified: docState.lastModified),
              ],
            ),
            // Floating insert button
            if (layoutMode != LayoutMode.focus)
              const FloatingInsertButton(),
            // Command palette overlay
            if (showCommandPalette)
              CommandPalette(
                onDismiss: () => 
                    ref.read(commandPaletteProvider.notifier).state = false,
              ),
          ],
        ),
        floatingActionButton: layoutMode == LayoutMode.focus
            ? FloatingActionButton.small(
                onPressed: () => 
                    ref.read(layoutModeProvider.notifier).state = LayoutMode.web,
                tooltip: 'Exit Focus Mode',
                child: const Icon(Icons.fullscreen_exit, size: 20),
              )
            : null,
      ),
    );
  }
}

