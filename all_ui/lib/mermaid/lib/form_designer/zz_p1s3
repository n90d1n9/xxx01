        backgroundColor: const Color(0xFF2D2D2D),
        actions: [
          // Selection count indicator
          if (selectionState.hasSelection)
            Container(
              margin: const EdgeInsets.symmetric(horizontal: 8, vertical: 12),
              padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
              decoration: BoxDecoration(
                color: Colors.blue,
                borderRadius: BorderRadius.circular(12),
              ),
              child: Row(
                children: [
                  const Icon(Icons.check_circle, size: 16),
                  const SizedBox(width: 6),
                  Text('${selectionState.count} selected'),
                ],
              ),
            ),
          // Search toggle
          IconButton(
            icon: Icon(showSearch ? Icons.search_off : Icons.search),
            tooltip: 'Search (Ctrl+F)',
            onPressed: () {
              ref.read(showSearchProvider.notifier).state = !showSearch;
            },
          ),
          const VerticalDivider(),
          // Undo/Redo
          IconButton(
            icon: const Icon(Icons.undo),
            tooltip: 'Undo (Ctrl+Z)',
            onPressed: canUndo ? () {
              ref.read(historyManagerProvider.notifier).undo();
            } : null,
          ),
          IconButton(
            icon: const Icon(Icons.redo),
            tooltip: 'Redo (Ctrl+Y)',
            onPressed: canRedo ? () {
              ref.read(historyManagerProvider.notifier).redo();
            } : null,
          ),
          const VerticalDivider(),
          // Copy/Paste/Delete
          IconButton(
            icon: const Icon(Icons.content_copy),
            tooltip: 'Copy (Ctrl+C)',
            onPressed: (selectedField != null || selectionState.hasSelection) ? () {
              _handleCopy(ref);
            } : null,
          ),
          IconButton(
            icon: const Icon(Icons.content_paste),
            tooltip: 'Paste (Ctrl+V)',
            onPressed: clipboard.isNotEmpty ? () {
              _handlePaste(ref);
            } : null,
          ),
          IconButton(
            icon: const Icon(Icons.delete),
            tooltip: 'Delete (Del)',
            onPressed: (selectedField != null || selectionState.hasSelection) ? () {
              _handleDelete(ref);
            } : null,
          ),
          const VerticalDivider(),
          IconButton(
            icon: const Icon(Icons.code),
            tooltip: 'Export',
            onPressed: () => _showExportDialog(context, ref),
          ),
        ],
      ),
      body: Column(
        children: [
          // Search bar
          if (showSearch) SearchBar(onSearch: (query) {
            ref.read(searchQueryProvider.notifier).state = query;
          }),
