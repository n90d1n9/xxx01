{{! SPRING BOOT ROUTE BUILDER - templates/springboot/route_builder.mustache }}
{{! ========================================================================== }}
package {{package}};

import org.apache.camel.builder.RouteBuilder;
import org.springframework.stereotype.Component;

/**
 * Route: {{workflow.name}}
 * {{workflow.description}}
 */
@Component
public class {{className}} extends RouteBuilder {
    
    @Override
    public void configure() throws Exception {
        // Error handler
        errorHandler(deadLetterChannel("direct:error")
            .maximumRedeliveries(3)
            .redeliveryDelay(1000));
        
        // Main route
        from("direct:{{workflow.name}}")
            .routeId("{{routeId}}")
            .log("Starting workflow: {{workflow.name}}")
            {{#workflow.nodes}}
            {{#eq camelComponent "split"}}
            .split(simple("{{config.expression}}"))
            {{/eq}}
            {{#eq camelComponent "filter"}}
            .filter(simple("{{config.expression}}"))
            {{/eq}}
            {{#eq camelComponent "choice"}}
            .choice()
                .when(simple("{{config.expression}}"))
                    .log("Condition matched")
                .otherwise()
                    .log("Condition not matched")
            .end()
            {{/eq}}
            {{#eq camelComponent "setBody"}}
            .setBody(constant("{{config.script}}"))
            {{/eq}}
            {{#eq camelComponent "process"}}
            .process(exchange -> {
                // Custom processing for: {{name}}
                log.info("Processing node: {{name}}");
            })
            {{/eq}}
            {{#hasConnector}}
            .to("{{connector.uri}}")
            {{/hasConnector}}
            .log("Completed node: {{name}}")
            {{/workflow.nodes}}
            .log("Workflow completed: {{workflow.name}}");
        
        // Error handling route
        from("direct:error")
            .log("Error in workflow: ${exception.message}")
            .to("log:error");
    }
}

