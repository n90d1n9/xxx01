{{! CAMEL XML ROUTE TEMPLATE - templates/camel/route.mustache }}
{{! ========================================================================== }}
<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns="http://camel.apache.org/schema/spring">
    <route id="{{workflow.id}}">
        <description>{{workflow.description}}</description>
        
        {{! Start node }}
        {{#hasStart}}
        <from uri="direct:{{workflow.name}}" />
        {{/hasStart}}
        
        {{! Process each node }}
        {{#nodes}}
        {{#eq type "splitter"}}
        <split streaming="{{config.splitter.streaming}}">
            <simple>{{config.splitter.expression}}</simple>
            {{/eq}}
            
            {{#eq type "aggregator"}}
            <aggregate completionSize="{{config.aggregator.completionSize}}" 
                       completionTimeout="{{config.aggregator.timeout}}">
                <correlationExpression>
                    <simple>${header.correlationId}</simple>
                </correlationExpression>
                {{/eq}}
                
                {{#eq type "filter"}}
                <filter>
                    <simple>{{config.condition}}</simple>
                    {{/eq}}
                    
                    {{#eq type "enricher"}}
                    <enrich>
                        <constant>{{config.enricher.resourceUri}}</constant>
                        {{/eq}}
                        
                        {{#eq type "transform"}}
                        <setBody>
                            <simple>{{config.transform.script}}</simple>
                        </setBody>
                        {{/eq}}
                        
                        {{#eq type "router"}}
                        <choice>
                            {{! Add routing logic based on edges }}
                            <otherwise>
                                <to uri="log:unmatched" />
                            </otherwise>
                        </choice>
                        {{/eq}}
                        
                        {{#eq type "llm"}}
                        <to uri="direct:llm-processor-{{id}}" />
                        {{/eq}}
                        
                        {{! Handle connector nodes }}
                        {{#hasConnector}}
                        <to uri="{{connector.uri}}" />
                        {{/hasConnector}}
                        
                        {{! Log each step }}
                        <log message="Processing node: {{name}}" />
                        {{/nodes}}
                        
                        {{! End node }}
                        {{#hasEnd}}
                        <to uri="log:workflow-complete" />
                        {{/hasEnd}}
    </route>
</routes>

{{! ========================================================================== }}
{{! CAMEL YAML ROUTE TEMPLATE - templates/camel/route_yaml.mustache }}
{{! ========================================================================== }}
- route:
    id: {{workflow.id}}
    description: {{workflow.description}}
    from:
      uri: direct:{{workflow.name}}
      steps:
        {{#nodes}}
        - log:
            message: "Processing: {{name}}"
        {{#eq type "splitter"}}
        - split:
            simple: "{{config.splitter.expression}}"
            streaming: {{config.splitter.streaming}}
        {{/eq}}
        {{#eq type "filter"}}
        - filter:
            simple: "{{config.condition}}"
        {{/eq}}
        {{#eq type "transform"}}
        - setBody:
            simple: "{{config.transform.script}}"
        {{/eq}}
        {{#hasConnector}}
        - to:
            uri: "{{config.connector.uri}}"
        {{/hasConnector}}
        {{/nodes}}
        - to:
            uri: "log:complete"

