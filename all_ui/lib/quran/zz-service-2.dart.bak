// ==================== RECITER MANAGEMENT SERVICE ====================
// services/reciter_management_service.dart

import 'dart:convert';
import 'package:shared_preferences/shared_preferences.dart';

import 'models/surah.dart';

class ReciterManagementService {
  static const String _selectedReciterKey = 'selected_reciter';
  static const String _downloadedRecitersKey = 'downloaded_reciters';

  final List<ReciterInfo> _availableReciters = [
    ReciterInfo(
      id: 'ar.alafasy',
      name: 'Mishary Rashid Alafasy',
      style: 'Murattal',
      baseUrl: 'https://cdn.islamic.network/quran/audio-surah/128/ar.alafasy',
      downloadSizeMB: 450.0,
    ),
    ReciterInfo(
      id: 'ar.abdulbasitmurattal',
      name: 'Abdul Basit (Murattal)',
      style: 'Murattal',
      baseUrl:
          'https://cdn.islamic.network/quran/audio-surah/128/ar.abdulbasitmurattal',
      downloadSizeMB: 520.0,
    ),
    ReciterInfo(
      id: 'ar.husary',
      name: 'Mahmoud Khalil Al-Hussary',
      style: 'Murattal',
      baseUrl: 'https://cdn.islamic.network/quran/audio-surah/128/ar.husary',
      downloadSizeMB: 480.0,
    ),
    ReciterInfo(
      id: 'ar.minshawi',
      name: 'Mohamed Siddiq Al-Minshawi',
      style: 'Mujawwad',
      baseUrl: 'https://cdn.islamic.network/quran/audio-surah/128/ar.minshawi',
      downloadSizeMB: 550.0,
    ),
    ReciterInfo(
      id: 'ar.saoodshuraym',
      name: 'Saood Ash-Shuraym',
      style: 'Murattal',
      baseUrl:
          'https://cdn.islamic.network/quran/audio-surah/128/ar.saoodshuraym',
      downloadSizeMB: 420.0,
    ),
    ReciterInfo(
      id: 'ar.abdullahalmatrod',
      name: 'Abdullah Al Matrood',
      style: 'Murattal',
      baseUrl:
          'https://cdn.islamic.network/quran/audio-surah/128/ar.abdullahalmatrod',
      downloadSizeMB: 430.0,
    ),
    ReciterInfo(
      id: 'ar.shaatree',
      name: 'Abu Bakr Ash-Shaatree',
      style: 'Murattal',
      baseUrl: 'https://cdn.islamic.network/quran/audio-surah/128/ar.shaatree',
      downloadSizeMB: 440.0,
    ),
  ];

  List<ReciterInfo> getAvailableReciters() {
    return _availableReciters;
  }

  Future<ReciterInfo> getSelectedReciter() async {
    try {
      final prefs = await SharedPreferences.getInstance();
      final reciterId = prefs.getString(_selectedReciterKey) ?? 'ar.alafasy';
      return _availableReciters.firstWhere(
        (r) => r.id == reciterId,
        orElse: () => _availableReciters.first,
      );
    } catch (e) {
      return _availableReciters.first;
    }
  }

  Future<void> selectReciter(String reciterId) async {
    try {
      final prefs = await SharedPreferences.getInstance();
      await prefs.setString(_selectedReciterKey, reciterId);
    } catch (e) {
      throw Exception('Failed to select reciter: $e');
    }
  }

  String getAudioUrl(String reciterId, int surahNumber, int ayahNumber) {
    final reciter = _availableReciters.firstWhere(
      (r) => r.id == reciterId,
      orElse: () => _availableReciters.first,
    );

    final surahPadded = surahNumber.toString().padLeft(3, '0');
    final ayahPadded = ayahNumber.toString().padLeft(3, '0');

    return '${reciter.baseUrl}/$surahPadded$ayahPadded.mp3';
  }

  Future<void> downloadSurah(String reciterId, int surahNumber) async {
    // This would implement actual download functionality
    // For now, just mark as downloaded
    final downloaded = await getDownloadedReciters();
    final key = '$reciterId-$surahNumber';
    if (!downloaded.contains(key)) {
      downloaded.add(key);
      await _saveDownloaded(downloaded);
    }
  }

  Future<bool> isReciterDownloaded(String reciterId) async {
    final downloaded = await getDownloadedReciters();
    return downloaded.any((d) => d.startsWith('$reciterId-'));
  }

  Future<List<String>> getDownloadedReciters() async {
    try {
      final prefs = await SharedPreferences.getInstance();
      return prefs.getStringList(_downloadedRecitersKey) ?? [];
    } catch (e) {
      return [];
    }
  }

  Future<void> deleteReciterDownloads(String reciterId) async {
    final downloaded = await getDownloadedReciters();
    downloaded.removeWhere((d) => d.startsWith('$reciterId-'));
    await _saveDownloaded(downloaded);
  }

  Future<void> _saveDownloaded(List<String> downloaded) async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setStringList(_downloadedRecitersKey, downloaded);
  }
}

// ==================== DHIKR SERVICE ====================
// services/dhikr_service.dart

class DhikrService {
  static const String _countsKey = 'dhikr_counts';
  static const String _customDhikrKey = 'custom_dhikr';

  final List<DhikrItem> _predefinedDhikr = [
    DhikrItem(
      id: 'subhanallah',
      arabic: 'سُبْحَانَ ٱللَّٰهِ',
      transliteration: 'SubhanAllah',
      translation: 'Glory be to Allah',
      targetCount: 33,
      category: 'tasbih',
    ),
    DhikrItem(
      id: 'alhamdulillah',
      arabic: 'ٱلْحَمْدُ لِلَّٰهِ',
      transliteration: 'Alhamdulillah',
      translation: 'All praise is due to Allah',
      targetCount: 33,
      category: 'tasbih',
    ),
    DhikrItem(
      id: 'allahuakbar',
      arabic: 'ٱللَّٰهُ أَكْبَرُ',
      transliteration: 'Allahu Akbar',
      translation: 'Allah is the Greatest',
      targetCount: 34,
      category: 'tasbih',
    ),
    DhikrItem(
      id: 'la_ilaha_illallah',
      arabic: 'لَا إِلَٰهَ إِلَّا ٱللَّٰهُ',
      transliteration: 'La ilaha illallah',
      translation: 'There is no god but Allah',
      targetCount: 100,
      category: 'tahlil',
    ),
    DhikrItem(
      id: 'astaghfirullah',
      arabic: 'أَسْتَغْفِرُ ٱللَّٰهَ',
      transliteration: 'Astaghfirullah',
      translation: 'I seek forgiveness from Allah',
      targetCount: 100,
      category: 'istighfar',
    ),
    DhikrItem(
      id: 'salawat',
      arabic: 'ٱللَّٰهُمَّ صَلِّ عَلَىٰ مُحَمَّدٍ',
      transliteration: 'Allahumma salli ala Muhammad',
      translation: 'O Allah, send blessings upon Muhammad',
      targetCount: 10,
      category: 'salawat',
    ),
    DhikrItem(
      id: 'la_hawla',
      arabic: 'لَا حَوْلَ وَلَا قُوَّةَ إِلَّا بِٱللَّٰهِ',
      transliteration: 'La hawla wa la quwwata illa billah',
      translation: 'There is no power nor strength except with Allah',
      targetCount: 10,
      category: 'general',
    ),
    DhikrItem(
      id: 'hasbi_allah',
      arabic: 'حَسْبِيَ ٱللَّٰهُ وَنِعْمَ ٱلْوَكِيلُ',
      transliteration: 'Hasbiyallahu wa ni\'mal wakil',
      translation:
          'Allah is sufficient for me, and He is the best disposer of affairs',
      category: 'general',
    ),
  ];

  List<DhikrItem> getPredefinedDhikr() {
    return _predefinedDhikr;
  }

  Future<Map<String, int>> getDhikrCounts() async {
    try {
      final prefs = await SharedPreferences.getInstance();
      final countsJson = prefs.getString(_countsKey);
      if (countsJson != null) {
        return Map<String, int>.from(jsonDecode(countsJson));
      }
      return {};
    } catch (e) {
      return {};
    }
  }

  Future<void> incrementDhikr(String dhikrId) async {
    try {
      final counts = await getDhikrCounts();
      counts[dhikrId] = (counts[dhikrId] ?? 0) + 1;
      await _saveCounts(counts);
    } catch (e) {
      throw Exception('Failed to increment dhikr: $e');
    }
  }

  Future<void> resetDhikr(String dhikrId) async {
    try {
      final counts = await getDhikrCounts();
      counts[dhikrId] = 0;
      await _saveCounts(counts);
    } catch (e) {
      throw Exception('Failed to reset dhikr: $e');
    }
  }

  Future<void> resetAllDhikr() async {
    try {
      final prefs = await SharedPreferences.getInstance();
      await prefs.remove(_countsKey);
    } catch (e) {
      throw Exception('Failed to reset all dhikr: $e');
    }
  }

  Future<void> addCustomDhikr(DhikrItem dhikr) async {
    try {
      final customDhikr = await getCustomDhikr();
      customDhikr.add(dhikr);
      await _saveCustomDhikr(customDhikr);
    } catch (e) {
      throw Exception('Failed to add custom dhikr: $e');
    }
  }

  Future<void> deleteCustomDhikr(String dhikrId) async {
    try {
      final customDhikr = await getCustomDhikr();
      customDhikr.removeWhere((d) => d.id == dhikrId);
      await _saveCustomDhikr(customDhikr);
    } catch (e) {
      throw Exception('Failed to delete custom dhikr: $e');
    }
  }

  Future<List<DhikrItem>> getCustomDhikr() async {
    try {
      final prefs = await SharedPreferences.getInstance();
      final customJson = prefs.getStringList(_customDhikrKey) ?? [];
      return customJson
          .map((json) => DhikrItem.fromJson(jsonDecode(json)))
          .toList();
    } catch (e) {
      return [];
    }
  }

  Future<List<DhikrItem>> getAllDhikr() async {
    final custom = await getCustomDhikr();
    final counts = await getDhikrCounts();

    final all = [..._predefinedDhikr, ...custom];
    return all.map((d) => d.copyWith(currentCount: counts[d.id] ?? 0)).toList();
  }

  List<DhikrItem> getDhikrByCategory(String category) {
    return _predefinedDhikr.where((d) => d.category == category).toList();
  }

  Future<void> _saveCounts(Map<String, int> counts) async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setString(_countsKey, jsonEncode(counts));
  }

  Future<void> _saveCustomDhikr(List<DhikrItem> customDhikr) async {
    final prefs = await SharedPreferences.getInstance();
    final customJson = customDhikr.map((d) => jsonEncode(d.toJson())).toList();
    await prefs.setStringList(_customDhikrKey, customJson);
  }
}

