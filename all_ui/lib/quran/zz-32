class TajweedRulesSection extends StatelessWidget {
  final String text;

  const TajweedRulesSection({super.key, required this.text});

  @override
  Widget build(BuildContext context) {
    final rules = _detectTajweedRules(text);
    
    if (rules.isEmpty) {
      return Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Text(
            'Tajweed Rules',
            style: Theme.of(context).textTheme.titleMedium,
          ),
          const SizedBox(height: 8),
          const Text('No specific tajweed rules detected in this ayah.'),
        ],
      );
    }

    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text(
          'Tajweed Rules Found',
          style: Theme.of(context).textTheme.titleMedium,
        ),
        const SizedBox(height: 12),
        ...rules.map((rule) => TajweedRuleCard(rule: rule)).toList(),
      ],
    );
  }

  List<TajweedRule> _detectTajweedRules(String text) {
    final Set<String> foundRuleIds = {};
    final allRules = TajweedRulesDatabase.getAllRules();
    
    for (var rule in allRules) {
      for (var pattern in rule.patterns) {
        final regex = RegExp(pattern);
        if (regex.hasMatch(text)) {
          foundRuleIds.add(rule.id);
          break;
        }
      }
    }
    
    // Return the actual rule objects
    return foundRuleIds
        .map((id) => TajweedRulesDatabase.getRule(id))
        .whereType<TajweedRule>()
        .toList();
  }
}

