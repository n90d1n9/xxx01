      patterns: [r'ۘ'],
      examples: ['عِوَجَاۘ قَيِّمًا', 'مَرْقَدِنَاۘ هَٰذَا'],
      priority: 9,
    ),
  };

  static List<TajweedRule> getAllRules() {
    return _rules.values.toList()..sort((a, b) => b.priority.compareTo(a.priority));
  }

  static TajweedRule? getRule(String id) {
    return _rules[id];
  }

  static List<TajweedRule> getRulesByCategory(TajweedCategory category) {
    return _rules.values.where((rule) => rule.category == category).toList()
      ..sort((a, b) => b.priority.compareTo(a.priority));
  }

  static List<String> getAllRuleIds() {
    return _rules.keys.toList();
  }
  
  static Map<TajweedCategory, List<TajweedRule>> getRulesGroupedByCategory() {
    final Map<TajweedCategory, List<TajweedRule>> grouped = {};
    for (var category in TajweedCategory.values) {
      grouped[category] = getRulesByCategory(category);
    }
    return grouped;
  }
}

