                            icon: Icon(
                              state.repeatMode == RepeatMode.none
                                  ? Icons.repeat
                                  : Icons.repeat_on,
                            ),
                            tooltip: 'Repeat',
                            onSelected: (mode) {
                              ref.read(audioServiceProvider).setRepeatMode(mode);
                            },
                            itemBuilder: (context) => const [
                              PopupMenuItem(
                                value: RepeatMode.none,
                                child: Text('No Repeat'),
                              ),
                              PopupMenuItem(
                                value: RepeatMode.ayah,
                                child: Text('Repeat Ayah'),
