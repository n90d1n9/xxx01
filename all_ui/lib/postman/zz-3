}

class _RequestsPanelState extends ConsumerState<RequestsPanel> {
  @override
  Widget build(BuildContext context) {
    final currentRequest = ref.watch(currentRequestProvider);

    return Row(
      children: [
        SizedBox(
          width: 300,
          child: Column(
            children: [
              Padding(
                padding: const EdgeInsets.all(8.0),
                child: ElevatedButton.icon(
                  onPressed: _createNewRequest,
                  icon: const Icon(Icons.add),
                  label: const Text('New Request'),
                  style: ElevatedButton.styleFrom(
                    minimumSize: const Size.fromHeight(48),
                  ),
                ),
              ),
              const Divider(height: 1),
              Expanded(child: _buildRequestList()),
            ],
          ),
        ),
        const VerticalDivider(thickness: 1, width: 1),
        Expanded(
          child: currentRequest != null
              ? RequestEditor(request: currentRequest)
              : const Center(
                  child: Text('Select or create a request'),
                ),
        ),
      ],
    );
  }

  Widget _buildRequestList() {
    final requests = ref.watch(requestsProvider);

    return ListView.builder(
      itemCount: requests.length,
      itemBuilder: (context, index) {
        final request = requests[index];
        final isSelected = ref.watch(currentRequestProvider)?.id == request.id;

        return ListTile(
          selected: isSelected,
          leading: _getMethodChip(request.method),
          title: Text(request.name),
          subtitle: Text(
            request.url,
            maxLines: 1,
            overflow: TextOverflow.ellipsis,
          ),
          trailing: IconButton(
            icon: const Icon(Icons.delete),
            onPressed: () {
              ref.read(requestsProvider.notifier).deleteRequest(request.id);
              if (isSelected) {
                ref.read(currentRequestProvider.notifier).state = null;
              }
            },
          ),
          onTap: () {
            ref.read(currentRequestProvider.notifier).state = request;
            ref.read(currentResponseProvider.notifier).state = null;
          },
        );
      },
    );
  }

  Widget _getMethodChip(HttpMethod method) {
    final colors = {
      HttpMethod.get: Colors.green,
      HttpMethod.post: Colors.blue,
      HttpMethod.put: Colors.orange,
      HttpMethod.patch: Colors.purple,
      HttpMethod.delete: Colors.red,
      HttpMethod.head: Colors.grey,
      HttpMethod.options: Colors.teal,
    };

    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
      decoration: BoxDecoration(
        color: colors[method],
        borderRadius: BorderRadius.circular(4),
      ),
      child: Text(
        method.name.toUpperCase(),
        style: const TextStyle(
          color: Colors.white,
          fontSize: 10,
          fontWeight: FontWeight.bold,
        ),
      ),
    );
  }

  void _createNewRequest() {
    final newRequest = ApiRequest(
      id: const Uuid().v4(),
      name: 'New Request',
      type: RequestType.rest,
      method: HttpMethod.get,
      url: 'https://api.example.com',
    );

    ref.read(requestsProvider.notifier).addRequest(newRequest);
    ref.read(currentRequestProvider.notifier).state = newRequest;
  }
}

class RequestEditor extends ConsumerStatefulWidget {
  final ApiRequest request;

  const RequestEditor({super.key, required this.request});

  @override
  ConsumerState<RequestEditor> createState() => _RequestEditorState();
}

class _RequestEditorState extends ConsumerState<RequestEditor> with SingleTickerProviderStateMixin {
  late TabController _tabController;
  late TextEditingController _nameController;
  late TextEditingController _urlController;
  late TextEditingController _bodyController;
  final List<MapEntry<TextEditingController, TextEditingController>> _headers = [];
  final List<MapEntry<TextEditingController, TextEditingController>> _queryParams = [];
  
  bool _isLoading = false;

  @override
  void initState() {
    super.initState();
    _tabController = TabController(length: 3, vsync: this);
    _initializeControllers();
  }

  void _initializeControllers() {
    _nameController = TextEditingController(text: widget.request.name);
    _urlController = TextEditingController(text: widget.request.url);
    _bodyController = TextEditingController(text: widget.request.body);

    _headers.clear();
    widget.request.headers.forEach((key, value) {
      _headers.add(MapEntry(
        TextEditingController(text: key),
        TextEditingController(text: value),
      ));
    });

    _queryParams.clear();
    widget.request.queryParams.forEach((key, value) {
      _queryParams.add(MapEntry(
        TextEditingController(text: key),
        TextEditingController(text: value),
      ));
    });
  }

  @override
  void didUpdateWidget(RequestEditor oldWidget) {
    super.didUpdateWidget(oldWidget);
    if (oldWidget.request.id != widget.request.id) {
      _disposeControllers();
      _initializeControllers();
    }
  }

  @override
  void dispose() {
    _tabController.dispose();
    _disposeControllers();
    super.dispose();
  }

  void _disposeControllers() {
    _nameController.dispose();
    _urlController.dispose();
    _bodyController.dispose();
    for (final pair in _headers) {
      pair.key.dispose();
      pair.value.dispose();
    }
    for (final pair in _queryParams) {
      pair.key.dispose();
      pair.value.dispose();
    }
  }

  @override
  Widget build(BuildContext context) {
    final response = ref.watch(currentResponseProvider);

    return Column(
      children: [
        _buildRequestConfig(),
        const Divider(height: 1),
        Expanded(
          child: Column(
            children: [
              Expanded(
                child: TabBarView(
                  controller: _tabController,
                  children: [
                    _buildBodyTab(),
                    _buildHeadersTab(),
                    _buildQueryParamsTab(),
                  ],
                ),
              ),
              if (response != null) ...[
                const Divider(height: 1),
                Expanded(child: _buildResponseViewer(response)),
              ],
            ],
          ),
        ),
      ],
    );
  }

  Widget _buildRequestConfig() {
    return Container(
      padding: const EdgeInsets.all(16),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          TextField(
            controller: _nameController,
            decoration: const InputDecoration(
              labelText: 'Request Name',
              border: OutlineInputBorder(),
            ),
            onChanged: (value) => _updateRequest(),
          ),
          const SizedBox(height: 16),
          Row(
            children: [
              DropdownButton<HttpMethod>(
                value: widget.request.method,
                onChanged: (method) {
                  if (method != null) {
                    ref.read(currentRequestProvider.notifier).state =
                        widget.request.copyWith(method: method);
                  }
                },
                items: HttpMethod.values.map((method) {
                  return DropdownMenuItem(
                    value: method,
                    child: Text(method.name.toUpperCase()),
                  );
                }).toList(),
              ),
              const SizedBox(width: 16),
              Expanded(
                child: TextField(
                  controller: _urlController,
                  decoration: const InputDecoration(
                    labelText: 'URL',
                    border: OutlineInputBorder(),
                  ),
                  onChanged: (value) => _updateRequest(),
                ),
              ),
              const SizedBox(width: 16),
              ElevatedButton.icon(
                onPressed: _isLoading ? null : _sendRequest,
                icon: _isLoading
                    ? const SizedBox(
                        width: 16,
                        height: 16,
                        child: CircularProgressIndicator(strokeWidth: 2),
                      )
                    : const Icon(Icons.send),
                label: const Text('Send'),
              ),
            ],
          ),
          const SizedBox(height: 16),
          TabBar(
            controller: _tabController,
            tabs: const [
              Tab(text: 'Body'),
              Tab(text: 'Headers'),
              Tab(text: 'Query Params'),
            ],
          ),
        ],
      ),
    );
  }

  Widget _buildBodyTab() {
    return Padding(
      padding: const EdgeInsets.all(16),
      child: TextField(
        controller: _bodyController,
        decoration: const InputDecoration(
          hintText: 'Request body (JSON, XML, etc.)',
          border: OutlineInputBorder(),
        ),
        maxLines: null,
        expands: true,
        onChanged: (value) => _updateRequest(),
      ),
    );
  }

  Widget _buildHeadersTab() {
    return ListView(
      padding: const EdgeInsets.all(16),
      children: [
        ..._headers.asMap().entries.map((entry) {
          return Padding(
            padding: const EdgeInsets.only(bottom: 8),
            child: Row(
              children: [
                Expanded(
                  child: TextField(
                    controller: entry.value.key,
                    decoration: const InputDecoration(
                      labelText: 'Key',
                      border: OutlineInputBorder(),
                    ),
                    onChanged: (value) => _updateRequest(),
                  ),
                ),
                const SizedBox(width: 8),
                Expanded(
                  child: TextField(
                    controller: entry.value.value,
                    decoration: const InputDecoration(
                      labelText: 'Value',
                      border: OutlineInputBorder(),
                    ),
                    onChanged: (value) => _updateRequest(),
                  ),
                ),
                IconButton(
                  icon: const Icon(Icons.delete),
                  onPressed: () {
                    setState(() {
                      entry.value.key.dispose();
                      entry.value.value.dispose();
                      _queryParams.removeAt(entry.key);
                    });
                    _updateRequest();
                  },
                ),
              ],
            ),
          );
        }),
        ElevatedButton.icon(
          onPressed: () {
            setState(() {
              _queryParams.add(MapEntry(
                TextEditingController(),
                TextEditingController(),
              ));
            });
          },
          icon: const Icon(Icons.add),
          label: const Text('Add Query Parameter'),
        ),
      ],
    );
  }

  Widget _buildResponseViewer(ApiResponse response) {
    return Container(
      color: Theme.of(context).colorScheme.surfaceVariant.withOpacity(0.3),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Container(
            padding: const EdgeInsets.all(16),
            child: Row(
              children: [
                Text(
                  'Response',
                  style: Theme.of(context).textTheme.titleMedium,
                ),
                const Spacer(),
                if (response.statusCode != null)
                  Chip(
                    label: Text(
                      '${response.statusCode}',
                      style: const TextStyle(fontWeight: FontWeight.bold),
                    ),
                    backgroundColor: _getStatusColor(response.statusCode!),
                  ),
                const SizedBox(width: 8),
                Text('${response.duration.inMilliseconds}ms'),
                if (response.size != null) ...[
                  const SizedBox(width: 8),
                  Text('${(response.size! / 1024).toStringAsFixed(2)} KB'),
                ],
              ],
            ),
          ),
          const Divider(height: 1),
          if (response.error != null)
            Expanded(
              child: Container(
                padding: const EdgeInsets.all(16),
                child: Text(
                  'Error: ${response.error}',
                  style: TextStyle(color: Theme.of(context).colorScheme.error),
                ),
              ),
            )
          else
            Expanded(
              child: SingleChildScrollView(
                padding: const EdgeInsets.all(16),
                child: SelectableText(
                  response.body,
                  style: const TextStyle(fontFamily: 'monospace'),
                ),
              ),
            ),
        ],
      ),
    );
  }

  Color _getStatusColor(int statusCode) {
    if (statusCode >= 200 && statusCode < 300) return Colors.green;
    if (statusCode >= 300 && statusCode < 400) return Colors.orange;
    if (statusCode >= 400 && statusCode < 500) return Colors.red;
    if (statusCode >= 500) return Colors.purple;
    return Colors.grey;
  }

  void _updateRequest() {
    final headers = <String, String>{};
    for (final pair in _headers) {
      if (pair.key.text.isNotEmpty) {
        headers[pair.key.text] = pair.value.text;
      }
    }

    final queryParams = <String, String>{};
    for (final pair in _queryParams) {
      if (pair.key.text.isNotEmpty) {
        queryParams[pair.key.text] = pair.value.text;
      }
    }

    final updatedRequest = widget.request.copyWith(
      name: _nameController.text,
      url: _urlController.text,
      body: _bodyController.text,
      headers: headers,
      queryParams: queryParams,
    );

    ref.read(requestsProvider.notifier).updateRequest(updatedRequest);
    ref.read(currentRequestProvider.notifier).state = updatedRequest;
  }

  Future<void> _sendRequest() async {
    setState(() => _isLoading = true);

    try {
      final activeEnv = ref.read(activeEnvironmentProvider);
      final apiService = ApiService();
      
      final response = await apiService.sendRestRequest(
        widget.request,
        activeEnv?.variables,
      );

      ref.read(currentResponseProvider.notifier).state = response;
    } finally {
      if (mounted) {
        setState(() => _isLoading = false);
      }
    }
  }
}

class CollectionsPanel extends ConsumerStatefulWidget {
  const CollectionsPanel({super.key});

  @override
  ConsumerState<CollectionsPanel> createState() => _CollectionsPanelState();
}

class _CollectionsPanelState extends ConsumerState<CollectionsPanel> {
  @override
  Widget build(BuildContext context) {
    final collections = ref.watch(collectionsProvider);

    return Column(
      children: [
        Padding(
          padding: const EdgeInsets.all(16),
          child: ElevatedButton.icon(
            onPressed: _createNewCollection,
            icon: const Icon(Icons.add),
            label: const Text('New Collection'),
            style: ElevatedButton.styleFrom(
              minimumSize: const Size.fromHeight(48),
            ),
          ),
        ),
        const Divider(height: 1),
        Expanded(
          child: collections.isEmpty
              ? const Center(child: Text('No collections yet'))
              : ListView.builder(
                  itemCount: collections.length,
                  itemBuilder: (context, index) {
                    final collection = collections[index];
                    return Card(
                      margin: const EdgeInsets.all(8),
                      child: ExpansionTile(
                        leading: const Icon(Icons.folder),
                        title: Text(collection.name),
                        subtitle: Text('${collection.requestIds.length} requests'),
                        trailing: IconButton(
                          icon: const Icon(Icons.delete),
                          onPressed: () {
                            ref.read(collectionsProvider.notifier)
                                .deleteCollection(collection.id);
                          },
                        ),
                        children: _buildCollectionRequests(collection),
                      ),
                    );
                  },
                ),
        ),
      ],
    );
  }

  List<Widget> _buildCollectionRequests(Collection collection) {
    final allRequests = ref.read(requestsProvider);
    final collectionRequests = allRequests
        .where((r) => collection.requestIds.contains(r.id))
        .toList();

    return collectionRequests.map((request) {
      return ListTile(
        leading: _getMethodIcon(request.method),
        title: Text(request.name),
        subtitle: Text(request.url, maxLines: 1, overflow: TextOverflow.ellipsis),
        onTap: () {
          ref.read(currentRequestProvider.notifier).state = request;
        },
      );
    }).toList();
  }

  Icon _getMethodIcon(HttpMethod method) {
    return Icon(
      Icons.http,
      color: _getMethodColor(method),
    );
  }

  Color _getMethodColor(HttpMethod method) {
    switch (method) {
      case HttpMethod.get:
        return Colors.green;
      case HttpMethod.post:
        return Colors.blue;
      case HttpMethod.put:
        return Colors.orange;
      case HttpMethod.patch:
        return Colors.purple;
      case HttpMethod.delete:
        return Colors.red;
      default:
        return Colors.grey;
    }
  }

  void _createNewCollection() {
    final nameController = TextEditingController();
    
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('New Collection'),
        content: TextField(
          controller: nameController,
          decoration: const InputDecoration(
            labelText: 'Collection Name',
            border: OutlineInputBorder(),
          ),
          autofocus: true,
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Cancel'),
          ),
          ElevatedButton(
            onPressed: () {
              if (nameController.text.isNotEmpty) {
                final newCollection = Collection(
                  id: const Uuid().v4(),
                  name: nameController.text,
                );
                ref.read(collectionsProvider.notifier).addCollection(newCollection);
                Navigator.pop(context);
              }
            },
            child: const Text('Create'),
          ),
        ],
      ),
    );
  }
}

class HistoryPanel extends ConsumerWidget {
  const HistoryPanel({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final requests = ref.watch(requestsProvider);
    final sortedRequests = [...requests]
      ..sort((a, b) => b.createdAt.compareTo(a.createdAt));

    return requests.isEmpty
        ? const Center(child: Text('No request history'))
        : ListView.builder(
            itemCount: sortedRequests.length,
            itemBuilder: (context, index) {
              final request = sortedRequests[index];
              return ListTile(
                leading: _getMethodChip(request.method),
                title: Text(request.name),
                subtitle: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(
                      request.url,
                      maxLines: 1,
                      overflow: TextOverflow.ellipsis,
                    ),
                    Text(
                      _formatDateTime(request.createdAt),
                      style: Theme.of(context).textTheme.bodySmall,
                    ),
                  ],
                ),
                onTap: () {
                  ref.read(currentRequestProvider.notifier).state = request;
                },
              );
            },
          );
  }

  Widget _getMethodChip(HttpMethod method) {
    final colors = {
      HttpMethod.get: Colors.green,
      HttpMethod.post: Colors.blue,
      HttpMethod.put: Colors.orange,
      HttpMethod.patch: Colors.purple,
      HttpMethod.delete: Colors.red,
      HttpMethod.head: Colors.grey,
      HttpMethod.options: Colors.teal,
    };

    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
      decoration: BoxDecoration(
        color: colors[method],
        borderRadius: BorderRadius.circular(4),
      ),
      child: Text(
        method.name.toUpperCase(),
        style: const TextStyle(
          color: Colors.white,
          fontSize: 10,
          fontWeight: FontWeight.bold,
        ),
      ),
    );
  }

  String _formatDateTime(DateTime dateTime) {
    final now = DateTime.now();
    final difference = now.difference(dateTime);

    if (difference.inDays > 0) {
      return '${difference.inDays}d ago';
    } else if (difference.inHours > 0) {
      return '${difference.inHours}h ago';
    } else if (difference.inMinutes > 0) {
      return '${difference.inMinutes}m ago';
    } else {
      return 'Just now';
    }
  }
}

