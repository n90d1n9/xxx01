final requestsProvider = StateNotifierProvider<RequestsNotifier, List<ApiRequest>>((ref) {
  return RequestsNotifier();
});

class RequestsNotifier extends StateNotifier<List<ApiRequest>> {
  RequestsNotifier() : super([]);

  void addRequest(ApiRequest request) {
    state = [...state, request];
  }

  void updateRequest(ApiRequest request) {
    state = [
      for (final r in state)
        if (r.id == request.id) request else r
    ];
  }

  void deleteRequest(String id) {
    state = state.where((r) => r.id != id).toList();
  }

  void importRequests(List<ApiRequest> requests) {
    state = [...state, ...requests];
  }
}

final collectionsProvider = StateNotifierProvider<CollectionsNotifier, List<Collection>>((ref) {
  return CollectionsNotifier();
});

class CollectionsNotifier extends StateNotifier<List<Collection>> {
  CollectionsNotifier() : super([]);

  void addCollection(Collection collection) {
    state = [...state, collection];
  }

  void updateCollection(Collection collection) {
    state = [
      for (final c in state)
        if (c.id == collection.id) collection else c
    ];
  }

  void deleteCollection(String id) {
    state = state.where((c) => c.id != id).toList();
  }

  void addRequestToCollection(String collectionId, String requestId) {
    state = [
      for (final c in state)
        if (c.id == collectionId)
          c.copyWith(requestIds: [...c.requestIds, requestId])
        else
          c
    ];
  }
}

final currentRequestProvider = StateProvider<ApiRequest?>((ref) => null);

final currentResponseProvider = StateProvider<ApiResponse?>((ref) => null);

final environmentsProvider = StateNotifierProvider<EnvironmentsNotifier, List<Environment>>((ref) {
  return EnvironmentsNotifier();
});

class EnvironmentsNotifier extends StateNotifier<List<Environment>> {
  EnvironmentsNotifier() : super([]);

  void addEnvironment(Environment env) {
    state = [...state, env];
  }

  void updateEnvironment(Environment env) {
    state = [
      for (final e in state)
        if (e.name == env.name) env else e
    ];
  }

  void deleteEnvironment(String name) {
    state = state.where((e) => e.name != name).toList();
  }
}

final activeEnvironmentProvider = StateProvider<Environment?>((ref) => null);

