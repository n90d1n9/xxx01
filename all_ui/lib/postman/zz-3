        children: [
          NavigationRail(
            selectedIndex: _selectedIndex,
            onDestinationSelected: (index) {
              setState(() => _selectedIndex = index);
            },
            labelType: NavigationRailLabelType.all,
            destinations: const [
              NavigationRailDestination(
                icon: Icon(Icons.http),
                label: Text('Requests'),
              ),
              NavigationRailDestination(
                icon: Icon(Icons.folder),
                label: Text('Collections'),
              ),
              NavigationRailDestination(
                icon: Icon(Icons.history),
                label: Text('History'),
              ),
            ],
          ),
          const VerticalDivider(thickness: 1, width: 1),
          Expanded(
            child: _selectedIndex == 0
                ? const RequestsPanel()
                : _selectedIndex == 1
                    ? const CollectionsPanel()
                    : const HistoryPanel(),
          ),
        ],
      ),
    );
  }

  void _showImportDialog() {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Import'),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            ListTile(
              leading: const Icon(Icons.post_add),
              title: const Text('Postman Collection'),
              onTap: () => _importFile('postman'),
            ),
            ListTile(
              leading: const Icon(Icons.api),
              title: const Text('OpenAPI / Swagger'),
              onTap: () => _importFile('openapi'),
            ),
          ],
        ),
      ),
    );
  }

  Future<void> _importFile(String type) async {
    Navigator.pop(context);
    
    final result = await FilePicker.platform.pickFiles(
      type: FileType.custom,
      allowedExtensions: ['json', 'yaml', 'yml'],
    );

    if (result != null && result.files.single.bytes != null) {
      try {
        final content = utf8.decode(result.files.single.bytes!);
        final json = jsonDecode(content);
        
        final importService = ImportService();
        final requests = type == 'postman'
            ? importService.importPostmanCollection(json)
            : importService.importOpenApiSpec(json);

        ref.read(requestsProvider.notifier).importRequests(requests);

        if (mounted) {
          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(content: Text('Imported ${requests.length} requests')),
          );
        }
      } catch (e) {
        if (mounted) {
          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(content: Text('Import failed: $e')),
          );
        }
      }
    }
  }

  void _showEnvironmentDialog() {
    showDialog(
      context: context,
      builder: (context) => const EnvironmentDialog(),
    );
  }
}

class RequestsPanel extends ConsumerStatefulWidget {
  const RequestsPanel({super.key});

  @override
