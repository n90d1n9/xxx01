class CodeGenerationDialog extends StatelessWidget {
  final IntegrationRoute route;
  final GenerationTarget target;
  final String generatedCode;

  const CodeGenerationDialog({
    super.key,
    required this.route,
    required this.target,
    required this.generatedCode,
  });

  @override
  Widget build(BuildContext context) {
    return Dialog(
      maxWidth: 1000,
      maxHeight: 800,
      child: Column(
        children: [
          _buildHeader(context),
          Expanded(child: _buildCodeView()),
          _buildFooter(context),
        ],
      ),
    );
  }

  Widget _buildHeader(BuildContext context) {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        border: Border(
          bottom: BorderSide(color: Theme.of(context).dividerColor),
        ),
      ),
      child: Row(
        children: [
          const Icon(Icons.code),
          const SizedBox(width: 12),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'Generated Code - ${_getTargetName()}',
                  style: const TextStyle(
                    fontSize: 20,
                    fontWeight: FontWeight.bold,
                  ),
                ),
                Text(
                  route.name,
                  style: TextStyle(
                    fontSize: 12,
                    color: Theme.of(context).disabledColor,
                  ),
                ),
              ],
            ),
          ),
          IconButton(
            icon: const Icon(Icons.close),
            onPressed: () => Navigator.pop(context),
          ),
        ],
      ),
    );
  }

  Widget _buildCodeView() {
    return Container(
      padding: const EdgeInsets.all(16),
      color: Colors.grey[900],
      child: SingleChildScrollView(
        child: SelectableText(
          generatedCode,
          style: const TextStyle(
            fontFamily: 'monospace',
            fontSize: 13,
            color: Colors.white,
          ),
        ),
      ),
    );
  }

  Widget _buildFooter(BuildContext context) {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        border: Border(
          top: BorderSide(color: Theme.of(context).dividerColor),
        ),
      ),
      child: Row(
        children: [
          Text(
            '${generatedCode.split('\n').length} lines',
            style: TextStyle(color: Theme.of(context).disabledColor),
          ),
          const Spacer(),
          OutlinedButton.icon(
            onPressed: _copyToClipboard,
            icon: const Icon(Icons.copy),
            label: const Text('Copy'),
          ),
          const SizedBox(width: 8),
          ElevatedButton.icon(
            onPressed: _downloadCode,
            icon: const Icon(Icons.download),
            label: const Text('Download'),
          ),
        ],
      ),
    );
  }

  String _getTargetName() {
    switch (target) {
      case GenerationTarget.camelJava:
        return 'Java DSL';
      case GenerationTarget.camelYaml:
        return 'YAML DSL';
      case GenerationTarget.camelXml:
        return 'XML DSL';
      case GenerationTarget.camelSpringBoot:
        return 'Spring Boot';
      case GenerationTarget.camelQuarkus:
        return 'Quarkus';
    }
  }

  void _copyToClipboard() {
    // TODO: Implement clipboard
    // Clipboard.setData(ClipboardData(text: generatedCode));
  }

  void _downloadCode() {
    // TODO: Implement download
  }
}

