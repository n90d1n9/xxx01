/// Provider for canvas connection state
final canvasConnectionStateProvider = 
    StateNotifierProvider<CanvasConnectionStateNotifier, CanvasConnectionState>((ref) {
  return CanvasConnectionStateNotifier();
});

class CanvasConnectionState {
  final String? sourceNodeId;
  final Offset? currentMousePosition;
  final bool isConnecting;

  const CanvasConnectionState({
    this.sourceNodeId,
    this.currentMousePosition,
    this.isConnecting = false,
  });

  CanvasConnectionState copyWith({
    String? sourceNodeId,
    Offset? currentMousePosition,
    bool? isConnecting,
  }) {
    return CanvasConnectionState(
      sourceNodeId: sourceNodeId ?? this.sourceNodeId,
      currentMousePosition: currentMousePosition ?? this.currentMousePosition,
      isConnecting: isConnecting ?? this.isConnecting,
    );
  }
}

class CanvasConnectionStateNotifier extends StateNotifier<CanvasConnectionState> {
  CanvasConnectionStateNotifier() : super(const CanvasConnectionState());

  void startConnection(String nodeId) {
    state = CanvasConnectionState(
      sourceNodeId: nodeId,
      isConnecting: true,
    );
  }

  void updateMousePosition(Offset position) {
    if (state.isConnecting) {
      state = state.copyWith(currentMousePosition: position);
    }
  }

  void cancelConnection() {
    state = const CanvasConnectionState();
  }

  void completeConnection() {
    state = const CanvasConnectionState();
  }
}

