  EndpointSchema inferSchemaFromData(Map<String, dynamic> data) {
    // Simple schema inference
    final schema = _buildSchemaFromData(data);
    
    return EndpointSchema(
      contentType: 'application/json',
      schema: schema,
    );
  }

  Map<String, dynamic> _buildSchemaFromData(dynamic data) {
    if (data is Map) {
      return {
        'type': 'object',
        'properties': {
          for (final entry in data.entries)
            entry.key: _buildSchemaFromData(entry.value),
        },
      };
    } else if (data is List) {
      return {
        'type': 'array',
        'items': data.isNotEmpty 
            ? _buildSchemaFromData(data.first)
            : {'type': 'string'},
      };
    } else if (data is int) {
      return {'type': 'integer'};
    } else if (data is double) {
      return {'type': 'number'};
    } else if (data is bool) {
      return {'type': 'boolean'};
    } else {
      return {'type': 'string'};
    }
  }
}

