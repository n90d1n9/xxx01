// ============================================================================

final connectionManagerProvider = Provider<ConnectionManager>((ref) {
  return ConnectionManager(ref);
});

class ConnectionManager {
  ConnectionManager(this.ref);
  final Ref ref;

  bool canConnect(String routeId, String fromNodeId, String toNodeId) {
    final routes = ref.read(integrationRoutesProvider);
    final route = routes.firstWhere((r) => r.id == routeId);
    
    // Find nodes
    final fromNode = route.nodes.firstWhere((n) => n.id == fromNodeId);
    final toNode = route.nodes.firstWhere((n) => n.id == toNodeId);
    
    // Get component definitions
    final fromComponent = _getComponent(fromNode.type);
    final toComponent = _getComponent(toNode.type);
    
    if (fromComponent == null || toComponent == null) return false;
    
    // Check if source can produce and target can consume
    if (!fromComponent.producerSupported) return false;
    if (!toComponent.consumerSupported && toComponent.id != 'log') return false;
    
    // Check for existing connection
    final hasExistingConnection = route.connections.any(
      (c) => c.from == fromNodeId && c.to == toNodeId,
    );
    
    return !hasExistingConnection;
  }

  void createConnection(String routeId, String fromNodeId, String toNodeId) {
    if (!canConnect(routeId, fromNodeId, toNodeId)) return;
    
    final connection = Connection(
      id: 'conn_${DateTime.now().millisecondsSinceEpoch}',
      from: fromNodeId,
      to: toNodeId,
    );
    
    ref.read(integrationRoutesProvider.notifier)
        .addConnection(routeId, connection);
  }

  void deleteConnection(String routeId, String connectionId) {
    ref.read(integrationRoutesProvider.notifier)
        .removeConnection(routeId, connectionId);
  }

  CamelComponent? _getComponent(String type) {
    final allComponents = CamelComponentsLibrary.getAllComponents();
    for (final category in allComponents.values) {
      for (final component in category) {
        if (component.id == type) return component;
      }
    }
    return null;
  }
}

