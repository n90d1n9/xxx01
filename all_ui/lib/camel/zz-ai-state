// ============================================================================

final integrationHistoryProvider = 
    StateNotifierProvider<IntegrationHistoryNotifier, IntegrationHistory>((ref) {
  return IntegrationHistoryNotifier();
});

class IntegrationHistory {
  final List<List<IntegrationRoute>> history;
  final int currentIndex;

  const IntegrationHistory({
    this.history = const [],
    this.currentIndex = -1,
  });

  bool get canUndo => currentIndex > 0;
  bool get canRedo => currentIndex < history.length - 1;

  IntegrationHistory copyWith({
    List<List<IntegrationRoute>>? history,
    int? currentIndex,
  }) {
    return IntegrationHistory(
      history: history ?? this.history,
      currentIndex: currentIndex ?? this.currentIndex,
    );
  }
}

class IntegrationHistoryNotifier extends StateNotifier<IntegrationHistory> {
  IntegrationHistoryNotifier() : super(const IntegrationHistory());

  void push(List<IntegrationRoute> routes) {
    final newHistory = [
      ...state.history.sublist(0, state.currentIndex + 1),
      routes,
    ];
    
    // Limit history size
    const maxHistorySize = 50;
    final startIndex = newHistory.length > maxHistorySize 
        ? newHistory.length - maxHistorySize 
        : 0;
    
    state = IntegrationHistory(
      history: newHistory.sublist(startIndex),
      currentIndex: newHistory.length - 1 - startIndex,
    );
  }

  List<IntegrationRoute>? undo() {
    if (!state.canUndo) return null;
    
    state = state.copyWith(currentIndex: state.currentIndex - 1);
    return state.history[state.currentIndex];
  }

  List<IntegrationRoute>? redo() {
    if (!state.canRedo) return null;
    
    state = state.copyWith(currentIndex: state.currentIndex + 1);
    return state.history[state.currentIndex];
  }

  void clear() {
    state = const IntegrationHistory();
  }
}

