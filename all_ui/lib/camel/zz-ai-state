final nodeConfigDialogProvider = Provider<NodeConfigDialogManager>((ref) {
  return NodeConfigDialogManager(ref);
});

class NodeConfigDialogManager {
  NodeConfigDialogManager(this.ref);
  final Ref ref;

  Future<Map<String, dynamic>?> showConfigDialog(
    BuildContext context,
    NodeCard node,
  ) async {
    final component = _getComponent(node.type);
    
    if (component == null) {
      return _showGenericConfigDialog(context, node);
    }
    
    // Show component-specific configuration dialog
    return showDialog<Map<String, dynamic>>(
      context: context,
      builder: (context) => NodeConfigurationDialog(
        node: node,
        component: component,
      ),
    );
  }

  Future<Map<String, dynamic>?> _showGenericConfigDialog(
    BuildContext context,
    NodeCard node,
  ) async {
    return showDialog<Map<String, dynamic>>(
      context: context,
      builder: (context) => GenericNodeConfigDialog(node: node),
    );
  }

  CamelComponent? _getComponent(String type) {
    final allComponents = CamelComponentsLibrary.getAllComponents();
    for (final category in allComponents.values) {
      for (final component in category) {
        if (component.id == type) return component;
      }
    }
    return null;
  }
}

