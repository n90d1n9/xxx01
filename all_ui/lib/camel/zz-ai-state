/// Provider for complete integration routes (enhanced WNode)
final integrationRoutesProvider = 
    StateNotifierProvider<IntegrationRoutesNotifier, List<IntegrationRoute>>((ref) {
  return IntegrationRoutesNotifier(ref);
});

class IntegrationRoutesNotifier extends StateNotifier<List<IntegrationRoute>> {
  IntegrationRoutesNotifier(this.ref) : super([]);
  final Ref ref;

  void addRoute(IntegrationRoute route) {
    state = [...state, route];
    _saveHistory();
  }

  void updateRoute(String id, IntegrationRoute route) {
    state = [
      for (final r in state)
        if (r.id == id) route else r,
    ];
    _saveHistory();
  }

  void deleteRoute(String id) {
    state = state.where((r) => r.id != id).toList();
    _saveHistory();
  }

  void addNodeToRoute(String routeId, NodeCard node) {
    state = [
      for (final route in state)
        if (route.id == routeId)
          route.copyWith(
            nodes: [...route.nodes, node],
          )
        else
          route,
    ];
    _saveHistory();
  }

  void updateNodeInRoute(String routeId, String nodeId, NodeCard node) {
    state = [
      for (final route in state)
        if (route.id == routeId)
          route.copyWith(
            nodes: [
              for (final n in route.nodes)
                if (n.id == nodeId) node else n,
            ],
          )
        else
          route,
    ];
    _saveHistory();
  }

  void deleteNodeFromRoute(String routeId, String nodeId) {
    state = [
      for (final route in state)
        if (route.id == routeId)
          route.copyWith(
            nodes: route.nodes.where((n) => n.id != nodeId).toList(),
            connections: route.connections
                .where((c) => c.from != nodeId && c.to != nodeId)
                .toList(),
          )
        else
          route,
    ];
    _saveHistory();
  }

  void addConnection(String routeId, Connection connection) {
    state = [
      for (final route in state)
        if (route.id == routeId)
          route.copyWith(
            connections: [...route.connections, connection],
          )
        else
          route,
    ];
    _saveHistory();
  }

  void removeConnection(String routeId, String connectionId) {
    state = [
      for (final route in state)
        if (route.id == routeId)
          route.copyWith(
            connections: route.connections
                .where((c) => c.id != connectionId)
                .toList(),
          )
        else
          route,
    ];
    _saveHistory();
  }

  void addTransformation(String routeId, TransformationStep transformation) {
    state = [
      for (final route in state)
        if (route.id == routeId)
          route.copyWith(
            transformations: [...route.transformations, transformation],
          )
        else
          route,
    ];
    _saveHistory();
  }

  void setErrorHandler(String routeId, ErrorHandler errorHandler) {
    state = [
      for (final route in state)
        if (route.id == routeId)
          route.copyWith(errorHandler: errorHandler)
        else
          route,
    ];
    _saveHistory();
  }

  void setRouting(String routeId, RoutingRule routing) {
    state = [
      for (final route in state)
        if (route.id == routeId)
          route.copyWith(routing: routing)
        else
          route,
    ];
    _saveHistory();
  }

  void _saveHistory() {
    // Save to history for undo/redo
    ref.read(integrationHistoryProvider.notifier).push(state);
  }
}

