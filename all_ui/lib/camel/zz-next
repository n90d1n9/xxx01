class DataFlowTracer {
  /// Trace data through entire route
  Future<DataTrace> traceData(
    dynamic input,
    IntegrationRoute route,
  ) async {
    final trace = DataTrace(
      routeId: route.id,
      startTime: DateTime.now(),
      initialData: input,
    );

    dynamic currentData = input;

    for (final node in route.nodes) {
      final stepTrace = await _traceNode(node, currentData);
      trace.steps.add(stepTrace);
      
      if (stepTrace.transformations.isNotEmpty) {
        trace.totalTransformations += stepTrace.transformations.length;
      }
      
      currentData = stepTrace.outputData;
    }

    trace.endTime = DateTime.now();
    trace.finalData = currentData;
    
    return trace;
  }

  Future<NodeTrace> _traceNode(
    NodeCard node,
    dynamic inputData,
  ) async {
    final transformations = <DataTransformation>[];
    dynamic currentData = inputData;

    // Detect transformations based on node type
    if (node.type == 'data-mapper') {
      final mappings = node.config['mappings'] as List? ?? [];
      
      for (final mapping in mappings) {
        final sourcePath = mapping['sourcePath'];
        final targetPath = mapping['targetPath'];
        
        final transformation = DataTransformation(
          type: TransformationType.mapping,
          sourcePath: sourcePath,
          targetPath: targetPath,
          beforeValue: _getValueByPath(currentData, sourcePath),
          afterValue: _getValueByPath(currentData, targetPath),
          operation: 'Map $sourcePath → $targetPath',
        );
        
        transformations.add(transformation);
      }
    } else if (node.type == 'content-based-router') {
      transformations.add(DataTransformation(
        type: TransformationType.routing,
        operation: 'Content-based routing',
        beforeValue: currentData,
        afterValue: currentData,
      ));
    }

    return NodeTrace(
      nodeId: node.id,
      nodeName: node.name,
      nodeType: node.type,
      inputData: inputData,
      outputData: currentData,
      transformations: transformations,
      timestamp: DateTime.now(),
    );
  }

  dynamic _getValueByPath(dynamic data, String path) {
    if (data is! Map) return null;
    
    final parts = path.split('.');
    dynamic current = data;
    
    for (final part in parts) {
      if (current is Map) {
        current = current[part];
      } else {
        return null;
      }
    }
    
    return current;
  }

  /// Generate visual data lineage
  DataLineage generateLineage(DataTrace trace) {
    final nodes = <LineageNode>[];
    final edges = <LineageEdge>[];

    for (var i = 0; i < trace.steps.length; i++) {
      final step = trace.steps[i];
      
      nodes.add(LineageNode(
        id: step.nodeId,
        label: step.nodeName,
        type: step.nodeType,
        transformations: step.transformations.length,
      ));

      if (i > 0) {
        edges.add(LineageEdge(
          from: trace.steps[i - 1].nodeId,
          to: step.nodeId,
          transformations: step.transformations,
        ));
      }
    }

    return DataLineage(
      nodes: nodes,
      edges: edges,
      totalTransformations: trace.totalTransformations,
    );
  }

  /// Show data diff between two points
  DataDiff diffData(dynamic before, dynamic after) {
    final changes = <DataChange>[];

    if (before is Map && after is Map) {
      // Compare maps
      final allKeys = {...before.keys, ...after.keys};
      
      for (final key in allKeys) {
        if (!before.containsKey(key)) {
          changes.add(DataChange(
            type: ChangeType.added,
            path: key,
            newValue: after[key],
          ));
        } else if (!after.containsKey(key)) {
          changes.add(DataChange(
            type: ChangeType.removed,
            path: key,
            oldValue: before[key],
          ));
        } else if (before[key] != after[key]) {
          changes.add(DataChange(
            type: ChangeType.modified,
            path: key,
            oldValue: before[key],
            newValue: after[key],
          ));
        }
      }
    }

    return DataDiff(changes: changes);
  }
}

class DataTrace {
  final String routeId;
  final DateTime startTime;
  DateTime? endTime;
  final dynamic initialData;
  dynamic finalData;
  final List<NodeTrace> steps = [];
  int totalTransformations = 0;

  DataTrace({
    required this.routeId,
    required this.startTime,
    required this.initialData,
  });

  Duration get duration => (endTime ?? DateTime.now()).difference(startTime);
}

