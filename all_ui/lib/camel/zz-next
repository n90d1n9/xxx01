}

class DataTransformation {
  final TransformationType type;
  final String? sourcePath;
  final String? targetPath;
  final dynamic beforeValue;
  final dynamic afterValue;
  final String operation;

  DataTransformation({
    required this.type,
    this.sourcePath,
    this.targetPath,
    this.beforeValue,
    this.afterValue,
    required this.operation,
  });
}

enum TransformationType {
  mapping,
  filtering,
  enrichment,
  aggregation,
  splitting,
  routing,
  validation,
}

