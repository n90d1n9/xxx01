  /// Suggest fixes for validation errors
  Future<List<FixSuggestion>> suggestFixes(ValidationResult validation) async {
    final fixes = <FixSuggestion>[];

    for (final issue in validation.errors) {
      switch (issue.category) {
        case IssueCategory.configuration:
          if (issue.message.contains('Required parameter')) {
            fixes.add(FixSuggestion(
              issue: issue,
              title: 'Add missing parameter',
              description: 'Set default value for required parameter',
              autoFixAvailable: true,
            ));
          }
          break;

        case IssueCategory.connections:
          if (issue.message.contains('not connected')) {
            fixes.add(FixSuggestion(
              issue: issue,
              title: 'Connect orphaned node',
              description: 'Suggest logical connections',
              autoFixAvailable: false,
            ));
          }
          break;

        default:
          break;
      }
    }

    return fixes;
  }
}

