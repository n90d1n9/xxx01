  final String from;
  final String to;
  final List<DataTransformation> transformations;

  LineageEdge({
    required this.from,
    required this.to,
    required this.transformations,
  });
}

class DataDiff {
  final List<DataChange> changes;

  DataDiff({required this.changes});

  int get addedCount => changes.where((c) => c.type == ChangeType.added).length;
  int get removedCount => changes.where((c) => c.type == ChangeType.removed).length;
  int get modifiedCount => changes.where((c) => c.type == ChangeType.modified).length;
}

class DataChange {
  final ChangeType type;
  final String path;
  final dynamic oldValue;
  final dynamic newValue;

  DataChange({
    required this.type,
    required this.path,
    this.oldValue,
    this.newValue,
  });
}

enum ChangeType { added, removed, modified }

