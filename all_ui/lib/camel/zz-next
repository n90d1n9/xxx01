class AdvancedDebugger {
  final Map<String, List<Breakpoint>> breakpoints = {};
  final Map<String, dynamic> variables = {};
  DebugState currentState = DebugState.idle;

  /// Set a breakpoint on a node
  void setBreakpoint(String nodeId, {String? condition}) {
    breakpoints.putIfAbsent(nodeId, () => []).add(
      Breakpoint(
        nodeId: nodeId,
        condition: condition,
        enabled: true,
      ),
    );
  }

  /// Execute route with debugging
  Future<DebugSession> debugRoute(
    IntegrationRoute route,
    Map<String, dynamic> input,
  ) async {
    final session = DebugSession(
      routeId: route.id,
      startTime: DateTime.now(),
    );

    currentState = DebugState.running;

    for (final node in route.nodes) {
      // Check if we should pause at this node
      if (await _shouldBreak(node.id, variables)) {
        currentState = DebugState.paused;
        session.pausedAt = node.id;
        
        // Wait for user to continue
        await _waitForContinue();
      }

      // Execute node and capture state
      final stepResult = await _executeNode(node, variables);
      session.steps.add(stepResult);
      
      // Update variables
      variables[node.id] = stepResult.output;
    }

    currentState = DebugState.completed;
    session.endTime = DateTime.now();
    return session;
  }

  Future<bool> _shouldBreak(String nodeId, Map<String, dynamic> vars) async {
    final bps = breakpoints[nodeId];
    if (bps == null || bps.isEmpty) return false;

    for (final bp in bps) {
      if (!bp.enabled) continue;
      
      if (bp.condition != null) {
        // Evaluate condition
        final result = _evaluateCondition(bp.condition!, vars);
        if (result) return true;
      } else {
        return true; // Unconditional breakpoint
      }
    }

    return false;
  }

  bool _evaluateCondition(String condition, Map<String, dynamic> vars) {
    // Simple condition evaluation
    // In production, use proper expression parser
    return true;
  }

  Future<void> _waitForContinue() async {
    // Wait for user to press continue
    await Future.delayed(Duration.zero);
  }

  Future<DebugStepResult> _executeNode(
    NodeCard node,
    Map<String, dynamic> input,
  ) async {
    final startTime = DateTime.now();
    
    try {
      // Simulate node execution
      final output = {'processed': true, 'input': input};
      
      return DebugStepResult(
        nodeId: node.id,
        nodeName: node.name,
        input: input,
        output: output,
        duration: DateTime.now().difference(startTime),
        success: true,
      );
    } catch (e) {
      return DebugStepResult(
        nodeId: node.id,
        nodeName: node.name,
        input: input,
        output: null,
        duration: DateTime.now().difference(startTime),
        success: false,
        error: e.toString(),
      );
    }
  }

  /// Step over (execute current node and move to next)
  Future<void> stepOver() async {
    if (currentState != DebugState.paused) return;
    currentState = DebugState.stepping;
    // Execute current node
    currentState = DebugState.paused;
  }

  /// Step into (enter node execution details)
  Future<void> stepInto() async {
    if (currentState != DebugState.paused) return;
    currentState = DebugState.steppingInto;
    // Enter detailed execution
    currentState = DebugState.paused;
  }

  /// Continue execution
  void continueExecution() {
    if (currentState == DebugState.paused) {
      currentState = DebugState.running;
    }
  }

  /// Stop debugging
  void stop() {
    currentState = DebugState.stopped;
    variables.clear();
  }

  /// Get variable value at specific node
  dynamic getVariable(String nodeId, String varName) {
    final nodeVars = variables[nodeId];
    return nodeVars?[varName];
  }

  /// Inspect all variables at node
  Map<String, dynamic> inspectVariables(String nodeId) {
    return Map.from(variables[nodeId] ?? {});
  }
}

enum DebugState {
  idle,
  running,
  paused,
  stepping,
  steppingInto,
  stopped,
  completed,
}

