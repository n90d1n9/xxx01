// ============================================================================
// MAIN DESIGNER SCREEN
// ============================================================================

class MainDesignerScreen extends ConsumerStatefulWidget {
  const MainDesignerScreen({super.key});

  @override
  ConsumerState<MainDesignerScreen> createState() => _MainDesignerScreenState();
}

class _MainDesignerScreenState extends ConsumerState<MainDesignerScreen> {
  @override
  void initState() {
    super.initState();
    _initializeApp();
  }

  Future<void> _initializeApp() async {
    // Initialize systems
    await ProviderSetupHelper.initializeSystems(ref);
    
    // Check if we need to show migration dialog
    final existingRoutes = ref.read(routesProvider);
    final integrationRoutes = ref.read(integrationRoutesProvider);
    
    if (existingRoutes.isNotEmpty && integrationRoutes.isEmpty) {
      WidgetsBinding.instance.addPostFrameCallback((_) {
        _showMigrationDialog();
      });
    } else if (integrationRoutes.isEmpty) {
      // Show welcome dialog
      WidgetsBinding.instance.addPostFrameCallback((_) {
        _showWelcomeDialog();
      });
    }
  }

  @override
  Widget build(BuildContext context) {
    final route = ref.watch(selectedRouteProvider);

    return Scaffold(
      appBar: AppBar(
        title: const Text('Apache Camel Visual Designer'),
        actions: [
          IconButton(
            icon: Icon(
              ref.watch(darkModeProvider) ? Icons.light_mode : Icons.dark_mode,
            ),
            onPressed: () {
              ref.read(darkModeProvider.notifier).state = 
                  !ref.read(darkModeProvider);
            },
            tooltip: 'Toggle Theme',
          ),
          IconButton(
            icon: const Icon(Icons.help_outline),
            onPressed: _showHelp,
            tooltip: 'Help',
          ),
        ],
      ),
      body: Column(
        children: [
          // Enhanced toolbar
          const EnhancedToolbar(),
          
          // Main content area
          Expanded(
            child: Row(
              children: [
                // Component Palette (left sidebar)
                SizedBox(
                  width: 280,
                  child: EnhancedComponentPalette(),
                ),
                
                // Canvas Area (center)
                Expanded(
                  child: route == null
                      ? const EmptyRouteState()
                      : const CanvasArea(),
                ),
                
                // Properties Panel (right sidebar)
                SizedBox(
                  width: 320,
                  child: route == null
                      ? const EmptyPropertiesPanel()
                      : const EnhancedPropertiesPanel(),
                ),
              ],
            ),
          ),
          
          // Status bar
          _buildStatusBar(),
        ],
      ),
      floatingActionButton: _buildFloatingActions(),
    );
  }

  Widget _buildStatusBar() {
    final route = ref.watch(selectedRouteProvider);
    final validation = route != null 
        ? ref.watch(routeValidationProvider(route.id))
        : null;

    return Container(
      height: 32,
      padding: const EdgeInsets.symmetric(horizontal: 16),
      decoration: BoxDecoration(
        color: Theme.of(context).cardColor,
        border: Border(
          top: BorderSide(color: Theme.of(context).dividerColor),
        ),
      ),
      child: Row(
        children: [
          if (route != null) ...[
            Text(
              '${route.nodes.length} nodes',
              style: Theme.of(context).textTheme.bodySmall,
            ),
            const SizedBox(width: 16),
            Text(
              '${route.connections.length} connections',
              style: Theme.of(context).textTheme.bodySmall,
            ),
            const SizedBox(width: 16),
            if (validation != null) ...[
              Icon(
                validation.isValid ? Icons.check_circle : Icons.error,
                size: 16,
                color: validation.isValid ? Colors.green : Colors.red,
              ),
              const SizedBox(width: 4),
              Text(
                validation.isValid 
                    ? 'Valid' 
                    : '${validation.errors.length} errors',
                style: Theme.of(context).textTheme.bodySmall?.copyWith(
                  color: validation.isValid ? Colors.green : Colors.red,
                ),
              ),
            ],
          ] else
            Text(
              'No route selected',
              style: Theme.of(context).textTheme.bodySmall,
            ),
          const Spacer(),
          Text(
            'Apache Camel Visual Designer v1.0',
            style: Theme.of(context).textTheme.bodySmall?.copyWith(
              color: Theme.of(context).disabledColor,
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildFloatingActions() {
    final route = ref.watch(selectedRouteProvider);
    
    return Column(
      mainAxisSize: MainAxisSize.min,
      children: [
        if (route == null)
          FloatingActionButton.extended(
            onPressed: _createNewRoute,
            icon: const Icon(Icons.add),
            label: const Text('New Route'),
          )
        else ...[
          FloatingActionButton(
            heroTag: 'validate',
            onPressed: () => _handleValidation(route.id),
            child: const Icon(Icons.check_circle_outline),
            tooltip: 'Validate Route',
          ),
          const SizedBox(height: 8),
          FloatingActionButton(
            heroTag: 'test',
            onPressed: () => _handleTest(route),
            child: const Icon(Icons.play_arrow),
            tooltip: 'Test Route',
          ),
          const SizedBox(height: 8),
          FloatingActionButton(
            heroTag: 'code',
            onPressed: () => _handleCodeGeneration(route),
            child: const Icon(Icons.code),
            tooltip: 'Generate Code',
          ),
        ],
      ],
    );
  }

  void _createNewRoute() {
    showDialog(
      context: context,
      builder: (context) => const NewRouteDialog(),
    );
  }

  void _handleValidation(String routeId) {
    ref.read(routeValidationProvider(routeId).notifier).validate();
    final validation = ref.read(routeValidationProvider(routeId));
    
    showDialog(
      context: context,
      builder: (context) => ValidationResultDialog(result: validation!),
    );
  }

  void _handleTest(IntegrationRoute route) {
    showDialog(
      context: context,
      builder: (context) => RouteTestDialog(route: route),
    );
  }

  void _handleCodeGeneration(IntegrationRoute route) {
    showDialog(
      context: context,
      builder: (context) => const CodeGenerationTargetDialog(),
    ).then((target) {
      if (target != null) {
        final code = ref.read(codeGeneratorProvider).generateCode(
          route.id,
          target as GenerationTarget,
        );
        
        showDialog(
          context: context,
          builder: (context) => CodeGenerationDialog(
            route: route,
            target: target,
            generatedCode: code,
          ),
        );
      }
    });
  }

  void _showMigrationDialog() {
    final existingRoutes = ref.read(routesProvider);
    
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (context) => MigrationDialog(existingRoutes: existingRoutes),
    ).then((migratedRoutes) {
      if (migratedRoutes != null) {
        ref.read(integrationRoutesProvider.notifier).state = migratedRoutes;
        
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text('✅ Routes migrated successfully!'),
            backgroundColor: Colors.green,
          ),
        );
      }
    });
  }

  void _showWelcomeDialog() {
    showDialog(
      context: context,
      builder: (context) => const WelcomeDialog(),
    );
  }

  void _showHelp() {
    showDialog(
      context: context,
      builder: (context) => const HelpDialog(),
    );
  }
}

