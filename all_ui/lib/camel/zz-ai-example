class EnhancedPropertiesPanel extends ConsumerWidget {
  const EnhancedPropertiesPanel({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final selectedNode = ref.watch(selectedNodeProvider);
    
    if (selectedNode == null) {
      return const EmptyPropertiesPanel();
    }

    return Container(
      decoration: BoxDecoration(
        border: Border(
          left: BorderSide(color: Theme.of(context).dividerColor),
        ),
      ),
      child: Column(
        children: [
          _buildHeader(context, selectedNode),
          Expanded(
            child: _buildProperties(context, ref, selectedNode),
          ),
        ],
      ),
    );
  }

  Widget _buildHeader(BuildContext context, NodeCard node) {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: node.color.withOpacity(0.1),
        border: Border(
          bottom: BorderSide(color: Theme.of(context).dividerColor),
        ),
      ),
      child: Row(
        children: [
          Icon(node.icon, color: node.color),
          const SizedBox(width: 12),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  node.name,
                  style: const TextStyle(
                    fontWeight: FontWeight.bold,
                    fontSize: 16,
                  ),
                ),
                Text(
                  node.type,
                  style: TextStyle(
                    fontSize: 12,
                    color: Theme.of(context).disabledColor,
                  ),
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildProperties(BuildContext context, WidgetRef ref, NodeCard node) {
    return ListView(
      padding: const EdgeInsets.all(16),
      children: [
        Text(
          'Configuration',
          style: Theme.of(context).textTheme.titleMedium,
        ),
        const SizedBox(height: 16),
        if (node.config.isEmpty)
          Text(
            'No configuration set',
            style: TextStyle(color: Theme.of(context).disabledColor),
          )
        else
          ...node.config.entries.map((entry) {
            return Padding(
              padding: const EdgeInsets.only(bottom: 12),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(
                    entry.key,
                    style: const TextStyle(fontWeight: FontWeight.bold),
                  ),
                  const SizedBox(height: 4),
                  Text(entry.value.toString()),
                ],
              ),
            );
          }),
        const SizedBox(height: 24),
        OutlinedButton.icon(
          onPressed: () => _configureNode(context, ref, node),
          icon: const Icon(Icons.settings),
          label: const Text('Configure'),
        ),
      ],
    );
  }

  void _configureNode(BuildContext context, WidgetRef ref, NodeCard node) async {
    final configManager = ref.read(nodeConfigDialogProvider);
    final newConfig = await configManager.showConfigDialog(context, node);
    
    if (newConfig != null) {
      final route = ref.read(selectedRouteProvider);
      if (route != null) {
        final updatedNode = node.copyWith(
          config: newConfig,
          name: newConfig['name'] ?? node.name,
        );
        
        ref
            .read(integrationRoutesProvider.notifier)
            .updateNodeInRoute(route.id, node.id, updatedNode);
      }
    }
  }
}