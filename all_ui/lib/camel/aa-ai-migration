  }

  static IntegrationRoute _createSampleRoute() {
    final node1 = NodeCard(
      id: 'node1',
      type: 'rest-endpoint',
      name: 'REST API',
      icon: Icons.api,
      color: Colors.blue,
      position: const Offset(100, 100),
      config: {
        'method': 'POST',
        'path': '/orders',
        'consumes': 'application/json',
