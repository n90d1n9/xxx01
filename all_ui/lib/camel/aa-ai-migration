      color: Colors.orange,
      position: const Offset(350, 100),
      config: {
        'sourceFormat': 'json',
        'targetFormat': 'json',
      },
    );

    final node3 = NodeCard(
      id: 'node3',
      type: 'kafka',
      name: 'Send to Kafka',
      icon: Icons.message,
      color: Colors.green,
      position: const Offset(600, 100),
