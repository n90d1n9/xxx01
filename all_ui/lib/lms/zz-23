// ==================== COMPREHENSIVE TRY OUT MODELS ====================

class TryOutPackage {
  final String id;
  final String title;
  final String description;
  final ExamType examType;
  final DateTime availableFrom;
  final DateTime availableUntil;
  final Duration duration;
  final int totalQuestions;
  final List<TryOutSection> sections;
  final bool isPremium;
  final int price;
  final String? thumbnail;
  final DifficultyLevel difficulty;
  final List<String> tags;

  TryOutPackage({
    required this.id,
    required this.title,
    required this.description,
    required this.examType,
    required this.availableFrom,
    required this.availableUntil,
    required this.duration,
    required this.totalQuestions,
    required this.sections,
    this.isPremium = false,
    this.price = 0,
    this.thumbnail,
    required this.difficulty,
    required this.tags,
  });
}

enum ExamType { snbt, snbp, simak, umUGM, umITB, umUI }
enum DifficultyLevel { easy, medium, hard, veryHard }

class TryOutSection {
  final String id;
  final String name;
  final SubjectCategory subject;
  final int questionCount;
  final Duration timeLimit;
  final List<TryOutQuestion> questions;
  final int order;

  TryOutSection({
    required this.id,
    required this.name,
    required this.subject,
    required this.questionCount,
    required this.timeLimit,
    required this.questions,
    required this.order,
  });
}

enum SubjectCategory {
  penalaranMatematika,
  literasiBahasaIndonesia,
  literasiBahasaInggris,
  matematikaSaintek,
  fisika,
  kimia,
  biologi,
}

class TryOutQuestion {
  final String id;
  final String sectionId;
  final String question;
  final String? imageUrl;
  final List<QuestionOption> options;
  final int correctAnswer;
  final String explanation;
  final int points;
  final QuestionDifficulty difficulty;
  final List<String> topics;
  final int order;

  TryOutQuestion({
    required this.id,
    required this.sectionId,
    required this.question,
    this.imageUrl,
    required this.options,
    required this.correctAnswer,
    required this.explanation,
    this.points = 4,
    required this.difficulty,
    required this.topics,
    required this.order,
  });
}

class QuestionOption {
  final String id;
  final String text;
  final String? imageUrl;

  QuestionOption({
    required this.id,
    required this.text,
    this.imageUrl,
  });
}

enum QuestionDifficulty { easy, medium, hard }

class TryOutAttempt {
  final String id;
  final String studentId;
  final String tryOutId;
  final DateTime startTime;
  final DateTime? endTime;
  final Map<String, int?> answers; // questionId -> selected option index
  final Map<String, Duration> timePerQuestion;
  final AttemptStatus status;
  final int? totalScore;
  final double? percentage;
  final Map<String, SectionResult>? sectionResults;

  TryOutAttempt({
    required this.id,
    required this.studentId,
    required this.tryOutId,
    required this.startTime,
    this.endTime,
    required this.answers,
    required this.timePerQuestion,
    required this.status,
    this.totalScore,
    this.percentage,
    this.sectionResults,
  });

  TryOutAttempt copyWith({
    Map<String, int?>? answers,
    DateTime? endTime,
    AttemptStatus? status,
    int? totalScore,
    double? percentage,
    Map<String, SectionResult>? sectionResults,
  }) {
    return TryOutAttempt(
      id: id,
      studentId: studentId,
      tryOutId: tryOutId,
      startTime: startTime,
      endTime: endTime ?? this.endTime,
      answers: answers ?? this.answers,
      timePerQuestion: timePerQuestion,
      status: status ?? this.status,
      totalScore: totalScore ?? this.totalScore,
      percentage: percentage ?? this.percentage,
      sectionResults: sectionResults ?? this.sectionResults,
    );
  }
}

enum AttemptStatus { notStarted, inProgress, paused, completed, reviewed }

class SectionResult {
  final String sectionId;
  final int correct;
  final int wrong;
  final int blank;
  final int score;
  final int maxScore;
  final double percentage;
  final Duration timeSpent;

  SectionResult({
    required this.sectionId,
    required this.correct,
    required this.wrong,
    required this.blank,
    required this.score,
    required this.maxScore,
    required this.percentage,
    required this.timeSpent,
  });
}

class TryOutLeaderboard {
  final String tryOutId;
  final List<LeaderboardEntry> entries;
  final DateTime lastUpdated;

  TryOutLeaderboard({
    required this.tryOutId,
    required this.entries,
    required this.lastUpdated,
  });
}

class LeaderboardEntry {
  final String userId;
  final String userName;
  final String avatar;
  final int score;
  final double percentage;
  final int rank;
  final Duration completionTime;
  final bool isCurrentUser;

  LeaderboardEntry({
    required this.userId,
    required this.userName,
    required this.avatar,
    required this.score,
    required this.percentage,
    required this.rank,
    required this.completionTime,
    this.isCurrentUser = false,
  });
}

