class PaginatedDataNotifier extends StateNotifier<List<String>> {
  PaginatedDataNotifier() : super([]);
  
  int _page = 1;
  bool _hasMore = true;

  Future<void> loadMore() async {
    if (!_hasMore) return;
    
    await Future.delayed(const Duration(seconds: 1));
    
    final newItems = List.generate(20, (i) => 'Item ${(_page * 20) + i}');
    state = [...state, ...newItems];
    
    _page++;
    if (_page > 5) _hasMore = false;
  }
}

