class FlashcardStudyScreen extends ConsumerWidget {
  const FlashcardStudyScreen({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final deck = ref.watch(selectedFlashcardDeckProvider);
    final currentIndex = ref.watch(currentFlashcardIndexProvider);
    final showAnswer = ref.watch(showFlashcardAnswerProvider);

    if (deck == null || deck.cards.isEmpty) {
      return Scaffold(
        appBar: AppBar(title: const Text('Flashcard')),
        body: const Center(child: Text('Tidak ada kartu')),
      );
    }

    final card = deck.cards[currentIndex];
    final progress = (currentIndex + 1) / deck.cards.length;

    return Scaffold(
      appBar: AppBar(
        title: Text('${deck.title} (${currentIndex + 1}/${deck.cards.length})'),
      ),
      body: Column(
        children: [
          LinearProgressIndicator(value: progress, minHeight: 4),
          Expanded(
            child: Padding(
              padding: const EdgeInsets.all(24),
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  GestureDetector(
                    onTap: () {
                      ref.read(showFlashcardAnswerProvider.notifier).state = !showAnswer;
                    },
                    child: Container(
                      constraints: const BoxConstraints(minHeight: 300),
                      width: double.infinity,
                      padding: const EdgeInsets.all(32),
                      decoration: BoxDecoration(
                        gradient: LinearGradient(
                          colors: showAnswer 
                              ? [const Color(0xFF10B981), const Color(0xFF059669)]
                              : [const Color(0xFF6366F1), const Color(0xFF8B5CF6)],
                        ),
                        borderRadius: BorderRadius.circular(24),
                        boxShadow: [
                          BoxShadow(
                            color: Colors.black.withOpacity(0.1),
                            blurRadius: 20,
                            offset: const Offset(0, 10),
                          ),
                        ],
                      ),
                      child: Column(
                        mainAxisAlignment: MainAxisAlignment.center,
                        children: [
                          Text(
                            showAnswer ? 'Jawaban' : 'Pertanyaan',
                            style: const TextStyle(
                              color: Colors.white70,
                              fontSize: 14,
                              fontWeight: FontWeight.w600,
                            ),
                          ),
                          const SizedBox(height: 24),
                          Text(
                            showAnswer ? card.back : card.front,
                            style: const TextStyle(
                              color: Colors.white,
                              fontSize: 28,
                              fontWeight: FontWeight.bold,
                            ),
                            textAlign: TextAlign.center,
                          ),
                          if (!showAnswer && card.hints != null && card.hints!.isNotEmpty) ...[
                            const SizedBox(height: 24),
                            Container(
                              padding: const EdgeInsets.all(12),
                              decoration: BoxDecoration(
                                color: Colors.white24,
                                borderRadius: BorderRadius.circular(12),
                              ),
                              child: Column(
                                crossAxisAlignment: CrossAxisAlignment.start,
                                children: [
                                  const Row(
                                    children: [
                                      Icon(Icons.lightbulb_outline, color: Colors.white, size: 16),
                                      SizedBox(width: 8),
                                      Text('Hint:', style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold)),
                                    ],
                                  ),
                                  const SizedBox(height: 4),
                                  ...card.hints!.map((hint) => Padding(
                                    padding: const EdgeInsets.only(top: 4),
                                    child: Text('• $hint', style: const TextStyle(color: Colors.white70, fontSize: 13)),
                                  )),
                                ],
                              ),
                            ),
                          ],
                        ],
                      ),
                    ),
                  ),
                  const SizedBox(height: 32),
                  Text(
                    showAnswer ? 'Apakah kamu menguasai kartu ini?' : 'Tap kartu untuk melihat jawaban',
                    style: TextStyle(color: Colors.grey[600], fontSize: 14),
                    textAlign: TextAlign.center,
                  ),
                  if (showAnswer) ...[
                    const SizedBox(height: 24),
                    Row(
                      children: [
                        Expanded(
                          child: OutlinedButton.icon(
                            onPressed: () => _nextCard(ref, false),
                            icon: const Icon(Icons.close),
                            label: const Text('Belum'),
                            style: OutlinedButton.styleFrom(
                              foregroundColor: Colors.red,
                              padding: const EdgeInsets.symmetric(vertical: 16),
                            ),
                          ),
                        ),
                        const SizedBox(width: 16),
                        Expanded(
                          child: ElevatedButton.icon(
                            onPressed: () => _nextCard(ref, true),
                            icon: const Icon(Icons.check),
                            label: const Text('Sudah'),
                            style: ElevatedButton.styleFrom(
                              backgroundColor: const Color(0xFF10B981),
                              foregroundColor: Colors.white,
                              padding: const EdgeInsets.symmetric(vertical: 16),
                            ),
                          ),
                        ),
                      ],
                    ),
                  ],
                ],
              ),
            ),
          ),
        ],
      ),
    );
  }

  void _nextCard(WidgetRef ref, bool mastered) {
    final deck = ref.read(selectedFlashcardDeckProvider);
    final currentIndex = ref.read(currentFlashcardIndexProvider);

    if (deck != null && currentIndex < deck.cards.length - 1) {
      ref.read(currentFlashcardIndexProvider.notifier).state = currentIndex + 1;
      ref.read(showFlashcardAnswerProvider.notifier).state = false;
    } else {
      // Completed all cards
      ref.read(currentFlashcardIndexProvider.notifier).state = 0;
      ref.read(showFlashcardAnswerProvider.notifier).state = false;
    }
  }
}

