  Color _getStatusColor(DocumentStatus status) {
    switch (status) {
      case DocumentStatus.notUploaded: return Colors.grey;
      case DocumentStatus.uploaded: return const Color(0xFFF59E0B);
      case DocumentStatus.verified: return const Color(0xFF10B981);
      case DocumentStatus.rejected: return const Color(0xFFEF4444);
    }
  }

  IconData _getStatusIcon(DocumentStatus status) {
    switch (status) {
      case DocumentStatus.notUploaded: return Icons.cloud_upload;
      case DocumentStatus.uploaded: return Icons.pending;
      case DocumentStatus.verified: return Icons.verified;
      case DocumentStatus.rejected: return Icons.error;
    }
  }

  String _getStatusText(DocumentStatus status) {
    switch (status) {
      case DocumentStatus.notUploaded: return 'Belum diupload';
      case DocumentStatus.uploaded: return 'Menunggu verifikasi';
      case DocumentStatus.verified: return 'Terverifikasi';
      case DocumentStatus.rejected: return 'Ditolak';
    }
  }

  String _getDocumentName(DocumentType type) {
    switch (type) {
      case DocumentType.ktp: return 'KTP';
      case DocumentType.kartuKeluarga: return 'Kartu Keluarga';
      case DocumentType.ijazah: return 'Ijazah';
      case DocumentType.rapor: return 'Rapor';
      case DocumentType.sertifikatPrestasi: return 'Sertifikat Prestasi';
      case DocumentType.suratRekomendasi: return 'Surat Rekomendasi';
      case DocumentType.fotoKTM: return 'Foto 3x4';
      case DocumentType.buktiPembayaran: return 'Bukti Pembayaran';
    }
  }
}

