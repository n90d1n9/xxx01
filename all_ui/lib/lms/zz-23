  IconData _getTypeIcon(RecommendationType type) {
    switch (type) {
      case RecommendationType.weakTopicFocus: return Icons.warning_amber;
      case RecommendationType.tryOutRecommendation: return Icons.quiz;
      case RecommendationType.studyMaterial: return Icons.book;
      case RecommendationType.restDay: return Icons.bedtime;
      default: return Icons.lightbulb;
    }
