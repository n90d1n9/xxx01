final selectedCourseProvider = StateProvider<CourseSchema?>((ref) => null);

final dashboardStatsProvider = Provider<DashboardStats>((ref) {
  final courses = ref.watch(coursesProvider).value ?? [];
  final enrollments = ref.watch(enrollmentsProvider);
  
  final published = courses.where((c) => c.status == CourseStatus.published).length;
  final totalStudents = courses.fold(0, (sum, c) => sum + c.enrolledCount);
  final avgProgress = enrollments.isEmpty 
      ? 0.0 
      : enrollments.fold(0.0, (sum, e) => sum + e.progress) / enrollments.length;

  final categoryMap = <String, int>{};
  for (var course in courses) {
    categoryMap[course.category] = (categoryMap[course.category] ?? 0) + 1;
  }

  final colors = [
    const Color(0xFF6366F1),
    const Color(0xFFEC4899),
    const Color(0xFF10B981),
    const Color(0xFFF59E0B),
    const Color(0xFF8B5CF6),
  ];

  final categoryStats = categoryMap.entries.map((e) {
    final index = categoryMap.keys.toList().indexOf(e.key);
    return CategoryStats(
      category: e.key,
      count: e.value,
      color: colors[index % colors.length],
    );
  }).toList();

  return DashboardStats(
    totalCourses: courses.length,
    activeCourses: published,
    completedCourses: courses.where((c) => c.status == CourseStatus.published).length,
    totalStudents: totalStudents,
    avgProgress: avgProgress,
    categoryBreakdown: categoryStats,
  );
});

