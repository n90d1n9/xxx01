class User {
  final String id;
  final String name;
  final String email;
  final String avatar;
  final UserRole role;
  final DateTime joinedDate;

  User({
    required this.id,
    required this.name,
    required this.email,
    required this.avatar,
    required this.role,
    required this.joinedDate,
  });

  User copyWith({String? name, String? email, UserRole? role}) {
    return User(
      id: id,
      name: name ?? this.name,
      email: email ?? this.email,
      avatar: avatar,
      role: role ?? this.role,
      joinedDate: joinedDate,
    );
  }
}

enum UserRole { student, instructor, admin }

class CourseSchema {
  final String id;
  final String title;
  final String description;
  final String instructorId;
  final String thumbnail;
  final String category;
  final DifficultyLevel difficulty;
  final List<String> tags;
  final List<ModuleSchema> modules;
  final DateTime createdAt;
  final DateTime? publishedAt;
  final CourseStatus status;
  final int enrolledCount;
  final double rating;

  CourseSchema({
    required this.id,
    required this.title,
    required this.description,
    required this.instructorId,
    required this.thumbnail,
    required this.category,
    required this.difficulty,
    required this.tags,
    required this.modules,
    required this.createdAt,
    this.publishedAt,
    required this.status,
    this.enrolledCount = 0,
    this.rating = 0.0,
  });

  CourseSchema copyWith({
    String? title,
    String? description,
    List<ModuleSchema>? modules,
    CourseStatus? status,
    DateTime? publishedAt,
  }) {
    return CourseSchema(
      id: id,
      title: title ?? this.title,
      description: description ?? this.description,
      instructorId: instructorId,
      thumbnail: thumbnail,
      category: category,
      difficulty: difficulty,
      tags: tags,
      modules: modules ?? this.modules,
      createdAt: createdAt,
      publishedAt: publishedAt ?? this.publishedAt,
      status: status ?? this.status,
      enrolledCount: enrolledCount,
      rating: rating,
    );
  }

  int get totalLessons => modules.fold(0, (sum, m) => sum + m.lessons.length);
  Duration get totalDuration => modules.fold(
    Duration.zero,
    (sum, m) => sum + m.lessons.fold(Duration.zero, (s, l) => s + l.duration),
  );
}

enum CourseStatus { draft, review, published, archived }
enum DifficultyLevel { beginner, intermediate, advanced }

class ModuleSchema {
  final String id;
  final String title;
  final String description;
  final int order;
  final List<LessonSchema> lessons;

  ModuleSchema({
    required this.id,
    required this.title,
    required this.description,
    required this.order,
    required this.lessons,
  });

  ModuleSchema copyWith({String? title, List<LessonSchema>? lessons}) {
    return ModuleSchema(
      id: id,
      title: title ?? this.title,
      description: description,
      order: order,
      lessons: lessons ?? this.lessons,
    );
  }
}

class LessonSchema {
  final String id;
  final String title;
  final String description;
  final LessonType type;
  final Duration duration;
  final int order;
  final String? videoUrl;
  final String? content;
  final QuizSchema? quiz;

  LessonSchema({
    required this.id,
    required this.title,
    required this.description,
    required this.type,
    required this.duration,
    required this.order,
    this.videoUrl,
    this.content,
    this.quiz,
  });
}

enum LessonType { video, text, quiz, assignment }

class QuizSchema {
  final String id;
  final List<QuestionSchema> questions;
  final int passingScore;

  QuizSchema({
    required this.id,
    required this.questions,
    required this.passingScore,
  });
}

class QuestionSchema {
  final String id;
  final String question;
  final List<String> options;
  final int correctAnswer;

  QuestionSchema({
    required this.id,
    required this.question,
    required this.options,
    required this.correctAnswer,
  });
}

class Enrollment {
  final String id;
  final String userId;
  final String courseId;
  final DateTime enrolledAt;
  final double progress;
  final Map<String, bool> completedLessons;
  final DateTime? lastAccessedAt;

  Enrollment({
    required this.id,
    required this.userId,
    required this.courseId,
    required this.enrolledAt,
    required this.progress,
    required this.completedLessons,
    this.lastAccessedAt,
  });

  Enrollment copyWith({
    double? progress,
    Map<String, bool>? completedLessons,
    DateTime? lastAccessedAt,
  }) {
    return Enrollment(
      id: id,
      userId: userId,
      courseId: courseId,
      enrolledAt: enrolledAt,
      progress: progress ?? this.progress,
      completedLessons: completedLessons ?? this.completedLessons,
      lastAccessedAt: lastAccessedAt ?? this.lastAccessedAt,
    );
  }
}

class DashboardStats {
  final int totalCourses;
  final int activeCourses;
  final int completedCourses;
  final int totalStudents;
  final double avgProgress;
  final List<CategoryStats> categoryBreakdown;

  DashboardStats({
    required this.totalCourses,
    required this.activeCourses,
    required this.completedCourses,
    required this.totalStudents,
    required this.avgProgress,
    required this.categoryBreakdown,
  });
}

class CategoryStats {
  final String category;
  final int count;
  final Color color;

  CategoryStats({
    required this.category,
    required this.count,
    required this.color,
  });
}

