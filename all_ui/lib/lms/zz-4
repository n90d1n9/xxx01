      ],
    );
  }

  Widget _buildStatsGrid(BuildContext context, DashboardStats stats) {
    return GridView.count(
      shrinkWrap: true,
      physics: const NeverScrollableScrollPhysics(),
      crossAxisCount: 4,
      mainAxisSpacing: 16,
      crossAxisSpacing: 16,
      childAspectRatio: 1.5,
      children: [
        _buildStatCard(
          context,
          'Total Courses',
          stats.totalCourses.toString(),
          Icons.school,
          const Color(0xFF6366F1),
        ),
        _buildStatCard(
          context,
          'Active Courses',
          stats.activeCourses.toString(),
