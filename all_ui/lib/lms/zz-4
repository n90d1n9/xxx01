  void _publishCourse() {
    if (_titleController.text.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Please enter a course title')),
      );
      return;
    }

    final course = CourseSchema(
      id: DateTime.now().millisecondsSinceEpoch.toString(),
      title: _titleController.text,
      description: _descriptionController.text,
      instructorId: ref.read(currentUserProvider).id,
      thumbnail: '📚',
      category: _selectedCategory,
      difficulty: _selectedDifficulty,
      tags: [],
      modules: _modules,
      createdAt: DateTime.now(),
      publishedAt: DateTime.now(),
      status: CourseStatus.published,
      enrolledCount: 0,
      rating: 0.0,
    );

    ref.read(coursesProvider.notifier).addCourse(course);

    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(content: Text('Course published successfully!')),
    );

    _titleController.clear();
    _descriptionController.clear();
    setState(() => _modules.clear());
  }
}

