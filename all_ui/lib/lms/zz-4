      progress: 0.65,
      completedLessons: {'l1': true, 'l2': true},
      lastAccessedAt: DateTime.now().subtract(const Duration(hours: 2)),
    ),
    Enrollment(
      id: 'e2',
      userId: '1',
      courseId: '2',
      enrolledAt: DateTime(2024, 3, 15),
      progress: 0.30,
      completedLessons: {'l4': true},
      lastAccessedAt: DateTime.now().subtract(const Duration(days: 1)),
    ),
  ];

  void updateProgress(String courseId, String lessonId, bool completed) {
    state = [
      for (final enrollment in state)
        if (enrollment.courseId == courseId)
          enrollment.copyWith(
            completedLessons: {
              ...enrollment.completedLessons,
              lessonId: completed,
            },
            lastAccessedAt: DateTime.now(),
          )
        else
          enrollment,
    ];
  }
}

