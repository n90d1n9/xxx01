@freezed
class SurveyResponse with _$SurveyResponse {
  const factory SurveyResponse({
    required String id,
    required DateTime timestamp,
    required Map<String, dynamic> answers,
    required double brandAwarenessScore,
    required double brandPerceptionScore,
  }) = _SurveyResponse;

  factory SurveyResponse.fromJson(Map<String, dynamic> json) =>
      _$SurveyResponseFromJson(json);
}

// lib/models/survey_question.dart
class SurveyQuestion {
  final String id;
  final String question;
  final QuestionType type;
  final List<String>? options;
  final String category;

  SurveyQuestion({
    required this.id,
    required this.question,
    required this.type,
    this.options,
    required this.category,
  });
}

enum QuestionType { multipleChoice, rating, openEnded }

// lib/providers/survey_provider.dart
import 'package:flutter_riverpod/flutter_riverpod.dart';

final surveyQuestionsProvider = Provider<List<SurveyQuestion>>((ref) {
  return [
    // Brand Awareness Questions
    SurveyQuestion(
      id: 'ba1',
      question: 'Have you heard of our brand before?',
      type: QuestionType.multipleChoice,
      options: ['Yes', 'No', 'Not sure'],
      category: 'awareness',
    ),
    SurveyQuestion(
      id: 'ba2',
      question: 'Without looking, can you recall our brand logo?',
      type: QuestionType.multipleChoice,
      options: ['Yes, clearly', 'Somewhat', 'No'],
      category: 'awareness',
    ),
    
    // Brand Perception Questions
    SurveyQuestion(
      id: 'bp1',
      question: 'How would you rate our brand\'s reputation?',
      type: QuestionType.rating,
      category: 'perception',
    ),
    SurveyQuestion(
      id: 'bp2',
      question: 'What values do you associate with our brand?',
      type: QuestionType.openEnded,
      category: 'perception',
    ),
    
    // Brand Strengths/Weaknesses
    SurveyQuestion(
      id: 'bs1',
      question: 'What aspects of our brand do you find most appealing?',
      type: QuestionType.openEnded,
      category: 'strengths',
    ),
    
    // Brand Equity
    SurveyQuestion(
      id: 'be1',
      question: 'How likely are you to recommend our brand to others?',
      type: QuestionType.rating,
      category: 'equity',
    ),
  ];
});

final surveyResponsesProvider =
    StateNotifierProvider<SurveyResponsesNotifier, List<SurveyResponse>>((ref) {
  return SurveyResponsesNotifier();
});

class SurveyResponsesNotifier extends StateNotifier<List<SurveyResponse>> {
  SurveyResponsesNotifier() : super([]);

  void addResponse(SurveyResponse response) {
    state = [...state, response];
  }
}

// lib/screens/survey_screen.dart
import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';

class SurveyScreen extends ConsumerStatefulWidget {
  const SurveyScreen({Key? key}) : super(key: key);

  @override
  _SurveyScreenState createState() => _SurveyScreenState();
}

class _SurveyScreenState extends ConsumerState<SurveyScreen> {
  final Map<String, dynamic> answers = {};
  int currentQuestionIndex = 0;

  void _submitAnswer(String questionId, dynamic answer) {
    setState(() {
      answers[questionId] = answer;
      if (currentQuestionIndex < 
          ref.read(surveyQuestionsProvider).length - 1) {
        currentQuestionIndex++;
      }
    });
  }

  Widget _buildQuestionWidget(SurveyQuestion question) {
    switch (question.type) {
      case QuestionType.multipleChoice:
        return Column(
          children: question.options!.map((option) {
            return ListTile(
              title: Text(option),
              leading: Radio<String>(
                value: option,
                groupValue: answers[question.id],
                onChanged: (value) => _submitAnswer(question.id, value),
              ),
            );
          }).toList(),
        );
      case QuestionType.rating:
        return Slider(
          value: (answers[question.id] ?? 0.0).toDouble(),
          min: 0,
          max: 10,
          divisions: 10,
          label: (answers[question.id] ?? 0).toString(),
          onChanged: (value) => _submitAnswer(question.id, value),
        );
      case QuestionType.openEnded:
        return TextField(
          onChanged: (value) => _submitAnswer(question.id, value),
          decoration: const InputDecoration(
            border: OutlineInputBorder(),
            hintText: 'Enter your answer',
          ),
        );
    }
  }

  @override
  Widget build(BuildContext context) {
    final questions = ref.watch(surveyQuestionsProvider);
    final currentQuestion = questions[currentQuestionIndex];

    return Scaffold(
      appBar: AppBar(
        title: const Text('Brand Awareness Survey'),
      ),
      body: Padding(
        padding: const EdgeInsets.all(16.0),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            LinearProgressIndicator(
              value: (currentQuestionIndex + 1) / questions.length,
            ),
            const SizedBox(height: 20),
            Text(
              'Question ${currentQuestionIndex + 1} of ${questions.length}',
              style: Theme.of(context).textTheme.bodyLarge,
            ),
            const SizedBox(height: 20),
            Text(
              currentQuestion.question,
              style: Theme.of(context).textTheme.headlineSmall,
            ),
            const SizedBox(height: 20),
            _buildQuestionWidget(currentQuestion),
          ],
        ),
      ),
      floatingActionButton: currentQuestionIndex == questions.length - 1
          ? FloatingActionButton.extended(
              onPressed: () {
                // Calculate scores and submit survey
                final response = SurveyResponse(
                  id: DateTime.now().toString(),
                  timestamp: DateTime.now(),
                  answers: answers,
                  brandAwarenessScore: _calculateAwarenessScore(),
                  brandPerceptionScore: _calculatePerceptionScore(),
                );
                ref.read(surveyResponsesProvider.notifier).addResponse(response);
                // Navigate to results or thank you screen
              },
              label: const Text('Submit Survey'),
              icon: const Icon(Icons.check),
            )
          : null,
    );
  }

  double _calculateAwarenessScore() {
    // Implement scoring logic based on awareness questions
    return 0.0;
  }

  double _calculatePerceptionScore() {
    // Implement scoring logic based on perception questions
    return 0.0;
  }
}

