// Update scoring logic in SurveyScreen
double _calculateAwarenessScore() {
  double score = 0.0;
  final questions = ref.read(surveyQuestionsProvider);
  
  // Calculate based on brand recognition
  if (answers['ba1'] == 'Yes') score += 5.0;
  else if (answers['ba1'] == 'Not sure') score += 2.5;
  
  // Calculate based on logo recall
  if (answers['ba2'] == 'Yes, clearly') score += 5.0;
  else if (answers['ba2'] == 'Somewhat') score += 2.5;
  
  return score / 2; // Normalize to 0-10 scale
}

double _calculatePerceptionScore() {
  double score = 0.0;
  int count = 0;
  
  // Add reputation rating
  if (answers['bp1'] != null) {
    score += answers['bp1'] as double;
    count++;
  }
  
  // Add value perception
  if (answers['be1'] != null) {
    score += answers['be1'] as double;
    count++;
  }
  
  return count > 0 ? score / count : 0.0;
}