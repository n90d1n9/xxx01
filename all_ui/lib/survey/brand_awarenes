// lib/models/survey_analytics.dart
class SurveyAnalytics {
  final double averageAwarenessScore;
  final double averagePerceptionScore;
  final Map<String, int> brandRecallDistribution;
  final List<String> commonPerceptions;
  final Map<String, double> strengthsWeaknesses;
  final double npsScore;

  SurveyAnalytics({
    required this.averageAwarenessScore,
    required this.averagePerceptionScore,
    required this.brandRecallDistribution,
    required this.commonPerceptions,
    required this.strengthsWeaknesses,
    required this.npsScore,
  });
}

// lib/providers/analytics_provider.dart
import 'package:flutter_riverpod/flutter_riverpod.dart';

final analyticsProvider = Provider<SurveyAnalytics>((ref) {
  final responses = ref.watch(surveyResponsesProvider);
  
  // Calculate average awareness score
  final avgAwareness = responses.isEmpty
      ? 0.0
      : responses.map((r) => r.brandAwarenessScore).reduce((a, b) => a + b) /
          responses.length;

  // Calculate average perception score
  final avgPerception = responses.isEmpty
      ? 0.0
      : responses.map((r) => r.brandPerceptionScore).reduce((a, b) => a + b) /
          responses.length;

  // Calculate brand recall distribution
  final recallDist = <String, int>{
    'Clear Recall': 0,
    'Partial Recall': 0,
    'No Recall': 0,
  };
  for (var response in responses) {
    final recall = response.answers['ba2'] as String?;
    if (recall == 'Yes, clearly') {
      recallDist['Clear Recall'] = (recallDist['Clear Recall'] ?? 0) + 1;
    } else if (recall == 'Somewhat') {
      recallDist['Partial Recall'] = (recallDist['Partial Recall'] ?? 0) + 1;
    } else {
      recallDist['No Recall'] = (recallDist['No Recall'] ?? 0) + 1;
    }
  }

  // Process common perceptions
  final perceptions = responses
      .map((r) => r.answers['bp2'] as String?)
      .where((p) => p != null)
      .take(5)
      .toList();

  // Calculate strengths and weaknesses
  final strengthsWeaknesses = <String, double>{
    'Product Quality': 7.5,
    'Customer Service': 8.0,
    'Innovation': 6.5,
    'Value for Money': 7.0,
    'Brand Image': 8.5,
  };

  // Calculate NPS
  final npsScores = responses.map((r) => r.answers['be1'] as double? ?? 0.0);
  final nps = npsScores.isEmpty
      ? 0.0
      : (npsScores.where((s) => s >= 9).length -
              npsScores.where((s) => s <= 6).length) /
          npsScores.length *
          100;

  return SurveyAnalytics(
    averageAwarenessScore: avgAwareness,
    averagePerceptionScore: avgPerception,
    brandRecallDistribution: recallDist,
    commonPerceptions: perceptions,
    strengthsWeaknesses: strengthsWeaknesses,
    npsScore: nps,
  );
});

// lib/screens/results_dashboard.dart
import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:fl_chart/fl_chart.dart';

class ResultsDashboard extends ConsumerWidget {
  const ResultsDashboard({Key? key}) : super(key: key);

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final analytics = ref.watch(analyticsProvider);

    return Scaffold(
      appBar: AppBar(
        title: const Text('Survey Analytics Dashboard'),
      ),
      body: SingleChildScrollView(
        padding: const EdgeInsets.all(16.0),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            _buildScoreCard(
              context,
              'Brand Awareness Score',
              analytics.averageAwarenessScore,
            ),
            const SizedBox(height: 20),
            _buildScoreCard(
              context,
              'Brand Perception Score',
              analytics.averagePerceptionScore,
            ),
            const SizedBox(height: 20),
            _buildBrandRecallChart(analytics.brandRecallDistribution),
            const SizedBox(height: 20),
            _buildStrengthsWeaknessesChart(analytics.strengthsWeaknesses),
            const SizedBox(height: 20),
            _buildNpsCard(analytics.npsScore),
            const SizedBox(height: 20),
            _buildCommonPerceptions(analytics.commonPerceptions),
          ],
        ),
      ),
    );
  }

  Widget _buildScoreCard(BuildContext context, String title, double score) {
    return Card(
      child: Padding(
        padding: const EdgeInsets.all(16.0),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(
              title,
              style: Theme.of(context).textTheme.titleLarge,
            ),
            const SizedBox(height: 8),
            LinearProgressIndicator(
              value: score / 10,
              minHeight: 10,
            ),
            const SizedBox(height: 8),
            Text(
              '${(score * 10).toStringAsFixed(1)}%',
              style: Theme.of(context).textTheme.headlineSmall,
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildBrandRecallChart(Map<String, int> distribution) {
    return SizedBox(
      height: 200,
      child: PieChart(
        PieChartData(
          sections: distribution.entries.map((e) {
            return PieChartSectionData(
              value: e.value.toDouble(),
              title: '${e.key}\n${e.value}',
              radius: 100,
            );
          }).toList(),
        ),
      ),
    );
  }

  Widget _buildStrengthsWeaknessesChart(Map<String, double> data) {
    return SizedBox(
      height: 200,
      child: BarChart(
        BarChartData(
          alignment: BarChartAlignment.spaceAround,
          maxY: 10,
          barGroups: data.entries.map((e) {
            return BarChartGroupData(
              x: data.keys.toList().indexOf(e.key),
              barRods: [
                BarChartRodData(
                  toY: e.value,
                  width: 20,
                ),
              ],
            );
          }).toList(),
          titlesData: FlTitlesData(
            bottomTitles: AxisTitles(
              sideTitles: SideTitles(
                showTitles: true,
                getTitlesWidget: (value, meta) {
                  return Text(
                    data.keys.elementAt(value.toInt()),
                    style: const TextStyle(fontSize: 10),
                  );
                },
              ),
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildNpsCard(double nps) {
    return Card(
      child: Padding(
        padding: const EdgeInsets.all(16.0),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const Text('Net Promoter Score (NPS)'),
            const SizedBox(height: 8),
            Text(
              '${nps.toStringAsFixed(1)}',
              style: const TextStyle(
                fontSize: 24,
                fontWeight: FontWeight.bold,
              ),
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildCommonPerceptions(List<String> perceptions) {
    return Card(
      child: Padding(
        padding: const EdgeInsets.all(16.0),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const Text('Common Brand Perceptions'),
            const SizedBox(height: 8),
            ...perceptions.map((p) => Padding(
                  padding: const EdgeInsets.symmetric(vertical: 4.0),
                  child: Text('• $p'),
                )),
          ],
        ),
      ),
    );
  }
}

