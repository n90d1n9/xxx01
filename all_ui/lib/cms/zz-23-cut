        return 'binary';
    }
  }

  static bool _isCastable(SQLType type) {
    return [SQLType.boolean, SQLType.date, SQLType.timestamp, SQLType.json, SQLType.jsonb].contains(type);
  }

  static String _getCastType(SQLType type) {
    switch (type) {
      case SQLType.boolean:
        return 'boolean';
      case SQLType.date:
      case SQLType.timestamp:
        return 'datetime';
      case SQLType.json:
      case SQLType.jsonb:
        return 'array';
      default:
        return 'string';
    }
  }

  static String _getValidationRules(FieldSchema field) {
    final rules = <String>[];
    
    if (field.validation != null) {
      if (field.validation!.minLength != null) {
        rules.add('min:${field.validation!.minLength}');
      }
      if (field.validation!.maxLength != null) {
        rules.add('max:${field.validation!.maxLength}');
      }
      if (field.validation!.pattern != null) {
        rules.add('regex:${field.validation!.pattern}');
      }
    }
    
    if (field.sqlType == SQLType.integer || field.sqlType == SQLType.bigint) {
      rules.add('integer');
    }
    
    if (field.uiType == UIFieldType.textInput && field.sqlType == SQLType.varchar) {
      rules.add('email');
    }
    
    return rules.join('|');
  }

  static String _getJsonDecoder(SQLType type, String name) {
    switch (type) {
      case SQLType.date:
      case SQLType.timestamp:
        return "DateTime.parse(json['$name'] as String)";
      case SQLType.json:
      case SQLType.jsonb:
        return "json['$name'] as Map<String, dynamic>?";
      default:
        return '';
    }
  }

  static String _getJsonEncoder(SQLType type, String name) {
    switch (type) {
      case SQLType.date:
      case SQLType.timestamp:
        return "$name?.toIso8601String()";
      default:
        return '';
    }
  }

  static String _getRelationType(RelationType type) {
    switch (type) {
      case RelationType.oneToOne:
        return 'hasOne';
      case RelationType.oneToMany:
        return 'hasMany';
      case RelationType.manyToOne:
        return 'belongsTo';
      case RelationType.manyToMany:
        return 'belongsToMany';
    }
  }
