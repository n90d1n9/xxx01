        Container(
          decoration: BoxDecoration(
            border: Border.all(color: Colors.grey.shade300),
            borderRadius: BorderRadius.circular(4),
          ),
          child: Column(
            children: choices.map((choice) {
              final isSelected = selected.contains(choice.toString());
              return CheckboxListTile(
                title: Text(choice.toString()),
                value: isSelected,
                onChanged: (checked) {
                  setState(() {
                    final newSelected = List.from(selected);
                    if (checked == true) {
                      newSelected.add(choice.toString());
                    } else {
                      newSelected.remove(choice.toString());
                    }
                    _formData[field.name] = newSelected;
                  });
                },
              );
            }).toList(),
          ),
        ),
      ],
    );
  }

