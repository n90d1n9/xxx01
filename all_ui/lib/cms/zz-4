class ContentEntriesPage extends ConsumerStatefulWidget {
  final ContentType contentType;

  const ContentEntriesPage({super.key, required this.contentType});

  @override
  ConsumerState<ContentEntriesPage> createState() => _ContentEntriesPageState();
}

class _ContentEntriesPageState extends ConsumerState<ContentEntriesPage> {
  bool _showPublishedOnly = false;

  @override
  Widget build(BuildContext context) {
    final entriesAsync = ref.watch(contentEntriesProvider(widget.contentType.id));

    return Scaffold(
      appBar: AppBar(
        title: Text(widget.contentType.pluralName),
        actions: [
          FilterChip(
            label: const Text('Published only'),
            selected: _showPublishedOnly,
            onSelected: (v) => setState(() => _showPublishedOnly = v),
          ),
          IconButton(
            icon: const Icon(Icons.refresh),
            onPressed: () => ref.read(contentEntriesProvider(widget.contentType.id).notifier).refresh(),
          ),
          const SizedBox(width: 8),
        ],
      ),
      body: entriesAsync.when(
        data: (entries) {
          final filteredEntries = _showPublishedOnly
              ? entries.where((e) => e.published).toList()
              : entries;

          if (filteredEntries.isEmpty) {
            return Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Icon(Icons.inbox, size: 64, color: Colors.grey.shade300),
                  const SizedBox(height: 16),
                  Text(
                    _showPublishedOnly ? 'No published entries' : 'No entries yet',
                    style: Theme.of(context).textTheme.titleLarge,
                  ),
                  const SizedBox(height: 8),
                  Text(
                    _showPublishedOnly
                        ? 'Publish an entry to see it here'
                        : 'Create your first ${widget.contentType.name.toLowerCase()}',
                    style: TextStyle(color: Colors.grey.shade600),
                  ),
                ],
              ),
            );
          }

          return ListView.builder(
            padding: const EdgeInsets.all(16),
            itemCount: filteredEntries.length,
            itemBuilder: (context, index) {
              final entry = filteredEntries[index];
              return _EntryListItem(
                entry: entry,
                contentType: widget.contentType,
              );
            },
          );
        },
        loading: () => const Center(child: CircularProgressIndicator()),
        error: (err, stack) => Center(child: Text('Error: $err')),
      ),
      floatingActionButton: FloatingActionButton.extended(
        onPressed: () => _showEntryForm(context),
        icon: const Icon(Icons.add),
        label: Text('New ${widget.contentType.name}'),
      ),
    );
  }

  void _showEntryForm(BuildContext context) {
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (_) => EntryFormPage(
          contentType: widget.contentType,
          onSave: (entry) {
            ref.read(contentEntriesProvider(widget.contentType.id).notifier).create(entry);
          },
        ),
      ),
    );
  }
}

class _EntryListItem extends ConsumerWidget {
  final ContentEntry entry;
  final ContentType contentType;

  const _EntryListItem({
    required this.entry,
    required this.contentType,
  });

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final firstField = contentType.fields.first;
    final title = entry.data[firstField.name]?.toString() ?? 'Untitled';

    return Card(
      margin: const EdgeInsets.only(bottom: 12),
      child: ListTile(
        leading: CircleAvatar(
          backgroundColor: entry.published
              ? Colors.green.shade100
              : Colors.orange.shade100,
          child: Icon(
            entry.published ? Icons.check_circle : Icons.edit_note,
            color: entry.published ? Colors.green : Colors.orange,
          ),
        ),
        title: Text(
          title,
          maxLines: 1,
          overflow: TextOverflow.ellipsis,
        ),
        subtitle: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text('Updated: ${DateFormat('MMM d, y HH:mm').format(entry.updatedAt)}'),
            if (entry.published && entry.publishedAt != null)
              Text('Published: ${DateFormat('MMM d, y').format(entry.publishedAt!)}'),
          ],
        ),
        isThreeLine: entry.published,
        trailing: PopupMenuButton(
          itemBuilder: (context) => [
            PopupMenuItem(
              child: Row(
                children: [
                  const Icon(Icons.edit),
                  const SizedBox(width: 8),
                  const Text('Edit'),
                ],
              ),
              onTap: () => Future.delayed(Duration.zero, () => _editEntry(context, ref)),
            ),
            PopupMenuItem(
              child: Row(
                children: [
                  Icon(entry.published ? Icons.unpublished : Icons.publish),
                  const SizedBox(width: 8),
                  Text(entry.published ? 'Unpublish' : 'Publish'),
                ],
              ),
              onTap: () => ref
                  .read(contentEntriesProvider(contentType.id).notifier)
                  .togglePublish(entry),
            ),
            PopupMenuItem(
              child: const Row(
                children: [Icon(Icons.copy), SizedBox(width: 8), Text('Duplicate')],
              ),
              onTap: () => ref
                  .read(contentEntriesProvider(contentType.id).notifier)
                  .duplicate(entry.id),
            ),
            const PopupMenuDivider(),
            PopupMenuItem(
              child: const Row(
                children: [
                  Icon(Icons.delete, color: Colors.red),
                  SizedBox(width: 8),
                  Text('Delete', style: TextStyle(color: Colors.red)),
                ],
              ),
              onTap: () => Future.delayed(Duration.zero, () => _confirmDelete(context, ref)),
            ),
          ],
        ),
        onTap: () => _editEntry(context, ref),
      ),
    );
  }

  void _editEntry(BuildContext context, WidgetRef ref) {
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (_) => EntryFormPage(
          contentType: contentType,
          entry: entry,
          onSave: (updated) {
            ref.read(contentEntriesProvider(contentType.id).notifier).update(updated);
          },
        ),
      ),
    );
  }

  void _confirmDelete(BuildContext context, WidgetRef ref) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Delete Entry'),
        content: const Text('Are you sure you want to delete this entry? This action cannot be undone.'),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Cancel'),
          ),
          FilledButton(
            onPressed: () {
              ref.read(contentEntriesProvider(contentType.id).notifier).delete(entry.id);
              Navigator.pop(context);
            },
            style: FilledButton.styleFrom(backgroundColor: Colors.red),
            child: const Text('Delete'),
          ),
        ],
      ),
    );
  }
}

