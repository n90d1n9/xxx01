  Widget _buildMultiSelectWidget(FieldDefinition field) {
    final choices = field.options?['choices'] as List? ?? [];
    final selected = _formData[field.name] as List? ?? [];
    
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Row(
          children: [
            Text(
              field.label,
              style: const TextStyle(fontWeight: FontWeight.w500),
