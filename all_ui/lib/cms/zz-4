  Widget _buildFieldWidget(FieldDefinition field) {
    switch (field.type) {
      case FieldType.text:
      case FieldType.email:
      case FieldType.url:
      case FieldType.phone:
        return _buildTextFieldWidget(field);
      
      case FieldType.textarea:
        return _buildTextAreaWidget(field);
      
      case FieldType.number:
        return _buildNumberFieldWidget(field);
      
      case FieldType.boolean:
        return _buildBooleanWidget(field);
      
      case FieldType.date:
        return _buildDateFieldWidget(field);
      
      case FieldType.datetime:
        return _buildDateTimeFieldWidget(field);
      
