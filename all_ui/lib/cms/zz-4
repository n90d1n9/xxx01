class FieldFormDialog extends StatefulWidget {
  final FieldDefinition? field;
  final Function(FieldDefinition) onSave;

  const FieldFormDialog({
    super.key,
    this.field,
    required this.onSave,
  });

  @override
  State<FieldFormDialog> createState() => _FieldFormDialogState();
}

class _FieldFormDialogState extends State<FieldFormDialog> {
  final _formKey = GlobalKey<FormState>();
  late TextEditingController _nameController;
  late TextEditingController _labelController;
  late TextEditingController _placeholderController;
  late TextEditingController _helpTextController;
  late TextEditingController _defaultValueController;
  late TextEditingController _minLengthController;
  late TextEditingController _maxLengthController;
  late TextEditingController _minController;
  late TextEditingController _maxController;
  late TextEditingController _patternController;
  late TextEditingController _optionsController;
  
  late FieldType _selectedType;
  late bool _required;
  bool _showValidation = false;

  @override
  void initState() {
    super.initState();
    _nameController = TextEditingController(text: widget.field?.name);
    _labelController = TextEditingController(text: widget.field?.label);
    _placeholderController = TextEditingController(text: widget.field?.placeholder);
    _helpTextController = TextEditingController(text: widget.field?.helpText);
    _defaultValueController = TextEditingController(text: widget.field?.defaultValue?.toString());
    _minLengthController = TextEditingController(text: widget.field?.validation?.minLength);
    _maxLengthController = TextEditingController(text: widget.field?.validation?.maxLength);
    _minController = TextEditingController(text: widget.field?.validation?.min);
    _maxController = TextEditingController(text: widget.field?.validation?.max);
    _patternController = TextEditingController(text: widget.field?.validation?.pattern);
    _optionsController = TextEditingController(
      text: widget.field?.options?['choices']?.join(', '),
    );
    
    _selectedType = widget.field?.type ?? FieldType.text;
    _required = widget.field?.required ?? false;
  }

  @override
  Widget build(BuildContext context) {
    return Dialog(
      child: Container(
        width: 600,
        constraints: const BoxConstraints(maxHeight: 700),
        child: Column(
          children: [
            Container(
              padding: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: Theme.of(context).colorScheme.surfaceContainerHighest,
                border: Border(bottom: BorderSide(color: Colors.grey.shade300)),
              ),
              child: Row(
                children: [
                  Text(
                    widget.field == null ? 'New Field' : 'Edit Field',
                    style: Theme.of(context).textTheme.titleLarge,
                  ),
                  const Spacer(),
                  IconButton(
                    icon: const Icon(Icons.close),
                    onPressed: () => Navigator.pop(context),
                  ),
                ],
              ),
            ),
            Expanded(
              child: SingleChildScrollView(
                padding: const EdgeInsets.all(24),
                child: Form(
                  key: _formKey,
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      TextFormField(
                        controller: _nameController,
                        decoration: const InputDecoration(
                          labelText: 'Field Name (API)',
                          hintText: 'e.g., title, author_name',
                          helperText: 'Used in API responses (lowercase, no spaces)',
                          border: OutlineInputBorder(),
                        ),
                        validator: (v) {
                          if (v?.isEmpty ?? true) return 'Required';
                          if (!RegExp(r'^[a-z_][a-z0-9_]*).hasMatch(v!)) {
                            return 'Only lowercase letters, numbers, and underscores';
                          }
                          return null;
                        },
                        onChanged: (v) {
                          if (_labelController.text.isEmpty) {
                            _labelController.text = v.split('_').map((w) => 
                              w.isEmpty ? '' : w[0].toUpperCase() + w.substring(1)
                            ).join(' ');
                          }
                        },
                      ),
                      const SizedBox(height: 16),
                      TextFormField(
                        controller: _labelController,
                        decoration: const InputDecoration(
                          labelText: 'Label',
                          hintText: 'e.g., Title, Author Name',
                          helperText: 'Display name shown in forms',
                          border: OutlineInputBorder(),
                        ),
                        validator: (v) => v?.isEmpty ?? true ? 'Required' : null,
                      ),
                      const SizedBox(height: 16),
                      DropdownButtonFormField<FieldType>(
                        value: _selectedType,
                        decoration: const InputDecoration(
                          labelText: 'Field Type',
                          border: OutlineInputBorder(),
                        ),
                        items: FieldType.values.map((type) {
                          return DropdownMenuItem(
                            value: type,
                            child: Row(
                              children: [
                                Icon(_getFieldIcon(type), size: 20),
                                const SizedBox(width: 8),
                                Text(type.name),
                              ],
                            ),
                          );
                        }).toList(),
                        onChanged: (v) => setState(() => _selectedType = v!),
                      ),
                      const SizedBox(height: 16),
                      SwitchListTile(
                        title: const Text('Required Field'),
                        subtitle: const Text('Users must provide a value'),
                        value: _required,
                        onChanged: (v) => setState(() => _required = v),
                        contentPadding: EdgeInsets.zero,
                      ),
                      const SizedBox(height: 16),
                      TextFormField(
                        controller: _placeholderController,
                        decoration: const InputDecoration(
                          labelText: 'Placeholder',
                          hintText: 'e.g., Enter title here...',
                          border: OutlineInputBorder(),
                        ),
                      ),
                      const SizedBox(height: 16),
                      TextFormField(
                        controller: _helpTextController,
                        decoration: const InputDecoration(
                          labelText: 'Help Text',
                          hintText: 'Additional guidance for users',
                          border: OutlineInputBorder(),
                        ),
                        maxLines: 2,
                      ),
                      const SizedBox(height: 16),
                      if (_needsOptions())
                        Column(
                          crossAxisAlignment: CrossAxisAlignment.start,
                          children: [
                            TextFormField(
                              controller: _optionsController,
                              decoration: const InputDecoration(
                                labelText: 'Options',
                                hintText: 'Option 1, Option 2, Option 3',
                                helperText: 'Comma-separated list of choices',
                                border: OutlineInputBorder(),
                              ),
                              maxLines: 3,
                            ),
                            const SizedBox(height: 16),
                          ],
                        ),
                      ExpansionTile(
                        title: const Text('Validation Rules'),
                        initiallyExpanded: _showValidation,
                        onExpansionChanged: (v) => setState(() => _showValidation = v),
                        children: [
                          const SizedBox(height: 8),
                          if (_supportsStringValidation())
                            ...[
                              Row(
                                children: [
                                  Expanded(
                                    child: TextFormField(
                                      controller: _minLengthController,
                                      decoration: const InputDecoration(
                                        labelText: 'Min Length',
                                        border: OutlineInputBorder(),
                                      ),
                                      keyboardType: TextInputType.number,
                                      inputFormatters: [FilteringTextInputFormatter.digitsOnly],
                                    ),
                                  ),
                                  const SizedBox(width: 16),
                                  Expanded(
                                    child: TextFormField(
                                      controller: _maxLengthController,
                                      decoration: const InputDecoration(
                                        labelText: 'Max Length',
                                        border: OutlineInputBorder(),
                                      ),
                                      keyboardType: TextInputType.number,
                                      inputFormatters: [FilteringTextInputFormatter.digitsOnly],
                                    ),
                                  ),
                                ],
                              ),
                              const SizedBox(height: 16),
                            ],
                          if (_selectedType == FieldType.number)
                            ...[
                              Row(
                                children: [
                                  Expanded(
                                    child: TextFormField(
                                      controller: _minController,
                                      decoration: const InputDecoration(
                                        labelText: 'Min Value',
                                        border: OutlineInputBorder(),
                                      ),
                                      keyboardType: TextInputType.number,
                                    ),
                                  ),
                                  const SizedBox(width: 16),
                                  Expanded(
                                    child: TextFormField(
                                      controller: _maxController,
                                      decoration: const InputDecoration(
                                        labelText: 'Max Value',
                                        border: OutlineInputBorder(),
                                      ),
                                      keyboardType: TextInputType.number,
                                    ),
                                  ),
                                ],
                              ),
                              const SizedBox(height: 16),
                            ],
                          if (_supportsStringValidation())
                            TextFormField(
                              controller: _patternController,
                              decoration: const InputDecoration(
                                labelText: 'Pattern (Regex)',
                                hintText: 'e.g., ^[A-Z][a-z]+,
                                border: OutlineInputBorder(),
                              ),
                            ),
                        ],
                      ),
                    ],
                  ),
                ),
              ),
            ),
            Container(
              padding: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: Theme.of(context).colorScheme.surfaceContainerHighest,
                border: Border(top: BorderSide(color: Colors.grey.shade300)),
              ),
              child: Row(
                mainAxisAlignment: MainAxisAlignment.end,
                children: [
                  TextButton(
                    onPressed: () => Navigator.pop(context),
                    child: const Text('Cancel'),
                  ),
                  const SizedBox(width: 8),
                  FilledButton(
                    onPressed: _save,
                    child: const Text('Save'),
                  ),
                ],
              ),
            ),
          ],
        ),
      ),
    );
  }

  bool _needsOptions() {
    return _selectedType == FieldType.select || _selectedType == FieldType.multiSelect;
  }

  bool _supportsStringValidation() {
    return [
      FieldType.text,
      FieldType.textarea,
      FieldType.email,
      FieldType.url,
      FieldType.phone,
    ].contains(_selectedType);
  }

  IconData _getFieldIcon(FieldType type) {
    switch (type) {
      case FieldType.text:
        return Icons.text_fields;
      case FieldType.textarea:
        return Icons.notes;
      case FieldType.richText:
        return Icons.format_align_left;
      case FieldType.number:
        return Icons.numbers;
      case FieldType.email:
        return Icons.email;
      case FieldType.url:
        return Icons.link;
      case FieldType.phone:
        return Icons.phone;
      case FieldType.date:
        return Icons.calendar_today;
      case FieldType.datetime:
        return Icons.access_time;
      case FieldType.time:
        return Icons.schedule;
      case FieldType.boolean:
        return Icons.toggle_on;
      case FieldType.image:
        return Icons.image;
      case FieldType.file:
        return Icons.attach_file;
      case FieldType.color:
        return Icons.palette;
      case FieldType.select:
        return Icons.arrow_drop_down_circle;
      case FieldType.multiSelect:
        return Icons.checklist;
      case FieldType.reference:
        return Icons.link;
      case FieldType.multiReference:
        return Icons.link;
      case FieldType.json:
        return Icons.code;
    }
  }

  void _save() {
    if (!_formKey.currentState!.validate()) return;

    ValidationRule? validation;
    if (_minLengthController.text.isNotEmpty ||
        _maxLengthController.text.isNotEmpty ||
        _minController.text.isNotEmpty ||
        _maxController.text.isNotEmpty ||
        _patternController.text.isNotEmpty) {
      validation = ValidationRule(
        minLength: _minLengthController.text.isEmpty ? null : _minLengthController.text,
        maxLength: _maxLengthController.text.isEmpty ? null : _maxLengthController.text,
        min: _minController.text.isEmpty ? null : _minController.text,
        max: _maxController.text.isEmpty ? null : _maxController.text,
        pattern: _patternController.text.isEmpty ? null : _patternController.text,
      );
    }

    Map<String, dynamic>? options;
    if (_needsOptions() && _optionsController.text.isNotEmpty) {
      options = {
        'choices': _optionsController.text.split(',').map((e) => e.trim()).where((e) => e.isNotEmpty).toList(),
      };
    }

    final field = FieldDefinition(
      id: widget.field?.id ?? 'field_${DateTime.now().millisecondsSinceEpoch}',
      name: _nameController.text,
      label: _labelController.text,
      type: _selectedType,
      required: _required,
      placeholder: _placeholderController.text.isEmpty ? null : _placeholderController.text,
      helpText: _helpTextController.text.isEmpty ? null : _helpTextController.text,
      defaultValue: _defaultValueController.text.isEmpty ? null : _defaultValueController.text,
      validation: validation,
      options: options,
      order: widget.field?.order,
    );

    widget.onSave(field);
    Navigator.pop(context);
  }

  @override
  void dispose() {
    _nameController.dispose();
    _labelController.dispose();
    _placeholderController.dispose();
    _helpTextController.dispose();
    _defaultValueController.dispose();
    _minLengthController.dispose();
    _maxLengthController.dispose();
    _minController.dispose();
    _maxController.dispose();
    _patternController.dispose();
    _optionsController.dispose();
    super.dispose();
  }
}

