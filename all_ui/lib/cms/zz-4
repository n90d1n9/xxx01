// REPOSITORY & SERVICE LAYER
// ============================================================================

class CMSRepository {
  final Map<String, ContentType> _contentTypes = {};
  final Map<String, List<ContentEntry>> _entries = {};
  int _idCounter = 1;

  String _generateId() => 'id_${_idCounter++}_${DateTime.now().millisecondsSinceEpoch}';

  // Content Types
  Future<List<ContentType>> getContentTypes() async {
    await Future.delayed(const Duration(milliseconds: 100));
    return _contentTypes.values.toList()
      ..sort((a, b) => a.name.compareTo(b.name));
  }

  Future<ContentType?> getContentType(String id) async {
    await Future.delayed(const Duration(milliseconds: 50));
    return _contentTypes[id];
  }

  Future<ContentType> createContentType(ContentType contentType) async {
    await Future.delayed(const Duration(milliseconds: 150));
    _contentTypes[contentType.id] = contentType;
    _entries[contentType.id] = [];
    return contentType;
  }

  Future<ContentType> updateContentType(ContentType contentType) async {
    await Future.delayed(const Duration(milliseconds: 150));
    _contentTypes[contentType.id] = contentType;
    return contentType;
  }

  Future<void> deleteContentType(String id) async {
    await Future.delayed(const Duration(milliseconds: 100));
    _contentTypes.remove(id);
    _entries.remove(id);
  }

  // Content Entries
  Future<List<ContentEntry>> getEntries(String contentTypeId, {bool? published}) async {
    await Future.delayed(const Duration(milliseconds: 100));
    var entries = _entries[contentTypeId] ?? [];
    if (published != null) {
      entries = entries.where((e) => e.published == published).toList();
    }
    return entries..sort((a, b) => b.createdAt.compareTo(a.createdAt));
  }

  Future<ContentEntry?> getEntry(String contentTypeId, String entryId) async {
    await Future.delayed(const Duration(milliseconds: 50));
    final entries = _entries[contentTypeId] ?? [];
    try {
      return entries.firstWhere((e) => e.id == entryId);
    } catch (_) {
      return null;
    }
  }

  Future<ContentEntry> createEntry(ContentEntry entry) async {
    await Future.delayed(const Duration(milliseconds: 150));
    _entries[entry.contentTypeId] = [
      ..._entries[entry.contentTypeId] ?? [],
      entry,
    ];
    return entry;
  }

  Future<ContentEntry> updateEntry(ContentEntry entry) async {
    await Future.delayed(const Duration(milliseconds: 150));
    final entries = List<ContentEntry>.from(_entries[entry.contentTypeId] ?? []);
    final idx = entries.indexWhere((e) => e.id == entry.id);
    if (idx != -1) {
      entries[idx] = entry;
      _entries[entry.contentTypeId] = entries;
    }
    return entry;
  }

  Future<void> deleteEntry(String contentTypeId, String entryId) async {
    await Future.delayed(const Duration(milliseconds: 100));
    _entries[contentTypeId] = (_entries[contentTypeId] ?? [])
        .where((e) => e.id != entryId)
        .toList();
  }

  Future<ContentEntry> duplicateEntry(String contentTypeId, String entryId) async {
    final original = await getEntry(contentTypeId, entryId);
    if (original == null) throw Exception('Entry not found');
    
    final duplicate = ContentEntry(
      id: _generateId(),
      contentTypeId: contentTypeId,
      data: Map.from(original.data),
      createdAt: DateTime.now(),
      updatedAt: DateTime.now(),
      createdBy: 'system',
      updatedBy: 'system',
      published: false,
    );
    
    return createEntry(duplicate);
  }

  Future<List<ContentEntry>> searchEntries(String contentTypeId, String query) async {
    await Future.delayed(const Duration(milliseconds: 100));
    final entries = _entries[contentTypeId] ?? [];
    return entries.where((entry) {
      return entry.data.values.any((value) =>
          value.toString().toLowerCase().contains(query.toLowerCase()));
    }).toList();
  }
}

// ============================================================================
// VALIDATION SERVICE
// ============================================================================

class ValidationService {
  static String? validateField(FieldDefinition field, dynamic value) {
    if (field.required && (value == null || value.toString().isEmpty)) {
      return '${field.label} is required';
    }

    if (value == null || value.toString().isEmpty) return null;

    final validation = field.validation;
    if (validation == null) return null;

    switch (field.type) {
      case FieldType.text:
      case FieldType.textarea:
      case FieldType.email:
      case FieldType.url:
      case FieldType.phone:
        final strValue = value.toString();
        if (validation.minLength != null) {
          final min = int.tryParse(validation.minLength!) ?? 0;
          if (strValue.length < min) {
            return validation.customMessage ?? 'Minimum length is $min characters';
          }
        }
        if (validation.maxLength != null) {
          final max = int.tryParse(validation.maxLength!) ?? 999999;
          if (strValue.length > max) {
            return validation.customMessage ?? 'Maximum length is $max characters';
          }
        }
        if (validation.pattern != null) {
          final regex = RegExp(validation.pattern!);
          if (!regex.hasMatch(strValue)) {
            return validation.customMessage ?? 'Invalid format';
          }
        }
        break;

      case FieldType.number:
        final numValue = double.tryParse(value.toString());
        if (numValue == null) return 'Must be a valid number';
        
        if (validation.min != null) {
          final min = double.tryParse(validation.min!) ?? 0;
          if (numValue < min) {
            return validation.customMessage ?? 'Minimum value is $min';
          }
        }
        if (validation.max != null) {
          final max = double.tryParse(validation.max!) ?? 999999;
          if (numValue > max) {
            return validation.customMessage ?? 'Maximum value is $max';
          }
        }
        break;

      case FieldType.email:
        final emailRegex = RegExp(r'^[\w-\.]+@([\w-]+\.)+[\w-]{2,4}$');
        if (!emailRegex.hasMatch(value.toString())) {
          return 'Invalid email address';
        }
        break;

      case FieldType.url:
        final urlRegex = RegExp(r'^https?:\/\/.+');
        if (!urlRegex.hasMatch(value.toString())) {
          return 'Invalid URL';
        }
        break;

      default:
        break;
    }

    return null;
  }
}

