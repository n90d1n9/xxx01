enum FieldType {
  text,
  richText,
  number,
  email,
  url,
  phone,
  date,
  datetime,
  time,
  boolean,
  image,
  file,
  color,
  reference,
  multiReference,
  select,
  multiSelect,
  textarea,
  json,
}

class ValidationRule {
  final String? minLength;
  final String? maxLength;
  final String? pattern;
  final String? min;
  final String? max;
  final String? customMessage;

  const ValidationRule({
    this.minLength,
    this.maxLength,
    this.pattern,
    this.min,
    this.max,
    this.customMessage,
  });

  Map<String, dynamic> toJson() => {
        'minLength': minLength,
        'maxLength': maxLength,
        'pattern': pattern,
        'min': min,
        'max': max,
        'customMessage': customMessage,
      };

  factory ValidationRule.fromJson(Map<String, dynamic> json) => ValidationRule(
        minLength: json['minLength'],
        maxLength: json['maxLength'],
        pattern: json['pattern'],
        min: json['min'],
        max: json['max'],
        customMessage: json['customMessage'],
      );
}

class FieldDefinition {
  final String id;
  final String name;
  final String label;
  final FieldType type;
  final bool required;
  final String? placeholder;
  final String? helpText;
  final dynamic defaultValue;
  final ValidationRule? validation;
  final Map<String, dynamic>? options;
  final String? referenceTo;
  final int? order;

  const FieldDefinition({
    required this.id,
    required this.name,
    required this.label,
    required this.type,
    this.required = false,
    this.placeholder,
    this.helpText,
    this.defaultValue,
    this.validation,
    this.options,
    this.referenceTo,
    this.order,
  });

  FieldDefinition copyWith({
    String? id,
    String? name,
    String? label,
    FieldType? type,
    bool? required,
    String? placeholder,
    String? helpText,
    dynamic defaultValue,
    ValidationRule? validation,
    Map<String, dynamic>? options,
    String? referenceTo,
    int? order,
  }) {
    return FieldDefinition(
      id: id ?? this.id,
      name: name ?? this.name,
      label: label ?? this.label,
      type: type ?? this.type,
      required: required ?? this.required,
      placeholder: placeholder ?? this.placeholder,
      helpText: helpText ?? this.helpText,
      defaultValue: defaultValue ?? this.defaultValue,
      validation: validation ?? this.validation,
      options: options ?? this.options,
      referenceTo: referenceTo ?? this.referenceTo,
      order: order ?? this.order,
    );
  }

  Map<String, dynamic> toJson() => {
        'id': id,
        'name': name,
        'label': label,
        'type': type.name,
        'required': required,
        'placeholder': placeholder,
        'helpText': helpText,
        'defaultValue': defaultValue,
        'validation': validation?.toJson(),
        'options': options,
        'referenceTo': referenceTo,
        'order': order,
      };

  factory FieldDefinition.fromJson(Map<String, dynamic> json) =>
      FieldDefinition(
        id: json['id'],
        name: json['name'],
        label: json['label'],
        type: FieldType.values.firstWhere((e) => e.name == json['type']),
        required: json['required'] ?? false,
        placeholder: json['placeholder'],
        helpText: json['helpText'],
        defaultValue: json['defaultValue'],
        validation: json['validation'] != null
            ? ValidationRule.fromJson(json['validation'])
            : null,
        options: json['options'],
        referenceTo: json['referenceTo'],
        order: json['order'],
      );
}

class ContentType {
  final String id;
  final String name;
  final String pluralName;
  final String description;
  final String icon;
  final List<FieldDefinition> fields;
  final DateTime createdAt;
  final DateTime updatedAt;
  final Map<String, dynamic>? settings;

  const ContentType({
    required this.id,
    required this.name,
    required this.pluralName,
    required this.description,
    required this.icon,
    required this.fields,
    required this.createdAt,
    required this.updatedAt,
    this.settings,
  });

  ContentType copyWith({
    String? id,
    String? name,
    String? pluralName,
    String? description,
    String? icon,
    List<FieldDefinition>? fields,
    DateTime? createdAt,
    DateTime? updatedAt,
    Map<String, dynamic>? settings,
  }) {
    return ContentType(
      id: id ?? this.id,
      name: name ?? this.name,
      pluralName: pluralName ?? this.pluralName,
      description: description ?? this.description,
      icon: icon ?? this.icon,
      fields: fields ?? this.fields,
      createdAt: createdAt ?? this.createdAt,
      updatedAt: updatedAt ?? this.updatedAt,
      settings: settings ?? this.settings,
    );
  }
}

