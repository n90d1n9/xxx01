        return _buildTimeFieldWidget(field);
      
      case FieldType.select:
        return _buildSelectWidget(field);
      
      case FieldType.multiSelect:
        return _buildMultiSelectWidget(field);
      
      case FieldType.color:
        return _buildColorFieldWidget(field);
      
      case FieldType.richText:
        return _buildRichTextWidget(field);
      
