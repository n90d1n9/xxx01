// Models
class MediaItem {
  final String id;
  final String url;
  final String title;
  final String author;
  final int likes;
  final int views;
  final MediaType type;
  final String category;
  final double aspectRatio;

  MediaItem({
    required this.id,
    required this.url,
    required this.title,
    required this.author,
    required this.likes,
    required this.views,
    required this.type,
    required this.category,
    this.aspectRatio = 1.0,
  });
}

enum MediaType { image, video }

enum FilterCategory { all, nature, urban, portrait, travel, lifestyle }

// State Management with Riverpod
class GalleryState {
  final List<MediaItem> items;
  final FilterCategory selectedFilter;
  final bool isLoading;

  GalleryState({
    required this.items,
    required this.selectedFilter,
    required this.isLoading,
  });

  GalleryState copyWith({
    List<MediaItem>? items,
    FilterCategory? selectedFilter,
    bool? isLoading,
  }) {
    return GalleryState(
      items: items ?? this.items,
      selectedFilter: selectedFilter ?? this.selectedFilter,
      isLoading: isLoading ?? this.isLoading,
    );
  }
}

class GalleryNotifier extends StateNotifier<GalleryState> {
  GalleryNotifier()
      : super(GalleryState(
          items: [],
          selectedFilter: FilterCategory.all,
          isLoading: true,
        )) {
    _loadMedia();
  }

  void _loadMedia() {
    // Simulate API call
    Future.delayed(const Duration(seconds: 2), () {
      state = state.copyWith(
        items: _generateDummyData(),
        isLoading: false,
      );
    });
  }

  void setFilter(FilterCategory filter) {
    state = state.copyWith(selectedFilter: filter);
  }

  List<MediaItem> get filteredItems {
    if (state.selectedFilter == FilterCategory.all) {
      return state.items;
    }
    return state.items
        .where((item) => item.category == state.selectedFilter.name)
        .toList();
  }

