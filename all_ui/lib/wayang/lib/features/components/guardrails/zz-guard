class PortDefinition {
  final String id;
  final String name;
  final String description;
  final String dataType;
  final bool required;
  
  PortDefinition({
    required this.id,
    required this.name,
    required this.description,
    required this.dataType,
    this.required = true,
  });
}

class ConfigFieldDefinition {
  final String key;
  final String label;
  
  ConfigFieldDefinition({required this.key, required this.label});
}

class ActionDefinition {
  final String type;
  ActionDefinition(this.type);
  Map<String, dynamic> toJson() => {'type': type};
}

