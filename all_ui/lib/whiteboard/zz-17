  void _showSettings(BuildContext context) {
    final state = ref.read(whiteboardProvider);
    final notifier = ref.read(whiteboardProvider.notifier);

    showDialog(
      context: context,
      builder:
          (context) => AlertDialog(
            title: const Text('Settings'),
            content: Column(
              mainAxisSize: MainAxisSize.min,
              children: [
                SwitchListTile(
