// ==================== CUSTOM PAINTER ====================

class WhiteboardPainter extends CustomPainter {
  final List<DrawingPath> paths;
  final Map<String, User> activeUsers;
  final double zoom;
  final Offset panOffset;
  final Set<String> selectedPathIds;
  final bool isGridVisible;
  final Map<String, WhiteboardImage> images;
  final String? selectedImageId;
  final Uint8List? backgroundImage;
  final List<LaserPoint> laserPoints;
  final bool showTouchIndicators;

  WhiteboardPainter({
    required this.paths,
    required this.activeUsers,
    required this.zoom,
    required this.panOffset,
    required this.selectedPathIds,
    required this.isGridVisible,
    this.images = const {},
    this.selectedImageId,
    this.backgroundImage,
    this.laserPoints = const [],
    this.showTouchIndicators = true,
  });

  @override
  void paint(Canvas canvas, Size size) {
    canvas.save();
    canvas.translate(panOffset.dx, panOffset.dy);
    canvas.scale(zoom);

    if (isGridVisible) {
      _drawGrid(canvas, size);
    }

    for (var image in images.values) {
      _drawImage(canvas, image);
      if (image.id == selectedImageId) {
        _drawImageSelection(canvas, image);
      }
    }

    for (var path in paths) {
      _drawPath(canvas, path);
      if (selectedPathIds.contains(path.id)) {
        _drawSelection(canvas, path);
      }
      if (path.isLocked) {
        _drawLockIndicator(canvas, path);
      }
    }

    // Draw laser pointer
    if (laserPoints.isNotEmpty) {
      _drawLaserPoints(canvas);
    }

    canvas.restore();
    _drawUserCursors(canvas);
  }

  void _drawLaserPoints(Canvas canvas) {
    if (laserPoints.length < 2) return;

    final paint =
        Paint()
          ..color = Colors.red
          ..strokeWidth = 3
          ..strokeCap = StrokeCap.round
          ..style = PaintingStyle.stroke;

    final path = Path();
    path.moveTo(laserPoints.first.point.dx, laserPoints.first.point.dy);

    for (var i = 1; i < laserPoints.length; i++) {
      final opacity =
          1.0 -
          (DateTime.now().difference(laserPoints[i].timestamp).inMilliseconds /
              1000);
      if (opacity > 0) {
        paint.color = Colors.red.withOpacity(opacity);
        path.lineTo(laserPoints[i].point.dx, laserPoints[i].point.dy);
      }
    }

    canvas.drawPath(path, paint);

    // Draw laser dot at end
    if (laserPoints.isNotEmpty) {
      final lastPoint = laserPoints.last;
      final dotPaint =
          Paint()
            ..color = Colors.red
            ..style = PaintingStyle.fill;
      canvas.drawCircle(lastPoint.point, 5, dotPaint);
    }
  }

  void _drawImage(Canvas canvas, WhiteboardImage whiteboardImage) {
    // Image drawing implementation (simplified for space)
  }

  void _drawImageSelection(Canvas canvas, WhiteboardImage image) {
    final rect = Rect.fromLTWH(
      image.position.dx,
      image.position.dy,
      image.size.width,
      image.size.height,
    );

    final paint =
        Paint()
          ..color = const Color(0xFF3B82F6).withOpacity(0.3)
          ..style = PaintingStyle.stroke
          ..strokeWidth = 2;

    canvas.drawRect(rect, paint);
  }

  void _drawGrid(Canvas canvas, Size size) {
    final paint =
        Paint()
          ..color = Colors.grey.withOpacity(0.2)
          ..strokeWidth = 1;

    const gridSize = 50.0;

    for (double x = 0; x < size.width / zoom; x += gridSize) {
      canvas.drawLine(Offset(x, 0), Offset(x, size.height / zoom), paint);
    }

    for (double y = 0; y < size.height / zoom; y += gridSize) {
      canvas.drawLine(Offset(0, y), Offset(size.width / zoom, y), paint);
    }
  }

  void _drawPath(Canvas canvas, DrawingPath path) {
    if (path.points.isEmpty) return;

    final paint = path.points.first.paint;

    if (path.tool == DrawingTool.stickyNote) {
      _drawStickyNote(canvas, path);
    } else if (path.tool == DrawingTool.text) {
      _drawText(canvas, path);
    } else if (path.tool == DrawingTool.pen ||
        path.tool == DrawingTool.eraser ||
        path.tool == DrawingTool.highlighter) {
      _drawFreehand(canvas, path, paint);
    } else if (path.tool == DrawingTool.line && path.points.length >= 2) {
      _drawLineWithStyle(
        canvas,
        path.points.first.point,
        path.points.last.point,
        paint,
        path.lineStyle,
      );
    } else if (path.tool == DrawingTool.arrow && path.points.length >= 2) {
      _drawArrow(
        canvas,
        path.points.first.point,
        path.points.last.point,
        paint,
        path.lineStyle,
      );
    } else if (path.tool == DrawingTool.rectangle && path.points.length >= 2) {
      _drawRectangle(canvas, path, paint);
    } else if (path.tool == DrawingTool.circle && path.points.length >= 2) {
      _drawCircle(canvas, path, paint);
    }
  }

  void _drawStickyNote(Canvas canvas, DrawingPath path) {
    if (path.points.length < 2) return;

    final rect = Rect.fromPoints(
      path.points.first.point,
      path.points.last.point,
    );

    final shadowPaint =
        Paint()
          ..color = Colors.black.withOpacity(0.2)
          ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 4);
    canvas.drawRect(rect.shift(const Offset(2, 2)), shadowPaint);

    final bgPaint =
        Paint()
          ..color = path.stickyNoteColor ?? const Color(0xFFFFF9C4)
          ..style = PaintingStyle.fill;
    canvas.drawRect(rect, bgPaint);

    final borderPaint =
        Paint()
          ..color = (path.stickyNoteColor ?? const Color(0xFFFFF9C4))
              .withOpacity(0.5)
          ..strokeWidth = 2
          ..style = PaintingStyle.stroke;
    canvas.drawRect(rect, borderPaint);

    if (path.text != null) {
      final textSpan = TextSpan(
        text: path.text,
        style: const TextStyle(
          color: Colors.black87,
          fontSize: 14,
          fontWeight: FontWeight.w500,
        ),
      );

      final textPainter = TextPainter(
        text: textSpan,
        textDirection: TextDirection.ltr,
        maxLines: 10,
      );

      textPainter.layout(maxWidth: rect.width - 20);
      textPainter.paint(canvas, rect.topLeft + const Offset(10, 10));
    }
  }

  void _drawFreehand(Canvas canvas, DrawingPath path, Paint paint) {
    final drawPath = Path();
    drawPath.moveTo(path.points.first.point.dx, path.points.first.point.dy);

    for (var i = 1; i < path.points.length; i++) {
      if (i < path.points.length - 1) {
        final current = path.points[i].point;
        final next = path.points[i + 1].point;
        final controlPoint = Offset(
          (current.dx + next.dx) / 2,
          (current.dy + next.dy) / 2,
        );
        drawPath.quadraticBezierTo(
          current.dx,
          current.dy,
          controlPoint.dx,
          controlPoint.dy,
        );
      } else {
        drawPath.lineTo(path.points[i].point.dx, path.points[i].point.dy);
      }
    }

    canvas.drawPath(drawPath, paint);
  }

  void _drawLineWithStyle(
    Canvas canvas,
    Offset start,
    Offset end,
    Paint paint,
    LineStyle style,
  ) {
    if (style == LineStyle.solid) {
      canvas.drawLine(start, end, paint);
    }
  }

  void _drawArrow(
    Canvas canvas,
    Offset start,
    Offset end,
    Paint paint,
    LineStyle style,
  ) {
    _drawLineWithStyle(canvas, start, end, paint, style);

    const arrowSize = 15.0;
    final angle = math.atan2(end.dy - start.dy, end.dx - start.dx);

    final arrowPath =
        Path()
          ..moveTo(end.dx, end.dy)
          ..lineTo(
            end.dx - arrowSize * math.cos(angle - math.pi / 6),
            end.dy - arrowSize * math.sin(angle - math.pi / 6),
          )
          ..moveTo(end.dx, end.dy)
          ..lineTo(
            end.dx - arrowSize * math.cos(angle + math.pi / 6),
            end.dy - arrowSize * math.sin(angle + math.pi / 6),
          );

    canvas.drawPath(arrowPath, paint);
  }

  void _drawRectangle(Canvas canvas, DrawingPath path, Paint paint) {
    final rect = Rect.fromPoints(
      path.points.first.point,
      path.points.last.point,
    );

    if (path.fillStyle != ShapeFillStyle.none && path.fillColor != null) {
      final fillPaint =
          Paint()
            ..color = path.fillColor!.withOpacity(path.opacity)
            ..style = PaintingStyle.fill;
      canvas.drawRect(rect, fillPaint);
    }

    canvas.drawRect(rect, paint);
  }

  void _drawCircle(Canvas canvas, DrawingPath path, Paint paint) {
    final center = path.points.first.point;
    final radius = (path.points.last.point - center).distance;

    if (path.fillStyle != ShapeFillStyle.none && path.fillColor != null) {
      final fillPaint =
          Paint()
            ..color = path.fillColor!.withOpacity(path.opacity)
            ..style = PaintingStyle.fill;
      canvas.drawCircle(center, radius, fillPaint);
    }

    canvas.drawCircle(center, radius, paint);
  }

  void _drawText(Canvas canvas, DrawingPath path) {
    if (path.text == null || path.points.isEmpty) return;

    final textSpan = TextSpan(
      text: path.text,
      style: TextStyle(
        color: path.points.first.paint.color,
        fontSize: 16 * (path.points.first.paint.strokeWidth / 3),
        fontWeight: FontWeight.w500,
      ),
    );

    final textPainter = TextPainter(
      text: textSpan,
      textDirection: TextDirection.ltr,
    );

    textPainter.layout();
    textPainter.paint(canvas, path.points.first.point);
  }

  void _drawSelection(Canvas canvas, DrawingPath path) {
    final rect = path.getBounds();

    final paint =
        Paint()
          ..color = const Color(0xFF3B82F6).withOpacity(0.3)
          ..style = PaintingStyle.stroke
          ..strokeWidth = 2;

    canvas.drawRect(rect, paint);
  }

  void _drawLockIndicator(Canvas canvas, DrawingPath path) {
    if (path.points.isEmpty) return;

    final position = path.points.first.point;
    final icon = Icons.lock;

    final textPainter = TextPainter(
      text: TextSpan(
        text: String.fromCharCode(icon.codePoint),
        style: TextStyle(
          fontSize: 16,
          fontFamily: icon.fontFamily,
          color: const Color(0xFFF59E0B),
        ),
      ),
      textDirection: TextDirection.ltr,
    );

    textPainter.layout();
    textPainter.paint(canvas, position - const Offset(20, 20));
  }

  void _drawUserCursors(Canvas canvas) {
    for (var user in activeUsers.values) {
      if (user.cursorPosition != null && user.isActive) {
        final transformedPos = Offset(
          user.cursorPosition!.dx * zoom + panOffset.dx,
          user.cursorPosition!.dy * zoom + panOffset.dy,
        );

        final cursorPaint =
            Paint()
              ..color = user.cursorColor
              ..style = PaintingStyle.fill;

        final cursorPath =
            Path()
              ..moveTo(transformedPos.dx, transformedPos.dy)
              ..lineTo(transformedPos.dx, transformedPos.dy + 20)
              ..lineTo(transformedPos.dx + 5, transformedPos.dy + 15)
              ..lineTo(transformedPos.dx + 10, transformedPos.dy + 18)
              ..lineTo(transformedPos.dx + 12, transformedPos.dy + 13)
              ..lineTo(transformedPos.dx + 15, transformedPos.dy + 15)
              ..lineTo(transformedPos.dx + 8, transformedPos.dy + 8)
              ..close();

        canvas.drawPath(cursorPath, cursorPaint);

        final textSpan = TextSpan(
          text: user.name,
          style: TextStyle(
            color: user.cursorColor,
            fontSize: 12,
            fontWeight: FontWeight.w600,
            backgroundColor: Colors.white.withOpacity(0.9),
          ),
        );

        final textPainter = TextPainter(
          text: textSpan,
          textDirection: TextDirection.ltr,
        );

        textPainter.layout();
        textPainter.paint(canvas, transformedPos + const Offset(15, 5));
      }
    }
  }

  @override
  bool shouldRepaint(WhiteboardPainter oldDelegate) => true;
}

// ==================== MOBILE GESTURE DETECTOR ====================

class MobileGestureDetector extends ConsumerStatefulWidget {
  final Widget child;

  const MobileGestureDetector({Key? key, required this.child})
    : super(key: key);

  @override
  ConsumerState<MobileGestureDetector> createState() =>
      _MobileGestureDetectorState();
}

class _MobileGestureDetectorState extends ConsumerState<MobileGestureDetector> {
  @override
  Widget build(BuildContext context) {
    final notifier = ref.read(whiteboardProvider.notifier);

    return GestureDetector(
      onScaleStart: notifier.handlePinchStart,
      onScaleUpdate: notifier.handlePinchUpdate,
      onScaleEnd: notifier.handlePinchEnd,
      onDoubleTap: () => notifier.handleDoubleTap(Offset.zero),
      onLongPress: () => notifier.handleLongPress(Offset.zero),
      child: widget.child,
    );
  }
}

