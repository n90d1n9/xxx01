class _ExportDialogState extends ConsumerState<ExportDialog> {
  ExportFormat _selectedFormat = ExportFormat.png;
  bool _exportSelection = false;
  bool _includeBackground = true;
  bool _isExporting = false;

  @override
  Widget build(BuildContext context) {
    return AlertDialog(
      title: const Text('Export Whiteboard'),
      content: Column(
        mainAxisSize: MainAxisSize.min,
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text('Format:', style: TextStyle(fontWeight: FontWeight.w600)),
          const SizedBox(height: 8),
          Wrap(
            spacing: 8,
            children: ExportFormat.values.map((format) {
              return ChoiceChip(
                label: Text(format.toString().split('.').last.toUpperCase()),
                selected: _selectedFormat == format,
                onSelected: (selected) {
                  if (selected) setState(() => _selectedFormat = format);
                },
              );
            }).toList(),
          ),
          const SizedBox(height: 16),
          CheckboxListTile(
            title: const Text('Export selection only'),
            value: _exportSelection,
            onChanged: (value) => setState(() => _exportSelection = value ?? false),
            contentPadding: EdgeInsets.zero,
          ),
          CheckboxListTile(
            title: const Text('Include background'),
            value: _includeBackground,
            onChanged: (value) => setState(() => _includeBackground = value ?? true),
            contentPadding: EdgeInsets.zero,
          ),
        ],
      ),
      actions: [
        TextButton(
          onPressed: () => Navigator.pop(context),
          child: const Text('Cancel'),
        ),
        ElevatedButton(
          onPressed: _isExporting ? null : _handleExport,
          style: ElevatedButton.styleFrom(
            backgroundColor: const Color(0xFF3B82F6),
          ),
          child: _isExporting
              ? const SizedBox(
                  width: 16,
                  height: 16,
                  child: CircularProgressIndicator(strokeWidth: 2, color: Colors.white),
                )
              : const Text('Export'),
        ),
      ],
    );
  }

  Future<void> _handleExport() async {
    setState(() => _isExporting = true);

    try {
      final notifier = ref.read(whiteboardProvider.notifier);

      switch (_selectedFormat) {
        case ExportFormat.png:
          final bytes = await notifier.exportToPNG();
          if (bytes != null) {
            // In a real app, save or download the file
            debugPrint('PNG exported: ${bytes.length} bytes');
            if (mounted) {
              ScaffoldMessenger.of(context).showSnackBar(
                const SnackBar(
                  content: Text('✓ Exported as PNG!'),
                  backgroundColor: Color(0xFF10B981),
                ),
              );
            }
          }
          break;
        case ExportFormat.svg:
          final svg = notifier.exportToSVG();
          debugPrint('SVG exported: ${svg.length} chars');
          if (mounted) {
            ScaffoldMessenger.of(context).showSnackBar(
              const SnackBar(
                content: Text('✓ Exported as SVG!'),
                backgroundColor: Color(0xFF10B981),
              ),
            );
          }
          break;
        case ExportFormat.json:
          final json = notifier.exportToJson();
          debugPrint('JSON exported: ${json.length} chars');
          if (mounted) {
            ScaffoldMessenger.of(context).showSnackBar(
              const SnackBar(
                content: Text('✓ Exported as JSON!'),
                backgroundColor: Color(0xFF10B981),
              ),
            );
          }
          break;
        case ExportFormat.pdf:
          // PDF export would require additional package
          if (mounted) {
            ScaffoldMessenger.of(context).showSnackBar(
              const SnackBar(
                content: Text('PDF export - coming soon!'),
                backgroundColor: Color(0xFFF59E0B),
              ),
            );
          }
          break;
      }

      if (mounted) Navigator.pop(context);
    } catch (e) {
      debugPrint('Export error: $e');
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Export failed: $e'),
            backgroundColor: const Color(0xFFEF4444),
          ),
        );
      }
    } finally {
      if (mounted) setState(() => _isExporting = false);
    }
  }
}

