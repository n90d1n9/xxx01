        border: Border.all(color: Colors.grey[300]!),
        borderRadius: BorderRadius.circular(8),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.1),
            blurRadius: 10,
            offset: const Offset(0, 2),
          ),
        ],
      ),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(8),
        child: CustomPaint(
          painter: MinimapPainter(
            paths: state.paths,
            zoom: state.zoom,
            panOffset: state.panOffset,
            viewportSize: const Size(1920, 1080),
          ),
        ),
      ),
    );
  }
}

class MinimapPainter extends CustomPainter {
  final List<DrawingPath> paths;
  final double zoom;
  final Offset panOffset;
  final Size viewportSize;

  MinimapPainter({
    required this.paths,
    required this.zoom,
    required this.panOffset,
    required this.viewportSize,
  });

  @override
  void paint(Canvas canvas, Size size) {
    final scale = math.min(size.width / 1920, size.height / 1080);
    
    canvas.save();
    canvas.scale(scale);

    // Draw simplified paths
    for (var path in paths) {
      if (path.points.isEmpty) continue;
      
      final paint = Paint()
        ..color = path.points.first.paint.color.withOpacity(0.5)
        ..strokeWidth = 1
        ..style = PaintingStyle.stroke;

      final drawPath = Path();
      drawPath.moveTo(path.points.first.point.dx, path.points.first.point.dy);
      
      for (var point in path.points.skip(1)) {
        drawPath.lineTo(point.point.dx, point.point.dy);
      }
      
      canvas.drawPath(drawPath, paint);
    }

    // Draw viewport rectangle
    final viewportRect = Rect.fromLTWH(
      -panOffset.dx / zoom,
      -panOffset.dy / zoom,
      viewportSize.width / zoom,
      viewportSize.height / zoom,
    );

    final viewportPaint = Paint()
      ..color = const Color(0xFF3B82F6).withOpacity(0.3)
      ..style = PaintingStyle.stroke
      ..strokeWidth = 2;

    canvas.drawRect(viewportRect, viewportPaint);

    canvas.restore();
  }

  @override
  bool shouldRepaint(MinimapPainter oldDelegate) => true;
}

