    ..strokeWidth = 2
    ..style = PaintingStyle.stroke;

  for (var i = 0; i <= 3; i++) {
    final x = 100.0 + i * 200.0;
    paths.add(DrawingPath(
      points: [
        DrawingPoint(point: Offset(x, 100), paint: paint, userId: 'system', timestamp: DateTime.now()),
        DrawingPoint(point: Offset(x, 700), paint: paint, userId: 'system', timestamp: DateTime.now()),
      ],
      id: 'grid_v_$i',
