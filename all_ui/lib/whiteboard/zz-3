// ==================== MODELS ====================

enum DrawingTool { pen, eraser, highlighter, line, rectangle, circle, arrow, text }

class DrawingPoint {
  final Offset point;
  final Paint paint;
  final String userId;
  final DateTime timestamp;
  final double pressure;

  DrawingPoint({
    required this.point,
    required this.paint,
    required this.userId,
    required this.timestamp,
    this.pressure = 1.0,
  });

  Map<String, dynamic> toJson() => {
    'x': point.dx,
    'y': point.dy,
    'userId': userId,
    'timestamp': timestamp.toIso8601String(),
    'pressure': pressure,
    'color': paint.color.value,
    'strokeWidth': paint.strokeWidth,
  };

  factory DrawingPoint.fromJson(Map<String, dynamic> json) {
    final paint = Paint()
      ..color = Color(json['color'])
      ..strokeWidth = json['strokeWidth']
      ..strokeCap = StrokeCap.round
      ..style = PaintingStyle.stroke;

    return DrawingPoint(
      point: Offset(json['x'], json['y']),
      paint: paint,
      userId: json['userId'],
      timestamp: DateTime.parse(json['timestamp']),
      pressure: json['pressure'] ?? 1.0,
    );
  }
}

class DrawingPath {
  final List<DrawingPoint> points;
  final String id;
  final String userId;
  final DrawingTool tool;
  final String? text;
  final bool isLocked;

  DrawingPath({
    required this.points,
    required this.id,
    required this.userId,
    required this.tool,
    this.text,
    this.isLocked = false,
  });

  Map<String, dynamic> toJson() => {
    'id': id,
    'userId': userId,
    'tool': tool.toString(),
    'text': text,
    'isLocked': isLocked,
    'points': points.map((p) => p.toJson()).toList(),
  };

  factory DrawingPath.fromJson(Map<String, dynamic> json) {
    return DrawingPath(
      id: json['id'],
      userId: json['userId'],
      tool: DrawingTool.values.firstWhere(
        (t) => t.toString() == json['tool'],
        orElse: () => DrawingTool.pen,
      ),
      text: json['text'],
      isLocked: json['isLocked'] ?? false,
      points: (json['points'] as List)
          .map((p) => DrawingPoint.fromJson(p))
          .toList(),
    );
  }

  DrawingPath copyWith({bool? isLocked}) {
    return DrawingPath(
      points: points,
      id: id,
      userId: userId,
      tool: tool,
      text: text,
      isLocked: isLocked ?? this.isLocked,
    );
  }
}

class User {
  final String id;
  final String name;
  final Color cursorColor;
  final Offset? cursorPosition;
  final bool isActive;

  User({
    required this.id,
    required this.name,
    required this.cursorColor,
    this.cursorPosition,
    this.isActive = true,
  });

  User copyWith({
    String? name,
    Color? cursorColor,
    Offset? cursorPosition,
    bool? isActive,
  }) {
    return User(
      id: id,
      name: name ?? this.name,
      cursorColor: cursorColor ?? this.cursorColor,
      cursorPosition: cursorPosition ?? this.cursorPosition,
      isActive: isActive ?? this.isActive,
    );
  }
}

class WhiteboardState {
  final List<DrawingPath> paths;
  final List<DrawingPath> redoStack;
  final DrawingTool currentTool;
  final Color currentColor;
  final double strokeWidth;
  final Map<String, User> activeUsers;
  final double zoom;
  final Offset panOffset;
  final String? selectedPathId;
  final bool isGridVisible;
  final bool isHandMode;

  WhiteboardState({
    this.paths = const [],
    this.redoStack = const [],
    this.currentTool = DrawingTool.pen,
    this.currentColor = Colors.black,
    this.strokeWidth = 3.0,
    this.activeUsers = const {},
    this.zoom = 1.0,
    this.panOffset = Offset.zero,
    this.selectedPathId,
    this.isGridVisible = false,
    this.isHandMode = false,
  });

  WhiteboardState copyWith({
    List<DrawingPath>? paths,
    List<DrawingPath>? redoStack,
    DrawingTool? currentTool,
    Color? currentColor,
    double? strokeWidth,
    Map<String, User>? activeUsers,
    double? zoom,
    Offset? panOffset,
    String? selectedPathId,
    bool? isGridVisible,
    bool? isHandMode,
    bool clearSelection = false,
  }) {
    return WhiteboardState(
      paths: paths ?? this.paths,
      redoStack: redoStack ?? this.redoStack,
      currentTool: currentTool ?? this.currentTool,
      currentColor: currentColor ?? this.currentColor,
      strokeWidth: strokeWidth ?? this.strokeWidth,
      activeUsers: activeUsers ?? this.activeUsers,
      zoom: zoom ?? this.zoom,
      panOffset: panOffset ?? this.panOffset,
      selectedPathId: clearSelection ? null : (selectedPathId ?? this.selectedPathId),
      isGridVisible: isGridVisible ?? this.isGridVisible,
      isHandMode: isHandMode ?? this.isHandMode,
    );
  }
}

// ==================== STATE NOTIFIER ====================

class WhiteboardNotifier extends StateNotifier<WhiteboardState> {
  WhiteboardNotifier() : super(WhiteboardState());

  DrawingPath? _currentPath;
  Offset? _startPoint;

  void startDrawing(Offset point, String userId, {double pressure = 1.0}) {
    if (state.isHandMode) return;

    _startPoint = point;
    
    final paint = Paint()
      ..color = state.currentTool == DrawingTool.eraser
          ? Colors.white
          : state.currentColor
      ..strokeWidth = state.currentTool == DrawingTool.highlighter
          ? state.strokeWidth * 3 * pressure
          : state.strokeWidth * pressure
      ..strokeCap = StrokeCap.round
      ..style = PaintingStyle.stroke;

    if (state.currentTool == DrawingTool.highlighter) {
      paint.color = state.currentColor.withOpacity(0.3);
    }

    _currentPath = DrawingPath(
      points: [
        DrawingPoint(
          point: point,
          paint: paint,
          userId: userId,
          timestamp: DateTime.now(),
          pressure: pressure,
        )
      ],
      id: '${userId}_${DateTime.now().millisecondsSinceEpoch}',
      userId: userId,
      tool: state.currentTool,
    );

    // Clear redo stack on new action
    state = state.copyWith(redoStack: []);
  }

  void updateDrawing(Offset point, String userId, {double pressure = 1.0}) {
    if (_currentPath == null || state.isHandMode) return;

    final paint = _currentPath!.points.first.paint;

    if (state.currentTool == DrawingTool.pen ||
        state.currentTool == DrawingTool.eraser ||
        state.currentTool == DrawingTool.highlighter) {
      _currentPath = DrawingPath(
        points: [
          ..._currentPath!.points,
          DrawingPoint(
            point: point,
            paint: paint,
            userId: userId,
            timestamp: DateTime.now(),
            pressure: pressure,
          )
        ],
        id: _currentPath!.id,
        userId: userId,
        tool: _currentPath!.tool,
      );

      state = state.copyWith(
        paths: [...state.paths.where((p) => p.id != _currentPath!.id), _currentPath!],
      );
    } else {
      // For shapes, just update the end point
      _currentPath = DrawingPath(
        points: [
          _currentPath!.points.first,
          DrawingPoint(
            point: point,
            paint: paint,
            userId: userId,
            timestamp: DateTime.now(),
            pressure: pressure,
          )
        ],
        id: _currentPath!.id,
        userId: userId,
        tool: _currentPath!.tool,
      );

      state = state.copyWith(
        paths: [...state.paths.where((p) => p.id != _currentPath!.id), _currentPath!],
      );
    }
  }

  void endDrawing() {
    if (_currentPath != null) {
      state = state.copyWith(
        paths: [...state.paths.where((p) => p.id != _currentPath!.id), _currentPath!],
      );
      _currentPath = null;
      _startPoint = null;
    }
  }

  void addTextPath(Offset position, String text, String userId) {
    final paint = Paint()
      ..color = state.currentColor
      ..strokeWidth = state.strokeWidth;

    final textPath = DrawingPath(
      points: [
        DrawingPoint(
          point: position,
          paint: paint,
          userId: userId,
          timestamp: DateTime.now(),
        )
      ],
      id: '${userId}_${DateTime.now().millisecondsSinceEpoch}',
      userId: userId,
      tool: DrawingTool.text,
      text: text,
    );

    state = state.copyWith(
      paths: [...state.paths, textPath],
      redoStack: [],
    );
  }

  void setTool(DrawingTool tool) {
    state = state.copyWith(currentTool: tool, isHandMode: false);
  }

  void setColor(Color color) {
    state = state.copyWith(currentColor: color);
  }

  void setStrokeWidth(double width) {
    state = state.copyWith(strokeWidth: width);
  }

  void toggleHandMode() {
    state = state.copyWith(isHandMode: !state.isHandMode);
  }

  void toggleGrid() {
    state = state.copyWith(isGridVisible: !state.isGridVisible);
  }

  void setZoom(double zoom) {
    state = state.copyWith(zoom: zoom.clamp(0.5, 3.0));
  }

  void setPanOffset(Offset offset) {
    state = state.copyWith(panOffset: offset);
  }

  void resetView() {
    state = state.copyWith(zoom: 1.0, panOffset: Offset.zero);
  }

  void clearBoard() {
    state = state.copyWith(paths: [], redoStack: []);
  }

  void undo() {
    if (state.paths.isNotEmpty) {
      final lastPath = state.paths.last;
      state = state.copyWith(
        paths: state.paths.sublist(0, state.paths.length - 1),
        redoStack: [...state.redoStack, lastPath],
      );
    }
  }

  void redo() {
    if (state.redoStack.isNotEmpty) {
      final redoPath = state.redoStack.last;
      state = state.copyWith(
        paths: [...state.paths, redoPath],
        redoStack: state.redoStack.sublist(0, state.redoStack.length - 1),
      );
    }
  }

  void selectPath(String? pathId) {
    state = state.copyWith(selectedPathId: pathId);
  }

  void deletePath(String pathId) {
    state = state.copyWith(
      paths: state.paths.where((p) => p.id != pathId).toList(),
      clearSelection: true,
      redoStack: [],
    );
  }

  void lockPath(String pathId) {
    final paths = state.paths.map((p) {
      if (p.id == pathId) return p.copyWith(isLocked: !p.isLocked);
      return p;
    }).toList();
    state = state.copyWith(paths: paths);
  }

  void updateUserCursor(String userId, Offset position) {
    final users = Map<String, User>.from(state.activeUsers);
    if (users.containsKey(userId)) {
      users[userId] = users[userId]!.copyWith(cursorPosition: position);
      state = state.copyWith(activeUsers: users);
    }
  }

  void addUser(User user) {
    final users = Map<String, User>.from(state.activeUsers);
    users[user.id] = user;
    state = state.copyWith(activeUsers: users);
  }

  void removeUser(String userId) {
    final users = Map<String, User>.from(state.activeUsers);
    users.remove(userId);
    state = state.copyWith(activeUsers: users);
  }

  String exportToJson() {
    final data = {
      'paths': state.paths.map((p) => p.toJson()).toList(),
      'version': '1.0',
      'timestamp': DateTime.now().toIso8601String(),
    };
    return jsonEncode(data);
  }

  void importFromJson(String jsonStr) {
    try {
      final data = jsonDecode(jsonStr);
      final paths = (data['paths'] as List)
          .map((p) => DrawingPath.fromJson(p))
          .toList();
      state = state.copyWith(paths: paths, redoStack: []);
    } catch (e) {
      debugPrint('Import error: $e');
    }
  }
}

// ==================== PROVIDERS ====================

final whiteboardProvider =
    StateNotifierProvider<WhiteboardNotifier, WhiteboardState>((ref) {
  return WhiteboardNotifier();
});

final currentUserProvider = Provider<User>((ref) {
  final colors = [
    const Color(0xFF3B82F6),
    const Color(0xFF10B981),
    const Color(0xFFF59E0B),
    const Color(0xFFEF4444),
    const Color(0xFF8B5CF6),
    const Color(0xFFEC4899),
  ];
  
  final userId = 'user_${DateTime.now().millisecondsSinceEpoch}';
  return User(
    id: userId,
    name: 'User ${userId.substring(userId.length - 4)}',
    cursorColor: colors[math.Random().nextInt(colors.length)],
  );
});

// ==================== CUSTOM PAINTER ====================

class WhiteboardPainter extends CustomPainter {
  final List<DrawingPath> paths;
  final Map<String, User> activeUsers;
  final double zoom;
  final Offset panOffset;
  final String? selectedPathId;
  final bool isGridVisible;

  WhiteboardPainter({
    required this.paths,
    required this.activeUsers,
    required this.zoom,
    required this.panOffset,
    this.selectedPathId,
    required this.isGridVisible,
  });

  @override
  void paint(Canvas canvas, Size size) {
    canvas.save();
    
    // Apply transformations
    canvas.translate(panOffset.dx, panOffset.dy);
    canvas.scale(zoom);

    // Draw grid
    if (isGridVisible) {
      _drawGrid(canvas, size);
    }

    // Draw paths
    for (var path in paths) {
      _drawPath(canvas, path);
      
      // Draw selection
      if (path.id == selectedPathId) {
        _drawSelection(canvas, path);
      }

      // Draw lock indicator
      if (path.isLocked) {
        _drawLockIndicator(canvas, path);
      }
    }

    canvas.restore();

    // Draw user cursors (not scaled)
    _drawUserCursors(canvas);
  }

  void _drawGrid(Canvas canvas, Size size) {
    final paint = Paint()
      ..color = Colors.grey.withOpacity(0.2)
      ..strokeWidth = 1;

    const gridSize = 50.0;
    
    for (double x = 0; x < size.width / zoom; x += gridSize) {
      canvas.drawLine(Offset(x, 0), Offset(x, size.height / zoom), paint);
    }
    
    for (double y = 0; y < size.height / zoom; y += gridSize) {
      canvas.drawLine(Offset(0, y), Offset(size.width / zoom, y), paint);
    }
  }

  void _drawPath(Canvas canvas, DrawingPath path) {
    if (path.points.isEmpty) return;

    final paint = path.points.first.paint;

    if (path.tool == DrawingTool.text) {
      _drawText(canvas, path);
    } else if (path.tool == DrawingTool.pen ||
        path.tool == DrawingTool.eraser ||
        path.tool == DrawingTool.highlighter) {
      final drawPath = Path();
      drawPath.moveTo(path.points.first.point.dx, path.points.first.point.dy);

      for (var i = 1; i < path.points.length; i++) {
        // Smooth curve
        if (i < path.points.length - 1) {
          final current = path.points[i].point;
          final next = path.points[i + 1].point;
          final controlPoint = Offset(
            (current.dx + next.dx) / 2,
            (current.dy + next.dy) / 2,
          );
          drawPath.quadraticBezierTo(
            current.dx,
            current.dy,
            controlPoint.dx,
            controlPoint.dy,
          );
        } else {
          drawPath.lineTo(path.points[i].point.dx, path.points[i].point.dy);
        }
      }

      canvas.drawPath(drawPath, paint);
    } else if (path.tool == DrawingTool.line && path.points.length >= 2) {
      canvas.drawLine(path.points.first.point, path.points.last.point, paint);
    } else if (path.tool == DrawingTool.arrow && path.points.length >= 2) {
      _drawArrow(canvas, path.points.first.point, path.points.last.point, paint);
    } else if (path.tool == DrawingTool.rectangle && path.points.length >= 2) {
      final rect = Rect.fromPoints(path.points.first.point, path.points.last.point);
      canvas.drawRect(rect, paint);
    } else if (path.tool == DrawingTool.circle && path.points.length >= 2) {
      final center = path.points.first.point;
      final radius = (path.points.last.point - center).distance;
      canvas.drawCircle(center, radius, paint);
    }
  }

  void _drawArrow(Canvas canvas, Offset start, Offset end, Paint paint) {
    canvas.drawLine(start, end, paint);

    // Arrow head
    const arrowSize = 15.0;
    final angle = math.atan2(end.dy - start.dy, end.dx - start.dx);
    
    final arrowPath = Path()
      ..moveTo(end.dx, end.dy)
      ..lineTo(
        end.dx - arrowSize * math.cos(angle - math.pi / 6),
        end.dy - arrowSize * math.sin(angle - math.pi / 6),
      )
      ..moveTo(end.dx, end.dy)
      ..lineTo(
        end.dx - arrowSize * math.cos(angle + math.pi / 6),
        end.dy - arrowSize * math.sin(angle + math.pi / 6),
      );

    canvas.drawPath(arrowPath, paint);
  }

  void _drawText(Canvas canvas, DrawingPath path) {
    if (path.text == null || path.points.isEmpty) return;

    final textSpan = TextSpan(
      text: path.text,
      style: TextStyle(
        color: path.points.first.paint.color,
        fontSize: 16 * (path.points.first.paint.strokeWidth / 3),
        fontWeight: FontWeight.w500,
      ),
    );

    final textPainter = TextPainter(
      text: textSpan,
      textDirection: TextDirection.ltr,
    );

    textPainter.layout();
    textPainter.paint(canvas, path.points.first.point);
  }

  void _drawSelection(Canvas canvas, DrawingPath path) {
    if (path.points.isEmpty) return;

    var minX = path.points.first.point.dx;
    var maxX = path.points.first.point.dx;
    var minY = path.points.first.point.dy;
    var maxY = path.points.first.point.dy;

    for (var point in path.points) {
      minX = math.min(minX, point.point.dx);
      maxX = math.max(maxX, point.point.dx);
      minY = math.min(minY, point.point.dy);
      maxY = math.max(maxY, point.point.dy);
    }

    final rect = Rect.fromLTRB(minX - 10, minY - 10, maxX + 10, maxY + 10);
    final paint = Paint()
      ..color = const Color(0xFF3B82F6).withOpacity(0.3)
      ..style = PaintingStyle.stroke
      ..strokeWidth = 2;

    canvas.drawRect(rect, paint);
  }

  void _drawLockIndicator(Canvas canvas, DrawingPath path) {
    if (path.points.isEmpty) return;

    final position = path.points.first.point;
    final icon = Icons.lock;
    
    final textPainter = TextPainter(
      text: TextSpan(
        text: String.fromCharCode(icon.codePoint),
        style: TextStyle(
          fontSize: 16,
          fontFamily: icon.fontFamily,
          color: const Color(0xFFF59E0B),
        ),
      ),
      textDirection: TextDirection.ltr,
    );

    textPainter.layout();
    textPainter.paint(canvas, position - const Offset(20, 20));
  }

  void _drawUserCursors(Canvas canvas) {
    for (var user in activeUsers.values) {
      if (user.cursorPosition != null && user.isActive) {
        final transformedPos = Offset(
          user.cursorPosition!.dx * zoom + panOffset.dx,
          user.cursorPosition!.dy * zoom + panOffset.dy,
        );

        // Cursor
        final cursorPaint = Paint()
          ..color = user.cursorColor
          ..style = PaintingStyle.fill;

        final cursorPath = Path()
          ..moveTo(transformedPos.dx, transformedPos.dy)
          ..lineTo(transformedPos.dx, transformedPos.dy + 20)
          ..lineTo(transformedPos.dx + 5, transformedPos.dy + 15)
          ..lineTo(transformedPos.dx + 10, transformedPos.dy + 18)
          ..lineTo(transformedPos.dx + 12, transformedPos.dy + 13)
          ..lineTo(transformedPos.dx + 15, transformedPos.dy + 15)
          ..lineTo(transformedPos.dx + 8, transformedPos.dy + 8)
          ..close();

        canvas.drawPath(cursorPath, cursorPaint);

        // User name
        final textSpan = TextSpan(
          text: user.name,
          style: TextStyle(
            color: user.cursorColor,
            fontSize: 12,
            fontWeight: FontWeight.w600,
            backgroundColor: Colors.white.withOpacity(0.9),
          ),
        );

        final textPainter = TextPainter(
          text: textSpan,
          textDirection: TextDirection.ltr,
        );

        textPainter.layout();
        textPainter.paint(canvas, transformedPos + const Offset(15, 5));
      }
    }
  }

  @override
  bool shouldRepaint(WhiteboardPainter oldDelegate) => true;
}

