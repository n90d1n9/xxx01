  Widget _buildCanvas(WhiteboardState state, WhiteboardNotifier notifier, User currentUser) {
    return Container(
      margin: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(12),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.08),
            blurRadius: 20,
            offset: const Offset(0, 4),
          ),
        ],
      ),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(12),
        child: GestureDetector(
          onPanStart: (details) {
            if (state.isHandMode) {
              _lastPanPosition = details.localPosition;
            } else if (state.currentTool == DrawingTool.text) {
              _showTextDialog(details.localPosition, notifier, currentUser.id);
            } else {
              notifier.startDrawing(
                _transformPoint(details.localPosition, state),
                currentUser.id,
                pressure: details.pressure,
              );
            }
          },
          onPanUpdate: (details) {
            if (state.isHandMode && _lastPanPosition != null) {
              final delta = details.localPosition - _lastPanPosition!;
              notifier.setPanOffset(state.panOffset + delta);
              _lastPanPosition = details.localPosition;
            } else if (state.currentTool != DrawingTool.text) {
              notifier.updateDrawing(
                _transformPoint(details.localPosition, state),
                currentUser.id,
                pressure: details.pressure,
              );
              notifier.updateUserCursor(
                currentUser.id,
                _transformPoint(details.localPosition, state),
              );
            }
          },
          onPanEnd: (details) {
            if (!state.isHandMode) {
              notifier.endDrawing();
            }
            _lastPanPosition = null;
          },
          child: Stack(
            children: [
              CustomPaint(
                painter: WhiteboardPainter(
                  paths: state.paths,
                  activeUsers: state.activeUsers,
                  zoom: state.zoom,
                  panOffset: state.panOffset,
                  selectedPathId: state.selectedPathId,
                  isGridVisible: state.isGridVisible,
                ),
                child: Container(),
              ),
              // Zoom indicator
              if (state.zoom != 1.0)
                Positioned(
                  top: 16,
                  right: 16,
                  child: Container(
                    padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                    decoration: BoxDecoration(
                      color: Colors.black.withOpacity(0.7),
                      borderRadius: BorderRadius.circular(20),
                    ),
                    child: Text(
                      '${(state.zoom * 100).toInt()}%',
                      style: const TextStyle(
                        color: Colors.white,
                        fontSize: 12,
                        fontWeight: FontWeight.w600,
                      ),
                    ),
                  ),
                ),
            ],
          ),
        ),
      ),
    );
  }

