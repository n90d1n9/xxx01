  Offset? _lastPanPosition;

  @override
  void initState() {
    super.initState();
    // Simulate adding current user
    WidgetsBinding.instance.addPostFrameCallback((_) {
      final user = ref.read(currentUserProvider);
      ref.read(whiteboardProvider.notifier).addUser(user);
    });
  }

