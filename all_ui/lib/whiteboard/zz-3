  Offset _transformPoint(Offset point, WhiteboardState state) {
    return Offset(
      (point.dx - state.panOffset.dx) / state.zoom,
      (point.dy - state.panOffset.dy) / state.zoom,
    );
  }

  void _showTextDialog(Offset position, WhiteboardNotifier notifier, String userId) {
    final controller = TextEditingController();
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Add Text'),
        content: TextField(
          controller: controller,
          autofocus: true,
          decoration: const InputDecoration(
            hintText: 'Enter text...',
            border: OutlineInputBorder(),
          ),
          maxLines: 3,
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Cancel'),
          ),
          ElevatedButton(
            onPressed: () {
              if (controller.text.isNotEmpty) {
                notifier.addTextPath(position, controller.text, userId);
              }
              Navigator.pop(context);
            },
            style: ElevatedButton.styleFrom(
              backgroundColor: const Color(0xFF3B82F6),
            ),
            child: const Text('Add'),
          ),
        ],
      ),
    );
  }

  void _showClearDialog(WhiteboardNotifier notifier) {
    Future.delayed(Duration.zero, () {
      showDialog(
        context: context,
        builder: (context) => AlertDialog(
          title: const Text('Clear Whiteboard'),
          content: const Text('Are you sure you want to clear the entire whiteboard? This action cannot be undone.'),
          actions: [
            TextButton(
              onPressed: () => Navigator.pop(context),
              child: const Text('Cancel'),
            ),
            ElevatedButton(
              onPressed: () {
                notifier.clearBoard();
                Navigator.pop(context);
              },
              style: ElevatedButton.styleFrom(
                backgroundColor: const Color(0xFFEF4444),
              ),
              child: const Text('Clear'),
            ),
          ],
        ),
      );
    });
  }

  void _exportWhiteboard(WhiteboardNotifier notifier) {
    final json = notifier.exportToJson();
    // In a real app, save to file or clipboard
    debugPrint('Exported: $json');
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(
        content: Text('Whiteboard exported! Check console for JSON.'),
        backgroundColor: Color(0xFF10B981),
      ),
    );
  }

  void _importWhiteboard(WhiteboardNotifier notifier) {
    // In a real app, load from file picker
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(
        content: Text('Import feature - connect to file picker'),
        backgroundColor: Color(0xFF3B82F6),
      ),
    );
  }
