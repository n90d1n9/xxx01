                  Expanded(
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Row(
                          children: [
                            Text(
                              user.name,
                              style: const TextStyle(
                                fontSize: 13,
                                fontWeight: FontWeight.w600,
                              ),
                            ),
                            if (isCurrentUser) ...[
                              const SizedBox(width: 4),
                              Container(
                                padding: const EdgeInsets.symmetric(horizontal: 6, vertical: 2),
                                decoration: BoxDecoration(
                                  color: const Color(0xFF10B981).withOpacity(0.1),
                                  borderRadius: BorderRadius.circular(4),
                                ),
                                child: const Text(
                                  'You',
                                  style: TextStyle(
                                    fontSize: 10,
                                    color: Color(0xFF10B981),
                                    fontWeight: FontWeight.w600,
                                  ),
                                ),
                              ),
                            ],
                          ],
                        ),
                        Text(
                          user.role.toString().split('.').last,
                          style: TextStyle(
                            fontSize: 11,
                            color: Colors.grey[600],
                          ),
                        ),
                      ],
                    ),
                  ),
                  if (!isCurrentUser)
                    IconButton(
                      icon: Icon(
                        isFollowing ? Icons.visibility : Icons.visibility_outlined,
                        size: 20,
                        color: isFollowing ? const Color(0xFF3B82F6) : Colors.grey[600],
                      ),
                      onPressed: () {
                        notifier.toggleFollowMode(user.id);
                        if (!isFollowing) {
                          notifier.followUser(user);
                        }
                      },
                      tooltip: isFollowing ? 'Stop following' : 'Follow user',
                      padding: EdgeInsets.zero,
                      constraints: const BoxConstraints(),
                    ),
                ],
              ),
            );
          }).toList(),
        ],
      ),
    );
  }
}

