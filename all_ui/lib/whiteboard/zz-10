  void _handleSelectTap(Offset localPosition, WhiteboardState state, WhiteboardNotifier notifier) {
    final transformedPoint = _transformPoint(localPosition, state);
    DrawingPath? tappedPath;
    for (var path in state.paths.reversed) {
      if (path.getBounds().contains(transformedPoint)) {
        tappedPath = path;
        break;
      }
    }
    if (tappedPath != null) {
      notifier.selectPath(tappedPath.id, addToSelection: HardwareKeyboard.instance.isShiftPressed);
    } else {
      notifier.clearSelection();
    }
  }

  Offset _transformPoint(Offset point, WhiteboardState state) {
    return Offset((point.dx - state.panOffset.dx) / state.zoom, (point.dy - state.panOffset.dy) / state.zoom);
  }

  String _formatSaveTime(DateTime time) {
    final now = DateTime.now();
    final diff = now.difference(time);
    if (diff.inSeconds < 60) return 'just now';
    if (diff.inMinutes < 60) return '${diff.inMinutes}m ago';
    if (diff.inHours < 24) return '${diff.inHours}h ago';
    return '${diff.inDays}d ago';
  }

