class KeyboardShortcuts extends ConsumerWidget {
  final Widget child;

  const KeyboardShortcuts({Key? key, required this.child}) : super(key: key);

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    return Focus(
      autofocus: true,
      onKey: (node, event) {
        if (event is RawKeyDownEvent) {
          final notifier = ref.read(whiteboardProvider.notifier);
          final currentUser = ref.read(currentUserProvider);
          
          final isCtrl = event.isControlPressed || event.isMetaPressed;
          
          if (isCtrl) {
            if (event.logicalKey == LogicalKeyboardKey.keyZ) {
              if (event.isShiftPressed) {
                notifier.redo();
              } else {
                notifier.undo();
              }
              return KeyEventResult.handled;
            } else if (event.logicalKey == LogicalKeyboardKey.keyY) {
              notifier.redo();
              return KeyEventResult.handled;
            } else if (event.logicalKey == LogicalKeyboardKey.keyC) {
              notifier.copySelected();
              return KeyEventResult.handled;
            } else if (event.logicalKey == LogicalKeyboardKey.keyV) {
              notifier.paste(currentUser.id);
              return KeyEventResult.handled;
            } else if (event.logicalKey == LogicalKeyboardKey.keyX) {
              notifier.copySelected();
              notifier.deleteSelected();
              return KeyEventResult.handled;
            } else if (event.logicalKey == LogicalKeyboardKey.keyA) {
              notifier.selectAll();
              return KeyEventResult.handled;
            } else if (event.logicalKey == LogicalKeyboardKey.keyD) {
              notifier.duplicateSelected();
              return KeyEventResult.handled;
            } else if (event.logicalKey == LogicalKeyboardKey.keyL) {
              notifier.lockSelected();
              return KeyEventResult.handled;
            }
          }
          
          if (event.logicalKey == LogicalKeyboardKey.delete || 
              event.logicalKey == LogicalKeyboardKey.backspace) {
            notifier.deleteSelected();
            return KeyEventResult.handled;
          } else if (event.logicalKey == LogicalKeyboardKey.escape) {
            notifier.clearSelection();
            return KeyEventResult.handled;
          } else if (event.logicalKey == LogicalKeyboardKey.keyG) {
            notifier.toggleGrid();
            return KeyEventResult.handled;
          } else if (event.logicalKey == LogicalKeyboardKey.keyH) {
            notifier.toggleHandMode();
            return KeyEventResult.handled;
          } else if (event.logicalKey == LogicalKeyboardKey.keyP) {
            notifier.setTool(DrawingTool.pen);
            return KeyEventResult.handled;
          } else if (event.logicalKey == LogicalKeyboardKey.keyE) {
            notifier.setTool(DrawingTool.eraser);
            return KeyEventResult.handled;
          } else if (event.logicalKey == LogicalKeyboardKey.keyT) {
            notifier.setTool(DrawingTool.text);
            return KeyEventResult.handled;
          } else if (event.logicalKey == LogicalKeyboardKey.keyS) {
            notifier.setTool(DrawingTool.select);
            return KeyEventResult.handled;
          } else if (event.logicalKey == LogicalKeyboardKey.bracketLeft) {
            notifier.bringToFront();
            return KeyEventResult.handled;
          } else if (event.logicalKey == LogicalKeyboardKey.bracketRight) {
            notifier.sendToBack();
            return KeyEventResult.handled;
          }
        }
        
        return KeyEventResult.ignored;
      },
      child: child,
    );
  }
}

