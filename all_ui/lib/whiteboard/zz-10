class ContextMenuArea extends StatelessWidget {
  final Widget child;
  final Offset? tapPosition;
  final VoidCallback onDelete;
  final VoidCallback onDuplicate;
  final VoidCallback onLock;
  final VoidCallback onBringToFront;
  final VoidCallback onSendToBack;
  final VoidCallback onCopy;
  final bool hasSelection;

  const ContextMenuArea({
    Key? key,
    required this.child,
    this.tapPosition,
    required this.onDelete,
    required this.onDuplicate,
    required this.onLock,
    required this.onBringToFront,
    required this.onSendToBack,
    required this.onCopy,
    required this.hasSelection,
  }) : super(key: key);

  @override
  Widget build(BuildContext context) {
    return GestureDetector(
      onSecondaryTapDown: (details) {
        if (!hasSelection) return;
        _showContextMenu(context, details.globalPosition);
      },
      child: child,
    );
  }

  void _showContextMenu(BuildContext context, Offset position) {
    showMenu(
      context: context,
      position: RelativeRect.fromLTRB(position.dx, position.dy, position.dx, position.dy),
      items: [
        PopupMenuItem(
          child: Row(
            children: [
              Icon(Icons.content_copy, size: 18, color: Colors.grey[700]),
              const SizedBox(width: 12),
              const Text('Copy'),
              const Spacer(),
              Text('Ctrl+C', style: TextStyle(fontSize: 12, color: Colors.grey[600])),
            ],
          ),
          onTap: onCopy,
        ),
        PopupMenuItem(
          child: Row(
            children: [
              Icon(Icons.content_paste, size: 18, color: Colors.grey[700]),
              const SizedBox(width: 12),
              const Text('Duplicate'),
              const Spacer(),
              Text('Ctrl+D', style: TextStyle(fontSize: 12, color: Colors.grey[600])),
            ],
          ),
          onTap: onDuplicate,
        ),
        const PopupMenuDivider(),
        PopupMenuItem(
          child: Row(
            children: [
              Icon(Icons.flip_to_front, size: 18, color: Colors.grey[700]),
              const SizedBox(width: 12),
              const Text('Bring to Front'),
            ],
          ),
          onTap: onBringToFront,
        ),
        PopupMenuItem(
          child: Row(
            children: [
              Icon(Icons.flip_to_back, size: 18, color: Colors.grey[700]),
              const SizedBox(width: 12),
              const Text('Send to Back'),
            ],
          ),
          onTap: onSendToBack,
        ),
        const PopupMenuDivider(),
        PopupMenuItem(
          child: Row(
            children: [
              Icon(Icons.lock, size: 18, color: Colors.grey[700]),
              const SizedBox(width: 12),
              const Text('Lock/Unlock'),
            ],
          ),
          onTap: onLock,
        ),
        const PopupMenuDivider(),
        PopupMenuItem(
          child: const Row(
            children: [
              Icon(Icons.delete, size: 18, color: Colors.red),
              SizedBox(width: 12),
              Text('Delete', style: TextStyle(color: Colors.red)),
            ],
          ),
          onTap: onDelete,
        ),
      ],
    );
  }
}

