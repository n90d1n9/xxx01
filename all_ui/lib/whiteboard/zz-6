class _LineStylePainter extends CustomPainter {
  final LineStyle lineStyle;

  _LineStylePainter({required this.lineStyle});

  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()
      ..color = const Color(0xFF6B7280)
      ..strokeWidth = 2
      ..strokeCap = StrokeCap.round;

    if (lineStyle == LineStyle.solid) {
      canvas.drawLine(Offset(0, size.height / 2), Offset(size.width, size.height / 2), paint);
    } else if (lineStyle == LineStyle.dashed) {
      var startX = 0.0;
      while (startX < size.width) {
        canvas.drawLine(
          Offset(startX, size.height / 2),
          Offset(math.min(startX + 8, size.width), size.height / 2),
          paint,
        );
        startX += 12;
      }
    } else if (lineStyle == LineStyle.dotted) {
      var startX = 0.0;
      while (startX < size.width) {
        canvas.drawCircle(Offset(startX, size.height / 2), 1.5, paint);
        startX += 6;
      }
    }
  }

  @override
  bool shouldRepaint(_LineStylePainter oldDelegate) => false;
}

