  Widget _buildCanvas(WhiteboardState state, WhiteboardNotifier notifier, User currentUser) {
    return Container(
      margin: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(12),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.08),
            blurRadius: 20,
            offset: const Offset(0, 4),
          ),
        ],
      ),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(12),
        child: ContextMenuArea(
          hasSelection: state.selectedPathIds.isNotEmpty,
          tapPosition: _contextMenuPosition,
          onDelete: notifier.deleteSelected,
          onDuplicate: notifier.duplicateSelected,
          onLock: notifier.lockSelected,
          onBringToFront: notifier.bringToFront,
          onSendToBack: notifier.sendToBack,
          onCopy: notifier.copySelected,
          child: GestureDetector(
            onPanStart: (details) {
              if (state.isHandMode) {
                _lastPanPosition = details.localPosition;
              } else if (state.currentTool == DrawingTool.text) {
                _showTextDialog(
                  _transformPoint(details.localPosition, state),
                  notifier,
                  currentUser.id,
                );
              } else if (state.currentTool == DrawingTool.select) {
                _handleSelectTap(details.localPosition, state, notifier);
              } else {
                notifier.startDrawing(
                  _transformPoint(details.localPosition, state),
                  currentUser.id,
                  pressure: details.pressure,
                );
              }
            },
            onPanUpdate: (details) {
              if (state.isHandMode && _lastPanPosition != null) {
                final delta = details.localPosition - _lastPanPosition!;
                notifier.setPanOffset(state.panOffset + delta);
                _lastPanPosition = details.localPosition;
              } else if (state.currentTool != DrawingTool.text && state.currentTool != DrawingTool.select) {
                notifier.updateDrawing(
                  _transformPoint(details.localPosition, state),
                  currentUser.id,
                  pressure: details.pressure,
                );
                notifier.updateUserCursor(
                  currentUser.id,
                  _transformPoint(details.localPosition, state),
                );
              }
            },
            onPanEnd: (details) {
              if (!state.isHandMode && state.currentTool != DrawingTool.select) {
                notifier.endDrawing();
              }
              _lastPanPosition = null;
            },
            child: Stack(
              children: [
                CustomPaint(
                  painter: WhiteboardPainter(
                    paths: state.paths,
                    activeUsers: state.activeUsers,
                    zoom: state.zoom,
                    panOffset: state.panOffset,
                    selectedPathIds: state.selectedPathIds,
                    isGridVisible: state.isGridVisible,
                  ),
                  child: Container(),
                ),
                if (state.zoom != 1.0)
                  Positioned(
                    top: 16,
                    right: 16,
                    child: Container(
                      padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                      decoration: BoxDecoration(
