import 'package:fl_chart/fl_chart.dart';

class AdvancedCharts {
  Widget createViolinPlot(List<List<double>> data) {
    return CustomPaint(
      painter: ViolinPlotPainter(
        data: data,
        style: ViolinPlotStyle(
          fillColor: Colors.blue.withOpacity(0.3),
          strokeColor: Colors.blue,
          showMedian: true,
          showQuartiles: true
        )
      )
    );
  }
  
  Widget createBubblePlot(List<Point3D> data) {
    return ScatterChart(
      ScatterChartData(
        spots: data.map((point) => ScatterSpot(
          point.x,
          point.y,
          size: point.z * 10, // Bubble size based on z value
          color: Colors.blue.withOpacity(0.6)
        )).toList(),
        borderData: FlBorderData(show: true),
        gridData: FlGridData(show: true),
      )
    );
  }
}


class AdvancedCharts {
