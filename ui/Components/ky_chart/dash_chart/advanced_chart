  Widget createSunburstChart(Map<String, dynamic> hierarchicalData) {
    return CustomPaint(
      painter: SunburstChartPainter(
        data: hierarchicalData,
        style: SunburstStyle(
          colorScheme: ColorScheme.sequential,
          innerRadius: 50,
          outerRadius: 200,
          animationDuration: Duration(milliseconds: 800),
          labelStyle: TextStyle(fontSize: 12),
          showValues: true,
        )
      )
    );
  }

  Widget createNetworkGraph(
    List<Node> nodes,
    List<Edge> edges, {
    required ForceDirectedLayout layout,
  }) {
    return CustomPaint(
      painter: NetworkGraphPainter(
        nodes: nodes,
        edges: edges,
        layout: layout,
        style: NetworkGraphStyle(
          nodeRadius: 8,
          edgeThickness: 1.5,
          nodeLabelStyle: TextStyle(fontSize: 10),
          interactive: true,
          zoomable: true,
          draggable: true,
        )
      )
    );
  }
}
