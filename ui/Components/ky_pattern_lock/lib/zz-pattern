## 4. Usage Examples

### Pattern Setup Screen

```dart
// lib/screens/pattern_setup_screen.dart
import 'package:flutter/material.dart';
import 'package:hooks_riverpod/hooks_riverpod.dart';
import '../widgets/pattern_lock.dart';
import '../providers/pattern_lock_provider.dart';

class PatternSetupScreen extends ConsumerStatefulWidget {
  @override
  _PatternSetupScreenState createState() => _PatternSetupScreenState();
}

class _PatternSetupScreenState extends ConsumerState<PatternSetupScreen> {
  String? firstPattern;
  bool step2 = false;

  @override
  Widget build(BuildContext context) {
    final patternState = ref.watch(patternLockProvider);

    return Scaffold(
      appBar: AppBar(
        title: Text(step2 ? 'Confirm Pattern' : 'Set Pattern'),
      ),
      body: Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Text(
              step2 
                  ? 'Draw your pattern again to confirm'
                  : 'Draw your unlock pattern',
              style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold),
            ),
            SizedBox(height: 40),
            PatternLock(
              size: 300,
              onPatternCompleted: (pattern) {
                if (!step2) {
                  // First pattern entry
                  if (patternState.selectedPoints.length >= 4) {
                    setState(() {
                      firstPattern = pattern;
                      step2 = true;
                    });
                    ref.read(patternLockProvider.notifier).reset();
                  }
                } else {
                  // Confirm pattern
                  if (firstPattern == pattern) {
                    // Save pattern
                    print('Pattern saved: $pattern');
                    ScaffoldMessenger.of(context).showSnackBar(
                      SnackBar(content: Text('Pattern saved successfully!')),
                    );
                    Navigator.pop(context, pattern);
                  } else {
                    ref.read(patternLockProvider.notifier).setError('Patterns do not match');
                    Future.delayed(Duration(milliseconds: 500), () {
                      setState(() {
                        step2 = false;
                        firstPattern = null;
                      });
                      ref.read(patternLockProvider.notifier).reset();
                    });
                  }
                }
              },
            ),
            if (patternState.errorMessage != null)
              Padding(
                padding: const EdgeInsets.all(20),
                child: Text(
                  patternState.errorMessage!,
                  style: TextStyle(color: Colors.red, fontSize: 16),
                ),
              ),
          ],
        ),
      ),
    );
  }
}
```

### Pattern Login Screen

```dart
// lib/screens/pattern_login_screen.dart
import 'package:flutter/material.dart';
import 'package:hooks_riverpod/hooks_riverpod.dart';
import '../widgets/pattern_lock.dart';
import '../providers/pattern_lock_provider.dart';

class PatternLoginScreen extends ConsumerWidget {
  // This should come from secure storage in real app
  final List<int> savedPattern = [0, 1, 2, 5, 8]; // Example pattern

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final patternState = ref.watch(patternLockProvider);

    return Scaffold(
      appBar: AppBar(
        title: Text('Unlock App'),
      ),
      body: Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(
              Icons.lock_outline,
              size: 80,
              color: Colors.blue,
            ),
            SizedBox(height: 20),
            Text(
              'Draw your pattern',
              style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold),
