              isSettingPattern: false,
              savedPattern: savedPattern,
              onPatternCompleted: (result) {
                if (result == 'success') {
                  // Navigate to home screen
                  ScaffoldMessenger.of(context).showSnackBar(
                    SnackBar(content: Text('Unlocked successfully!')),
                  );
                }
              },
            ),
            if (patternState.errorMessage != null)
              Padding(
                padding: const EdgeInsets.all(20),
                child: Text(
                  patternState.errorMessage!,
                  style: TextStyle(color: Colors.red, fontSize: 16),
                ),
              ),
            TextButton(
              onPressed: () {
                ref.read(patternLockProvider.notifier).reset();
              },
              child: Text('Reset'),
            ),
          ],
        ),
      ),
    );
  }
}
