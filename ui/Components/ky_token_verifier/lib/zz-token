## 4. Create Authentication Screen

```dart
// lib/screens/authentication_screen.dart
import 'package:flutter/material.dart';
import 'package:hooks_riverpod/hooks_riverpod.dart';
import '../widgets/pattern_token_auth.dart';
import '../providers/pattern_lock_provider.dart';
import '../providers/token_provider.dart';

class AuthenticationScreen extends ConsumerStatefulWidget {
  final AuthMode mode;
  final List<int>? savedPattern;

  const AuthenticationScreen({
    Key? key,
    this.mode = AuthMode.both,
    this.savedPattern,
  }) : super(key: key);

  @override
  _AuthenticationScreenState createState() => _AuthenticationScreenState();
}

class _AuthenticationScreenState extends ConsumerState<AuthenticationScreen> {
  bool isAuthenticated = false;

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text(_getTitle()),
        elevation: 0,
      ),
      body: isAuthenticated
          ? _buildAuthenticatedContent()
          : _buildAuthContent(),
    );
  }

  String _getTitle() {
    if (isAuthenticated) return 'Welcome!';
    
    switch (widget.mode) {
      case AuthMode.pattern:
        return 'Pattern Authentication';
      case AuthMode.token:
        return 'Token Verification';
      case AuthMode.both:
        return 'Secure Access';
    }
  }

  Widget _buildAuthContent() {
    return Center(
      child: SingleChildScrollView(
        padding: const EdgeInsets.all(20),
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            // App logo/icon
            Container(
              width: 100,
              height: 100,
              decoration: BoxDecoration(
                color: Colors.blue.withOpacity(0.1),
                shape: BoxShape.circle,
              ),
              child: const Icon(
                Icons.security,
                size: 50,
                color: Colors.blue,
              ),
            ),
            const SizedBox(height: 20),
            
            // Description
            Text(
              _getDescription(),
              textAlign: TextAlign.center,
              style: const TextStyle(
                fontSize: 16,
                color: Colors.grey,
              ),
            ),
            const SizedBox(height: 40),

            // Authentication widget
            PatternTokenAuth(
              mode: widget.mode,
              savedPattern: widget.savedPattern,
              onAuthenticationSuccess: () {
                setState(() {
                  isAuthenticated = true;
                });
              },
              onPatternSaved: (pattern) {
                // Save pattern to secure storage
                print('New pattern saved: $pattern');
                ScaffoldMessenger.of(context).showSnackBar(
                  const SnackBar(
                    content: Text('Pattern saved successfully!'),
                    backgroundColor: Colors.green,
                  ),
                );
              },
            ),
          ],
        ),
      ),
    );
  }

  String _getDescription() {
    switch (widget.mode) {
      case AuthMode.pattern:
        return 'Draw your pattern to access the app';
      case AuthMode.token:
        return 'Enter your verification token';
      case AuthMode.both:
        return 'Two-factor authentication required\nComplete both steps to continue';
    }
  }

  Widget _buildAuthenticatedContent() {
    return Center(
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          const Icon(
            Icons.check_circle,
            size: 100,
            color: Colors.green,
          ),
          const SizedBox(height: 20),
          const Text(
            'Authentication Successful!',
            style: TextStyle(
              fontSize: 24,
              fontWeight: FontWeight.bold,
            ),
          ),
          const SizedBox(height: 10),
          Text(
            'You have successfully authenticated',
            style: TextStyle(
              fontSize: 16,
              color: Colors.grey[600],
            ),
          ),
          const SizedBox(height: 40),
          ElevatedButton.icon(
            onPressed: () {
              // Navigate to main app content
              Navigator.pushReplacementNamed(context, '/home');
            },
            icon: const Icon(Icons.home),
            label: const Text('Go to Home'),
            style: ElevatedButton.styleFrom(
              minimumSize: const Size(200, 50),
            ),
          ),
          const SizedBox(height: 10),
          TextButton.icon(
            onPressed: () {
              ref.read(patternLockProvider.notifier).reset();
              ref.read(tokenProvider.notifier).clearToken();
              setState(() {
                isAuthenticated = false;
              });
            },
            icon: const Icon(Icons.lock_open),
            label: const Text('Logout'),
          ),
        ],
      ),
    );
  }
}
