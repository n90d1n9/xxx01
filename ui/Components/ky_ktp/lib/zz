```dart
// lib/services/ktp_document_detector.dart
import 'dart:io';
import 'dart:math';
import 'package:google_ml_kit/google_ml_kit.dart';
import 'package:image/image.dart' as img;

class KTPDocumentDetector {
  // KTP aspect ratio is approximately 1.586 (85.6mm x 53.98mm)
  static const double KTP_ASPECT_RATIO = 85.6 / 54.0;
  static const double ASPECT_TOLERANCE = 0.2;
  
  // Minimum area coverage for valid KTP
  static const double MIN_COVERAGE = 0.4;
  static const double MAX_COVERAGE = 0.9;

  Future<DocumentDetectionResult> detectKTP(File imageFile) async {
    try {
      final image = img.decodeImage(await imageFile.readAsBytes());
      if (image == null) {
        return DocumentDetectionResult(
          isValid: false,
          message: 'Failed to decode image',
        );
      }

      // Detect document boundaries
      final documentRect = await _findDocumentBoundaries(imageFile);
      
      if (documentRect == null) {
        return DocumentDetectionResult(
          isValid: false,
          message: 'Could not detect KTP boundaries',
          documentRect: documentRect,
        );
      }

      // Check aspect ratio
      final aspectRatio = documentRect.width / documentRect.height;
      final aspectRatioValid = (aspectRatio - KTP_ASPECT_RATIO).abs() <= ASPECT_TOLERANCE;

      // Check coverage
      final coverage = (documentRect.width * documentRect.height) / (image.width * image.height);
      final coverageValid = coverage >= MIN_COVERAGE && coverage <= MAX_COVERAGE;

      // Check image quality
      final qualityResult = await _checkImageQuality(image);

      // Overall validity
      final isValid = aspectRatioValid && 
                      coverageValid && 
                      qualityResult.isValid;

      return DocumentDetectionResult(
        isValid: isValid,
        message: _generateMessage(isValid, aspectRatioValid, coverageValid, qualityResult),
        documentRect: documentRect,
        confidence: _calculateConfidence(aspectRatioValid, coverageValid, qualityResult),
        qualityIssues: qualityResult.issues,
      );
    } catch (e) {
      return DocumentDetectionResult(
        isValid: false,
        message: 'Detection error: $e',
      );
    }
  }

  Future<Rect?> _findDocumentBoundaries(File imageFile) async {
    // Use edge detection or document scanner algorithms
    // This is a simplified version - in production, use ML Kit document scanner
    
    try {
      final inputImage = InputImage.fromFile(imageFile);
      
      // Use image labeling to find document
      final labeler = GoogleMlKit.vision.imageLabeler();
      final labels = await labeler.processImage(inputImage);
      
      // Look for document-related labels
      for (final label in labels) {
        if (label.label.toLowerCase().contains('document') || 
            label.label.toLowerCase().contains('id') ||
            label.label.toLowerCase().contains('card')) {
          // Found document - return estimated rectangle
          return Rect.fromLTWH(
            imageFile.lengthSync() * 0.1, // Simplified
            imageFile.lengthSync() * 0.1,
            imageFile.lengthSync() * 0.8,
            imageFile.lengthSync() * 0.8,
          );
        }
      }
      
      labeler.close();
    } catch (e) {
      print('Document detection error: $e');
    }
    
    return null;
  }

  Future<ImageQualityResult> _checkImageQuality(img.Image image) async {
    final issues = <String>[];
    
    // Check brightness
    final brightness = _calculateBrightness(image);
    if (brightness < 80) {
      issues.add('Image too dark');
    } else if (brightness > 200) {
      issues.add('Image too bright');
    }
    
    // Check contrast
    final contrast = _calculateContrast(image);
    if (contrast < 30) {
      issues.add('Low contrast');
    }
    
    // Check sharpness
    final sharpness = _calculateSharpness(image);
    if (sharpness < 10) {
      issues.add('Image blurry');
    }
    
    // Check for glare
    final hasGlare = _detectGlare(image);
    if (hasGlare) {
      issues.add('Glare detected');
    }
    
    return ImageQualityResult(
      isValid: issues.isEmpty,
      issues: issues,
      brightness: brightness,
      contrast: contrast,
      sharpness: sharpness,
    );
  }

  double _calculateBrightness(img.Image image) {
    int total = 0;
    for (int y = 0; y < image.height; y += 10) {
      for (int x = 0; x < image.width; x += 10) {
        final pixel = image.getPixel(x, y);
        total += (img.getRed(pixel) + img.getGreen(pixel) + img.getBlue(pixel)) ~/ 3;
      }
    }
    return total / ((image.width / 10) * (image.height / 10));
  }

