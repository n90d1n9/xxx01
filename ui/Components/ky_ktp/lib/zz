class KTPGuidePainter extends CustomPainter {
  final DocumentDetectionResult? detectionResult;
  final bool isValid;

  KTPGuidePainter({
    required this.detectionResult,
    required this.isValid,
  });

  @override
  void paint(Canvas canvas, Size size) {
    final center = Offset(size.width / 2, size.height / 2);
    
    // Calculate KTP rectangle based on aspect ratio
    final ktpWidth = size.width * 0.8;
    final ktpHeight = ktpWidth / KTPDocumentDetector.KTP_ASPECT_RATIO;
    
    final ktpRect = Rect.fromCenter(
      center: center,
      width: ktpWidth,
      height: ktpHeight,
    );

    // Draw semi-transparent overlay outside KTP area
    final overlayPaint = Paint()
      ..color = Colors.black.withOpacity(0.5)
      ..style = PaintingStyle.fill;
    
    _drawOverlay(canvas, size, ktpRect, overlayPaint);

    // Draw KTP border
    final borderPaint = Paint()
      ..color = isValid ? Colors.green : Colors.yellow
      ..style = PaintingStyle.stroke
      ..strokeWidth = 3
      ..strokeCap = StrokeCap.round;

    canvas.drawRect(ktpRect, borderPaint);

    // Draw corner guides
    _drawCornerGuides(canvas, ktpRect, isValid ? Colors.green : Colors.white);

    // Draw detected document rectangle if available
    if (detectionResult?.documentRect != null) {
      final detectedRect = detectionResult!.documentRect!;
      
      // Scale detected rect to canvas size
      final scaledRect = Rect.fromLTRB(
        detectedRect.left * size.width,
        detectedRect.top * size.height,
        detectedRect.right * size.width,
        detectedRect.bottom * size.height,
      );
      
      final detectedPaint = Paint()
        ..color = Colors.blue.withOpacity(0.3)
        ..style = PaintingStyle.stroke
        ..strokeWidth = 2;
      
      canvas.drawRect(scaledRect, detectedPaint);
    }

    // Draw alignment markers
    _drawAlignmentMarkers(canvas, ktpRect);
  }

  void _drawOverlay(Canvas canvas, Size size, Rect ktpRect, Paint paint) {
    // Draw overlay excluding KTP area
    canvas.drawRect(Rect.fromLTWH(0, 0, size.width, ktpRect.top), paint);
    canvas.drawRect(Rect.fromLTWH(0, ktpRect.bottom, size.width, size.height - ktpRect.bottom), paint);
    canvas.drawRect(Rect.fromLTWH(0, ktpRect.top, ktpRect.left, ktpRect.height), paint);
    canvas.drawRect(Rect.fromLTWH(ktpRect.right, ktpRect.top, size.width - ktpRect.right, ktpRect.height), paint);
  }

  void _drawCornerGuides(Canvas canvas, Rect rect, Color color) {
    final guidePaint = Paint()
      ..color = color
      ..style = PaintingStyle.stroke
      ..strokeWidth = 4;

    const cornerLength = 30;

    // Top-left corner
    canvas.drawLine(
      Offset(rect.left, rect.top + cornerLength),
      Offset(rect.left, rect.top),
      guidePaint,
    );
    canvas.drawLine(
      Offset(rect.left, rect.top),
      Offset(rect.left + cornerLength, rect.top),
      guidePaint,
    );

    // Top-right corner
    canvas.drawLine(
      Offset(rect.right - cornerLength, rect.top),
      Offset(rect.right, rect.top),
      guidePaint,
    );
    canvas.drawLine(
      Offset(rect.right, rect.top),
      Offset(rect.right, rect.top + cornerLength),
      guidePaint,
    );

    // Bottom-left corner
    canvas.drawLine(
      Offset(rect.left, rect.bottom - cornerLength),
      Offset(rect.left, rect.bottom),
      guidePaint,
    );
    canvas.drawLine(
      Offset(rect.left, rect.bottom),
      Offset(rect.left + cornerLength, rect.bottom),
      guidePaint,
    );

    // Bottom-right corner
    canvas.drawLine(
      Offset(rect.right - cornerLength, rect.bottom),
      Offset(rect.right, rect.bottom),
      guidePaint,
    );
    canvas.drawLine(
      Offset(rect.right, rect.bottom),
      Offset(rect.right, rect.bottom - cornerLength),
      guidePaint,
    );
  }

  void _drawAlignmentMarkers(Canvas canvas, Rect rect) {
    final markerPaint = Paint()
      ..color = Colors.white.withOpacity(0.5)
      ..style = PaintingStyle.stroke
      ..strokeWidth = 1;

    // Draw center cross
    final center = rect.center;
    canvas.drawLine(
      Offset(center.dx - 20, center.dy),
      Offset(center.dx + 20, center.dy),
      markerPaint,
    );
    canvas.drawLine(
      Offset(center.dx, center.dy - 20),
      Offset(center.dx, center.dy + 20),
      markerPaint,
    );
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => true;
}
