    useEffect(() {
      if (cameraController.value != null && 
          isInitialized.value && 
          !isCapturing.value && 
          !isProcessing.value) {
        
        _startDocumentDetection(
          cameraController.value!,
          documentDetector,
          detectionResult,
        );
      }
      return null;
    }, [cameraController.value, isInitialized.value, isCapturing.value]);

    // Auto-capture when document is properly positioned
    useEffect(() {
      if (autoCapture && 
          detectionResult.value != null && 
          detectionResult.value!.isValid && 
          !isCapturing.value && 
          !isProcessing.value) {
        
        _startAutoCapture(
          context,
          cameraController.value,
          captureProgress,
          isCapturing,
          capturedImage,
          isProcessing,
          extractedInfo,
          ocrService,
          onCaptureComplete,
        );
      }
      return () => captureTimer?.cancel();
    }, [detectionResult.value, autoCapture]);

    return Container(
      child: Column(
        children: [
          // Camera Preview with Overlay
          if (cameraController.value != null && isInitialized.value)
            Stack(
              children: [
                Container(
                  height: 500,
                  decoration: BoxDecoration(
                    borderRadius: BorderRadius.circular(16),
                    border: Border.all(
                      color: _getBorderColor(detectionResult.value),
                      width: 3,
                    ),
                  ),
                  child: ClipRRect(
                    borderRadius: BorderRadius.circular(16),
                    child: CameraPreview(cameraController.value!),
                  ),
                ),
                
                // KTP Guide Overlay
                _buildKTPGuideOverlay(detectionResult.value),
                
                // Capture Progress Indicator
                if (isCapturing.value)
                  _buildCaptureProgress(captureProgress.value),
                
                // Status Indicator
                _buildStatusIndicator(detectionResult.value),
                
                // Quality Indicators
                _buildQualityIndicators(detectionResult.value),
              ],
            )
          else
            Container(
              height: 500,
              decoration: BoxDecoration(
                color: Colors.grey[200],
                borderRadius: BorderRadius.circular(16),
              ),
              child: const Center(
                child: CircularProgressIndicator(),
              ),
            ),

          const SizedBox(height: 16),

          // Instructions Card
          _buildInstructionsCard(detectionResult.value),

          const SizedBox(height: 16),

          // Manual Capture Button
          if (!autoCapture)
            ElevatedButton.icon(
              onPressed: detectionResult.value?.isValid == true && !isCapturing.value
                  ? () => _manualCapture(
                      context,
                      cameraController.value,
                      capturedImage,
                      isProcessing,
                      extractedInfo,
                      ocrService,
                      onCaptureComplete,
                    )
                  : null,
              icon: const Icon(Icons.camera),
              label: const Text('Capture KTP'),
              style: ElevatedButton.styleFrom(
                minimumSize: const Size(200, 50),
              ),
            ),

          // Retry Button
          if (extractedInfo.value != null)
            TextButton.icon(
              onPressed: () {
                capturedImage.value = null;
                extractedInfo.value = null;
                isProcessing.value = false;
              },
              icon: const Icon(Icons.refresh),
              label: const Text('Capture Again'),
            ),
        ],
      ),
    );
  }

  Widget _buildKTPGuideOverlay(DocumentDetectionResult? result) {
    return CustomPaint(
      size: Size.infinite,
      painter: KTPGuidePainter(
        detectionResult: result,
        isValid: result?.isValid ?? false,
