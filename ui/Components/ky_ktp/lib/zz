  double calculateConfidence(KTPInfo? extractedInfo) {
    if (extractedInfo == null) return 0.0;
    
    int totalFields = 16; // Number of KTP fields
    int filledFields = 0;
    
    if (extractedInfo.nik.isNotEmpty) filledFields++;
    if (extractedInfo.nama.isNotEmpty) filledFields++;
    if (extractedInfo.tempatLahir.isNotEmpty) filledFields++;
    if (extractedInfo.jenisKelamin.isNotEmpty) filledFields++;
    if (extractedInfo.golonganDarah.isNotEmpty) filledFields++;
    if (extractedInfo.alamat.isNotEmpty) filledFields++;
    if (extractedInfo.rtRw.isNotEmpty) filledFields++;
    if (extractedInfo.kelDesa.isNotEmpty) filledFields++;
    if (extractedInfo.kecamatan.isNotEmpty) filledFields++;
    if (extractedInfo.agama.isNotEmpty) filledFields++;
    if (extractedInfo.statusPerkawinan.isNotEmpty) filledFields++;
    if (extractedInfo.pekerjaan.isNotEmpty) filledFields++;
    if (extractedInfo.kewarganegaraan.isNotEmpty) filledFields++;
    
    return filledFields / totalFields;
  }
