## 8. Create KTP Provider for State Management

```dart
// lib/providers/ktp_provider.dart
import 'package:riverpod/riverpod.dart';
import 'package:flutter_secure_storage/flutter_secure_storage.dart';
import '../models/ktp_model.dart';
import '../services/ktp_ocr_service.dart';

enum KTPVerificationStatus {
  notStarted,
  capturing,
  processing,
  verified,
  failed,
}

class KTPVerificationState {
  final KTPVerificationStatus status;
  final KTPInfo? ktpInfo;
  final String? errorMessage;
  final double confidence;

  KTPVerificationState({
    required this.status,
    this.ktpInfo,
    this.errorMessage,
    this.confidence = 0.0,
  });

  KTPVerificationState copyWith({
    KTPVerificationStatus? status,
    KTPInfo? ktpInfo,
    String? errorMessage,
    double? confidence,
  }) {
    return KTPVerificationState(
      status: status ?? this.status,
      ktpInfo: ktpInfo ?? this.ktpInfo,
      errorMessage: errorMessage,
      confidence: confidence ?? this.confidence,
    );
  }
}

class KTPNotifier extends StateNotifier<KTPVerificationState> {
  KTPNotifier() : super(KTPVerificationState(status: KTPVerificationStatus.notStarted));

  final FlutterSecureStorage _storage = const FlutterSecureStorage();
  final KTPOCRService _ocrService = KTPOCRService();

  Future<void> verifyKTP(KTPInfo ktpInfo) async {
    state = state.copyWith(
      status: KTPVerificationStatus.processing,
      ktpInfo: ktpInfo,
    );

    try {
      // Perform additional validation
      final isValid = _validateKTPData(ktpInfo);
      
      if (isValid) {
        // Save encrypted KTP data
        await _saveKTPData(ktpInfo);
        
        state = state.copyWith(
          status: KTPVerificationStatus.verified,
          confidence: 1.0,
        );
      } else {
        state = state.copyWith(
          status: KTPVerificationStatus.failed,
          errorMessage: 'Data KTP tidak valid',
        );
      }
    } catch (e) {
      state = state.copyWith(
        status: KTPVerificationStatus.failed,
        errorMessage: 'Verifikasi gagal: $e',
      );
    }
  }

  bool _validateKTPData(KTPInfo ktpInfo) {
    // Validate NIK
    if (ktpInfo.nik.length != 16) return false;
    
    // Validate name (minimum 3 characters)
    if (ktpInfo.nama.length < 3) return false;
    
    // Validate date of birth (not in future)
    if (ktpInfo.tanggalLahir.isAfter(DateTime.now())) return false;
    
    // Validate address
    if (ktpInfo.alamat.isEmpty) return false;
    
    return true;
  }

  Future<void> _saveKTPData(KTPInfo ktpInfo) async {
    // Encrypt and save KTP data
    final jsonData = ktpInfo.toJson();
    await _storage.write(
      key: 'ktp_data',
      value: jsonData.toString(),
    );
  }

  Future<KTPInfo?> getSavedKTP() async {
    final data = await _storage.read(key: 'ktp_data');
    if (data != null) {
      // Parse and return KTP info
    }
    return null;
  }

  void reset() {
    state = KTPVerificationState(status: KTPVerificationStatus.notStarted);
  }
}

final ktpProvider = StateNotifierProvider<KTPNotifier, KTPVerificationState>((ref) {
  return KTPNotifier();
});
