    // Simplified signature extraction
    try {
      final image = img.decodeImage(await imageFile.readAsBytes());
      if (image == null) return null;
      
      // Assume signature is in bottom portion of KTP
      final signatureRegion = img.copyCrop(
        image,
        image.width ~/ 2,
        image.height * 3 ~/ 4,
        image.width ~/ 2,
        image.height ~/ 4,
