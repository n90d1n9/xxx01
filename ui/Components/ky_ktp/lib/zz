          ),
          const SizedBox(width: 12),
          Expanded(
            child: Text(
              text,
              style: TextStyle(
                color: isComplete ? Colors.black : Colors.grey,
                decoration: isComplete ? TextDecoration.lineThrough : null,
              ),
            ),
          ),
        ],
      ),
    );
  }

  Color _getBorderColor(DocumentDetectionResult? result) {
    if (result == null) return Colors.grey;
    if (result.isValid) return Colors.green;
    if (result.qualityIssues.isNotEmpty) return Colors.orange;
    return Colors.yellow;
  }

  Future<void> _initializeCamera(
    ValueNotifier<CameraController?> controller,
    ValueNotifier<bool> initialized,
  ) async {
    try {
      final cameras = await availableCameras();
      final camera = cameras.firstWhere(
        (camera) => camera.lensDirection == CameraLensDirection.back,
        orElse: () => cameras.first,
      );

      final cameraController = CameraController(
        camera,
        ResolutionPreset.high,
        enableAudio: false,
      );

      await cameraController.initialize();
      controller.value = cameraController;
      initialized.value = true;
    } catch (e) {
      print('Camera initialization error: $e');
    }
  }

  void _startDocumentDetection(
    CameraController controller,
    KTPDocumentDetector detector,
    ValueNotifier<DocumentDetectionResult?> result,
  ) {
    const captureInterval = Duration(milliseconds: 500);
    Timer.periodic(captureInterval, (timer) async {
      if (!controller.value.isInitialized) return;

      try {
        final image = await controller.takePicture();
        final detection = await detector.detectKTP(File(image.path));
        result.value = detection;
      } catch (e) {
        print('Detection error: $e');
      }
    });
  }

  void _startAutoCapture(
    BuildContext context,
    CameraController? controller,
    ValueNotifier<double> progress,
    ValueNotifier<bool> isCapturing,
    ValueNotifier<File?> capturedImage,
    ValueNotifier<bool> isProcessing,
    ValueNotifier<KTPInfo?> extractedInfo,
    KTPOCRService ocrService,
    Function(KTPInfo)? onComplete,
  ) {
    isCapturing.value = true;
    progress.value = 0.0;
    
    const totalSteps = 20;
    var step = 0;
    
    Timer.periodic(const Duration(milliseconds: 50), (timer) async {
      step++;
      progress.value = step / totalSteps;
      
      if (step >= totalSteps) {
        timer.cancel();
        await _captureAndProcess(
          context,
          controller,
          capturedImage,
          isProcessing,
          extractedInfo,
          ocrService,
          onComplete,
        );
        isCapturing.value = false;
      }
    });
  }

  Future<void> _manualCapture(
    BuildContext context,
    CameraController? controller,
    ValueNotifier<File?> capturedImage,
    ValueNotifier<bool> isProcessing,
    ValueNotifier<KTPInfo?> extractedInfo,
    KTPOCRService ocrService,
    Function(KTPInfo)? onComplete,
  ) async {
    await _captureAndProcess(
      context,
      controller,
      capturedImage,
      isProcessing,
      extractedInfo,
      ocrService,
      onComplete,
    );
  }

  Future<void> _captureAndProcess(
    BuildContext context,
    CameraController? controller,
    ValueNotifier<File?> capturedImage,
    ValueNotifier<bool> isProcessing,
    ValueNotifier<KTPInfo?> extractedInfo,
    KTPOCRService ocrService,
    Function(KTPInfo)? onComplete,
  ) async {
    if (controller == null || !controller.value.isInitialized) return;

    try {
      isProcessing.value = true;
      
      // Capture image
      final image = await controller.takePicture();
      capturedImage.value = File(image.path);
      
      // Show processing dialog
      showDialog(
        context: context,
        barrierDismissible: false,
        builder: (context) => const Center(
          child: CircularProgressIndicator(),
        ),
      );
      
      // Perform OCR
      final info = await ocrService.extractKTPInfo(capturedImage.value!);
      
      Navigator.pop(context); // Close dialog
      
      if (info != null) {
        extractedInfo.value = info;
        onComplete?.call(info);
        
        // Show success dialog
        _showSuccessDialog(context, info);
      } else {
        _showErrorDialog(context, 'Gagal membaca KTP. Silakan coba lagi.');
      }
    } catch (e) {
      Navigator.pop(context);
      _showErrorDialog(context, 'Error: $e');
    } finally {
      isProcessing.value = false;
    }
  }

  void _showSuccessDialog(BuildContext context, KTPInfo info) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Icon(Icons.check_circle, color: Colors.green, size: 64),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const Text(
              'KTP Berhasil Dipindai',
              style: TextStyle(
                fontSize: 18,
                fontWeight: FontWeight.bold,
              ),
            ),
            const SizedBox(height: 16),
            _buildInfoRow('NIK', info.nik),
            _buildInfoRow('Nama', info.nama),
            _buildInfoRow('Tempat/Tgl Lahir', '${info.tempatLahir}, ${DateFormat('dd-MM-yyyy').format(info.tanggalLahir)}'),
            _buildInfoRow('Alamat', info.alamat),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('OK'),
          ),
        ],
      ),
    );
  }

  Widget _buildInfoRow(String label, String value) {
    return Padding(
      padding: const EdgeInsets.symmetric(vertical: 4),
      child: Row(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          SizedBox(
            width: 100,
            child: Text(
              label,
              style: const TextStyle(
                fontWeight: FontWeight.bold,
                color: Colors.grey,
              ),
            ),
          ),
          Expanded(
            child: Text(value),
          ),
        ],
      ),
    );
  }

  void _showErrorDialog(BuildContext context, String message) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Icon(Icons.error, color: Colors.red, size: 64),
        content: Text(message),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('OK'),
          ),
        ],
      ),
    );
  }
