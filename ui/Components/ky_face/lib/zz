// lib/widgets/facenet_camera_widget.dart
import 'package:flutter/material.dart';
import 'package:hooks_riverpod/hooks_riverpod.dart';
import 'package:flutter_hooks/flutter_hooks.dart';
import 'package:camera/camera.dart';
import 'package:google_ml_kit/google_ml_kit.dart';
import 'dart:io';
import '../providers/facenet_provider.dart';

class FaceNetCameraWidget extends HookConsumerWidget {
  final Function(FaceNetFace)? onFaceRegistered;
  final Function(FaceNetFace?)? onFaceVerified;
  final bool enableLiveness;

  const FaceNetCameraWidget({
    Key? key,
    this.onFaceRegistered,
    this.onFaceVerified,
    this.enableLiveness = true,
  }) : super(key: key);

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final faceState = ref.watch(faceNetProvider);
    final faceNotifier = ref.read(faceNetProvider.notifier);
    
    final cameraController = useState<CameraController?>(null);
    final isInitialized = useState(false);
    final registrationName = useTextEditingController();
    final similarityScore = useState<double>(0.0);

    // Initialize camera
    useEffect(() {
      _initializeCamera(cameraController, isInitialized);
      return () {
        cameraController.value?.dispose();
      };
    }, []);

    // Real-time face detection
    useEffect(() {
      if (cameraController.value != null && isInitialized.value) {
        _startRealTimeDetection(cameraController.value!, ref);
      }
      return null;
    }, [cameraController.value, isInitialized.value]);

    return Container(
      padding: const EdgeInsets.all(16),
      child: Column(
        children: [
          // Camera Preview
          if (cameraController.value != null && isInitialized.value)
            Stack(
              children: [
                Container(
                  height: 400,
                  decoration: BoxDecoration(
                    borderRadius: BorderRadius.circular(12),
                    border: Border.all(color: Colors.grey.shade300, width: 2),
                  ),
                  child: ClipRRect(
                    borderRadius: BorderRadius.circular(12),
                    child: CameraPreview(cameraController.value!),
                  ),
                ),
                
                // Face overlay and confidence indicator
                if (faceState.detectedFace != null)
                  Positioned(
                    bottom: 16,
                    right: 16,
                    child: Container(
                      padding: const EdgeInsets.all(8),
                      decoration: BoxDecoration(
                        color: Colors.black.withOpacity(0.7),
                        borderRadius: BorderRadius.circular(8),
                      ),
                      child: Column(
                        children: [
                          Text(
                            'Confidence: ${(faceState.confidence * 100).toStringAsFixed(1)}%',
                            style: const TextStyle(color: Colors.white),
                          ),
                          if (faceState.matchedFace != null)
                            Text(
                              'Match: ${faceState.matchedFace!.name}',
                              style: const TextStyle(color: Colors.green),
                            ),
                        ],
                      ),
                    ),
                  ),
              ],
            )
          else
            Container(
              height: 400,
              decoration: BoxDecoration(
                color: Colors.grey[200],
                borderRadius: BorderRadius.circular(12),
              ),
              child: const Center(
                child: CircularProgressIndicator(),
              ),
            ),

          const SizedBox(height: 16),

          // Status Display
          _buildStatusCard(faceState, context),

          const SizedBox(height: 16),

          // Similarity Score Bar
          if (faceState.confidence > 0)
            Column(
              children: [
                LinearProgressIndicator(
                  value: faceState.confidence,
                  backgroundColor: Colors.grey[200],
                  valueColor: AlwaysStoppedAnimation<Color>(
                    faceState.confidence >= 0.8 ? Colors.green : Colors.orange,
                  ),
                ),
                const SizedBox(height: 4),
                Text(
                  'Similarity Score: ${(faceState.confidence * 100).toStringAsFixed(1)}%',
                  style: TextStyle(
                    color: faceState.confidence >= 0.8 ? Colors.green : Colors.orange,
                  ),
                ),
              ],
            ),

          const SizedBox(height: 16),

          // Registration Input
          if (faceState.status == FaceNetStatus.faceDetected)
            Padding(
              padding: const EdgeInsets.symmetric(vertical: 8),
              child: TextField(
                controller: registrationName,
                decoration: InputDecoration(
                  labelText: 'Enter name for registration',
                  border: OutlineInputBorder(
                    borderRadius: BorderRadius.circular(12),
                  ),
                  prefixIcon: const Icon(Icons.person),
                ),
              ),
            ),

