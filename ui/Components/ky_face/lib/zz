## 4. Create FaceNet Provider

```dart
// lib/providers/facenet_provider.dart
import 'package:riverpod/riverpod.dart';
import 'package:camera/camera.dart';
import 'package:google_ml_kit/google_ml_kit.dart';
import 'dart:io';
import '../services/facenet_service.dart';

enum FaceNetStatus {
  initial,
  detecting,
  faceDetected,
  noFace,
  multipleFaces,
  processing,
  generatingEmbedding,
  registered,
  verifying,
  verified,
  failed,
  livenessChecking,
  livenessPassed,
  livenessFailed
}

enum LivenessStep {
  initial,
  blink,
  smile,
  turnLeft,
  turnRight,
  nod,
  completed
}

class FaceNetState {
  final FaceNetStatus status;
  final String? errorMessage;
  final Face? detectedFace;
  final List<Face> faces;
  final File? capturedImage;
  final Float32List? currentEmbedding;
  final FaceNetFace? matchedFace;
  final LivenessStep currentLivenessStep;
  final int livenessProgress;
  final Map<LivenessStep, bool> completedSteps;
  final double confidence;

  FaceNetState({
    required this.status,
    this.errorMessage,
    this.detectedFace,
    this.faces = const [],
    this.capturedImage,
    this.currentEmbedding,
    this.matchedFace,
    this.currentLivenessStep = LivenessStep.initial,
    this.livenessProgress = 0,
    this.completedSteps = const {},
    this.confidence = 0.0,
  });

  FaceNetState copyWith({
    FaceNetStatus? status,
    String? errorMessage,
    Face? detectedFace,
    List<Face>? faces,
    File? capturedImage,
    Float32List? currentEmbedding,
    FaceNetFace? matchedFace,
    LivenessStep? currentLivenessStep,
    int? livenessProgress,
    Map<LivenessStep, bool>? completedSteps,
    double? confidence,
  }) {
    return FaceNetState(
      status: status ?? this.status,
      errorMessage: errorMessage,
      detectedFace: detectedFace ?? this.detectedFace,
      faces: faces ?? this.faces,
      capturedImage: capturedImage ?? this.capturedImage,
      currentEmbedding: currentEmbedding ?? this.currentEmbedding,
      matchedFace: matchedFace ?? this.matchedFace,
      currentLivenessStep: currentLivenessStep ?? this.currentLivenessStep,
      livenessProgress: livenessProgress ?? this.livenessProgress,
      completedSteps: completedSteps ?? this.completedSteps,
      confidence: confidence ?? this.confidence,
    );
  }

  bool get isFaceValid => faces.length == 1;
}

class FaceNetNotifier extends StateNotifier<FaceNetState> {
  FaceNetNotifier(this._faceNetService) : super(FaceNetState(status: FaceNetStatus.initial));

  final FaceNetService _faceNetService;
  final FaceDetector _faceDetector = GoogleMlKit.vision.faceDetector(
    FaceDetectorOptions(
      enableContours: true,
      enableLandmarks: true,
      enableClassification: true,
      enableTracking: true,
      performanceMode: FaceDetectorMode.fast,
    ),
  );

  final List<LivenessStep> _livenessSequence = [
    LivenessStep.blink,
    LivenessStep.smile,
    LivenessStep.turnLeft,
    LivenessStep.turnRight,
    LivenessStep.nod,
  ];

  // Initialize FaceNet service
  Future<void> initialize() async {
    try {
      await _faceNetService.initialize();
    } catch (e) {
      state = state.copyWith(
        status: FaceNetStatus.failed,
        errorMessage: 'Failed to initialize FaceNet: $e',
      );
    }
  }

  // Detect face from image
  Future<void> detectFace(File imageFile) async {
    state = state.copyWith(status: FaceNetStatus.detecting);

    try {
      final inputImage = InputImage.fromFile(imageFile);
      final faces = await _faceDetector.processImage(inputImage);

      if (faces.isEmpty) {
        state = state.copyWith(
          status: FaceNetStatus.noFace,
          errorMessage: 'No face detected',
        );
      } else if (faces.length > 1) {
        state = state.copyWith(
          status: FaceNetStatus.multipleFaces,
          errorMessage: 'Multiple faces detected',
        );
      } else {
        state = state.copyWith(
          status: FaceNetStatus.faceDetected,
          detectedFace: faces.first,
          faces: faces,
          capturedImage: imageFile,
        );
      }
    } catch (e) {
      state = state.copyWith(
        status: FaceNetStatus.failed,
        errorMessage: 'Detection failed: $e',
      );
    }
  }

  // Generate embedding from detected face
  Future<Float32List?> generateEmbedding() async {
    if (state.faces.isEmpty || state.capturedImage == null) {
      state = state.copyWith(
        status: FaceNetStatus.failed,
        errorMessage: 'No face detected',
      );
      return null;
    }

    state = state.copyWith(status: FaceNetStatus.generatingEmbedding);

    try {
      final embedding = await _faceNetService.generateEmbedding(
        state.capturedImage!,
        state.faces.first,
      );

      state = state.copyWith(
        currentEmbedding: embedding,
        status: FaceNetStatus.faceDetected,
      );

      return embedding;
    } catch (e) {
      state = state.copyWith(
        status: FaceNetStatus.failed,
        errorMessage: 'Embedding generation failed: $e',
      );
      return null;
    }
  }

  // Register face
  Future<FaceNetFace?> registerFace(String name) async {
    if (state.faces.isEmpty || state.capturedImage == null) {
      state = state.copyWith(
        status: FaceNetStatus.failed,
        errorMessage: 'No face detected',
      );
      return null;
    }

    state = state.copyWith(status: FaceNetStatus.processing);

    try {
      final face = await _faceNetService.registerFace(
        name,
        state.capturedImage!,
        state.faces.first,
      );

      state = state.copyWith(
        status: FaceNetStatus.registered,
        matchedFace: face,
      );

      return face;
    } catch (e) {
      state = state.copyWith(
        status: FaceNetStatus.failed,
        errorMessage: 'Registration failed: $e',
      );
      return null;
    }
  }

  // Verify face
  Future<FaceNetFace?> verifyFace() async {
    if (state.faces.isEmpty || state.capturedImage == null) {
      state = state.copyWith(
        status: FaceNetStatus.failed,
        errorMessage: 'No face detected',
      );
      return null;
    }

    state = state.copyWith(status: FaceNetStatus.verifying);

    try {
      // Generate embedding if not already done
      Float32List embedding = state.currentEmbedding ?? 
          await _faceNetService.generateEmbedding(
            state.capturedImage!,
            state.faces.first,
          );

      // Find best match
      final match = await _faceNetService.findBestMatch(embedding);
      
      if (match != null) {
        final similarity = _faceNetService.calculateSimilarity(
          embedding,
          match.embedding,
        );

        state = state.copyWith(
          status: FaceNetStatus.verified,
          matchedFace: match,
          currentEmbedding: embedding,
          confidence: similarity,
        );
      } else {
        state = state.copyWith(
          status: FaceNetStatus.failed,
          errorMessage: 'No matching face found',
        );
      }

      return match;
    } catch (e) {
      state = state.copyWith(
        status: FaceNetStatus.failed,
        errorMessage: 'Verification failed: $e',
      );
      return null;
    }
  }

  // Liveness detection methods
  void startLivenessCheck() {
    state = state.copyWith(
      status: FaceNetStatus.livenessChecking,
      currentLivenessStep: _livenessSequence.first,
      livenessProgress: 0,
      completedSteps: {},
    );
  }

  void processLivenessStep(LivenessStep step, bool passed) {
    if (state.status != FaceNetStatus.livenessChecking) return;

    final updatedSteps = Map<LivenessStep, bool>.from(state.completedSteps);
    updatedSteps[step] = passed;

    final nextStepIndex = _livenessSequence.indexOf(step) + 1;
    final nextStep = nextStepIndex < _livenessSequence.length 
        ? _livenessSequence[nextStepIndex] 
        : LivenessStep.completed;

    final progress = ((updatedSteps.length / _livenessSequence.length) * 100).toInt();

    if (nextStep == LivenessStep.completed && updatedSteps.values.every((v) => v)) {
      state = state.copyWith(
        status: FaceNetStatus.livenessPassed,
        currentLivenessStep: LivenessStep.completed,
        completedSteps: updatedSteps,
        livenessProgress: 100,
      );
    } else if (!passed) {
      state = state.copyWith(
        status: FaceNetStatus.livenessFailed,
        errorMessage: 'Liveness check failed at ${step.toString()}',
        completedSteps: updatedSteps,
      );
    } else {
      state = state.copyWith(
        currentLivenessStep: nextStep,
        completedSteps: updatedSteps,
        livenessProgress: progress,
      );
    }
  }

  // Face management
  List<FaceNetFace> getRegisteredFaces() {
    return _faceNetService.getRegisteredFaces();
  }

  Future<void> deleteFace(String faceId) async {
    await _faceNetService.deleteFace(faceId);
  }

  // Reset state
  void reset() {
    state = FaceNetState(status: FaceNetStatus.initial);
  }

  // Clean up
  @override
  void dispose() {
    _faceDetector.close();
    _faceNetService.dispose();
    super.dispose();
  }
}

final faceNetProvider = StateNotifierProvider<FaceNetNotifier, FaceNetState>((ref) {
  final service = FaceNetService();
  final notifier = FaceNetNotifier(service);
  notifier.initialize();
  return notifier;
});
```

