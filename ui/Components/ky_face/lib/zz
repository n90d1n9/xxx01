// lib/services/face_position_analyzer.dart
import 'package:google_ml_kit/google_ml_kit.dart';
import 'dart:math';
import '../widgets/face_guide_overlay.dart';

class FacePositionAnalyzer {
  // Optimal face size relative to frame (40-60% of frame height)
  static const double MIN_FACE_RATIO = 0.25;
  static const double MAX_FACE_RATIO = 0.6;
  static const double OPTIMAL_FACE_RATIO = 0.4;
  
  // Optimal position offset (within 15% of center)
  static const double MAX_CENTER_OFFSET = 0.15;
  
  // Optimal head rotation angles
  static const double MAX_YAW_ANGLE = 15; // degrees
  static const double MAX_ROLL_ANGLE = 15; // degrees
  static const double MAX_PITCH_ANGLE = 15; // degrees
  
  // Brightness threshold (0-255)
  static const double MIN_BRIGHTNESS = 80;
  
  // Blur detection threshold
  static const double MAX_BLUR = 0.3;

  FacePositionStatus analyzePosition(
    Face face,
    Size frameSize,
    double brightness,
    double blurAmount,
  ) {
    final boundingBox = face.boundingBox;
    
    // Check face size
    final faceHeight = boundingBox.height;
    final frameHeight = frameSize.height;
    final faceRatio = faceHeight / frameHeight;
    
    if (faceRatio < MIN_FACE_RATIO) {
      return FacePositionStatus.tooFar;
    }
    if (faceRatio > MAX_FACE_RATIO) {
      return FacePositionStatus.tooClose;
    }
    
    // Check face position
    final faceCenter = Offset(
      boundingBox.left + boundingBox.width / 2,
      boundingBox.top + boundingBox.height / 2,
    );
    final frameCenter = Offset(frameSize.width / 2, frameSize.height / 2);
    
    final offsetX = (faceCenter.dx - frameCenter.dx) / frameSize.width;
    final offsetY = (faceCenter.dy - frameCenter.dy) / frameSize.height;
    
    if (offsetX.abs() > MAX_CENTER_OFFSET) {
      return offsetX > 0 ? FacePositionStatus.tooRight : FacePositionStatus.tooLeft;
    }
    if (offsetY.abs() > MAX_CENTER_OFFSET) {
      return offsetY > 0 ? FacePositionStatus.tooLow : FacePositionStatus.tooHigh;
    }
    
    // Check head orientation
    final eulerY = face.headEulerAngleY ?? 0; // Yaw (left-right)
    final eulerZ = face.headEulerAngleZ ?? 0; // Roll (tilt)
    final eulerX = face.headEulerAngleX ?? 0; // Pitch (up-down)
    
    if (eulerY.abs() > MAX_YAW_ANGLE || 
        eulerZ.abs() > MAX_ROLL_ANGLE || 
        eulerX.abs() > MAX_PITCH_ANGLE) {
      return FacePositionStatus.tilted;
    }
    
    // Check lighting
    if (brightness < MIN_BRIGHTNESS) {
      return FacePositionStatus.dark;
    }
    
    // Check blur
    if (blurAmount > MAX_BLUR) {
      return FacePositionStatus.blurry;
    }
    
    return FacePositionStatus.optimal;
  }

  double calculatePositionScore(Face face, Size frameSize) {
    double score = 1.0;
    
    final boundingBox = face.boundingBox;
    final faceHeight = boundingBox.height;
    final frameHeight = frameSize.height;
    final faceRatio = faceHeight / frameHeight;
    
    // Score for face size (optimal at 0.4)
    final sizeScore = 1.0 - min((faceRatio - OPTIMAL_FACE_RATIO).abs() * 2, 1.0);
    
    // Score for face position
    final faceCenter = Offset(
      boundingBox.left + boundingBox.width / 2,
      boundingBox.top + boundingBox.height / 2,
    );
    final frameCenter = Offset(frameSize.width / 2, frameSize.height / 2);
    
    final distance = sqrt(
      pow(faceCenter.dx - frameCenter.dx, 2) + 
      pow(faceCenter.dy - frameCenter.dy, 2)
    );
    final maxDistance = sqrt(pow(frameSize.width / 2, 2) + pow(frameSize.height / 2, 2));
    final positionScore = 1.0 - min(distance / maxDistance, 1.0);
    
    // Score for head orientation
    final eulerY = (face.headEulerAngleY?.abs() ?? 0) / MAX_YAW_ANGLE;
    final eulerZ = (face.headEulerAngleZ?.abs() ?? 0) / MAX_ROLL_ANGLE;
    final eulerX = (face.headEulerAngleX?.abs() ?? 0) / MAX_PITCH_ANGLE;
    
    final orientationScore = 1.0 - min(max(eulerY, max(eulerZ, eulerX)), 1.0);
    
    // Weighted average
    score = sizeScore * 0.3 + positionScore * 0.4 + orientationScore * 0.3;
    
    return max(0.0, min(score, 1.0));
  }

  String getPositionAdvice(FacePositionStatus status) {
    switch (status) {
      case FacePositionStatus.optimal:
        return "Perfect! Hold still for capture";
      case FacePositionStatus.tooClose:
        return "Move phone further away - face too large";
      case FacePositionStatus.tooFar:
        return "Bring phone closer - face too small";
      case FacePositionStatus.tooLeft:
        return "Move phone right - face too far left";
      case FacePositionStatus.tooRight:
        return "Move phone left - face too far right";
      case FacePositionStatus.tooHigh:
        return "Lower phone - face too high";
      case FacePositionStatus.tooLow:
        return "Raise phone - face too low";
      case FacePositionStatus.tilted:
        return "Keep face straight to camera";
      case FacePositionStatus.dark:
        return "Move to brighter area";
      case FacePositionStatus.blurry:
        return "Hold phone steady";
    }
  }
}
