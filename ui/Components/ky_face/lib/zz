  Widget _buildStatusCard(FaceNetState state, BuildContext context) {
    Color statusColor;
    IconData statusIcon;
    String statusText;

    switch (state.status) {
      case FaceNetStatus.faceDetected:
        statusColor = Colors.green;
        statusIcon = Icons.face;
        statusText = 'Face Detected';
        break;
      case FaceNetStatus.noFace:
        statusColor = Colors.orange;
        statusIcon = Icons.face_retouching_natural;
        statusText = 'No Face Detected';
        break;
      case FaceNetStatus.multipleFaces:
        statusColor = Colors.orange;
        statusIcon = Icons.group;
        statusText = 'Multiple Faces Detected';
        break;
      case FaceNetStatus.generatingEmbedding:
        statusColor = Colors.blue;
        statusIcon = Icons.token;
        statusText = 'Generating Face Embedding...';
        break;
      case FaceNetStatus.registered:
        statusColor = Colors.green;
        statusIcon = Icons.app_registration;
        statusText = 'Face Registered Successfully';
        break;
      case FaceNetStatus.verified:
        statusColor = Colors.green;
        statusIcon = Icons.verified_user;
        statusText = 'Face Verified: ${state.matchedFace?.name ?? "Unknown"}';
        break;
      case FaceNetStatus.verifying:
        statusColor = Colors.blue;
        statusIcon = Icons.search;
        statusText = 'Verifying Face...';
        break;
      case FaceNetStatus.failed:
        statusColor = Colors.red;
        statusIcon = Icons.error;
        statusText = state.errorMessage ?? 'Verification Failed';
        break;
      default:
        statusColor = Colors.grey;
        statusIcon = Icons.info;
        statusText = 'Position your face in the frame';
    }

    return Container(
      padding: const EdgeInsets.all(12),
