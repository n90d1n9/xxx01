class HTMLExporter {
  static String generateHTML(BuilderProject project) {
    final page = project.pages.first;
    final sections = page.sections.map((s) => _generateSection(s)).join('\n');

    return '''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${project.name}</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    $sections
    <script src="script.js"></script>
</body>
</html>
''';
  }

  static String _generateSection(SectionData section) {
    final components = section.components.map((c) => _generateComponent(c)).join('\n        ');
    return '''
    <section id="${section.id}" class="section-${section.type}">
        $components
    </section>''';
  }

  static String _generateComponent(ComponentData component) {
    switch (component.type) {
      case 'text':
      case 'heading':
        final tag = component.props?['tag'] ?? 'p';
        final content = component.props?['content'] ?? '';
        return '<$tag>$content</$tag>';
      case 'button':
        final text = component.props?['text'] ?? 'Button';
        return '<button class="btn">${text}</button>';
      case 'image':
        final src = component.props?['src'] ?? '';
        final alt = component.props?['alt'] ?? '';
        return '<img src="$src" alt="$alt" />';
      case 'container':
        final children = component.children.map((c) => _generateComponent(c)).join('\n');
        return '<div class="container">\n$children\n</div>';
      default:
        return '<div class="${component.type}"></div>';
    }
  }

  static String generateCSS(BuilderProject project) {
    return '''
