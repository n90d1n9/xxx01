  }

  @override
  void dispose() {
    _previewController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final animState = ref.watch(animationEditorProvider);

    return Dialog(
      child: Container(
        width: 1000,
        height: 700,
        child: Row(
          children: [
            // Left Panel - Animation Controls
            Container(
              width: 300,
              padding: const EdgeInsets.all(24),
              decoration: BoxDecoration(
                border: Border(right: BorderSide(color: Colors.grey[300]!)),
              ),
              child: _buildControlPanel(animState),
            ),

            // Center - Timeline
            Expanded(
              child: Column(
                children: [
                  _buildPreviewArea(),
                  _buildTimeline(animState),
                ],
              ),
            ),

            // Right Panel - Properties
            Container(
              width: 250,
              padding: const EdgeInsets.all(24),
              decoration: BoxDecoration(
                border: Border(left: BorderSide(color: Colors.grey[300]!)),
              ),
              child: _buildPropertiesPanel(animState),
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildControlPanel(AnimationEditorState animState) {
    return ListView(
      children: [
        const Text('Animation Type', style: TextStyle(fontWeight: FontWeight.bold)),
        const SizedBox(height: 12),
        SegmentedButton<String>(
          segments: const [
            ButtonSegment(value: 'entrance', label: Text('Entrance')),
            ButtonSegment(value: 'scroll', label: Text('Scroll')),
            ButtonSegment(value: 'hover', label: Text('Hover')),
          ],
          selected: {animState.type},
          onSelectionChanged: (selected) {
            ref.read(animationEditorProvider.notifier).setType(selected.first);
          },
        ),
        const SizedBox(height: 24),
        const Text('Animation Presets', style: TextStyle(fontWeight: FontWeight.bold)),
        const SizedBox(height: 12),
        _AnimationPresetCard(
          title: 'Fade In',
          icon: Icons.visibility,
          onTap: () => _applyPreset('fadeIn'),
        ),
        _AnimationPresetCard(
          title: 'Slide Up',
          icon: Icons.arrow_upward,
          onTap: () => _applyPreset('slideUp'),
        ),
        _AnimationPresetCard(
          title: 'Scale',
          icon: Icons.zoom_in,
          onTap: () => _applyPreset('scale'),
        ),
        _AnimationPresetCard(
          title: 'Bounce',
          icon: Icons.sports_basketball,
          onTap: () => _applyPreset('bounce'),
        ),
        _AnimationPresetCard(
          title: 'Rotate',
          icon: Icons.rotate_right,
          onTap: () => _applyPreset('rotate'),
        ),
        const SizedBox(height: 24),
        const Text('Duration', style: TextStyle(fontWeight: FontWeight.bold)),
        const SizedBox(height: 12),
        Slider(
          value: animState.duration.inMilliseconds.toDouble(),
          min: 100,
          max: 3000,
          divisions: 29,
          label: '${animState.duration.inMilliseconds}ms',
          onChanged: (value) {
            ref.read(animationEditorProvider.notifier)
                .setDuration(Duration(milliseconds: value.toInt()));
          },
        ),
      ],
    );
  }

  Widget _buildPreviewArea() {
    return Expanded(
      child: Container(
        color: Colors.grey[100],
        child: Center(
          child: AnimatedBuilder(
            animation: _previewController,
            builder: (context, child) {
              return Transform.translate(
                offset: Offset(0, -50 * (1 - _previewController.value)),
                child: Opacity(
                  opacity: _previewController.value,
                  child: Container(
                    width: 200,
                    height: 200,
                    decoration: BoxDecoration(
                      color: Colors.blue,
                      borderRadius: BorderRadius.circular(12),
                    ),
                    child: const Center(
                      child: Text(
