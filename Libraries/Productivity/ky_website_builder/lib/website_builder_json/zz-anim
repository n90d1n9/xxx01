// Animation State Provider
final animationEditorProvider = StateNotifierProvider<AnimationEditorNotifier, AnimationEditorState>((ref) {
  return AnimationEditorNotifier();
});

class AnimationEditorState {
  final String type; // entrance, scroll, hover, keyframe
  final Duration duration;
  final String curve;
  final double delay;
  final List<KeyframeData> keyframes;
  final bool isPlaying;

  AnimationEditorState({
    this.type = 'entrance',
    this.duration = const Duration(milliseconds: 500),
    this.curve = 'easeInOut',
    this.delay = 0,
    this.keyframes = const [],
    this.isPlaying = false,
  });

  AnimationEditorState copyWith({
    String? type,
    Duration? duration,
    String? curve,
    double? delay,
    List<KeyframeData>? keyframes,
    bool? isPlaying,
  }) {
    return AnimationEditorState(
      type: type ?? this.type,
      duration: duration ?? this.duration,
      curve: curve ?? this.curve,
      delay: delay ?? this.delay,
      keyframes: keyframes ?? this.keyframes,
      isPlaying: isPlaying ?? this.isPlaying,
    );
  }
}

class KeyframeData {
  final double position; // 0.0 to 1.0
  final Map<String, dynamic> properties;

  KeyframeData({required this.position, required this.properties});
}

class AnimationEditorNotifier extends StateNotifier<AnimationEditorState> {
  AnimationEditorNotifier() : super(AnimationEditorState());

  void setType(String type) => state = state.copyWith(type: type);
  void setDuration(Duration duration) => state = state.copyWith(duration: duration);
  void setCurve(String curve) => state = state.copyWith(curve: curve);
  void setDelay(double delay) => state = state.copyWith(delay: delay);
  void togglePlayback() => state = state.copyWith(isPlaying: !state.isPlaying);

  void addKeyframe(KeyframeData keyframe) {
    state = state.copyWith(keyframes: [...state.keyframes, keyframe]);
  }

  void removeKeyframe(int index) {
    final newKeyframes = [...state.keyframes];
    newKeyframes.removeAt(index);
    state = state.copyWith(keyframes: newKeyframes);
  }
}

