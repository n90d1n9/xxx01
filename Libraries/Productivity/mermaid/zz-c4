// ==================== C4 MODELS ====================

enum C4DiagramType {
  context,     // System Context
  container,   // Container diagram
  component,   // Component diagram
  dynamic,     // Dynamic diagram
  deployment   // Deployment diagram
}

enum C4ElementType {
  person,
  system,
  systemDb,
  systemQueue,
  systemExt,
  systemDbExt,
  systemQueueExt,
  container,
  containerDb,
  containerQueue,
  containerExt,
  containerDbExt,
  containerQueueExt,
  component,
  componentDb,
  componentQueue,
  componentExt,
  componentDbExt,
  componentQueueExt,
  node,
  boundary,
}

enum C4RelationType {
  relationship,
  relationshipDown,
  relationshipUp,
  relationshipLeft,
  relationshipRight,
  biDirectional,
}

class C4Element {
  final String id;
  final String alias;
  final String label;
  final C4ElementType type;
  final String? description;
  final String? technology;
  final String? link;
  Offset position;
  Size size;

  C4Element({
    required this.id,
    required this.alias,
    required this.label,
    required this.type,
    this.description,
    this.technology,
    this.link,
    this.position = Offset.zero,
    this.size = const Size(240, 180),
  });

  bool get isExternal => type.name.contains('Ext');
  bool get isDatabase => type.name.contains('Db');
  bool get isQueue => type.name.contains('Queue');
  bool get isPerson => type == C4ElementType.person;
  bool get isBoundary => type == C4ElementType.boundary;
}

class C4Relationship {
  final String from;
  final String to;
  final String label;
  final C4RelationType type;
  final String? technology;
  final String? description;

  C4Relationship({
    required this.from,
    required this.to,
    required this.label,
    this.type = C4RelationType.relationship,
    this.technology,
    this.description,
  });
}

class C4Boundary {
  final String id;
  final String label;
  final String? type;
  final List<String> children;
  Rect bounds;

  C4Boundary({
    required this.id,
    required this.label,
    this.type,
    this.children = const [],
    this.bounds = Rect.zero,
  });
}

class C4Diagram {
  final C4DiagramType type;
  final String title;
  final List<C4Element> elements;
  final List<C4Relationship> relationships;
  final List<C4Boundary> boundaries;
  final String rawCode;

  C4Diagram({
    required this.type,
    this.title = '',
    this.elements = const [],
    this.relationships = const [],
    this.boundaries = const [],
    required this.rawCode,
  });
}

// ==================== C4 PARSER ====================

class C4Parser {
  static C4Diagram parse(String code) {
    final lines = code.trim().split('\n').map((e) => e.trim()).where((e) => e.isNotEmpty).toList();
    
    if (lines.isEmpty) {
      return C4Diagram(type: C4DiagramType.context, rawCode: code);
    }

    final firstLine = lines[0].toLowerCase();
    C4DiagramType diagramType = C4DiagramType.context;
    
    if (firstLine.contains('c4context')) {
      diagramType = C4DiagramType.context;
    } else if (firstLine.contains('c4container')) {
      diagramType = C4DiagramType.container;
    } else if (firstLine.contains('c4component')) {
      diagramType = C4DiagramType.component;
    } else if (firstLine.contains('c4dynamic')) {
      diagramType = C4DiagramType.dynamic;
    } else if (firstLine.contains('c4deployment')) {
      diagramType = C4DiagramType.deployment;
    }

    final elements = <C4Element>[];
    final relationships = <C4Relationship>[];
    final boundaries = <C4Boundary>[];
    String title = '';

    for (var i = 0; i < lines.length; i++) {
      final line = lines[i].trim();
      if (line.isEmpty || line.startsWith('%%')) continue;

      // Parse title
      if (line.toLowerCase().startsWith('title')) {
        title = line.substring(5).trim();
        continue;
      }

      // Parse Person
      if (line.startsWith('Person(') || line.startsWith('Person_Ext(')) {
        elements.add(_parsePerson(line));
        continue;
      }

      // Parse System
      if (line.contains('System(') || line.contains('SystemDb(') || 
          line.contains('SystemQueue(') || line.contains('System_Ext(') ||
          line.contains('SystemDb_Ext(') || line.contains('SystemQueue_Ext(')) {
        elements.add(_parseSystem(line));
        continue;
      }

      // Parse Container
      if (line.contains('Container(') || line.contains('ContainerDb(') || 
          line.contains('ContainerQueue(') || line.contains('Container_Ext(') ||
          line.contains('ContainerDb_Ext(') || line.contains('ContainerQueue_Ext(')) {
        elements.add(_parseContainer(line));
        continue;
      }

      // Parse Component
      if (line.contains('Component(') || line.contains('ComponentDb(') || 
          line.contains('ComponentQueue(') || line.contains('Component_Ext(') ||
          line.contains('ComponentDb_Ext(') || line.contains('ComponentQueue_Ext(')) {
        elements.add(_parseComponent(line));
        continue;
      }

      // Parse Boundary
      if (line.startsWith('Boundary(') || line.startsWith('Enterprise_Boundary(') ||
          line.startsWith('System_Boundary(') || line.startsWith('Container_Boundary(')) {
        boundaries.add(_parseBoundary(line));
        continue;
      }

      // Parse Relationships
      if (line.startsWith('Rel(') || line.startsWith('BiRel(') || 
          line.startsWith('Rel_Down(') || line.startsWith('Rel_Up(') ||
          line.startsWith('Rel_Left(') || line.startsWith('Rel_Right(')) {
        relationships.add(_parseRelationship(line));
        continue;
      }
    }

    // Auto-layout elements
    _layoutElements(elements, boundaries, diagramType);

    return C4Diagram(
      type: diagramType,
      title: title,
      elements: elements,
      relationships: relationships,
      boundaries: boundaries,
      rawCode: code,
    );
  }

  static C4Element _parsePerson(String line) {
    final isExternal = line.startsWith('Person_Ext(');
    final match = RegExp(r'\(([^,]+),\s*"([^"]+)"(?:,\s*"([^"]*)")?(?:,\s*"([^"]*)")?\)').firstMatch(line);
    
    if (match != null) {
      return C4Element(
        id: match.group(1)!.trim(),
        alias: match.group(1)!.trim(),
        label: match.group(2)!.trim(),
        type: isExternal ? C4ElementType.systemExt : C4ElementType.person,
        description: match.group(3)?.trim(),
        technology: match.group(4)?.trim(),
        size: const Size(200, 240),
      );
    }
    
    return C4Element(
      id: 'unknown',
      alias: 'unknown',
      label: 'Unknown Person',
      type: C4ElementType.person,
    );
  }

  static C4Element _parseSystem(String line) {
    C4ElementType type = C4ElementType.system;
    
    if (line.contains('SystemDb_Ext(')) {
      type = C4ElementType.systemDbExt;
    } else if (line.contains('SystemQueue_Ext(')) {
      type = C4ElementType.systemQueueExt;
    } else if (line.contains('System_Ext(')) {
      type = C4ElementType.systemExt;
    } else if (line.contains('SystemDb(')) {
      type = C4ElementType.systemDb;
    } else if (line.contains('SystemQueue(')) {
      type = C4ElementType.systemQueue;
    }

    final match = RegExp(r'\(([^,]+),\s*"([^"]+)"(?:,\s*"([^"]*)")?(?:,\s*"([^"]*)")?\)').firstMatch(line);
    
    if (match != null) {
      return C4Element(
        id: match.group(1)!.trim(),
        alias: match.group(1)!.trim(),
        label: match.group(2)!.trim(),
        type: type,
        description: match.group(3)?.trim(),
        technology: match.group(4)?.trim(),
      );
    }
    
    return C4Element(
      id: 'unknown',
      alias: 'unknown',
      label: 'Unknown System',
      type: type,
    );
  }

  static C4Element _parseContainer(String line) {
    C4ElementType type = C4ElementType.container;
    
    if (line.contains('ContainerDb_Ext(')) {
      type = C4ElementType.containerDbExt;
    } else if (line.contains('ContainerQueue_Ext(')) {
      type = C4ElementType.containerQueueExt;
    } else if (line.contains('Container_Ext(')) {
      type = C4ElementType.containerExt;
    } else if (line.contains('ContainerDb(')) {
      type = C4ElementType.containerDb;
    } else if (line.contains('ContainerQueue(')) {
      type = C4ElementType.containerQueue;
    }

    final match = RegExp(r'\(([^,]+),\s*"([^"]+)"(?:,\s*"([^"]*)")?(?:,\s*"([^"]*)")?\)').firstMatch(line);
    
    if (match != null) {
      return C4Element(
        id: match.group(1)!.trim(),
        alias: match.group(1)!.trim(),
        label: match.group(2)!.trim(),
        type: type,
        description: match.group(3)?.trim(),
        technology: match.group(4)?.trim(),
      );
    }
    
    return C4Element(
      id: 'unknown',
      alias: 'unknown',
      label: 'Unknown Container',
      type: type,
    );
  }

  static C4Element _parseComponent(String line) {
    C4ElementType type = C4ElementType.component;
    
    if (line.contains('ComponentDb_Ext(')) {
      type = C4ElementType.componentDbExt;
    } else if (line.contains('ComponentQueue_Ext(')) {
      type = C4ElementType.componentQueueExt;
    } else if (line.contains('Component_Ext(')) {
      type = C4ElementType.componentExt;
    } else if (line.contains('ComponentDb(')) {
      type = C4ElementType.componentDb;
    } else if (line.contains('ComponentQueue(')) {
      type = C4ElementType.componentQueue;
    }

    final match = RegExp(r'\(([^,]+),\s*"([^"]+)"(?:,\s*"([^"]*)")?(?:,\s*"([^"]*)")?\)').firstMatch(line);
    
    if (match != null) {
      return C4Element(
        id: match.group(1)!.trim(),
        alias: match.group(1)!.trim(),
        label: match.group(2)!.trim(),
        type: type,
        description: match.group(3)?.trim(),
        technology: match.group(4)?.trim(),
        size: const Size(200, 160),
      );
    }
    
    return C4Element(
      id: 'unknown',
      alias: 'unknown',
      label: 'Unknown Component',
      type: type,
    );
  }

  static C4Boundary _parseBoundary(String line) {
    final match = RegExp(r'\(([^,]+),\s*"([^"]+)"(?:,\s*"([^"]*)")?\)').firstMatch(line);
    
    if (match != null) {
      return C4Boundary(
        id: match.group(1)!.trim(),
        label: match.group(2)!.trim(),
        type: match.group(3)?.trim(),
      );
    }
    
    return C4Boundary(
      id: 'unknown',
      label: 'Unknown Boundary',
    );
  }

  static C4Relationship _parseRelationship(String line) {
    C4RelationType type = C4RelationType.relationship;
    
    if (line.startsWith('BiRel(')) {
      type = C4RelationType.biDirectional;
    } else if (line.startsWith('Rel_Down(')) {
      type = C4RelationType.relationshipDown;
    } else if (line.startsWith('Rel_Up(')) {
      type = C4RelationType.relationshipUp;
    } else if (line.startsWith('Rel_Left(')) {
      type = C4RelationType.relationshipLeft;
    } else if (line.startsWith('Rel_Right(')) {
      type = C4RelationType.relationshipRight;
    }

    final match = RegExp(r'\(([^,]+),\s*([^,]+),\s*"([^"]+)"(?:,\s*"([^"]*)")?(?:,\s*"([^"]*)")?\)').firstMatch(line);
    
    if (match != null) {
      return C4Relationship(
        from: match.group(1)!.trim(),
        to: match.group(2)!.trim(),
        label: match.group(3)!.trim(),
        type: type,
        technology: match.group(4)?.trim(),
        description: match.group(5)?.trim(),
      );
    }
    
    return C4Relationship(
      from: 'unknown',
      to: 'unknown',
      label: 'Unknown',
    );
  }

  static void _layoutElements(List<C4Element> elements, List<C4Boundary> boundaries, C4DiagramType type) {
    if (elements.isEmpty) return;

    final internalElements = elements.where((e) => !e.isExternal).toList();
    final externalElements = elements.where((e) => e.isExternal).toList();

    const startX = 100.0;
    const startY = 150.0;
    const spacingX = 300.0;
    const spacingY = 280.0;

    // Layout internal elements in grid
    final cols = math.sqrt(internalElements.length).ceil();
    for (var i = 0; i < internalElements.length; i++) {
      final row = i ~/ cols;
      final col = i % cols;
      internalElements[i].position = Offset(
        startX + col * spacingX,
        startY + row * spacingY,
      );
    }

    // Layout external elements around the perimeter
    final perimeter = externalElements.length;
    for (var i = 0; i < externalElements.length; i++) {
      final angle = (i / perimeter) * 2 * math.pi - math.pi / 2;
      final radius = 500.0;
      final centerX = startX + (cols - 1) * spacingX / 2;
      final centerY = startY + ((internalElements.length / cols).ceil() - 1) * spacingY / 2;
      
      externalElements[i].position = Offset(
        centerX + radius * math.cos(angle),
        centerY + radius * math.sin(angle),
      );
    }

    // Calculate boundary bounds
    for (final boundary in boundaries) {
      final boundaryElements = elements.where((e) => 
        boundary.children.contains(e.id) || boundary.children.contains(e.alias)
      ).toList();

      if (boundaryElements.isNotEmpty) {
        double minX = double.infinity;
        double minY = double.infinity;
        double maxX = double.negativeInfinity;
        double maxY = double.negativeInfinity;

        for (final elem in boundaryElements) {
          minX = math.min(minX, elem.position.dx);
          minY = math.min(minY, elem.position.dy);
          maxX = math.max(maxX, elem.position.dx + elem.size.width);
          maxY = math.max(maxY, elem.position.dy + elem.size.height);
        }

        boundary.bounds = Rect.fromLTRB(
          minX - 40,
          minY - 60,
          maxX + 40,
          maxY + 40,
        );
      }
    }
  }
}

// ==================== STATE MANAGEMENT ====================

class C4State {
  final String code;
  final C4Diagram diagram;
  final String? error;

  C4State({
    required this.code,
    required this.diagram,
    this.error,
  });

  C4State copyWith({
    String? code,
    C4Diagram? diagram,
    String? error,
  }) {
    return C4State(
      code: code ?? this.code,
      diagram: diagram ?? this.diagram,
      error: error,
    );
  }
}

class C4Notifier extends StateNotifier<C4State> {
  C4Notifier()
      : super(C4State(
          code: '''C4Context
title System Context diagram for Internet Banking System

Person(customer, "Personal Banking Customer", "A customer of the bank")
System(banking_system, "Internet Banking System", "Allows customers to view information about their bank accounts")
System_Ext(mail_system, "E-mail system", "The internal Microsoft Exchange e-mail system")
System_Ext(mainframe, "Mainframe Banking System", "Stores all of the core banking information")

Rel(customer, banking_system, "Uses")
Rel_Back(customer, mail_system, "Sends e-mails to")
Rel_Neighbor(banking_system, mail_system, "Sends e-mails", "SMTP")
Rel(banking_system, mainframe, "Uses")''',
          diagram: C4Parser.parse('''C4Context
title System Context diagram for Internet Banking System

Person(customer, "Personal Banking Customer", "A customer of the bank")
System(banking_system, "Internet Banking System", "Allows customers to view information about their bank accounts")
System_Ext(mail_system, "E-mail system", "The internal Microsoft Exchange e-mail system")
System_Ext(mainframe, "Mainframe Banking System", "Stores all of the core banking information")

Rel(customer, banking_system, "Uses")
Rel_Back(customer, mail_system, "Sends e-mails to")
Rel_Neighbor(banking_system, mail_system, "Sends e-mails", "SMTP")
Rel(banking_system, mainframe, "Uses")'''),
        ));

  void updateCode(String newCode) {
    try {
      final diagram = C4Parser.parse(newCode);
      state = C4State(code: newCode, diagram: diagram);
    } catch (e) {
      state = state.copyWith(error: e.toString());
    }
  }

  void loadTemplate(String template) {
    updateCode(template);
  }
}

final c4Provider = StateNotifierProvider<C4Notifier, C4State>((ref) {
  return C4Notifier();
});

final isEditModeProvider = StateProvider<bool>((ref) => true);

