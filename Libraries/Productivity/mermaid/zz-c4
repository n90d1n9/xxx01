// ==================== C4 PAINTER ====================

class C4DiagramPainter extends StatelessWidget {
  final C4Diagram diagram;

  const C4DiagramPainter({super.key, required this.diagram});

  @override
  Widget build(BuildContext context) {
    return CustomPaint(
      size: const Size(1400, 1000),
      painter: _C4DiagramCustomPainter(diagram),
    );
  }
}

class _C4DiagramCustomPainter extends CustomPainter {
  final C4Diagram diagram;

  _C4DiagramCustomPainter(this.diagram);

  @override
  void paint(Canvas canvas, Size size) {
    // Draw title
    if (diagram.title.isNotEmpty) {
      _drawText(
        canvas,
        diagram.title,
        Offset(size.width / 2, 40),
        size.width - 100,
        fontSize: 24,
        fontWeight: FontWeight.bold,
      );
    }

    // Draw boundaries first
    for (final boundary in diagram.boundaries) {
      _drawBoundary(canvas, boundary);
    }

    // Draw relationships
    for (final rel in diagram.relationships) {
      final fromElem = diagram.elements.firstWhere(
        (e) => e.id == rel.from || e.alias == rel.from,
        orElse: () => diagram.elements.first,
      );
      final toElem = diagram.elements.firstWhere(
        (e) => e.id == rel.to || e.alias == rel.to,
        orElse: () => diagram.elements.first,
      );
      _drawRelationship(canvas, fromElem, toElem, rel);
    }

    // Draw elements
    for (final element in diagram.elements) {
      _drawElement(canvas, element);
    }
  }

  void _drawBoundary(Canvas canvas, C4Boundary boundary) {
    if (boundary.bounds == Rect.zero) return;

    final paint = Paint()
      ..color = Colors.grey[300]!.withOpacity(0.3)
      ..style = PaintingStyle.fill;

    final borderPaint = Paint()
      ..color = Colors.grey[500]!
      ..strokeWidth = 2.0
      ..style = PaintingStyle.stroke
      ..strokeDashArray = [8, 4];

    final rrect = RRect.fromRectAndRadius(boundary.bounds, const Radius.circular(12));
    canvas.drawRRect(rrect, paint);
    _drawDashedRRect(canvas, rrect, borderPaint);

    // Draw boundary label
    _drawText(
      canvas,
      boundary.label,
      Offset(boundary.bounds.left + 20, boundary.bounds.top + 20),
      boundary.bounds.width - 40,
      fontSize: 16,
      fontWeight: FontWeight.bold,
      align: TextAlign.left,
      textColor: Colors.grey[700]!,
    );
  }

  void _drawElement(Canvas canvas, C4Element element) {
    final rect = Rect.fromLTWH(
      element.position.dx,
      element.position.dy,
      element.size.width,
      element.size.height,
    );

    // Determine colors based on element type
    Color fillColor;
    Color borderColor;
    IconData? icon;

    if (element.isPerson) {
      fillColor = element.isExternal ? Colors.grey[300]! : Colors.blue[300]!;
      borderColor = element.isExternal ? Colors.grey[700]! : Colors.blue[800]!;
      icon = Icons.person;
    } else if (element.isDatabase) {
      fillColor = element.isExternal ? Colors.grey[300]! : Colors.cyan[300]!;
      borderColor = element.isExternal ? Colors.grey[700]! : Colors.cyan[800]!;
      icon = Icons.storage;
    } else if (element.isQueue) {
      fillColor = element.isExternal ? Colors.grey[300]! : Colors.orange[300]!;
      borderColor = element.isExternal ? Colors.grey[700]! : Colors.orange[800]!;
      icon = Icons.queue;
    } else {
      fillColor = element.isExternal ? Colors.grey[300]! : Colors.lightBlue[200]!;
      borderColor = element.isExternal ? Colors.grey[700]! : Colors.blue[700]!;
      icon = Icons.apps;
    }

    final paint = Paint()..color = fillColor;
    final borderPaint = Paint()
      ..color = borderColor
      ..strokeWidth = 2.5
      ..style = PaintingStyle.stroke;

    // Draw person shape (special case)
    if (element.isPerson) {
      _drawPersonShape(canvas, rect, paint, borderPaint, element);
    } else if (element.isDatabase) {
      _drawDatabaseShape(canvas, rect, paint, borderPaint, element);
    } else if (element.isQueue) {
      _drawQueueShape(canvas, rect, paint, borderPaint, element);
    } else {
      _drawBoxShape(canvas, rect, paint, borderPaint, element);
    }
  }

  void _drawPersonShape(Canvas canvas, Rect rect, Paint fillPaint, Paint borderPaint, C4Element element) {
    // Draw head
    final headCenter = Offset(rect.center.dx, rect.top + 40);
    final headRadius = 25.0;
    
    canvas.drawCircle(headCenter, headRadius, fillPaint);
    canvas.drawCircle(headCenter, headRadius, borderPaint);

    // Draw body box
    final bodyRect = Rect.fromLTWH(
      rect.left + 20,
      rect.top + 75,
      rect.width - 40,
      rect.height - 85,
    );

    canvas.drawRRect(
      RRect.fromRectAndRadius(bodyRect, const Radius.circular(8)),
      fillPaint,
    );
    canvas.drawRRect(
      RRect.fromRectAndRadius(bodyRect, const Radius.circular(8)),
      borderPaint,
    );

    // Draw labels
    _drawElementLabels(canvas, bodyRect, element);
  }

  void _drawDatabaseShape(Canvas canvas, Rect rect, Paint fillPaint, Paint borderPaint, C4Element element) {
    const topHeight = 20.0;
    
    // Draw top ellipse
    final topRect = Rect.fromLTWH(rect.left, rect.top, rect.width, topHeight);
    canvas.drawOval(topRect, fillPaint);
    canvas.drawOval(topRect, borderPaint);

    // Draw cylinder body
    final path = Path()
      ..moveTo(rect.left, rect.top + topHeight / 2)
      ..lineTo(rect.left, rect.bottom - topHeight / 2)
      ..arcToPoint(
        Offset(rect.right, rect.bottom - topHeight / 2),
        radius: Radius.circular(rect.width / 2),
      )
      ..lineTo(rect.right, rect.top + topHeight / 2);

    canvas.drawPath(path, fillPaint);
    canvas.drawPath(path, borderPaint);

    // Draw icon
    _drawIcon(canvas, Icons.storage, Offset(rect.center.dx, rect.top + 50), borderPaint.color);

    // Draw labels
    final labelRect = Rect.fromLTWH(rect.left + 10, rect.top + 80, rect.width - 20, rect.height - 90);
    _drawElementLabels(canvas, labelRect, element);
  }

  void _drawQueueShape(Canvas canvas, Rect rect, Paint fillPaint, Paint borderPaint, C4Element element) {
    // Draw main rectangle
    canvas.drawRRect(
      RRect.fromRectAndRadius(rect, const Radius.circular(8)),
      fillPaint,
    );
    canvas.drawRRect(
      RRect.fromRectAndRadius(rect, const Radius.circular(8)),
      borderPaint,
    );

    // Draw queue lines
    const lineSpacing = 8.0;
    final lineCount = 3;
    final startY = rect.top + 30;

    for (var i = 0; i < lineCount; i++) {
      final y = startY + i * lineSpacing;
      canvas.drawLine(
        Offset(rect.left + 20, y),
        Offset(rect.right - 20, y),
        borderPaint,
      );
    }

    // Draw icon
    _drawIcon(canvas, Icons.queue, Offset(rect.center.dx, rect.top + 60), borderPaint.color);

    // Draw labels
    final labelRect = Rect.fromLTWH(rect.left + 10, rect.top + 90, rect.width - 20, rect.height - 100);
    _drawElementLabels(canvas, labelRect, element);
  }

  void _drawBoxShape(Canvas canvas, Rect rect, Paint fillPaint, Paint borderPaint, C4Element element) {
    canvas.drawRRect(
      RRect.fromRectAndRadius(rect, const Radius.circular(8)),
      fillPaint,
    );
    canvas.drawRRect(
      RRect.fromRectAndRadius(rect, const Radius.circular(8)),
      borderPaint,
    );

    // Draw icon
    _drawIcon(canvas, Icons.apps, Offset(rect.center.dx, rect.top + 30), borderPaint.color);

    // Draw labels
    final labelRect = Rect.fromLTWH(rect.left + 10, rect.top + 60, rect.width - 20, rect.height - 70);
    _drawElementLabels(canvas, labelRect, element);
  }

  void _drawElementLabels(Canvas canvas, Rect rect, C4Element element) {
    var currentY = rect.top + 10;

    // Draw label (title)
    _drawText(
      canvas,
      element.label,
      Offset(rect.center.dx, currentY),
      rect.width - 20,
      fontSize: 14,
      fontWeight: FontWeight.bold,
    );
    currentY += 30;

    // Draw technology
    if (element.technology != null && element.technology!.isNotEmpty) {
      _drawText(
        canvas,
        '[${element.technology}]',
        Offset(rect.center.dx, currentY),
        rect.width - 20,
        fontSize: 11,
        textColor: Colors.grey[700]!,
      );
      currentY += 25;
    }

    // Draw description
    if (element.description != null && element.description!.isNotEmpty) {
      _drawText(
        canvas,
        element.description!,
        Offset(rect.center.dx, currentY),
        rect.width - 20,
        fontSize: 10,
        textColor: Colors.grey[600]!,
      );
    }
  }

  void _drawIcon(Canvas canvas, IconData iconData, Offset position, Color color) {
    final textPainter = TextPainter(
      text: TextSpan(
        text: String.fromCharCode(iconData.codePoint),
        style: TextStyle(
          fontFamily: iconData.fontFamily,
          fontSize: 24,
          color: color,
        ),
      ),
      textDirection: TextDirection.ltr,
    )..layout();

    textPainter.paint(
      canvas,
      Offset(position.dx - textPainter.width / 2, position.dy - textPainter.height / 2),
    );
  }

  void _drawRelationship(Canvas canvas, C4Element from, C4Element to, C4Relationship rel) {
    final fromCenter = Offset(
      from.position.dx + from.size.width / 2,
      from.position.dy + from.size.height / 2,
    );
    final toCenter = Offset(
      to.position.dx + to.size.width / 2,
      to.position.dy + to.size.height / 2,
    );

    // Calculate edge points
    final fromPoint = _getEdgePoint(from, toCenter);
    final toPoint = _getEdgePoint(to, fromCenter);

    final paint = Paint()
      ..color = Colors.black87
      ..strokeWidth = 2.0
      ..style = PaintingStyle.stroke;

    // Draw line
    canvas.drawLine(fromPoint, toPoint, paint);

    // Draw arrow
    _drawArrow(canvas, fromPoint, toPoint, paint.color);

    // Draw bidirectional arrow if needed
    if (rel.type == C4RelationType.biDirectional) {
      _drawArrow(canvas, toPoint, fromPoint, paint.color);
    }

    // Draw label
    final midPoint = Offset(
      (fromPoint.dx + toPoint.dx) / 2,
      (fromPoint.dy + toPoint.dy) / 2,
    );

    final labelParts = <String>[];
    labelParts.add(rel.label);
    if (rel.technology != null && rel.technology!.isNotEmpty) {
      labelParts.add('[${rel.technology}]');
    }

    final labelText = labelParts.join('\n');

    _drawText(
      canvas,
      labelText,
      midPoint,
      200,
      fontSize: 11,
      bgColor: Colors.white,
      textColor: Colors.black87,
    );
  }

  Offset _getEdgePoint(C4Element element, Offset targetCenter) {
    final elementCenter = Offset(
      element.position.dx + element.size.width / 2,
      element.position.dy + element.size.height / 2,
    );

    final angle = math.atan2(
      targetCenter.dy - elementCenter.dy,
      targetCenter.dx - elementCenter.dx,
    );

    final halfWidth = element.size.width / 2;
    final halfHeight = element.size.height / 2;

    // Determine which edge of the rectangle to use
    final absAngle = angle.abs();
    final threshold = math.atan2(halfHeight, halfWidth);

    Offset edgePoint;

    if (absAngle <= threshold) {
      // Right edge
      edgePoint = Offset(
        elementCenter.dx + halfWidth,
        elementCenter.dy + halfWidth * math.tan(angle),
      );
    } else if (absAngle >= math.pi - threshold) {
      // Left edge
      edgePoint = Offset(
        elementCenter.dx - halfWidth,
        elementCenter.dy - halfWidth * math.tan(angle),
      );
    } else if (angle > 0) {
      // Bottom edge
      edgePoint = Offset(
        elementCenter.dx + halfHeight / math.tan(angle),
        elementCenter.dy + halfHeight,
      );
    } else {
      // Top edge
      edgePoint = Offset(
        elementCenter.dx - halfHeight / math.tan(angle),
        elementCenter.dy - halfHeight,
      );
    }

    return edgePoint;
  }

  void _drawArrow(Canvas canvas, Offset from, Offset to, Color color) {
    final paint = Paint()
      ..color = color
      ..style = PaintingStyle.fill;

    const arrowSize = 12.0;
    final angle = math.atan2(to.dy - from.dy, to.dx - from.dx);

    final path = Path()
      ..moveTo(to.dx, to.dy)
      ..lineTo(
        to.dx - arrowSize * math.cos(angle - math.pi / 6),
        to.dy - arrowSize * math.sin(angle - math.pi / 6),
      )
      ..lineTo(
        to.dx - arrowSize * math.cos(angle + math.pi / 6),
        to.dy - arrowSize * math.sin(angle + math.pi / 6),
      )
      ..close();

    canvas.drawPath(path, paint);
  }

  void _drawDashedRRect(Canvas canvas, RRect rrect, Paint paint) {
    const dashWidth = 8.0;
    const dashSpace = 4.0;
    final path = Path()..addRRect(rrect);
    
    for (final metric in path.computeMetrics()) {
      var distance = 0.0;
      while (distance < metric.length) {
        final start = metric.getTangentForOffset(distance);
        final end = metric.getTangentForOffset(math.min(distance + dashWidth, metric.length));
        if (start != null && end != null) {
          canvas.drawLine(start.position, end.position, paint);
        }
        distance += dashWidth + dashSpace;
      }
    }
  }

  void _drawText(
    Canvas canvas,
    String text,
    Offset position,
    double maxWidth, {
    double fontSize = 13,
    FontWeight fontWeight = FontWeight.normal,
    TextAlign align = TextAlign.center,
    Color textColor = Colors.black87,
    Color? bgColor,
  }) {
    final textPainter = TextPainter(
      text: TextSpan(
        text: text,
        style: TextStyle(
          color: textColor,
          fontSize: fontSize,
          fontWeight: fontWeight,
          backgroundColor: bgColor,
        ),
      ),
      textAlign: align,
      textDirection: TextDirection.ltr,
    )..layout(maxWidth: maxWidth);

    final offset = align == TextAlign.center
        ? Offset(
            position.dx - textPainter.width / 2,
            position.dy - textPainter.height / 2,
          )
        : Offset(position.dx, position.dy - textPainter.height / 2);

    textPainter.paint(canvas, offset);
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => true;
}

