class AgendaItemsNotifier extends StateNotifier<AsyncValue<List<AgendaItem>>> {
  final StorageService _storage;

  AgendaItemsNotifier(this._storage) : super(const AsyncValue.loading()) {
    _loadItems();
  }

  Future<void> _loadItems() async {
    try {
      final items = await _storage.loadItems();
      if (items.isEmpty) {
        state = AsyncValue.data(_getInitialItems());
        await _saveItems();
      } else {
        state = AsyncValue.data(items);
      }
    } catch (e, stack) {
      state = AsyncValue.error(e, stack);
    }
  }

  List<AgendaItem> _getInitialItems() {
    final now = DateTime.now();
    return [
      AgendaItem(
        id: '1',
        title: 'Team Standup',
        description: 'Daily team sync meeting',
        startTime: DateTime(now.year, now.month, now.day, 9, 0),
        endTime: DateTime(now.year, now.month, now.day, 9, 30),
        color: Colors.blue,
        category: 'Meeting',
        location: 'Conference Room A',
        tags: ['recurring', 'team'],
        priority: Priority.high,
      ),
      AgendaItem(
        id: '2',
        title: 'Lunch with Sarah',
        description: 'Catch up lunch',
        startTime: DateTime(now.year, now.month, now.day, 12, 30),
        endTime: DateTime(now.year, now.month, now.day, 13, 30),
        color: Colors.purple,
        category: 'Personal',
        location: 'Downtown Cafe',
        tags: ['social'],
        priority: Priority.medium,
      ),
      AgendaItem(
        id: '3',
        title: 'Gym Workout',
        description: 'Leg day training',
        startTime: DateTime(now.year, now.month, now.day, 18, 0),
        endTime: DateTime(now.year, now.month, now.day, 19, 30),
        color: Colors.red,
        category: 'Health',
        location: 'Fitness Center',
        tags: ['exercise', 'routine'],
        priority: Priority.medium,
      ),
    ];
  }

  Future<void> _saveItems() async {
    final items = state.valueOrNull ?? [];
    await _storage.saveItems(items);
  }

  Future<void> addItem(AgendaItem item) async {
    state = AsyncValue.data([...?state.valueOrNull, item]);
    await _saveItems();
  }

  Future<void> updateItem(AgendaItem item) async {
    final items = state.valueOrNull ?? [];
    state = AsyncValue.data([
      for (final i in items)
        if (i.id == item.id) item else i,
    ]);
    await _saveItems();
  }

  Future<void> deleteItem(String id) async {
    final items = state.valueOrNull ?? [];
    state = AsyncValue.data(items.where((item) => item.id != id).toList());
    await _saveItems();
  }

  Future<void> toggleComplete(String id) async {
    final items = state.valueOrNull ?? [];
    state = AsyncValue.data([
      for (final item in items)
        if (item.id == id)
          item.copyWith(isCompleted: !item.isCompleted)
        else
          item,
    ]);
    await _saveItems();
  }
}

// Filtered Items Provider
final filteredItemsProvider = Provider<List<AgendaItem>>((ref) {
  final itemsAsync = ref.watch(agendaItemsProvider);
  final searchQuery = ref.watch(searchQueryProvider).toLowerCase();
  final selectedCategories = ref.watch(selectedCategoriesProvider);
  final showCompleted = ref.watch(showCompletedProvider);

  return itemsAsync.when(
    data: (items) {
      var filtered = items;

      if (searchQuery.isNotEmpty) {
        filtered = filtered.where((item) {
          return item.title.toLowerCase().contains(searchQuery) ||
              item.description.toLowerCase().contains(searchQuery) ||
              item.tags.any((tag) => tag.toLowerCase().contains(searchQuery));
        }).toList();
      }

      if (selectedCategories.isNotEmpty) {
        filtered =
            filtered.where((item) => selectedCategories.contains(item.category)).toList();
      }

      if (!showCompleted) {
        filtered = filtered.where((item) => !item.isCompleted).toList();
      }

      return filtered;
    },
    loading: () => [],
    error: (_, __) => [],
  );
});

// Statistics Provider
final statisticsProvider = Provider<Map<String, dynamic>>((ref) {
  final items = ref.watch(agendaItemsProvider).valueOrNull ?? [];
  final now = DateTime.now();
  final today = DateTime(now.year, now.month, now.day);

  final todayItems = items.where((item) {
    final itemDate = DateTime(
      item.startTime.year,
      item.startTime.month,
      item.startTime.day,
    );
    return itemDate == today;
  }).toList();

  final completedToday = todayItems.where((item) => item.isCompleted).length;
  final totalToday = todayItems.length;
  final upcomingToday = todayItems.where((item) {
    return item.startTime.isAfter(now) && !item.isCompleted;
  }).length;

  return {
    'totalToday': totalToday,
    'completedToday': completedToday,
    'upcomingToday': upcomingToday,
    'completionRate': totalToday > 0 ? (completedToday / totalToday) * 100 : 0.0,
  };
});

