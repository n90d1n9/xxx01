      endTime: _endTime,
      color: _selectedColor,
      category: _selectedCategory,
      location: _locationController.text.isEmpty ? null : _locationController.text,
      tags: _tags,
      priority: _selectedPriority,
      isCompleted: widget.editItem?.isCompleted ?? false,
