import 'package:flutter/material.dart';
import 'package:flutter_riverpod/legacy.dart';
import 'package:intl/intl.dart';

// Models
class AgendaItem {
  final String id;
  final String title;
  final String description;
  final DateTime startTime;
  final DateTime endTime;
  final Color color;
  final String category;

  AgendaItem({
    required this.id,
    required this.title,
    required this.description,
    required this.startTime,
    required this.endTime,
    required this.color,
    required this.category,
  });

  AgendaItem copyWith({
    String? id,
    String? title,
    String? description,
    DateTime? startTime,
    DateTime? endTime,
    Color? color,
    String? category,
  }) {
    return AgendaItem(
      id: id ?? this.id,
      title: title ?? this.title,
      description: description ?? this.description,
      startTime: startTime ?? this.startTime,
      endTime: endTime ?? this.endTime,
      color: color ?? this.color,
      category: category ?? this.category,
    );
  }
}

enum ViewMode { day, week, month }

// State Providers
final selectedDateProvider = StateProvider<DateTime>((ref) => DateTime.now());
final viewModeProvider = StateProvider<ViewMode>((ref) => ViewMode.day);

// Agenda Items Provider
final agendaItemsProvider = StateNotifierProvider<AgendaItemsNotifier, List<AgendaItem>>((ref) {
  return AgendaItemsNotifier();
});

class AgendaItemsNotifier extends StateNotifier<List<AgendaItem>> {
  AgendaItemsNotifier() : super(_initialItems());

  static List<AgendaItem> _initialItems() {
    final now = DateTime.now();
    return [
      AgendaItem(
        id: '1',
        title: 'Team Meeting',
        description: 'Discuss Q4 objectives',
        startTime: DateTime(now.year, now.month, now.day, 9, 0),
        endTime: DateTime(now.year, now.month, now.day, 10, 30),
        color: Colors.blue,
        category: 'Work',
      ),
      AgendaItem(
        id: '2',
        title: 'Lunch Break',
        description: 'Healthy meal',
        startTime: DateTime(now.year, now.month, now.day, 12, 0),
        endTime: DateTime(now.year, now.month, now.day, 13, 0),
        color: Colors.orange,
        category: 'Personal',
      ),
      AgendaItem(
        id: '3',
        title: 'Gym Session',
        description: 'Upper body workout',
        startTime: DateTime(now.year, now.month, now.day, 18, 0),
        endTime: DateTime(now.year, now.month, now.day, 19, 30),
        color: Colors.green,
        category: 'Health',
      ),
      AgendaItem(
        id: '4',
        title: 'Project Review',
        description: 'Review sprint progress',
        startTime: DateTime(now.year, now.month, now.day + 1, 14, 0),
        endTime: DateTime(now.year, now.month, now.day + 1, 15, 30),
        color: Colors.purple,
        category: 'Work',
      ),
    ];
  }

  void addItem(AgendaItem item) {
    state = [...state, item];
  }

  void updateItem(AgendaItem item) {
    state = [
      for (final i in state)
        if (i.id == item.id) item else i,
    ];
  }

  void deleteItem(String id) {
    state = state.where((item) => item.id != id).toList();
  }
}

