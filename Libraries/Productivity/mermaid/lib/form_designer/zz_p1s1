          const Text(
            'PROPERTIES',
            style: TextStyle(
              color: Colors.white70,
              fontSize: 12,
              fontWeight: FontWeight.bold,
            ),
          ),
          const SizedBox(height: 16),
          const Text('Label', style: TextStyle(color: Colors.white)),
