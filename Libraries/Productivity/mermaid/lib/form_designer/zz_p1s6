// ============================================================================

class PropertiesPanel extends ConsumerWidget {
  const PropertiesPanel({Key? key}) : super(key: key);

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final selectedField = ref.watch(selectedFieldProvider);

    if (selectedField == null) {
      return Container(
        width: 300,
        color: const Color(0xFF252526),
        child: const Center(
          child: Text('No field selected', style: TextStyle(color: Colors.white54)),
        ),
      );
    }

    return Container(
      width: 300,
      color: const Color(0xFF252526),
      padding: const EdgeInsets.all(16),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text(
            'PROPERTIES',
            style: TextStyle(
              color: Colors.white70,
              fontSize: 12,
              fontWeight: FontWeight.bold,
            ),
          ),
          const SizedBox(height: 16),
          const Text('Label', style: TextStyle(color: Colors.white)),
          const SizedBox(height: 8),
          TextField(
            controller: TextEditingController(text: selectedField.label ?? ''),
            style: const TextStyle(color: Colors.white),
            decoration: InputDecoration(
              filled: true,
              fillColor: const Color(0xFF1E1E1E),
              border: OutlineInputBorder(borderRadius: BorderRadius.circular(6)),
            ),
            onChanged: (value) {
              ref.read(formFieldsProvider.notifier).updateField(
                    selectedField.id,
                    selectedField.copyWith(label: value),
                  );
            },
          ),
        ],
      ),
    );
  }
}

