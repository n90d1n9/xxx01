final historyManagerProvider = StateNotifierProvider<HistoryManager, HistoryState>((ref) {
  return HistoryManager();
});

final formFieldsProvider = StateNotifierProvider<FormFieldsNotifier, List<FieldConfig>>((ref) {
  return FormFieldsNotifier(ref);
});

