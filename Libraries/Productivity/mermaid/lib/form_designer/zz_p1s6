            tooltip: 'Undo (Ctrl+Z)',
            onPressed: canUndo ? () {
              ref.read(historyManagerProvider.notifier).undo();
            } : null,
          ),
          // Redo button
          IconButton(
            icon: const Icon(Icons.redo),
            tooltip: 'Redo (Ctrl+Y)',
            onPressed: canRedo ? () {
              ref.read(historyManagerProvider.notifier).redo();
            } : null,
          ),
          // History viewer
          IconButton(
            icon: const Icon(Icons.history),
            tooltip: 'History',
            onPressed: () => _showHistory(context, ref),
          ),
          const VerticalDivider(),
          IconButton(
            icon: const Icon(Icons.code),
            tooltip: 'Export',
            onPressed: () => _showExportDialog(context, ref),
          ),
        ],
      ),
      body: Focus(
        autofocus: true,
        onKey: (node, event) {
          if (event is RawKeyDownEvent) {
            // Ctrl+Z for Undo
            if (event.isControlPressed && event.logicalKey == LogicalKeyboardKey.keyZ) {
              if (canUndo) ref.read(historyManagerProvider.notifier).undo();
              return KeyEventResult.handled;
            }
            // Ctrl+Y or Ctrl+Shift+Z for Redo
            if (event.isControlPressed && 
                (event.logicalKey == LogicalKeyboardKey.keyY ||
                 (event.isShiftPressed && event.logicalKey == LogicalKeyboardKey.keyZ))) {
              if (canRedo) ref.read(historyManagerProvider.notifier).redo();
              return KeyEventResult.handled;
            }
          }
          return KeyEventResult.ignored;
        },
        child: Row(
          children: [
            const ComponentPalette(),
            const Expanded(child: FormCanvas()),
            const PropertiesPanel(),
          ],
        ),
      ),
    );
  }

  void _showHistory(BuildContext context, WidgetRef ref) {
    final historyState = ref.read(historyManagerProvider);
    
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        backgroundColor: const Color(0xFF2D2D2D),
        title: const Text('History', style: TextStyle(color: Colors.white)),
        content: SizedBox(
          width: 400,
          height: 400,
          child: historyState.history.isEmpty
              ? const Center(
                  child: Text('No history yet', style: TextStyle(color: Colors.white54)),
                )
              : ListView.builder(
                  itemCount: historyState.history.length,
                  itemBuilder: (context, index) {
                    final command = historyState.history[index];
                    final isCurrent = index == historyState.currentIndex;
                    
                    return ListTile(
                      leading: Icon(
                        isCurrent ? Icons.radio_button_checked : Icons.circle_outlined,
                        color: isCurrent ? Colors.blue : Colors.white54,
                        size: 16,
                      ),
                      title: Text(
                        command.description,
                        style: TextStyle(
                          color: isCurrent ? Colors.white : Colors.white54,
                          fontWeight: isCurrent ? FontWeight.bold : FontWeight.normal,
                        ),
                      ),
                      onTap: () {
                        // Jump to this point in history
                        final current = historyState.currentIndex;
                        if (index < current) {
                          for (int i = current; i > index; i--) {
                            ref.read(historyManagerProvider.notifier).undo();
                          }
                        } else if (index > current) {
                          for (int i = current; i < index; i++) {
                            ref.read(historyManagerProvider.notifier).redo();
                          }
                        }
                        Navigator.pop(context);
                      },
                    );
                  },
                ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Close'),
          ),
        ],
      ),
    );
  }

  void _showExportDialog(BuildContext context, WidgetRef ref) {
    final config = ref.read(formFieldsProvider.notifier).exportConfig();

    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        backgroundColor: const Color(0xFF2D2D2D),
        title: const Text('Export Config', style: TextStyle(color: Colors.white)),
        content: SizedBox(
          width: 600,
          height: 400,
          child: SingleChildScrollView(
            child: SelectableText(
              config,
              style: const TextStyle(
                color: Color(0xFF4EC9B0),
                fontFamily: 'monospace',
                fontSize: 12,
              ),
            ),
          ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Close'),
          ),
          ElevatedButton.icon(
            icon: const Icon(Icons.copy),
            label: const Text('Copy'),
            onPressed: () {
              Clipboard.setData(ClipboardData(text: config));
              ScaffoldMessenger.of(context).showSnackBar(
                const SnackBar(content: Text('✅ Copied!')),
              );
            },
          ),
        ],
      ),
    );
  }
}

