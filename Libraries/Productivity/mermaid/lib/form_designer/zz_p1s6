  KeyEventResult _handleKeyEvent(RawKeyEvent event, WidgetRef ref) {
    if (event is! RawKeyDownEvent) return KeyEventResult.ignored;

    final isCtrl = event.isControlPressed;
    final isShift = event.isShiftPressed;
    final key = event.logicalKey;

    // Ctrl+Z - Undo
    if (isCtrl && key == LogicalKeyboardKey.keyZ && !isShift) {
      final canUndo = ref.read(historyManagerProvider).currentIndex >= 0;
      if (canUndo) {
        ref.read(historyManagerProvider.notifier).undo();
        return KeyEventResult.handled;
      }
    }

    // Ctrl+Y or Ctrl+Shift+Z - Redo
    if ((isCtrl && key == LogicalKeyboardKey.keyY) ||
        (isCtrl && isShift && key == LogicalKeyboardKey.keyZ)) {
      final historyState = ref.read(historyManagerProvider);
      final canRedo = historyState.currentIndex < historyState.history.length - 1;
      if (canRedo) {
        ref.read(historyManagerProvider.notifier).redo();
        return KeyEventResult.handled;
      }
    }

    // Ctrl+C - Copy
    if (isCtrl && key == LogicalKeyboardKey.keyC) {
      _handleCopy(ref);
      return KeyEventResult.handled;
    }

    // Ctrl+V - Paste
    if (isCtrl && key == LogicalKeyboardKey.keyV) {
      _handlePaste(ref);
      return KeyEventResult.handled;
    }

    // Ctrl+X - Cut
    if (isCtrl && key == LogicalKeyboardKey.keyX) {
      _handleCopy(ref);
      _handleDelete(ref);
      return KeyEventResult.handled;
    }

    // Delete or Backspace - Delete selected
    if (key == LogicalKeyboardKey.delete || key == LogicalKeyboardKey.backspace) {
      _handleDelete(ref);
      return KeyEventResult.handled;
    }

    // Ctrl+A - Select All
    if (isCtrl && key == LogicalKeyboardKey.keyA) {
      _handleSelectAll(ref);
      return KeyEventResult.handled;
    }

    // Escape - Deselect
    if (key == LogicalKeyboardKey.escape) {
      ref.read(selectedFieldProvider.notifier).state = null;
      ref.read(selectedFieldsProvider.notifier).state = {};
      return KeyEventResult.handled;
    }

    // Ctrl+F - Toggle Search
    if (isCtrl && key == LogicalKeyboardKey.keyF) {
      ref.read(showSearchProvider.notifier).state = !ref.read(showSearchProvider);
      return KeyEventResult.handled;
    }

    // Ctrl+D - Duplicate
    if (isCtrl && key == LogicalKeyboardKey.keyD) {
      final selectedField = ref.read(selectedFieldProvider);
      if (selectedField != null) {
        ref.read(formFieldsProvider.notifier).duplicateField(selectedField);
        return KeyEventResult.handled;
      }
    }

    return KeyEventResult.ignored;
  }

  void _handleCopy(WidgetRef ref) {
    final selectedField = ref.read(selectedFieldProvider);
    final selectedFields = ref.read(selectedFieldsProvider);

    if (selectedFields.isNotEmpty) {
      final fields = ref.read(formFieldsProvider);
      final fieldsToCopy = fields.where((f) => selectedFields.contains(f.id)).toList();
      ref.read(clipboardProvider.notifier).copy(fieldsToCopy);
    } else if (selectedField != null) {
      ref.read(clipboardProvider.notifier).copy([selectedField]);
    }
  }

  void _handlePaste(WidgetRef ref) {
    final clipboard = ref.read(clipboardProvider);
    for (final field in clipboard) {
      final newField = _duplicateFieldRecursive(field);
      ref.read(formFieldsProvider.notifier).addField(newField);
    }
  }

  void _handleDelete(WidgetRef ref) {
    final selectedField = ref.read(selectedFieldProvider);
    final selectedFields = ref.read(selectedFieldsProvider);

    if (selectedFields.isNotEmpty) {
      for (final id in selectedFields) {
        ref.read(formFieldsProvider.notifier).deleteField(id);
      }
      ref.read(selectedFieldsProvider.notifier).state = {};
    } else if (selectedField != null) {
      ref.read(formFieldsProvider.notifier).deleteField(selectedField.id);
      ref.read(selectedFieldProvider.notifier).state = null;
    }
  }

  void _handleSelectAll(WidgetRef ref) {
    final fields = ref.read(formFieldsProvider);
    final allIds = fields.map((f) => f.id).toSet();
    ref.read(selectedFieldsProvider.notifier).state = allIds;
  }

  FieldConfig _duplicateFieldRecursive(FieldConfig field) {
    return field.copyWith(
      id: 'field_${DateTime.now().millisecondsSinceEpoch}_${DateTime.now().microsecond}',
      name: field.name != null ? '${field.name}_copy' : null,
      children: field.children?.map((child) => _duplicateFieldRecursive(child)).toList(),
    );
  }

  void _showHistory(BuildContext context, WidgetRef ref) {
    final historyState = ref.read(historyManagerProvider);
    
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        backgroundColor: const Color(0xFF2D2D2D),
        title: const Text('History', style: TextStyle(color: Colors.white)),
        content: SizedBox(
          width: 400,
          height: 400,
          child: historyState.history.isEmpty
              ? const Center(
                  child: Text('No history yet', style: TextStyle(color: Colors.white54)),
                )
              : ListView.builder(
                  itemCount: historyState.history.length,
                  itemBuilder: (context, index) {
                    final command = historyState.history[index];
                    final isCurrent = index == historyState.currentIndex;
                    
                    return ListTile(
                      leading: Icon(
                        isCurrent ? Icons.radio_button_checked : Icons.circle_outlined,
                        color: isCurrent ? Colors.blue : Colors.white54,
                        size: 16,
                      ),
                      title: Text(
                        command.description,
                        style: TextStyle(
                          color: isCurrent ? Colors.white : Colors.white54,
                          fontWeight: isCurrent ? FontWeight.bold : FontWeight.normal,
                        ),
                      ),
                    );
                  },
                ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Close'),
          ),
        ],
      ),
    );
  }

  void _showExportDialog(BuildContext context, WidgetRef ref) {
    final config = ref.read(formFieldsProvider.notifier).exportConfig();

    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        backgroundColor: const Color(0xFF2D2D2D),
        title: const Text('Export Config', style: TextStyle(color: Colors.white)),
        content: SizedBox(
          width: 600,
          height: 400,
          child: SingleChildScrollView(
            child: SelectableText(
              config,
              style: const TextStyle(
                color: Color(0xFF4EC9B0),
