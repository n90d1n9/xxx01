    switch (iconName) {
      case 'article':
        return Icons.article;
      case 'image':
        return Icons.image;
      case 'video':
        return Icons.video_library;
      case 'person':
        return Icons.person;
      case 'category':
        return Icons.category;
      case 'settings':
        return Icons.settings;
      default:
        return Icons.folder;
    }
