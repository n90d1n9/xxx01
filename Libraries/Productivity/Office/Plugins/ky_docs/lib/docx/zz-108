    this.isFavorite = false,
  });

  DocumentMetadata copyWith({
    String? id,
    String? title,
    DateTime? createdAt,
    DateTime? modifiedAt,
    String? author,
    int? wordCount,
    int? characterCount,
    List<String>? tags,
