const SizedBox(width: 8),
              Text(
                'Slides (${presentation.slides.length})',
                style: const TextStyle(
                  color: Colors.white,
                  fontSize: 14,
                  fontWeight: FontWeight.w600,
                ),
              ),
            ],
          ),
        ),
        Expanded(
          child: ListView.builder(
            padding: const EdgeInsets.all(8),
            itemCount: presentation.slides.length,
            itemBuilder: (context, index) {
              final slide = presentation.slides[index];
              final isActive = index == presentation.currentSlideIndex;
              return GestureDetector(
                onTap: () {
                  ref.read(presentationProvider.notifier).setCurrentSlide(index);
                },
                child: Container(
                  margin: const EdgeInsets.only(bottom: 8),
                  padding: const EdgeInsets.all(8),
                  decoration: BoxDecoration(
                    color: isActive ? const Color(0xFF334155) : const Color(0xFF0F172A),
                    borderRadius: BorderRadius.circular(8),
                    border: isActive
                        ? Border.all(color: const Color(0xFF3B82F6), width: 2)
                        : null,
                  ),
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      Container(
                        height: 80,
                        decoration: BoxDecoration(
                          color: slide.getThemeBackground(),
                          borderRadius: BorderRadius.circular(4),
                        ),
                        child: Center(
                          child: Text(
                            slide.title ?? 'Slide ${index + 1}',
                            style: TextStyle(
                              fontSize: 10,
                              color: slide.getThemeTextColor(),
                            ),
                            textAlign: TextAlign.center,
                            maxLines: 2,
                          ),
                        ),
                      ),
                      const SizedBox(height: 8),
                      Row(
                        children: [
                          Text(
                            'Slide ${index + 1}',
                            style: const TextStyle(
                              color: Colors.white70,
                              fontSize: 12,
                            ),
                          ),
                          const Spacer(),
                          _ThemeIndicator(theme: slide.theme),
                        ],
                      ),
                    ],
                  ),
                ),
              );
            },
          ),
        ),
        Container(
          padding: const EdgeInsets.all(8),
          child: ElevatedButton.icon(
            onPressed: () {
              ref.read(presentationProvider.notifier).addSlide();
            },
            icon: const Icon(Icons.add, size: 16),
            label: const Text('Add Slide'),
            style: ElevatedButton.styleFrom(
              backgroundColor: const Color(0xFF3B82F6),
              minimumSize: const Size.fromHeight(40),
            ),
          ),
        ),
      ],
    );
  }
}

class _ThemeIndicator extends StatelessWidget {
  final SlideTheme theme;

  const _ThemeIndicator({required this.theme});

  @override
  Widget build(BuildContext context) {
    Color color;
    switch (theme) {
      case SlideTheme.minimal:
        color = Colors.white;
        break;
      case SlideTheme.modern:
        color = const Color(0xFF3B82F6);
        break;
      case SlideTheme.bold:
        color = const Color(0xFF1E293B);
        break;
      case SlideTheme.dark:
        color = const Color(0xFF0F172A);
        break;
      case SlideTheme.colorful:
        color = const Color(0xFFF59E0B);
        break;
    }
    
    return Container(
      width: 16,
      height: 16,
      decoration: BoxDecoration(
        color: color,
        borderRadius: BorderRadius.circular(3),
        border: Border.all(color: Colors.white24),
      ),
    );
  }
}

