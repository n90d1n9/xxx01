// ==================== CANVAS ====================

class CollaborativeCanvas extends ConsumerWidget {
  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final presentation = ref.watch(presentationProvider);
    final currentSlide = presentation.slides[presentation.currentSlideIndex];
    final selectedComponent = ref.watch(selectedComponentProvider);

    return Container(
      color: const Color(0xFF0F172A),
      child: Center(
        child: Stack(
          clipBehavior: Clip.none,
          children: [
            Container(
              width: 1200,
              height: 675,
              decoration: BoxDecoration(
                color: currentSlide.getThemeBackground(),
                boxShadow: [
                  BoxShadow(
                    color: Colors.black.withOpacity(0.5),
                    blurRadius: 30,
                    offset: const Offset(0, 10),
                  ),
                ],
              ),
              child: Stack(
                children: [
                  // Title
                  if (currentSlide.title != null)
                    Center(
                      child: Padding(
                        padding: const EdgeInsets.all(48),
                        child: Text(
                          currentSlide.title!,
                          style: TextStyle(
                            fontSize: 48,
                            fontWeight: FontWeight.bold,
                            color: currentSlide.getThemeTextColor(),
                          ),
                          textAlign: TextAlign.center,
                        ),
                      ),
                    ),
                  // Components
                  ...currentSlide.components.map((component) {
                    return DraggableComponent(
                      key: ValueKey(component.id),
                      component: component,
                      isSelected: selectedComponent == component.id,
                      onTap: () {
                        ref.read(selectedComponentProvider.notifier).state =
                            component.id;
                      },
                      onPositionChanged: (newPosition) {
                        ref
                            .read(presentationProvider.notifier)
                            .updateComponent(
                              presentation.currentSlideIndex,
                              component.id,
                              component.copyWith(position: newPosition),
                            );
                      },
                      onDelete: () {
                        ref
                            .read(presentationProvider.notifier)
                            .deleteComponent(
                              presentation.currentSlideIndex,
                              component.id,
                            );
                        ref.read(selectedComponentProvider.notifier).state =
                            null;
                      },
                    );
                  }),
                ],
              ),
            ),
            // Live cursors
            ...presentation.collaborators
                .where((u) =>
                    u.isOnline && u.id != '1' && u.cursorPosition != null)
                .map((user) => LiveCursor(user: user)),
          ],
        ),
      ),
    );
  }
}