import 'package:flutter/material.dart';
import 'package:flutter_riverpod/legacy.dart';

import '../models/enums.dart';
import '../models/promotion.dart';
import '../screens/promotion_detail_screen.dart';
import '../screens/promotion_form_screen.dart';

class PromotionListTile extends ConsumerWidget {
  final Promotion promotion;

  const PromotionListTile({super.key, required this.promotion});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    return Card(
      margin: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
      child: ListTile(
        leading: CircleAvatar(
          backgroundColor: _getColorForPromotionType(promotion.type),
          child: Icon(
            _getIconForPromotionType(promotion.type),
            color: Colors.white,
          ),
        ),
        title: Row(
          children: [
            Expanded(
              child: Text(
                _getPromotionTypeDisplayName(promotion.type),
                style: const TextStyle(fontWeight: FontWeight.bold),
              ),
            ),
            if (promotion.isActive)
              Container(
                padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                decoration: BoxDecoration(
                  color: Colors.green,
                  borderRadius: BorderRadius.circular(12),
                ),
                child: const Text(
                  'Active',
                  style: TextStyle(color: Colors.white, fontSize: 12),
                ),
              ),
          ],
        ),
        subtitle: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const SizedBox(height: 4),
            Row(
              children: [
                const Text('Original: '),
                Text(
                  'Rp ${promotion.originPrice.toStringAsFixed(0)}',
                  style: const TextStyle(
                    decoration: TextDecoration.lineThrough,
                    color: Colors.grey,
                  ),
                ),
                const SizedBox(width: 8),
                const Text('Promo: '),
                Text(
                  'Rp ${promotion.promoPrice.toStringAsFixed(0)}',
                  style: const TextStyle(
                    fontWeight: FontWeight.bold,
                    color: Colors.red,
                  ),
                ),
              ],
            ),
            const SizedBox(height: 4),
            if (promotion.product != null)
              Text(
                'Product: ${promotion.product!.name}',
                maxLines: 1,
                overflow: TextOverflow.ellipsis,
              ),
          ],
        ),
        trailing: Row(
          mainAxisSize: MainAxisSize.min,
          children: [
            IconButton(
              icon: const Icon(Icons.edit),
              onPressed: () {
                Navigator.push(
                  context,
                  MaterialPageRoute(
                    builder:
                        (context) => PromotionFormScreen(promotion: promotion),
                  ),
                );
              },
            ),
            IconButton(
              icon: const Icon(Icons.delete_outline),
              onPressed: () {
                _confirmDelete(context, ref, promotion);
              },
            ),
          ],
        ),
        onTap: () {
          Navigator.push(
            context,
            MaterialPageRoute(
              builder: (context) => PromotionDetailScreen(promotion: promotion),
            ),
          );
        },
      ),
    );
  }

  void _confirmDelete(
    BuildContext context,
    WidgetRef ref,
    Promotion promotion,
  ) {
    showDialog(
      context: context,
      builder:
          (context) => AlertDialog(
            title: const Text('Delete Promotion'),
            content: const Text(
              'Are you sure you want to delete this promotion?',
            ),
            actions: [
              TextButton(
                onPressed: () => Navigator.pop(context),
                child: const Text('Cancel'),
              ),
              TextButton(
                onPressed: () {
                  ref
                      .read(promotionsProvider.notifier)
                      .deletePromotion(promotion.id);
                  Navigator.pop(context);
                },
                child: const Text('Delete'),
              ),
            ],
          ),
    );
  }

  String _getPromotionTypeDisplayName(PromotionType type) {
    // Get English display name from enum
    final typeName = type.toString().split('.').last;
    // Replace underscores with spaces and capitalize each word
    return typeName.replaceAll('_', ' ');
  }

  Color _getColorForPromotionType(PromotionType type) {
    switch (type) {
      case PromotionType.Discount:
        return Colors.blue;
      case PromotionType.Coupons:
        return Colors.orange;
      case PromotionType.Point:
        return Colors.purple;
      case PromotionType.Bogo:
        return Colors.red;
      case PromotionType.Loyalty:
        return Colors.teal;
      case PromotionType.Bundling:
        return Colors.amber;
      case PromotionType.Customize:
        return Colors.indigo;
      default:
        return Colors.grey;
    }
  }

  IconData _getIconForPromotionType(PromotionType type) {
    switch (type) {
      case PromotionType.Discount:
        return Icons.percent;
      case PromotionType.Coupons:
        return Icons.confirmation_number;
      case PromotionType.Point:
        return Icons.stars;
      case PromotionType.Bogo:
        return Icons.card_giftcard;
      case PromotionType.Loyalty:
        return Icons.favorite;
      case PromotionType.Bundling:
        return Icons.inventory_2;
      case PromotionType.Customize:
        return Icons.build;
      case PromotionType.Flash_Sale:
        return Icons.flash_on;
      case PromotionType.Free_Shipping:
        return Icons.local_shipping;
      case PromotionType.Free_Gift:
        return Icons.redeem;
      default:
        return Icons.sell;
    }
  }
}
