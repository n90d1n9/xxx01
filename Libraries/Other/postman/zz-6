          mainAxisSize: MainAxisSize.min,
          children: [
            ListTile(
              leading: const Icon(Icons.post_add, color: Colors.orange),
              title: const Text('Postman Collection'),
              subtitle: const Text('v2.0 and v2.1 format'),
              onTap: () {
                Navigator.pop(context);
                _importFile('postman');
              },
            ),
            ListTile(
              leading: const Icon(Icons.api, color: Colors.green),
              title: const Text('OpenAPI Specification'),
              subtitle: const Text('v3.0+ format'),
              onTap: () {
                Navigator.pop(context);
                _importFile('openapi');
              },
            ),
            ListTile(
              leading: const Icon(Icons.description, color: Colors.blue),
              title: const Text('Swagger Specification'),
              subtitle: const Text('v2.0 format'),
              onTap: () {
                Navigator.pop(context);
                _importFile('swagger');
              },
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Cancel'),
          ),
        ],
      ),
    );
  }

  Future<void> _importFile(String type) async {
    final result = await FilePicker.platform.pickFiles(
      type: FileType.custom,
      allowedExtensions: ['json', 'yaml', 'yml'],
    );

    if (result != null && result.files.single.bytes != null) {
      try {
        final content = utf8.decode(result.files.single.bytes!);
        final json = jsonDecode(content);
        
        final importService = ImportService();
        List<ApiRequest> requests;
        
        switch (type) {
          case 'postman':
            requests = importService.importPostmanCollection(json);
            break;
          case 'openapi':
            requests = importService.importOpenApiSpec(json);
            break;
          case 'swagger':
            requests = importService.importSwaggerSpec(json);
            break;
          default:
            requests = [];
        }

        ref.read(requestsProvider.notifier).importRequests(requests);

        if (mounted) {
          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(
              content: Text('Successfully imported ${requests.length} requests'),
              backgroundColor: Colors.green,
            ),
          );
        }
      } catch (e) {
        if (mounted) {
          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(
              content: Text('Import failed: $e'),
              backgroundColor: Colors.red,
            ),
          );
        }
      }
    }
  }

  void _showEnvironmentDialog() {
    showDialog(
      context: context,
      builder: (context) => const EnvironmentDialog(),
    );
  }
}

class CreateRequestDialog extends ConsumerStatefulWidget {
  const CreateRequestDialog({super.key});

  @override
