  void _loadEnvironment(Environment env) {
    _nameController.text = env.name;
    
    for (final pair in _variables) {
      pair.key.dispose();
      pair.value.dispose();
    }
    _variables.clear();

    env.variables.forEach((key, value) {
      _variables.add(MapEntry(
        TextEditingController(text: key),
        TextEditingController(text: value),
      ));
    });

    if (_variables.isEmpty) {
      _variables.add(MapEntry(TextEditingController(), TextEditingController()));
    }
  }

  void _clearForm() {
    _nameController.clear();
    for (final pair in _variables) {
      pair.key.dispose();
      pair.value.dispose();
    }
    _variables.clear();
    _variables.add(MapEntry(TextEditingController(), TextEditingController()));
  }

  void _saveEnvironment() {
    if (_nameController.text.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Please enter an environment name')),
      );
      return;
    }

    final variables = <String, String>{};
    for (final pair in _variables) {
      if (pair.key.text.isNotEmpty) {
        variables[pair.key.text] = pair.value.text;
      }
    }

    final env = Environment(
      id: _selectedEnvId ?? const Uuid().v4(),
      name: _nameController.text,
      variables: variables,
    );

    if (_selectedEnvId == null) {
      ref.read(environmentsProvider.notifier).addEnvironment(env);
    } else {
      ref.read(environmentsProvider.notifier).updateEnvironment(env);
    }

    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text('Environment ${_selectedEnvId == null ? "created" : "updated"}'),
        backgroundColor: Colors.green,
      ),
    );

    setState(() {
      _selectedEnvId = env.id;
    });
  }
