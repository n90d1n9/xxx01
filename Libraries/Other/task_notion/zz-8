class NotificationsDialog extends ConsumerWidget {
  const NotificationsDialog({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final tasks = ref.watch(filteredTasksProvider);
    final overdueTasks = tasks.where((t) => t.isOverdue).toList();
    final dueSoonTasks = tasks.where((t) {
      if (t.dueDate == null || t.status == TaskStatus.done) return false;
      final daysUntilDue = t.dueDate!.difference(DateTime.now()).inDays;
      return daysUntilDue >= 0 && daysUntilDue <= 2;
    }).toList();

    return AlertDialog(
      title: const Row(
        children: [
          Icon(Icons.notifications_active),
          SizedBox(width: 12),
          Text('Notifications'),
        ],
      ),
      content: SizedBox(
        width: 400,
        height: 400,
        child: overdueTasks.isEmpty && dueSoonTasks.isEmpty
            ? const Center(child: Text('No notifications'))
            : ListView(
                children: [
                  if (overdueTasks.isNotEmpty) ...[
                    const ListTile(
                      leading: Icon(Icons.warning, color: Colors.red),
                      title: Text('Overdue Tasks', style: TextStyle(fontWeight: FontWeight.bold)),
                    ),
                    ...overdueTasks.map((task) => ListTile(
