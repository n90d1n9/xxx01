class TimeTrackerWidget extends ConsumerWidget {
  const TimeTrackerWidget({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final timeEntriesAsync = ref.watch(timeEntriesProvider);

    return timeEntriesAsync.when(
      data: (entries) {
        final activeEntry = entries.where((e) => e.endTime == null).firstOrNull;
        
        if (activeEntry == null) {
          return IconButton.outlined(
            icon: const Icon(Icons.play_arrow),
            onPressed: () => _showStartTimerDialog(context, ref),
            tooltip: 'Start Timer',
          );
        }

        final duration = DateTime.now().difference(activeEntry.startTime);
        final hours = duration.inHours;
        final minutes = duration.inMinutes % 60;

        return Container(
          padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 8),
          decoration: BoxDecoration(
            color: Colors.green.shade50,
            borderRadius: BorderRadius.circular(8),
            border: Border.all(color: Colors.green.shade200),
          ),
          child: Row(
            mainAxisSize: MainAxisSize.min,
            children: [
              Icon(Icons.timer, size: 16, color: Colors.green.shade700),
              const SizedBox(width: 8),
              Text(
                '${hours.toString().padLeft(2, '0')}:${minutes.toString().padLeft(2, '0')}',
                style: TextStyle(
                  fontWeight: FontWeight.bold,
                  color: Colors.green.shade700,
                ),
              ),
              const SizedBox(width: 8),
              InkWell(
                onTap: () {
                  ref.read(timeEntriesProvider.notifier).stopTimer(activeEntry.id);
                },
                child: Icon(Icons.stop, size: 16, color: Colors.green.shade700),
              ),
            ],
          ),
        );
      },
      loading: () => const SizedBox.shrink(),
      error: (_, __) => const SizedBox.shrink(),
    );
  }

  void _showStartTimerDialog(BuildContext context, WidgetRef ref) {
    final tasksAsync = ref.read(tasksProvider);
    final tasks = tasksAsync.valueOrNull ?? [];

    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Start Time Tracking'),
        content: SizedBox(
          width: 400,
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              const Text('Select a task to track time:'),
              const SizedBox(height: 16),
              ...tasks.where((t) => t.status != TaskStatus.done).take(5).map((task) {
                return ListTile(
                  title: Text(task.title),
                  subtitle: Text(task.parentId ?? 'No project'),
                  onTap: () {
                    ref.read(timeEntriesProvider.notifier).startTimer(task.id, task.title);
                    Navigator.pop(context);
                  },
                );
              }),
            ],
          ),
        ),
      ),
    );
  }
}

