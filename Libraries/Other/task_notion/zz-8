// ==================== STORAGE SERVICE ====================

class StorageService {
  static const String _tasksKey = 'tasks';
  static const String _projectsKey = 'projects';
  static const String _timeEntriesKey = 'timeEntries';
  static const String _activityLogsKey = 'activityLogs';
  static const String _settingsKey = 'settings';

  Future<void> saveTasks(List<Task> tasks) async {
    final prefs = await SharedPreferences.getInstance();
    final jsonList = tasks.map((t) => t.toJson()).toList();
    await prefs.setString(_tasksKey, jsonEncode(jsonList));
  }

  Future<List<Task>> loadTasks() async {
    final prefs = await SharedPreferences.getInstance();
    final jsonString = prefs.getString(_tasksKey);
    if (jsonString == null) return [];
    final jsonList = jsonDecode(jsonString) as List;
    return jsonList.map((json) => Task.fromJson(json)).toList();
  }

  Future<void> saveProjects(List<Project> projects) async {
    final prefs = await SharedPreferences.getInstance();
    final jsonList = projects.map((p) => p.toJson()).toList();
    await prefs.setString(_projectsKey, jsonEncode(jsonList));
  }

  Future<List<Project>> loadProjects() async {
    final prefs = await SharedPreferences.getInstance();
    final jsonString = prefs.getString(_projectsKey);
    if (jsonString == null) return _getDefaultProjects();
    final jsonList = jsonDecode(jsonString) as List;
    return jsonList.map((json) => Project.fromJson(json)).toList();
  }

  Future<void> saveTimeEntries(List<TimeEntry> entries) async {
    final prefs = await SharedPreferences.getInstance();
    final jsonList = entries.map((e) => e.toJson()).toList();
    await prefs.setString(_timeEntriesKey, jsonEncode(jsonList));
  }

  Future<List<TimeEntry>> loadTimeEntries() async {
    final prefs = await SharedPreferences.getInstance();
    final jsonString = prefs.getString(_timeEntriesKey);
    if (jsonString == null) return [];
    final jsonList = jsonDecode(jsonString) as List;
    return jsonList.map((json) => TimeEntry.fromJson(json)).toList();
  }

  Future<void> saveActivityLogs(List<ActivityLog> logs) async {
    final prefs = await SharedPreferences.getInstance();
    final jsonList = logs.map((l) => l.toJson()).toList();
    await prefs.setString(_activityLogsKey, jsonEncode(jsonList));
  }

  Future<List<ActivityLog>> loadActivityLogs() async {
    final prefs = await SharedPreferences.getInstance();
    final jsonString = prefs.getString(_activityLogsKey);
    if (jsonString == null) return [];
    final jsonList = jsonDecode(jsonString) as List;
    return jsonList.map((json) => ActivityLog.fromJson(json)).toList();
  }

  List<Project> _getDefaultProjects() {
    return [
      Project(
        id: 'personal',
        name: 'Personal',
        description: 'Personal tasks and notes',
        color: Colors.blue,
        icon: Icons.person,
        createdAt: DateTime.now(),
      ),
      Project(
        id: 'work',
        name: 'Work',
        description: 'Work-related tasks',
        color: Colors.orange,
        icon: Icons.work,
        createdAt: DateTime.now(),
      ),
    ];
  }
}

