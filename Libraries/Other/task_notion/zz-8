});

final projectsProvider = StateNotifierProvider<ProjectsNotifier, AsyncValue<List<Project>>>((ref) {
  return ProjectsNotifier(ref.read(storageServiceProvider));
});

final timeEntriesProvider = StateNotifierProvider<TimeEntriesNotifier, AsyncValue<List<TimeEntry>>>((ref) {
  return TimeEntriesNotifier(ref.read(storageServiceProvider));
});

final activityLogsProvider = StateNotifierProvider<ActivityLogsNotifier, AsyncValue<List<ActivityLog>>>((ref) {
  return ActivityLogsNotifier(ref.read(storageServiceProvider));
});

final selectedProjectProvider = StateProvider<String?>((ref) => null);
final currentViewProvider = StateProvider<ViewType>((ref) => ViewType.board);
final searchQueryProvider = StateProvider<String>((ref) => '');
final selectedTagsProvider = StateProvider<Set<String>>((ref) => {});
final selectedPriorityProvider = StateProvider<Set<TaskPriority>>((ref) => {});
final selectedStatusProvider = StateProvider<Set<TaskStatus>>((ref) => {});
final selectedCalendarDayProvider = StateProvider<DateTime>((ref) => DateTime.now());
final focusModeProvider = StateProvider<bool>((ref) => false);
final currentUserProvider = StateProvider<String>((ref) => 'Current User');

final filteredTasksProvider = Provider<List<Task>>((ref) {
  final tasksAsync = ref.watch(tasksProvider);
  final selectedProject = ref.watch(selectedProjectProvider);
  final searchQuery = ref.watch(searchQueryProvider);
  final selectedTags = ref.watch(selectedTagsProvider);
  final selectedPriorities = ref.watch(selectedPriorityProvider);
  final selectedStatuses = ref.watch(selectedStatusProvider);

  return tasksAsync.when(
    data: (tasks) {
      var filtered = tasks;

      if (selectedProject != null) {
        filtered = filtered.where((t) => t.parentId == selectedProject).toList();
      }

      if (searchQuery.isNotEmpty) {
        filtered = filtered.where((t) =>
          t.title.toLowerCase().contains(searchQuery.toLowerCase()) ||
          t.description.toLowerCase().contains(searchQuery.toLowerCase())
        ).toList();
      }

      if (selectedTags.isNotEmpty) {
        filtered = filtered.where((t) =>
          t.tags.any((tag) => selectedTags.contains(tag))
        ).toList();
      }

      if (selectedPriorities.isNotEmpty) {
        filtered = filtered.where((t) => selectedPriorities.contains(t.priority)).toList();
      }

      if (selectedStatuses.isNotEmpty) {
        filtered = filtered.where((t) => selectedStatuses.contains(t.status)).toList();
      }

      return filtered;
    },
    loading: () => [],
    error: (_, __) => [],
  );
});

final tasksByStatusProvider = Provider<Map<TaskStatus, List<Task>>>((ref) {
  final tasks = ref.watch(filteredTasksProvider);
  return {
    TaskStatus.todo: tasks.where((t) => t.status == TaskStatus.todo).toList()
      ..sort((a, b) => a.position.compareTo(b.position)),
    TaskStatus.inProgress: tasks.where((t) => t.status == TaskStatus.inProgress).toList()
      ..sort((a, b) => a.position.compareTo(b.position)),
    TaskStatus.review: tasks.where((t) => t.status == TaskStatus.review).toList()
      ..sort((a, b) => a.position.compareTo(b.position)),
    TaskStatus.done: tasks.where((t) => t.status == TaskStatus.done).toList()
      ..sort((a, b) => a.position.compareTo(b.position)),
  };
});

final allTagsProvider = Provider<Set<String>>((ref) {
  final tasksAsync = ref.watch(tasksProvider);
  return tasksAsync.when(
    data: (tasks) {
      final tags = <String>{};
      for (final task in tasks) {
        tags.addAll(task.tags);
      }
      return tags;
    },
    loading: () => {},
    error: (_, __) => {},
  );
});

final statisticsProvider = Provider<Map<String, dynamic>>((ref) {
  final tasks = ref.watch(filteredTasksProvider);
  final timeEntries = ref.watch(timeEntriesProvider).valueOrNull ?? [];
  
  final completedTasks = tasks.where((t) => t.status == TaskStatus.done).length;
  final totalTasks = tasks.length;
  final overdueTasks = tasks.where((t) => t.isOverdue).length;
  
  final totalEstimatedHours = tasks.fold<int>(0, (sum, t) => sum + t.estimatedHours);
  final totalActualHours = tasks.fold<int>(0, (sum, t) => sum + t.actualHours);
  
  final completionRate = totalTasks > 0 ? (completedTasks / totalTasks * 100) : 0.0;
  
  return {
    'total': totalTasks,
    'todo': tasks.where((t) => t.status == TaskStatus.todo).length,
    'inProgress': tasks.where((t) => t.status == TaskStatus.inProgress).length,
    'review': tasks.where((t) => t.status == TaskStatus.review).length,
    'done': completedTasks,
    'overdue': overdueTasks,
    'completionRate': completionRate,
    'totalEstimatedHours': totalEstimatedHours,
    'totalActualHours': totalActualHours,
    'hoursVariance': totalActualHours - totalEstimatedHours,
  };
});

final tasksForCalendarProvider = Provider.family<List<Task>, DateTime>((ref, date) {
  final tasks = ref.watch(filteredTasksProvider);
  return tasks.where((task) {
    if (task.dueDate == null) return false;
    return task.dueDate!.year == date.year &&
           task.dueDate!.month == date.month &&
           task.dueDate!.day == date.day;
  }).toList();
});

// ==================== STATE NOTIFIERS ====================

class TasksNotifier extends StateNotifier<AsyncValue<List<Task>>> {
  final StorageService _storage;
  final Ref _ref;

  TasksNotifier(this._storage, this._ref) : super(const AsyncValue.loading()) {
    _loadTasks();
  }

  Future<void> _loadTasks() async {
    state = const AsyncValue.loading();
    try {
      final tasks = await _storage.loadTasks();
      state = AsyncValue.data(tasks);
    } catch (e, stack) {
      state = AsyncValue.error(e, stack);
    }
  }

  Future<void> _saveTasks(List<Task> tasks) async {
    await _storage.saveTasks(tasks);
  }

  void _logActivity(String taskId, String action, Map<String, dynamic> details) {
    final currentUser = _ref.read(currentUserProvider);
    final log = ActivityLog(
      id: const Uuid().v4(),
      taskId: taskId,
      action: action,
      user: currentUser,
      timestamp: DateTime.now(),
      details: details,
    );
    _ref.read(activityLogsProvider.notifier).addLog(log);
  }

  Future<void> addTask(Task task) async {
    state.whenData((tasks) {
      final updated = [...tasks, task];
      state = AsyncValue.data(updated);
      _saveTasks(updated);
      _logActivity(task.id, 'created', {'title': task.title});
    });
  }

  Future<void> updateTask(String id, Task updatedTask) async {
    state.whenData((tasks) {
      final oldTask = tasks.firstWhere((t) => t.id == id);
      final updated = [
        for (final task in tasks)
          if (task.id == id) updatedTask else task,
      ];
      state = AsyncValue.data(updated);
      _saveTasks(updated);
      
      if (oldTask.status != updatedTask.status) {
        _logActivity(id, 'status_changed', {
          'from': oldTask.status.name,
          'to': updatedTask.status.name,
        });
      }
    });
  }

  Future<void> deleteTask(String id) async {
    state.whenData((tasks) {
      final task = tasks.firstWhere((t) => t.id == id);
      final updated = tasks.where((task) => task.id != id).toList();
      state = AsyncValue.data(updated);
      _saveTasks(updated);
      _logActivity(id, 'deleted', {'title': task.title});
    });
  }

  Future<void> updateTaskStatus(String id, TaskStatus status) async {
    state.whenData((tasks) {
      final updated = [
        for (final task in tasks)
          if (task.id == id) task.copyWith(status: status) else task,
      ];
      state = AsyncValue.data(updated);
      _saveTasks(updated);
    });
  }

  Future<void> addComment(String taskId, String text) async {
    state.whenData((tasks) {
      final currentUser = _ref.read(currentUserProvider);
      final comment = TaskComment(
        id: const Uuid().v4(),
        text: text,
        author: currentUser,
        createdAt: DateTime.now(),
      );
      
      final updated = [
        for (final task in tasks)
          if (task.id == taskId)
            task.copyWith(comments: [...task.comments, comment])
          else
            task,
      ];
      state = AsyncValue.data(updated);
      _saveTasks(updated);
      _logActivity(taskId, 'commented', {'text': text});
    });
  }

  Future<void> addSubtask(String taskId, String subtaskTitle) async {
    state.whenData((tasks) {
      final subtask = Subtask(
        id: const Uuid().v4(),
        title: subtaskTitle,
      );
      
      final updated = [
        for (final task in tasks)
          if (task.id == taskId)
            task.copyWith(subtasks: [...task.subtasks, subtask])
          else
            task,
      ];
      state = AsyncValue.data(updated);
      _saveTasks(updated);
    });
  }

  Future<void> toggleSubtask(String taskId, String subtaskId) async {
    state.whenData((tasks) {
      final updated = [
        for (final task in tasks)
          if (task.id == taskId)
            task.copyWith(
              subtasks: [
                for (final subtask in task.subtasks)
                  if (subtask.id == subtaskId)
                    subtask.copyWith(isCompleted: !subtask.isCompleted)
                  else
                    subtask,
              ],
            )
          else
            task,
      ];
      state = AsyncValue.data(updated);
      _saveTasks(updated);
    });
  }

  Future<void> bulkUpdateStatus(List<String> taskIds, TaskStatus status) async {
    state.whenData((tasks) {
      final updated = [
        for (final task in tasks)
          if (taskIds.contains(task.id))
            task.copyWith(status: status)
          else
            task,
      ];
      state = AsyncValue.data(updated);
      _saveTasks(updated);
    });
  }

  Future<void> bulkDelete(List<String> taskIds) async {
    state.whenData((tasks) {
      final updated = tasks.where((task) => !taskIds.contains(task.id)).toList();
      state = AsyncValue.data(updated);
      _saveTasks(updated);
    });
  }
}

class ProjectsNotifier extends StateNotifier<AsyncValue<List<Project>>> {
  final StorageService _storage;

  ProjectsNotifier(this._storage) : super(const AsyncValue.loading()) {
    _loadProjects();
  }

  Future<void> _loadProjects() async {
    state = const AsyncValue.loading();
    try {
      final projects = await _storage.loadProjects();
      state = AsyncValue.data(projects);
    } catch (e, stack) {
      state = AsyncValue.error(e, stack);
    }
  }

  Future<void> _saveProjects(List<Project> projects) async {
    await _storage.saveProjects(projects);
  }

  Future<void> addProject(Project project) async {
    state.whenData((projects) {
      final updated = [...projects, project];
      state = AsyncValue.data(updated);
      _saveProjects(updated);
    });
  }

  Future<void> deleteProject(String id) async {
    state.whenData((projects) {
      final updated = projects.where((p) => p.id != id).toList();
      state = AsyncValue.data(updated);
      _saveProjects(updated);
    });
  }
}

class TimeEntriesNotifier extends StateNotifier<AsyncValue<List<TimeEntry>>> {
  final StorageService _storage;
  Timer? _activeTimer;

  TimeEntriesNotifier(this._storage) : super(const AsyncValue.loading()) {
    _loadEntries();
  }

  Future<void> _loadEntries() async {
    state = const AsyncValue.loading();
    try {
      final entries = await _storage.loadTimeEntries();
      state = AsyncValue.data(entries);
    } catch (e, stack) {
      state = AsyncValue.error(e, stack);
    }
  }

  Future<void> _saveEntries(List<TimeEntry> entries) async {
    await _storage.saveTimeEntries(entries);
  }

  Future<void> startTimer(String taskId, String description) async {
    state.whenData((entries) {
      final entry = TimeEntry(
        id: const Uuid().v4(),
        taskId: taskId,
        startTime: DateTime.now(),
        description: description,
      );
      final updated = [...entries, entry];
      state = AsyncValue.data(updated);
      _saveEntries(updated);
      
      // Auto-refresh every minute
      _activeTimer?.cancel();
      _activeTimer = Timer.periodic(const Duration(minutes: 1), (_) {
        state = AsyncValue.data([...updated]);
      });
    });
  }

  Future<void> stopTimer(String entryId) async {
    state.whenData((entries) {
      _activeTimer?.cancel();
      final updated = [
        for (final entry in entries)
          if (entry.id == entryId)
            TimeEntry(
              id: entry.id,
              taskId: entry.taskId,
              startTime: entry.startTime,
              endTime: DateTime.now(),
              description: entry.description,
            )
          else
            entry,
      ];
      state = AsyncValue.data(updated);
      _saveEntries(updated);
    });
  }

  TimeEntry? getActiveEntry() {
    return state.valueOrNull?.firstWhere(
      (e) => e.endTime == null,
      orElse: () => TimeEntry(
        id: '',
        taskId: '',
        startTime: DateTime.now(),
      ),
    );
  }

  @override
  void dispose() {
    _activeTimer?.cancel();
    super.dispose();
  }
}

class ActivityLogsNotifier extends StateNotifier<AsyncValue<List<ActivityLog>>> {
  final StorageService _storage;

  ActivityLogsNotifier(this._storage) : super(const AsyncValue.loading()) {
    _loadLogs();
  }

  Future<void> _loadLogs() async {
    state = const AsyncValue.loading();
    try {
      final logs = await _storage.loadActivityLogs();
      state = AsyncValue.data(logs);
    } catch (e, stack) {
      state = AsyncValue.error(e, stack);
    }
  }

  Future<void> _saveLogs(List<ActivityLog> logs) async {
    await _storage.saveActivityLogs(logs);
  }

  Future<void> addLog(ActivityLog log) async {
    state.whenData((logs) {
      final updated = [...logs, log];
      // Keep only last 1000 logs
      final trimmed = updated.length > 1000 ? updated.sublist(updated.length - 1000) : updated;
      state = AsyncValue.data(trimmed);
      _saveLogs(trimmed);
    });
  }

  List<ActivityLog> getLogsForTask(String taskId) {
    return state.valueOrNull?.where((log) => log.taskId == taskId).toList() ?? [];
  }
}

