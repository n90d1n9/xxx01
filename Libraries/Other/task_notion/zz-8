// ==================== MODELS ====================

enum TaskStatus { todo, inProgress, review, done }
enum TaskPriority { low, medium, high, urgent }
enum ViewType { board, list, calendar, timeline, gantt, analytics }

class Task {
  final String id;
  final String title;
  final String description;
  final TaskStatus status;
  final TaskPriority priority;
  final DateTime createdAt;
  final DateTime? dueDate;
  final DateTime? startDate;
  final List<String> tags;
  final String? parentId;
  final List<Subtask> subtasks;
  final List<String> dependencies;
  final List<TaskComment> comments;
  final List<TaskAttachment> attachments;
  final int estimatedHours;
  final int actualHours;
  final String? assignedTo;
  final Map<String, dynamic> customFields;
  final bool isRecurring;
  final String? recurringPattern;
  final int position;

  Task({
    required this.id,
    required this.title,
    this.description = '',
    this.status = TaskStatus.todo,
    this.priority = TaskPriority.medium,
    required this.createdAt,
    this.dueDate,
    this.startDate,
    this.tags = const [],
    this.parentId,
    this.subtasks = const [],
    this.dependencies = const [],
    this.comments = const [],
    this.attachments = const [],
    this.estimatedHours = 0,
    this.actualHours = 0,
    this.assignedTo,
    this.customFields = const {},
    this.isRecurring = false,
    this.recurringPattern,
    this.position = 0,
  });

  double get completionPercentage {
    if (subtasks.isEmpty) return status == TaskStatus.done ? 100 : 0;
    final completed = subtasks.where((s) => s.isCompleted).length;
    return (completed / subtasks.length) * 100;
  }

  bool get isOverdue {
    if (dueDate == null || status == TaskStatus.done) return false;
    return dueDate!.isBefore(DateTime.now());
  }

  Task copyWith({
    String? title,
    String? description,
    TaskStatus? status,
    TaskPriority? priority,
    DateTime? dueDate,
    DateTime? startDate,
    List<String>? tags,
    String? parentId,
    List<Subtask>? subtasks,
    List<String>? dependencies,
    List<TaskComment>? comments,
    List<TaskAttachment>? attachments,
    int? estimatedHours,
    int? actualHours,
    String? assignedTo,
    Map<String, dynamic>? customFields,
    bool? isRecurring,
    String? recurringPattern,
    int? position,
  }) {
    return Task(
      id: id,
      title: title ?? this.title,
      description: description ?? this.description,
      status: status ?? this.status,
      priority: priority ?? this.priority,
      createdAt: createdAt,
      dueDate: dueDate ?? this.dueDate,
      startDate: startDate ?? this.startDate,
      tags: tags ?? this.tags,
      parentId: parentId ?? this.parentId,
      subtasks: subtasks ?? this.subtasks,
      dependencies: dependencies ?? this.dependencies,
      comments: comments ?? this.comments,
      attachments: attachments ?? this.attachments,
      estimatedHours: estimatedHours ?? this.estimatedHours,
      actualHours: actualHours ?? this.actualHours,
      assignedTo: assignedTo ?? this.assignedTo,
      customFields: customFields ?? this.customFields,
      isRecurring: isRecurring ?? this.isRecurring,
      recurringPattern: recurringPattern ?? this.recurringPattern,
      position: position ?? this.position,
    );
  }

  Map<String, dynamic> toJson() {
    return {
      'id': id,
      'title': title,
      'description': description,
      'status': status.index,
      'priority': priority.index,
      'createdAt': createdAt.toIso8601String(),
      'dueDate': dueDate?.toIso8601String(),
      'startDate': startDate?.toIso8601String(),
      'tags': tags,
      'parentId': parentId,
      'subtasks': subtasks.map((s) => s.toJson()).toList(),
      'dependencies': dependencies,
      'comments': comments.map((c) => c.toJson()).toList(),
      'attachments': attachments.map((a) => a.toJson()).toList(),
      'estimatedHours': estimatedHours,
      'actualHours': actualHours,
      'assignedTo': assignedTo,
      'customFields': customFields,
      'isRecurring': isRecurring,
      'recurringPattern': recurringPattern,
      'position': position,
    };
  }

  factory Task.fromJson(Map<String, dynamic> json) {
    return Task(
      id: json['id'],
      title: json['title'],
      description: json['description'] ?? '',
      status: TaskStatus.values[json['status'] ?? 0],
      priority: TaskPriority.values[json['priority'] ?? 1],
      createdAt: DateTime.parse(json['createdAt']),
      dueDate: json['dueDate'] != null ? DateTime.parse(json['dueDate']) : null,
      startDate: json['startDate'] != null ? DateTime.parse(json['startDate']) : null,
      tags: List<String>.from(json['tags'] ?? []),
      parentId: json['parentId'],
      subtasks: (json['subtasks'] as List?)?.map((s) => Subtask.fromJson(s)).toList() ?? [],
      dependencies: List<String>.from(json['dependencies'] ?? []),
      comments: (json['comments'] as List?)?.map((c) => TaskComment.fromJson(c)).toList() ?? [],
      attachments: (json['attachments'] as List?)?.map((a) => TaskAttachment.fromJson(a)).toList() ?? [],
      estimatedHours: json['estimatedHours'] ?? 0,
      actualHours: json['actualHours'] ?? 0,
      assignedTo: json['assignedTo'],
      customFields: Map<String, dynamic>.from(json['customFields'] ?? {}),
      isRecurring: json['isRecurring'] ?? false,
      recurringPattern: json['recurringPattern'],
      position: json['position'] ?? 0,
    );
  }
}

class Subtask {
  final String id;
  final String title;
  final bool isCompleted;

  Subtask({
    required this.id,
    required this.title,
    this.isCompleted = false,
  });

  Subtask copyWith({String? title, bool? isCompleted}) {
    return Subtask(
      id: id,
      title: title ?? this.title,
      isCompleted: isCompleted ?? this.isCompleted,
    );
  }

  Map<String, dynamic> toJson() => {
    'id': id,
    'title': title,
    'isCompleted': isCompleted,
  };

  factory Subtask.fromJson(Map<String, dynamic> json) => Subtask(
    id: json['id'],
    title: json['title'],
    isCompleted: json['isCompleted'] ?? false,
  );
}

