final reportDataProvider = Provider<ReportData>((ref) {
  final period = ref.watch(reportPeriodProvider);
  final expenses = ref.watch(expensesProvider);
  
  final now = DateTime.now();
  DateTime startDate;
  DateTime endDate = now;

  switch (period) {
    case ReportPeriod.daily:
