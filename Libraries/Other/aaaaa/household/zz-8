// Models (keeping all previous models)
class DailyTask {
  final String id;
  final String title;
  final bool completed;
  final DateTime date;
  final String? notes;
  final TaskPriority priority;
  final String? assignedTo;

  DailyTask({
    required this.id,
    required this.title,
    required this.completed,
    required this.date,
    this.notes,
    this.priority = TaskPriority.medium,
    this.assignedTo,
  });

  Map<String, dynamic> toJson() => {
        'id': id,
        'title': title,
        'completed': completed,
        'date': date.toIso8601String(),
        'notes': notes,
        'priority': priority.index,
        'assignedTo': assignedTo,
      };

  factory DailyTask.fromJson(Map<String, dynamic> json) => DailyTask(
        id: json['id'],
        title: json['title'],
        completed: json['completed'],
        date: DateTime.parse(json['date']),
        notes: json['notes'],
        priority: TaskPriority.values[json['priority'] ?? 1],
        assignedTo: json['assignedTo'],
      );

  DailyTask copyWith({
    String? title,
    bool? completed,
    DateTime? date,
    String? notes,
    TaskPriority? priority,
    String? assignedTo,
  }) {
    return DailyTask(
      id: id,
      title: title ?? this.title,
      completed: completed ?? this.completed,
      date: date ?? this.date,
      notes: notes ?? this.notes,
      priority: priority ?? this.priority,
      assignedTo: assignedTo ?? this.assignedTo,
    );
  }
}

enum TaskPriority { low, medium, high }

class ShoppingItem {
  final String id;
  final String name;
  final double price;
  final int quantity;
  final bool purchased;
  final String category;
  final String? notes;
  final DateTime createdAt;

  ShoppingItem({
    required this.id,
    required this.name,
    required this.price,
    this.quantity = 1,
    required this.purchased,
    required this.category,
    this.notes,
    DateTime? createdAt,
  }) : createdAt = createdAt ?? DateTime.now();

  Map<String, dynamic> toJson() => {
        'id': id,
        'name': name,
        'price': price,
        'quantity': quantity,
        'purchased': purchased,
        'category': category,
        'notes': notes,
        'createdAt': createdAt.toIso8601String(),
      };

  factory ShoppingItem.fromJson(Map<String, dynamic> json) => ShoppingItem(
        id: json['id'],
        name: json['name'],
        price: json['price'],
        quantity: json['quantity'] ?? 1,
        purchased: json['purchased'],
        category: json['category'],
        notes: json['notes'],
        createdAt: json['createdAt'] != null
            ? DateTime.parse(json['createdAt'])
            : DateTime.now(),
      );

  ShoppingItem copyWith({
    String? name,
    double? price,
    int? quantity,
    bool? purchased,
    String? category,
    String? notes,
  }) {
    return ShoppingItem(
      id: id,
      name: name ?? this.name,
      price: price ?? this.price,
      quantity: quantity ?? this.quantity,
      purchased: purchased ?? this.purchased,
      category: category ?? this.category,
      notes: notes ?? this.notes,
      createdAt: createdAt,
    );
  }
}

class BudgetCategory {
  final String name;
  final double budget;
  final double spent;
  final IconData icon;
  final Color color;

  BudgetCategory({
    required this.name,
    required this.budget,
    required this.spent,
    required this.icon,
    required this.color,
  });

  Map<String, dynamic> toJson() => {
        'name': name,
        'budget': budget,
        'spent': spent,
      };

  factory BudgetCategory.fromJson(Map<String, dynamic> json) {
    final categoryConfig = _getCategoryConfig(json['name']);
    return BudgetCategory(
      name: json['name'],
      budget: json['budget'],
      spent: json['spent'],
      icon: categoryConfig['icon'],
      color: categoryConfig['color'],
    );
  }

  static Map<String, dynamic> _getCategoryConfig(String name) {
    switch (name) {
      case 'Groceries':
        return {'icon': Icons.shopping_basket, 'color': Colors.green};
      case 'Utilities':
        return {'icon': Icons.electrical_services, 'color': Colors.blue};
      case 'Entertainment':
        return {'icon': Icons.movie, 'color': Colors.purple};
      case 'Transportation':
        return {'icon': Icons.directions_car, 'color': Colors.orange};
      case 'Healthcare':
        return {'icon': Icons.medical_services, 'color': Colors.red};
      case 'Education':
        return {'icon': Icons.school, 'color': Colors.indigo};
      default:
        return {'icon': Icons.more_horiz, 'color': Colors.grey};
    }
  }

  BudgetCategory copyWith({String? name, double? budget, double? spent}) {
    return BudgetCategory(
      name: name ?? this.name,
      budget: budget ?? this.budget,
      spent: spent ?? this.spent,
      icon: icon,
      color: color,
    );
  }
}

