            overallRiskScore = sum / (int) validScores;
            
            if (overallRiskScore >= 80) riskLevel = TenderRiskLevel.CRITICAL;
            else if (overallRiskScore >= 60) riskLevel = TenderRiskLevel.HIGH;
            else if (overallRiskScore >= 40) riskLevel = TenderRiskLevel.MEDIUM;
            else riskLevel = TenderRiskLevel.LOW;
        }
