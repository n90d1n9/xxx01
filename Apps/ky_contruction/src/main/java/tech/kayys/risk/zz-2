public class NotificationMessage {
    public Long id;
    public NotificationService.NotificationType type;
    public Long riskId;
    public Long workflowId;
    public Long stepId;
    public Long kriId;
    public NotificationService.AlertType alertType;
    public String title;
    public String message;
    public List<String> recipients;
    public LocalDateTime timestamp;
    public NotificationPriority priority = NotificationPriority.NORMAL;
    public NotificationStatus status = NotificationStatus.PENDING;
    public String templateId;
    public Map<String, Object> templateData;
    public List<String> channels; // email, sms, push, etc.
    public LocalDateTime scheduledTime;
    public Integer retryCount = 0;
    public Integer maxRetries = 3;
    public String errorMessage;
    public String correlationId;
    public NotificationCategory category;
    public Map<String, String> metadata;
    
    public NotificationMessage() {
        this.templateData = new HashMap<>();
        this.channels = new ArrayList<>();
        this.metadata = new HashMap<>();
        this.correlationId = UUID.randomUUID().toString();
    }
    
    public enum NotificationPriority {
        LOW(1),
        NORMAL(2),
        HIGH(3),
        CRITICAL(4);
        
        private final int level;
        NotificationPriority(int level) { this.level = level; }
        public int getLevel() { return level; }
    }
    
    public enum NotificationStatus {
        PENDING("Pending"),
        SENT("Sent"),
        DELIVERED("Delivered"),
        FAILED("Failed"),
        SCHEDULED("Scheduled"),
        CANCELLED("Cancelled"),
        EXPIRED("Expired");
        
        private final String label;
        NotificationStatus(String label) { this.label = label; }
        public String getLabel() { return label; }
    }
    
    public enum NotificationCategory {
        RISK_ALERT("Risk Alert"),
        WORKFLOW("Workflow"),
        KRI_BREACH("KRI Breach"),
        COMPLIANCE("Compliance"),
        SYSTEM("System"),
        REMINDER("Reminder"),
        ESCALATION("Escalation");
        
        private final String label;
        NotificationCategory(String label) { this.label = label; }
        public String getLabel() { return label; }
    }
    
    // Factory methods for creating different types of notifications
    public static NotificationMessage createRiskAlert(RiskRegister risk, NotificationService.AlertType alertType) {
        NotificationMessage msg = new NotificationMessage();
        msg.type = NotificationService.NotificationType.RISK_ALERT;
        msg.category = NotificationCategory.RISK_ALERT;
        msg.riskId = risk.id;
        msg.alertType = alertType;
        msg.title = "Risk Alert: " + risk.riskTitle;
        msg.message = buildRiskAlertMessage(risk, alertType);
        msg.priority = determineAlertPriority(alertType);
        msg.timestamp = LocalDateTime.now();
        msg.templateId = "risk-alert-template";
        msg.channels = List.of("email", "system");
        
        // Add template data
        msg.templateData.put("riskTitle", risk.riskTitle);
        msg.templateData.put("riskScore", risk.residualRiskScore);
        msg.templateData.put("owner", risk.owner != null ? risk.owner.getFullName() : "Unknown");
        
        return msg;
    }
    
    public static NotificationMessage createWorkflowNotification(RiskWorkflow workflow, WorkflowStep step) {
        NotificationMessage msg = new NotificationMessage();
        msg.type = NotificationService.NotificationType.WORKFLOW;
        msg.category = NotificationCategory.WORKFLOW;
        msg.workflowId = workflow.id;
        msg.stepId = step.id;
        msg.riskId = workflow.risk.id;
        msg.title = "Workflow Action Required";
        msg.message = String.format("Workflow step '%s' requires your attention for risk: %s", 
                                   step.stepName, workflow.risk.riskTitle);
        msg.priority = NotificationPriority.NORMAL;
        msg.timestamp = LocalDateTime.now();
        msg.templateId = "workflow-notification-template";
        msg.channels = List.of("email", "system");
        msg.recipients = List.of(step.assignedTo.email);
        
        return msg;
    }
    
    public static NotificationMessage createKRIBreach(KeyRiskIndicator kri, BigDecimal breachValue) {
        NotificationMessage msg = new NotificationMessage();
        msg.type = NotificationService.NotificationType.KRI_BREACH;
        msg.category = NotificationCategory.KRI_BREACH;
        msg.kriId = kri.id;
        msg.riskId = kri.risk.id;
        msg.title = "KRI Threshold Breach";
        msg.message = String.format("KRI '%s' has breached threshold: %s %s (Threshold: %s)", 
                                   kri.indicatorName, breachValue, kri.unitOfMeasure, kri.thresholdValue);
        msg.priority = NotificationPriority.HIGH;
        msg.timestamp = LocalDateTime.now();
        msg.templateId = "kri-breach-template";
        msg.channels = List.of("email", "sms", "system");
        msg.recipients = List.of(kri.risk.owner.email, kri.responsibleParty);
        
        return msg;
    }
    
    private static String buildRiskAlertMessage(RiskRegister risk, NotificationService.AlertType alertType) {
        return switch (alertType) {
            case HIGH_RISK -> String.format("High risk identified: %s (Score: %d)", 
                                           risk.riskTitle, risk.residualRiskScore);
            case OVERDUE_ACTION -> String.format("Overdue mitigation action for risk: %s", 
                                                risk.riskTitle);
            case REVIEW_DUE -> String.format("Risk review due: %s", risk.riskTitle);
            case ESCALATION -> String.format("Risk escalated: %s", risk.riskTitle);
        };
    }
    
    private static NotificationPriority determineAlertPriority(NotificationService.AlertType alertType) {
        return switch (alertType) {
            case HIGH_RISK, ESCALATION -> NotificationPriority.HIGH;
            case OVERDUE_ACTION -> NotificationPriority.NORMAL;
            case REVIEW_DUE -> NotificationPriority.LOW;
        };
    }
    
    public boolean isExpired() {
        if (scheduledTime == null) return false;
        return LocalDateTime.now().isAfter(scheduledTime.plusHours(24)); // 24-hour expiry
    }
    
    public boolean canRetry() {
        return retryCount < maxRetries && status == NotificationStatus.FAILED;
    }
}

// EmailService.java - Complete standalone service class
@ApplicationScoped
public class EmailService {
    
    private static final Logger log = LoggerFactory.getLogger(EmailService.class);
    
    @ConfigProperty(name = "app.email.enabled", defaultValue = "true")
    boolean emailEnabled;
    
    @ConfigProperty(name = "app.email.from")
    Optional<String> fromAddress;
    
    @ConfigProperty(name = "app.email.smtp.host")
    Optional<String> smtpHost;
    
    @ConfigProperty(name = "app.email.smtp.port", defaultValue = "587")
    int smtpPort;
    
    @ConfigProperty(name = "app.email.smtp.username")
    Optional<String> smtpUsername;
    
    @ConfigProperty(name = "app.email.smtp.password")
    Optional<String> smtpPassword;
    
    @ConfigProperty(name = "app.email.smtp.tls", defaultValue = "true")
    boolean smtpTls;
    
    @ConfigProperty(name = "app.email.template.base-url")
    Optional<String> baseUrl;
    
    @Inject
    @Channel("email-queue")
    Emitter<EmailMessage> emailEmitter;
    
    private final Map<String, EmailTemplate> emailTemplates = new HashMap<>();
    private Properties smtpProperties;
    
    @PostConstruct
    public void initializeEmailService() {
        setupSMTPProperties();
        loadEmailTemplates();
        log.info("Email service initialized. Enabled: {}", emailEnabled);
    }
    
    public CompletableFuture<Boolean> sendNotificationEmail(NotificationMessage notification) {
        if (!emailEnabled || fromAddress.isEmpty()) {
            log.warn("Email service is disabled or not configured properly");
            return CompletableFuture.completedFuture(false);
        }
        
        return CompletableFuture.supplyAsync(() -> {
            try {
                EmailMessage email = createEmailFromNotification(notification);
                return sendEmailDirect(email);
                
            } catch (Exception e) {
                log.error("Failed to send notification email for ID: " + notification.id, e);
                updateNotificationStatus(notification, NotificationMessage.NotificationStatus.FAILED, e.getMessage());
                return false;
            }
        });
    }
    
    public void sendBulkNotifications(List<NotificationMessage> notifications) {
        if (!emailEnabled) return;
        
        List<CompletableFuture<Boolean>> futures = notifications.stream()
                .filter(this::shouldSendEmail)
                .map(this::sendNotificationEmail)
                .collect(Collectors.toList());
        
        CompletableFuture.allOf(futures.toArray(new CompletableFuture[0]))
                .thenRun(() -> log.info("Completed sending {} bulk emails", futures.size()));
    }
    
    public boolean sendCustomEmail(String to, String subject, String body, String templateId) {
        if (!emailEnabled) return false;
        
        EmailMessage email = new EmailMessage();
        email.to = List.of(to);
        email.from = fromAddress.orElse("noreply@company.com");
        email.subject = subject;
        email.body = templateId != null ? applyTemplate(body, templateId, Map.of()) : body;
        email.priority = EmailPriority.NORMAL;
        email.timestamp = LocalDateTime.now();
        
        return sendEmailDirect(email);
    }
    
    public boolean sendEmailWithAttachment(String to, String subject, String body, 
                                         List<EmailMessage.EmailAttachment> attachments) {
        if (!emailEnabled) return false;
        
        EmailMessage email = new EmailMessage();
        email.to = List.of(to);
        email.from = fromAddress.orElse("noreply@company.com");
        email.subject = subject;
        email.body = body;
        email.attachments = attachments;
        email.priority = EmailPriority.NORMAL;
        
        return sendEmailDirect(email);
    }
    
    private boolean sendEmailDirect(EmailMessage emailMessage) {
        try {
            Session session = Session.getInstance(smtpProperties, new Authenticator() {
                @Override
                protected PasswordAuthentication getPasswordAuthentication() {
                    return new PasswordAuthentication(
                        smtpUsername.orElse(""), 
                        smtpPassword.orElse("")
                    );
                }
            });
            
            MimeMessage message = createMimeMessage(session, emailMessage);
            Transport.send(message);
            
            emailMessage.status = EmailMessage.EmailStatus.SENT;
            log.info("Email sent successfully to: {}", emailMessage.to);
            return true;
            
        } catch (MessagingException e) {
            log.error("Failed to send email to: " + emailMessage.to, e);
            emailMessage.status = EmailMessage.EmailStatus.FAILED;
            emailMessage.errorMessage = e.getMessage();
            return false;
        }
    }
    
    private MimeMessage createMimeMessage(Session session, EmailMessage emailMessage) throws MessagingException {
        MimeMessage message = new MimeMessage(session);
        
        // Set basic properties
        message.setFrom(new InternetAddress(emailMessage.from));
        message.setSubject(emailMessage.subject);
        message.setSentDate(new Date());
        
        // Set recipients
        for (String recipient : emailMessage.to) {
            message.addRecipient(Message.RecipientType.TO, new InternetAddress(recipient));
        }
        
        if (emailMessage.cc != null) {
            for (String cc : emailMessage.cc) {
                message.addRecipient(Message.RecipientType.CC, new InternetAddress(cc));
            }
        }
        
        if (emailMessage.bcc != null) {
            for (String bcc : emailMessage.bcc) {
                message.addRecipient(Message.RecipientType.BCC, new InternetAddress(bcc));
            }
        }
        
        // Set priority
        String priority = switch (emailMessage.priority) {
            case LOW -> "5";
            case NORMAL -> "3";
            case HIGH -> "2";
            case CRITICAL -> "1";
        };
        message.setHeader("X-Priority", priority);
        
        // Set content
        if (emailMessage.attachments != null && !emailMessage.attachments.isEmpty()) {
            // Multipart message with attachments
            MimeMultipart multipart = new MimeMultipart();
            
            // Add body part
            MimeBodyPart bodyPart = new MimeBodyPart();
            bodyPart.setContent(emailMessage.body, "text/html; charset=utf-8");
            multipart.addBodyPart(bodyPart);
            
            // Add attachments
            for (EmailMessage.EmailAttachment attachment : emailMessage.attachments) {
                MimeBodyPart attachmentPart = new MimeBodyPart();
                attachmentPart.setDataHandler(new DataHandler(new ByteArrayDataSource(
                    attachment.content, attachment.contentType)));
                attachmentPart.setFileName(attachment.fileName);
                
                if (attachment.inline) {
                    attachmentPart.setHeader("Content-ID", "<" + attachment.contentId + ">");
                    attachmentPart.setDisposition(MimeBodyPart.INLINE);
                } else {
                    attachmentPart.setDisposition(MimeBodyPart.ATTACHMENT);
                }
                
                multipart.addBodyPart(attachmentPart);
            }
            
            message.setContent(multipart);
        } else {
            // Simple HTML message
            message.setContent(emailMessage.body, "text/html; charset=utf-8");
        }
        
        return message;
    }
    
    private EmailMessage createEmailFromNotification(NotificationMessage notification) {
        EmailMessage email = new EmailMessage();
        email.to = notification.recipients;
        email.from = fromAddress.orElse("noreply@company.com");
        email.subject = notification.title;
        email.body = buildEmailBody(notification);
        email.priority = mapNotificationPriorityToEmailPriority(notification.priority);
        email.timestamp = notification.timestamp;
        email.notificationId = notification.id;
        email.templateId = notification.templateId;
        
        return email;
    }
    
    private String buildEmailBody(NotificationMessage notification) {
        if (notification.templateId != null && emailTemplates.containsKey(notification.templateId)) {
            return applyTemplate(emailTemplates.get(notification.templateId).getTemplate(), 
                               notification.templateId, notification.templateData);
        }
        
        return buildDefaultEmailTemplate(notification);
    }
    
    private String applyTemplate(String template, String templateId, Map<String, Object> templateData) {
        String result = template;
        
        // Add system-wide template variables
        templateData.put("systemUrl", baseUrl.orElse("http://localhost:8080"));
        templateData.put("currentYear", String.valueOf(LocalDate.now().getYear()));
        templateData.put("companyName", "Your Company Name");
        
        // Replace template variables
        for (Map.Entry<String, Object> entry : templateData.entrySet()) {
            String placeholder = "{{" + entry.getKey() + "}}";
            String value = entry.getValue() != null ? String.valueOf(entry.getValue()) : "";
            result = result.replace(placeholder, value);
        }
        
        return result;
    }
    
    private String buildDefaultEmailTemplate(NotificationMessage notification) {
        return String.format("""
            <html>
            <body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto;">
                <div style="background: linear-gradient(135deg, #667eea 0%%, #764ba2 100%%); color: white; padding: 20px; text-align: center;">
                    <h1 style="margin: 0; font-size: 24px;">🔔 %s</h1>
                </div>
                <div style="padding: 20px; background: #f8f9fa; border: 1px solid #dee2e6;">
                    <h2 style="color: #495057; margin-top: 0;">Risk Management Notification</h2>
                    <div style="background: white; padding: 15px; border-radius: 8px; margin: 15px 0; border-left: 4px solid %s;">
                        <p><strong>Message:</strong> %s</p>
                        <p><strong>Priority:</strong> <span style="color: %s; font-weight: bold;">%s</span></p>
                        <p><strong>Time:</strong> %s</p>
                        <p><strong>Category:</strong> %s</p>
                    </div>
                    <div style="margin-top: 20px; padding: 15px; background: #e9ecef; border-radius: 8px;">
                        <p style="margin: 0;"><strong>⚡ Action Required:</strong> Please log into the Risk Management System to review and take appropriate action.</p>
                    </div>
                    <div style="text-align: center; margin: 20px 0;">
                        <a href="%s" style="background: #007bff; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; display: inline-block;">
                            🚀 Access Risk Management System
                        </a>
                    </div>
                </div>
                <div style="background: #6c757d; color: white; padding: 15px; text-align: center; font-size: 12px;">
                    <p style="margin: 0;">Enterprise Risk Management System | Automated Notification</p>
                    <p style="margin: 5px 0 0 0;">Please do not reply to this email. For support, contact your IT administrator.</p>
                </div>
            </body>
            </html>
            """, 
            notification.title,
            getPriorityColor(notification.priority),
            notification.message,
            getPriorityColor(notification.priority),
            notification.priority.name(),
            notification.timestamp.format(DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss")),
            notification.category != null ? notification.category.getLabel() : "System",
            baseUrl.orElse("http://localhost:8080")
        );
    }
    
    private String getPriorityColor(NotificationMessage.NotificationPriority priority) {
        return switch (priority) {
            case LOW -> "#28a745";      // Green
            case NORMAL -> "#007bff";   // Blue
            case HIGH -> "#fd7e14";     // Orange
            case CRITICAL -> "#dc3545"; // Red
        };
    }
    
    private EmailPriority mapNotificationPriorityToEmailPriority(NotificationMessage.NotificationPriority priority) {
        return switch (priority) {
