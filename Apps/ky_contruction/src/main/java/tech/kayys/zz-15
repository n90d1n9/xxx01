cat <<EOF > load-test.js
import http from 'k6/http';
import { check, sleep } from 'k6';

export let options = {
  stages: [
    { duration: '2m', target: 10 }, // Ramp up
    { duration: '5m', target: 50 }, // Stay at 50 users
    { duration: '2m', target: 100 }, // Ramp up to 100 users
    { duration: '5m', target: 100 }, // Stay at 100 users
    { duration: '2m', target: 0 }, // Ramp down
  ],
  thresholds: {
    http_req_duration: ['p(95)<2000'], // 95% of requests must complete below 2s
    http_req_failed: ['rate<0.1'], // Error rate must be below 10%
  },
};

const BASE_URL = __ENV.BASE_URL || 'http://localhost:8080';

export default function () {
  // Test dashboard endpoint
  let response = http.get(\`\${BASE_URL}/api/reports/dashboard\`);
  check(response, {
    'dashboard status is 200': (r) => r.status === 200,
    'dashboard response time < 1000ms': (r) => r.timings.duration < 1000,
  });

  // Test project list
  response = http.get(\`\${BASE_URL}/api/projects\`);
  check(response, {
    'projects status is 200': (r) => r.status === 200,
    'projects response time < 500ms': (r) => r.timings.duration < 500,
  });

  // Test health check
  response = http.get(\`\${BASE_URL}/health/ready\`);
  check(response, {
    'health check is UP': (r) => r.status === 200,
  });

  sleep(1);
}
EOF

