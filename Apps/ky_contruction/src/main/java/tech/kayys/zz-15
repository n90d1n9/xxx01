        if (projectId != null) {
            query.append(" and project.id = ?").append(params.size() + 1);
            params.add(projectId);
        }
        
        if (workPackageId != null) {
            query.append(" and workPackage.id = ?").append(params.size() + 1);
            params.add(workPackageId);
        }
        
        if (fromDateStr != null) {
            LocalDate fromDate = LocalDate.parse(fromDateStr);
            query.append(" and date >= ?").append(params.size() + 1);
            params.add(fromDate);
        }
        
        if (toDateStr != null) {
            LocalDate toDate = LocalDate.parse(toDateStr);
            query.append(" and date <= ?").append(params.size() + 1);
            params.add(toDate);
        }
        
        query.append(" ORDER BY date DESC");
        
        productivity = LaborProductivity.list(query.toString(), params.toArray());
        return Response.ok(productivity).build();
    }
    
