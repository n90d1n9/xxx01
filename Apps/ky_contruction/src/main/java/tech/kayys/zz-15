# Production deployment script
#!/bin/bash

set -e

echo "🏗️  Starting enterprise deployment of Konstruksi PMS..."

# Configuration
APP_NAME="konstruksi-pms-enterprise"
VERSION=${1:-$(git rev-parse --short HEAD)}
IMAGE_NAME="$APP_NAME:$VERSION"
REGISTRY=${REGISTRY:-"your-registry.com"}
NAMESPACE=${NAMESPACE:-"konstruksi-pms"}
ENVIRONMENT=${ENVIRONMENT:-"production"}

# Build native application for performance
echo "📦 Building native application..."
./mvnw clean package -Pnative -Dquarkus.native.container-build=true

# Build optimized Docker image
echo "🐳 Building optimized Docker image..."
docker build -f Dockerfile.enterprise -t $IMAGE_NAME .
docker tag $IMAGE_NAME $REGISTRY/$IMAGE_NAME

# Security scan
echo "🔒 Running security scan..."
docker run --rm -v /var/run/docker.sock:/var/run/docker.sock \
  -v $HOME/.cache:/tmp/.cache/ \
  aquasec/trivy:latest image --exit-code 0 --no-progress --format table $IMAGE_NAME

# Push to registry
echo "⬆️  Pushing to registry..."
docker push $REGISTRY/$IMAGE_NAME

# Database migration
echo "🗄️  Running database migrations..."
kubectl create job --from=cronjob/db-migration migration-$(date +%Y%m%d-%H%M%S) -n $NAMESPACE || true

# Deploy to Kubernetes with zero downtime
echo "🚀 Deploying to Kubernetes..."
envsubst < k8s/deployment-$ENVIRONMENT.yaml | kubectl apply -f -

# Wait for rollout
echo "⏳ Waiting for rollout to complete..."
kubectl rollout status deployment/$APP_NAME -n $NAMESPACE --timeout=600s

# Run smoke tests
echo "🧪 Running smoke tests..."
kubectl run smoke-test --rm -i --restart=Never \
  --image=curlimages/curl:latest \
  -- curl -f http://$APP_NAME-service.$NAMESPACE.svc.cluster.local:8080/health/ready

# Update monitoring
echo "📊 Updating monitoring configuration..."
kubectl apply -f monitoring/ -n $NAMESPACE

# Cleanup old images
echo "🧹 Cleaning up..."
docker system prune -f

echo "✅ Deployment completed successfully!"
echo "🌐 Application URL: https://konstruksi-pms.$ENVIRONMENT.your-domain.com"
echo "📈 Grafana: https://grafana.$ENVIRONMENT.your-domain.com"
echo "🔍 Logs: kubectl logs -f deployment/$APP_NAME -n $NAMESPACE"

