#!/bin/bash

# Database backup script
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
BACKUP_DIR="/opt/backups"
DB_NAME="konstruksi_pms_enterprise"
DB_USER="konstruksi_user"

# Create backup directory
mkdir -p $BACKUP_DIR

# Full database backup
echo "Creating full database backup..."
pg_dump -h localhost -U $DB_USER -F c -b -v -f "$BACKUP_DIR/db_backup_$TIMESTAMP.backup" $DB_NAME

# Compress backup
gzip "$BACKUP_DIR/db_backup_$TIMESTAMP.backup"

# Upload to cloud storage (AWS S3 example)
aws s3 cp "$BACKUP_DIR/db_backup_$TIMESTAMP.backup.gz" s3://konstruksi-pms-backups/

# Clean old local backups (keep 7 days)
find $BACKUP_DIR -name "db_backup_*.backup.gz" -mtime +7 -delete

echo "Backup completed: db_backup_$TIMESTAMP.backup.gz"

# File upload backup
tar -czf "$BACKUP_DIR/uploads_backup_$TIMESTAMP.tar.gz" /tmp/konstruksi-uploads/
aws s3 cp "$BACKUP_DIR/uploads_backup_$TIMESTAMP.tar.gz" s3://konstruksi-pms-backups/uploads/

echo "✅ Backup process completed"

