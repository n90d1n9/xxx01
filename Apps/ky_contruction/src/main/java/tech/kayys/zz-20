@Path("/api/construction/drawings")
@Produces(MediaType.APPLICATION_JSON)
@Consumes(MediaType.APPLICATION_JSON)
public class ConstructionDrawingController {
    
    @GET
    @Path("/projects/{projectId}")
    public Response getProjectDrawings(@PathParam("projectId") Long projectId,
                                     @QueryParam("discipline") String discipline,
                                     @QueryParam("type") String drawingType,
                                     @QueryParam("status") String status) {
        List<ConstructionDrawing> drawings;
        
        StringBuilder query = new StringBuilder("project.id = ?1");
        List<Object> params = new ArrayList<>();
        params.add(projectId);
        
        if (discipline != null) {
            try {
                ConstructionDrawing.DrawingDiscipline disc = 
                        ConstructionDrawing.DrawingDiscipline.valueOf(discipline.toUpperCase());
                query.append(" and discipline = ?").append(params.size() + 1);
                params.add(disc);
            } catch (IllegalArgumentException e) {
                return Response.status(400).entity("Invalid discipline: " + discipline).build();
            }
        }
        
        if (drawingType != null) {
            try {
                ConstructionDrawing.DrawingType type = 
                        ConstructionDrawing.DrawingType.valueOf(drawingType.toUpperCase());
                query.append(" and drawingType = ?").append(params.size() + 1);
                params.add(type);
            } catch (IllegalArgumentException e) {
                return Response.status(400).entity("Invalid drawing type: " + drawingType).build();
            }
        }
        
        if (status != null) {
            try {
                ConstructionDrawing.DrawingStatus drawingStatus = 
                        ConstructionDrawing.DrawingStatus.valueOf(status.toUpperCase());
                query.append(" and status = ?").append(params.size() + 1);
                params.add(drawingStatus);
            } catch (IllegalArgumentException e) {
                return Response.status(400).entity("Invalid status: " + status).build();
            }
        }
        
        query.append(" ORDER BY drawingNumber");
        
        drawings = ConstructionDrawing.list(query.toString(), params.toArray());
        return Response.ok(drawings).build();
    }
    
    @POST
    public Response createDrawing(@Valid ConstructionDrawing drawing) {
        // Generate drawing number if not provided
        if (drawing.drawingNumber == null || drawing.drawingNumber.isEmpty()) {
            drawing.drawingNumber = generateDrawingNumber(drawing);
        }
        
        drawing.issuedDate = LocalDate.now();
        drawing.persist();
        
        return Response.status(201).entity(drawing).build();
    }
    
    @PUT
    @Path("/{id}/status")
    @RolesAllowed({"PROJECT_MANAGER", "SITE_ENGINEER"})
    public Response updateDrawingStatus(@PathParam("id") Long id,
                                       @QueryParam("status") String status,
                                       @QueryParam("updatedBy") String updatedBy) {
        ConstructionDrawing drawing = ConstructionDrawing.findById(id);
        if (drawing == null) {
            return Response.status(404).build();
        }
        
        try {
            ConstructionDrawing.DrawingStatus newStatus = 
                    ConstructionDrawing.DrawingStatus.valueOf(status.toUpperCase());
            drawing.status = newStatus;
            
            if (newStatus == ConstructionDrawing.DrawingStatus.APPROVED) {
                drawing.approvedBy = updatedBy;
            } else if (newStatus == ConstructionDrawing.DrawingStatus.FOR_REVIEW) {
                drawing.checkedBy = updatedBy;
            }
            
            drawing.persist();
            return Response.ok(drawing).build();
            
        } catch (IllegalArgumentException e) {
            return Response.status(400).entity("Invalid status: " + status).build();
        }
    }
    
    @POST
    @Path("/{id}/revisions")
    public Response createRevision(@PathParam("id") Long id, DrawingRevision revision) {
        ConstructionDrawing drawing = ConstructionDrawing.findById(id);
        if (drawing == null) {
            return Response.status(404).build();
        }
        
        revision.drawing = drawing;
        revision.revisionDate = LocalDate.now();
        revision.persist();
        
        // Update drawing's current revision
        drawing.currentRevision = revision.revisionCode;
        drawing.persist();
        
        return Response.status(201).entity(revision).build();
    }
    
    @GET
    @Path("/{id}/revisions")
    public Response getDrawingRevisions(@PathParam("id") Long id) {
        List<DrawingRevision> revisions = DrawingRevision
                .list("drawing.id = ?1 ORDER BY revisionDate DESC", id);
        return Response.ok(revisions).build();
    }
    
    private String generateDrawingNumber(ConstructionDrawing drawing) {
        String prefix = drawing.discipline.getPrefix();
        String projectCode = drawing.project.projectCode;
        String typeCode = drawing.drawingType.name().substring(0, 2);
        
        long count = ConstructionDrawing.count("project = ?1 and discipline = ?2", 
                drawing.project, drawing.discipline) + 1;
        
        return String.format("%s-%s-%s-%03d", projectCode, prefix, typeCode, count);
    }
}

