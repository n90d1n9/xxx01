    private void updatePhaseStatus(ConstructionPhase phase) {
        if (phase.physicalProgressPercentage == null) return;
        
        BigDecimal progress = phase.physicalProgressPercentage;
        
        if (progress.compareTo(BigDecimal.ZERO) == 0) {
            if (phase.actualStartDate != null) {
                phase.status = ConstructionPhase.PhaseStatus.PREPARING;
            } else {
                phase.status = ConstructionPhase.PhaseStatus.NOT_STARTED;
            }
        } else if (progress.compareTo(new BigDecimal("100")) == 0) {
            phase.status = ConstructionPhase.PhaseStatus.COMPLETED;
            if (phase.actualEndDate == null) {
                phase.actualEndDate = LocalDate.now();
            }
        } else {
            phase.status = ConstructionPhase.PhaseStatus.IN_PROGRESS;
            if (phase.actualStartDate == null) {
                phase.actualStartDate = LocalDate.now();
            }
        }
    }
    
    private boolean activitiesOverlap(PhaseActivity activity1, PhaseActivity activity2) {
        if (activity1.plannedStartDate == null || activity1.plannedEndDate == null ||
            activity2.plannedStartDate == null || activity2.plannedEndDate == null) {
            return false;
        }
        
        return !(activity1.plannedEndDate.isBefore(activity2.plannedStartDate) ||
                activity2.plannedEndDate.isBefore(activity1.plannedStartDate));
    }
    
    private void generateOptimizationRecommendations(PhaseResourceOptimization optimization) {
        List<String> recommendations = new ArrayList<>();
        
        if (!optimization.resourceConflicts.isEmpty()) {
            recommendations.add("Detected " + optimization.resourceConflicts.size() + 
                    " resource conflicts. Consider activity rescheduling or additional resources.");
        }
        
        if (optimization.phase.isDelayed()) {
            recommendations.add("Phase is " + optimization.phase.getDaysDelayed() + 
                    " days delayed. Consider crash duration strategies.");
        }
        
        Double spi = optimization.phase.getSchedulePerformanceIndex();
        if (spi != null && spi < 0.9) {
            recommendations.add("Schedule Performance Index (" + String.format("%.2f", spi) + 
                    ") indicates schedule issues. Review critical activities.");
        }
        
        Double cpi = optimization.phase.getCostPerformanceIndex();
        if (cpi != null && cpi < 0.9) {
            recommendations.add("Cost Performance Index (" + String.format("%.2f", cpi) + 
                    ") indicates cost overrun. Review budget allocation.");
        }
        
        optimization.recommendations = String.join(" ", recommendations);
    }
    
