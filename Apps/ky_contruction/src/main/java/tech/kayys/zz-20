    public Response getMilestoneDashboard(@QueryParam("project") Long projectId) {
        Map<String, Object> dashboard = new HashMap<>();
        
        String baseCondition = projectId != null ? "project.id = " + projectId + " and " : "";
        
        // Overall statistics
        long totalMilestones = ConstructionMilestone.count(
                (baseCondition + "1=1").replace(" and 1=1", ""));
        long completedMilestones = ConstructionMilestone.count(
                baseCondition + "status = 'COMPLETED'");
        long overdueMilestones = ConstructionMilestone.count(
                baseCondition + "plannedDate < CURRENT_DATE and status != 'COMPLETED'");
        long criticalMilestones = ConstructionMilestone.count(
                baseCondition + "criticalMilestone = true");
        
        dashboard.put("totalMilestones", totalMilestones);
        dashboard.put("completedMilestones", completedMilestones);
        dashboard.put("overdueMilestones", overdueMilestones);
