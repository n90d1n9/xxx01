    static {
        // Initialize with some standard Indonesian construction productivity rates
        STANDARD_RATES.put("CONCRETE_m3", new BigDecimal("2.5"));
        STANDARD_RATES.put("MASONRY_m2", new BigDecimal("4.0"));
