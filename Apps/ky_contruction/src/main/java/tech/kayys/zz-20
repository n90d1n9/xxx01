    public BigDecimal getStandardProductivityRate(WorkCategory category, String unit) {
        if (category == null || unit == null) return null;
        
        String key = category.code + "_" + unit.toLowerCase();
        return STANDARD_RATES.get(key);
    }
    
    public BigDecimal getHSPKRate(String hspkCode, String region) {
        // In a real implementation, this would query the official HSPK database
        // For now, return a sample rate
        HSPKRate rate = HSPKRate.find("hspkCode = ?1 and region = ?2 and isActive = true", 
                hspkCode, region).firstResult();
        
        return rate != null ? rate.rateValue : null;
    }
    
    public List<HSPKRate> searchHSPKRates(String description, String region) {
        return HSPKRate.list("description ILIKE ?1 and region = ?2 and isActive = true", 
                "%" + description + "%", region);
    }
}

