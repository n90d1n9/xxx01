CREATE OR REPLACE FUNCTION calculate_critical_path(project_id_param BIGINT)
RETURNS TABLE (
    phase_id BIGINT,
    phase_code VARCHAR,
    phase_name VARCHAR,
    early_start DATE,
    early_finish DATE,
    late_start DATE,
    late_finish DATE,
    total_float INTEGER,
    is_critical BOOLEAN
) AS $
BEGIN
    -- Simple critical path calculation
    -- In a real implementation, this would use CPM algorithm
    RETURN QUERY
    SELECT 
        cp.id,
        cp.phase_code,
        cp.phase_name,
        cp.planned_start_date as early_start,
        cp.planned_end_date as early_finish,
        cp.planned_start_date as late_start,
        cp.planned_end_date as late_finish,
        0 as total_float,
        cp.critical_path as is_critical
    FROM construction_phases cp
    WHERE cp.project_id = project_id_param
    ORDER BY cp.phase_sequence;
END;
$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION update_construction_progress(phase_id_param BIGINT)
RETURNS VOID AS $
DECLARE
    phase_record RECORD;
    total_budget DECIMAL;
    weighted_progress DECIMAL;
BEGIN
    -- Get phase record
    SELECT * INTO phase_record FROM construction_phases WHERE id = phase_id_param;
    
    IF phase_record IS NULL THEN
        RAISE EXCEPTION 'Phase not found: %', phase_id_param;
    END IF;
    
    -- Calculate weighted progress from activities
    SELECT 
        COALESCE(SUM(activity_budget), 0),
        CASE 
            WHEN SUM(activity_budget) > 0 THEN
                SUM(COALESCE(activity_budget, 0) * COALESCE(progress_percentage, 0)) / SUM(activity_budget)
            ELSE 0
        END
    INTO total_budget, weighted_progress
    FROM phase_activities 
    WHERE phase_id = phase_id_param;
    
    -- Update phase progress
    UPDATE construction_phases 
    SET 
        physical_progress_percentage = weighted_progress,
        actual_cost = (
            SELECT COALESCE(SUM(actual_cost), 0) 
            FROM phase_activities 
            WHERE phase_id = phase_id_param
        )
    WHERE id = phase_id_param;
    
    -- Update phase status based on progress
    UPDATE construction_phases
    SET status = CASE
        WHEN weighted_progress = 0 THEN 'NOT_STARTED'
        WHEN weighted_progress = 100 THEN 'COMPLETED'
        WHEN weighted_progress > 0 THEN 'IN_PROGRESS'
        ELSE status
    END
    WHERE id = phase_id_param;
    
END;
$ LANGUAGE plpgsql;

-- Triggers for automatic updates
CREATE OR REPLACE FUNCTION trigger_update_phase_progress()
RETURNS TRIGGER AS $
BEGIN
    -- Update phase progress when activity progress changes
    PERFORM update_construction_progress(NEW.phase_id);
    RETURN NEW;
END;
$ LANGUAGE plpgsql;

CREATE TRIGGER trig_activity_progress_update
    AFTER UPDATE OF progress_percentage, actual_cost ON phase_activities
    FOR EACH ROW
    EXECUTE FUNCTION trigger_update_phase_progress();

CREATE OR REPLACE FUNCTION trigger_update_project_progress()
RETURNS TRIGGER AS $
BEGIN
    -- Update project progress when phase progress changes
    UPDATE projects 
    SET 
        progress_percentage = (
            SELECT COALESCE(ROUND(AVG(physical_progress_percentage)), 0)
            FROM construction_phases 
            WHERE project_id = NEW.project_id
        ),
        actual_cost = (
            SELECT COALESCE(SUM(actual_cost), 0)
            FROM construction_phases 
            WHERE project_id = NEW.project_id
        )
    WHERE id = NEW.project_id;
    
    RETURN NEW;
END;
$ LANGUAGE plpgsql;

CREATE TRIGGER trig_phase_progress_update
    AFTER UPDATE OF physical_progress_percentage, actual_cost ON construction_phases
    FOR EACH ROW
    EXECUTE FUNCTION trigger_update_project_progress();

