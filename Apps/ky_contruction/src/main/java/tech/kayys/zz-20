        existing.description = phase.description;
        existing.plannedStartDate = phase.plannedStartDate;
        existing.plannedEndDate = phase.plannedEndDate;
        existing.phaseBudget = phase.phaseBudget;
        existing.environmentalImpact = phase.environmentalImpact;
        existing.sniStandards = phase.sniStandards;
        existing.k3Requirements = phase.k3Requirements;
        
        existing.persist();
        return Response.ok(existing).build();
    }
    
