@Path("/api/construction/milestones")
@Produces(MediaType.APPLICATION_JSON)
@Consumes(MediaType.APPLICATION_JSON)
public class ConstructionMilestoneController {
    
    @GET
    @Path("/projects/{projectId}")
    public Response getProjectMilestones(@PathParam("projectId") Long projectId,
                                       @QueryParam("category") String category,
                                       @QueryParam("status") String status,
                                       @QueryParam("critical") Boolean critical) {
        List<ConstructionMilestone> milestones;
        
        StringBuilder query = new StringBuilder("project.id = ?1");
        List<Object> params = new ArrayList<>();
        params.add(projectId);
        
        if (category != null) {
            try {
                ConstructionMilestone.MilestoneCategory cat = 
                        ConstructionMilestone.MilestoneCategory.valueOf(category.toUpperCase());
                query.append(" and category = ?").append(params.size() + 1);
                params.add(cat);
            } catch (IllegalArgumentException e) {
                return Response.status(400).entity("Invalid category: " + category).build();
            }
        }
        
        if (status != null) {
            try {
                ConstructionMilestone.MilestoneStatus milestoneStatus = 
                        ConstructionMilestone.MilestoneStatus.valueOf(status.toUpperCase());
                query.append(" and status = ?").append(params.size() + 1);
                params.add(milestoneStatus);
            } catch (IllegalArgumentException e) {
                return Response.status(400).entity("Invalid status: " + status).build();
            }
        }
        
        if (critical != null) {
            query.append(" and criticalMilestone = ?").append(params.size() + 1);
            params.add(critical);
        }
        
        query.append(" ORDER BY plannedDate");
        
        milestones = ConstructionMilestone.list(query.toString(), params.toArray());
        return Response.ok(milestones).build();
    }
    
    @POST
    public Response createMilestone(@Valid ConstructionMilestone milestone) {
        // Generate milestone code
        long count = ConstructionMilestone.count("project", milestone.project) + 1;
        milestone.milestoneCode = String.format("MS-%s-%03d", 
                milestone.project.projectCode, count);
        
        milestone.persist();
        return Response.status(201).entity(milestone).build();
    }
    
    @PUT
