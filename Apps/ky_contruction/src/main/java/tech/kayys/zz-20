@ApplicationScoped
public class DetailedBoQService {
    
    @Inject
    DetailedBoQAnalysisRepository analysisRepository;
    
    @Inject
    HSPKIntegrationService hspkService;
    
    @Transactional
    public DetailedBoQAnalysis createDetailedAnalysis(Long boqItemId) {
        BoqItem boqItem = BoqItem.findById(boqItemId);
        if (boqItem == null) {
            throw new IllegalArgumentException("BoQ item not found");
        }
        
        DetailedBoQAnalysis analysis = new DetailedBoQAnalysis();
        analysis.boqItem = boqItem;
        
        // Set default cost breakdowns based on work category
        setDefaultCostBreakdown(analysis, boqItem.workCategory);
        
        // Calculate productivity rates
        calculateProductivityRates(analysis, boqItem);
        
        // Set risk factors based on project and work type
        calculateRiskFactors(analysis, boqItem);
        
        // Calculate Indonesian compliance costs
        calculateComplianceCosts(analysis, boqItem);
        
        analysisRepository.persist(analysis);
        return analysis;
    }
    
    @Transactional
    public void updateAnalysisFromActual(Long analysisId, BigDecimal actualQuantity, 
                                       BigDecimal actualCost, int actualHours) {
        DetailedBoQAnalysis analysis = analysisRepository.findById(analysisId);
        if (analysis == null) return;
        
        // Calculate actual productivity
        if (actualHours > 0 && actualQuantity != null) {
            analysis.actualProductivityRate = actualQuantity.divide(
                    new BigDecimal(actualHours), 4, java.math.RoundingMode.HALF_UP);
            
            if (analysis.standardProductivityRate != null && 
                !analysis.standardProductivityRate.equals(BigDecimal.ZERO)) {
                analysis.productivityFactor = analysis.actualProductivityRate.divide(
                        analysis.standardProductivityRate, 3, java.math.RoundingMode.HALF_UP);
            }
        }
        
        // Calculate actual waste
        if (analysis.boqItem.quantity != null && actualQuantity != null) {
            BigDecimal expectedQuantity = analysis.boqItem.quantity;
            if (actualQuantity.compareTo(expectedQuantity) > 0) {
                BigDecimal waste = actualQuantity.subtract(expectedQuantity);
                analysis.actualWastePercentage = waste.divide(expectedQuantity, 4, 
                        java.math.RoundingMode.HALF_UP).multiply(new BigDecimal("100"));
                
                if (actualCost != null) {
                    BigDecimal unitCost = actualCost.divide(actualQuantity, 2, 
                            java.math.RoundingMode.HALF_UP);
                    analysis.wasteCostImpact = waste.multiply(unitCost);
                }
            }
        }
        
        analysisRepository.persist(analysis);
    }
    
    public BoQOptimizationReport generateOptimizationReport(Long projectId) {
        List<DetailedBoQAnalysis> analyses = analysisRepository.findByProject(projectId);
        BoQOptimizationReport report = new BoQOptimizationReport();
        report.projectId = projectId;
        report.generatedDate = LocalDateTime.now();
        
        // Analyze cost optimization opportunities
        List<CostOptimizationOpportunity> opportunities = new ArrayList<>();
        
        for (DetailedBoQAnalysis analysis : analyses) {
            // Check for high waste items
            if (analysis.actualWastePercentage != null && 
                analysis.actualWastePercentage.compareTo(new BigDecimal("10")) > 0) {
                
                CostOptimizationOpportunity opportunity = new CostOptimizationOpportunity();
                opportunity.boqItem = analysis.boqItem;
                opportunity.type = OptimizationType.WASTE_REDUCTION;
                opportunity.currentCost = analysis.boqItem.totalPrice;
                opportunity.potentialSavings = analysis.wasteCostImpact;
                opportunity.recommendation = String.format(
                        "Reduce waste from %.1f%% to 5%% through better material handling",
                        analysis.actualWastePercentage.doubleValue());
                opportunities.add(opportunity);
            }
            
            // Check for low productivity items
            if (analysis.productivityFactor != null && 
                analysis.productivityFactor.compareTo(new BigDecimal("0.8")) < 0) {
                
                CostOptimizationOpportunity opportunity = new CostOptimizationOpportunity();
                opportunity.boqItem = analysis.boqItem;
                opportunity.type = OptimizationType.PRODUCTIVITY_IMPROVEMENT;
                opportunity.currentCost = analysis.boqItem.totalPrice;
                
                // Calculate potential savings from improved productivity
                BigDecimal improvementPotential = new BigDecimal("0.2"); // 20% improvement
                BigDecimal currentLaborCost = analysis.boqItem.totalPrice.multiply(
                        analysis.laborCostPercentage.divide(new BigDecimal("100")));
                opportunity.potentialSavings = currentLaborCost.multiply(improvementPotential);
                
                opportunity.recommendation = String.format(
                        "Improve productivity from %.1f to standard rate through training and better methods",
                        analysis.actualProductivityRate.doubleValue());
                opportunities.add(opportunity);
            }
            
            // Check for alternative material opportunities
            checkMaterialAlternatives(analysis, opportunities);
        }
        
        report.optimizationOpportunities = opportunities;
        report.totalPotentialSavings = opportunities.stream()
                .map(o -> o.potentialSavings != null ? o.potentialSavings : BigDecimal.ZERO)
                .reduce(BigDecimal.ZERO, BigDecimal::add);
        
        return report;
    }
    
    private void setDefaultCostBreakdown(DetailedBoQAnalysis analysis, WorkCategory category) {
        if (category == null) return;
        
        // Set typical cost breakdowns by work category
        String categoryCode = category.code;
        switch (categoryCode) {
            case "CONCRETE":
                analysis.materialCostPercentage = new BigDecimal("65");
                analysis.laborCostPercentage = new BigDecimal("25");
                analysis.equipmentCostPercentage = new BigDecimal("10");
                break;
            case "STEEL":
                analysis.materialCostPercentage = new BigDecimal("70");
                analysis.laborCostPercentage = new BigDecimal("20");
                analysis.equipmentCostPercentage = new BigDecimal("10");
                break;
            case "MASONRY":
                analysis.materialCostPercentage = new BigDecimal("50");
                analysis.laborCostPercentage = new BigDecimal("40");
                analysis.equipmentCostPercentage = new BigDecimal("10");
                break;
            case "MEP":
                analysis.materialCostPercentage = new BigDecimal("60");
                analysis.laborCostPercentage = new BigDecimal("30");
                analysis.equipmentCostPercentage = new BigDecimal("10");
                break;
            case "FINISHING":
                analysis.materialCostPercentage = new BigDecimal("45");
                analysis.laborCostPercentage = new BigDecimal("50");
                analysis.equipmentCostPercentage = new BigDecimal("5");
                break;
            default:
                analysis.materialCostPercentage = new BigDecimal("55");
                analysis.laborCostPercentage = new BigDecimal("35");
                analysis.equipmentCostPercentage = new BigDecimal("10");
        }
    }
    
    private void calculateProductivityRates(DetailedBoQAnalysis analysis, BoqItem boqItem) {
        // Get standard productivity rates from HSPK or internal database
        BigDecimal standardRate = hspkService.getStandardProductivityRate(
                boqItem.workCategory, boqItem.unit);
        
        if (standardRate != null) {
            analysis.standardProductivityRate = standardRate;
        } else {
            // Set default rates based on work type
            setDefaultProductivityRates(analysis, boqItem.workCategory);
        }
        
        // Set expected waste percentages
        setExpectedWastePercentages(analysis, boqItem.workCategory);
    }
    
    private void setDefaultProductivityRates(DetailedBoQAnalysis analysis, WorkCategory category) {
        if (category == null) return;
        
        String categoryCode = category.code;
        switch (categoryCode) {
            case "CONCRETE":
                analysis.standardProductivityRate = new BigDecimal("2.5"); // m3/hour
                analysis.expectedWastePercentage = new BigDecimal("5");
                break;
            case "MASONRY":
                analysis.standardProductivityRate = new BigDecimal("4.0"); // m2/hour
                analysis.expectedWastePercentage = new BigDecimal("8");
                break;
            case "STEEL":
                analysis.standardProductivityRate = new BigDecimal("0.8"); // ton/hour
                analysis.expectedWastePercentage = new BigDecimal("3");
                break;
            case "FINISHING":
                analysis.standardProductivityRate = new BigDecimal("8.0"); // m2/hour
                analysis.expectedWastePercentage = new BigDecimal("10");
                break;
            default:
                analysis.standardProductivityRate = new BigDecimal("1.0");
                analysis.expectedWastePercentage = new BigDecimal("5");
        }
    }
    
    private void setExpectedWastePercentages(DetailedBoQAnalysis analysis, WorkCategory category) {
        // Already set in setDefaultProductivityRates
    }
    
    private void calculateRiskFactors(DetailedBoQAnalysis analysis, BoqItem boqItem) {
        Project project = boqItem.project;
        
        // Complexity factor based on project type and building height
        if (project.projectType != null) {
            String projectTypeCode = project.projectType.code;
            switch (projectTypeCode) {
                case "HIGH_RISE":
                    analysis.complexityFactor = new BigDecimal("1.15");
                    analysis.accessDifficultyFactor = new BigDecimal("1.10");
                    break;
                case "INFRASTRUCTURE":
                    analysis.complexityFactor = new BigDecimal("1.20");
                    analysis.weatherRiskFactor = new BigDecimal("1.15");
                    break;
                case "INDUSTRIAL":
                    analysis.complexityFactor = new BigDecimal("1.10");
                    analysis.qualityRiskFactor = new BigDecimal("1.05");
                    break;
                default:
                    analysis.complexityFactor = new BigDecimal("1.00");
            }
        }
        
        // Weather risk factor based on location and season
        calculateWeatherRiskFactor(analysis, project);
        
        // Quality risk factor based on work category
        calculateQualityRiskFactor(analysis, boqItem.workCategory);
    }
    
    private void calculateWeatherRiskFactor(DetailedBoQAnalysis analysis, Project project) {
        // Indonesian climate considerations
        LocalDate now = LocalDate.now();
        int month = now.getMonthValue();
        
        // Rainy season: October to April
        if (month >= 10 || month <= 4) {
            analysis.weatherRiskFactor = new BigDecimal("1.10");
        } else {
            analysis.weatherRiskFactor = new BigDecimal("1.00");
        }
        
        // Regional variations
        if (project.location != null) {
            String location = project.location.toLowerCase();
            if (location.contains("jakarta") || location.contains("surabaya")) {
                // Urban areas with more weather protection
                analysis.weatherRiskFactor = analysis.weatherRiskFactor.multiply(new BigDecimal("0.95"));
            } else if (location.contains("kalimantan") || location.contains("papua")) {
                // Remote areas with higher weather impact
                analysis.weatherRiskFactor = analysis.weatherRiskFactor.multiply(new BigDecimal("1.10"));
            }
        }
    }
    
    private void calculateQualityRiskFactor(DetailedBoQAnalysis analysis, WorkCategory category) {
        if (category == null) return;
        
        String categoryCode = category.code;
        switch (categoryCode) {
            case "CONCRETE":
            case "STEEL":
                // High quality requirements
                analysis.qualityRiskFactor = new BigDecimal("1.08");
                break;
            case "MEP":
                // Very high quality requirements
                analysis.qualityRiskFactor = new BigDecimal("1.10");
                break;
            case "FINISHING":
                // Medium quality requirements
                analysis.qualityRiskFactor = new BigDecimal("1.05");
                break;
            default:
                analysis.qualityRiskFactor = new BigDecimal("1.00");
        }
    }
    
    private void calculateComplianceCosts(DetailedBoQAnalysis analysis, BoqItem boqItem) {
        if (boqItem.totalPrice == null) return;
        
        BigDecimal basePrice = boqItem.totalPrice;
        
        // SNI compliance cost (typically 2-5% of item cost)
        analysis.sniComplianceCost = basePrice.multiply(new BigDecimal("0.03"));
        
        // K3 compliance cost (typically 1-3% of item cost)
        analysis.k3ComplianceCost = basePrice.multiply(new BigDecimal("0.02"));
        
        // Environmental compliance cost (typically 1-2% of item cost)
        analysis.environmentalComplianceCost = basePrice.multiply(new BigDecimal("0.015"));
        
        // Local content percentage (TKDN) - default 40% for construction
        analysis.localContentPercentage = new BigDecimal("40");
    }
    
    private void checkMaterialAlternatives(DetailedBoQAnalysis analysis, 
                                         List<CostOptimizationOpportunity> opportunities) {
        // Check if there are cheaper alternatives with similar specifications
        // This is a simplified version - in practice, this would query a materials database
        
        if (analysis.boqItem.workCategory != null && 
            analysis.boqItem.unitPrice != null &&
            analysis.boqItem.unitPrice.compareTo(new BigDecimal("1000000")) > 0) {
            
            CostOptimizationOpportunity opportunity = new CostOptimizationOpportunity();
            opportunity.boqItem = analysis.boqItem;
            opportunity.type = OptimizationType.MATERIAL_SUBSTITUTION;
            opportunity.currentCost = analysis.boqItem.totalPrice;
            opportunity.potentialSavings = analysis.boqItem.totalPrice.multiply(new BigDecimal("0.15"));
            opportunity.recommendation = "Consider alternative materials or suppliers for cost reduction";
            opportunities.add(opportunity);
        }
    }
    
    // Report classes
    public static class BoQOptimizationReport {
        public Long projectId;
        public LocalDateTime generatedDate;
        public List<CostOptimizationOpportunity> optimizationOpportunities;
        public BigDecimal totalPotentialSavings;
    }
    
    public static class CostOptimizationOpportunity {
        public BoqItem boqItem;
        public OptimizationType type;
        public BigDecimal currentCost;
        public BigDecimal potentialSavings;
        public String recommendation;
    }
    
    public enum OptimizationType {
        WASTE_REDUCTION,
        PRODUCTIVITY_IMPROVEMENT,
        MATERIAL_SUBSTITUTION,
        METHOD_IMPROVEMENT,
        BULK_PURCHASING
    }
}

