    public Response completeMilestone(@PathParam("id") Long id,
                                    @QueryParam("completedBy") String completedBy,
                                    @QueryParam("comments") String comments) {
        ConstructionMilestone milestone = ConstructionMilestone.findById(id);
        if (milestone == null) {
            return Response.status(404).build();
        }
        
        milestone.status = ConstructionMilestone.MilestoneStatus.COMPLETED;
        milestone.actualDate = LocalDate.now();
        milestone.comments = comments;
        
        if (milestone.approvalRequired) {
            milestone.approvedBy = completedBy;
            milestone.approvalDate = LocalDate.now();
        }
        
        milestone.persist();
        return Response.ok(milestone).build();
    }
    
    @GET
