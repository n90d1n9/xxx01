    public Response getUpcomingMilestones(@QueryParam("project") Long projectId,
                                        @QueryParam("days") Integer days) {
        int daysBefore = days != null ? days : 30;
        LocalDate cutoffDate = LocalDate.now().plusDays(daysBefore);
        
        List<ConstructionMilestone> upcoming;
        String baseQuery = "plannedDate BETWEEN CURRENT_DATE AND ?1 and status != 'COMPLETED'";
        
        if (projectId != null) {
            upcoming = ConstructionMilestone.list(
                    "project.id = ?1 and " + baseQuery, projectId, cutoffDate);
        } else {
            upcoming = ConstructionMilestone.list(baseQuery, cutoffDate);
        }
        
        return Response.ok(upcoming).build();
    }
    
