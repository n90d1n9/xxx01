-- Performance optimization views
CREATE OR REPLACE VIEW v_construction_phase_performance AS
SELECT 
    cp.id,
    cp.project_id,
    cp.phase_code,
    cp.phase_name,
    cp.phase_sequence,
    cp.physical_progress_percentage,
    cp.financial_progress_percentage,
    cp.planned_start_date,
    cp.planned_end_date,
    cp.actual_start_date,
    cp.actual_end_date,
    cp.phase_budget,
    cp.actual_cost,
    cp.status,
    CASE 
        WHEN cp.planned_end_date < CURRENT_DATE AND cp.status != 'COMPLETED' THEN true
        ELSE false
    END as is_delayed,
    CASE 
        WHEN cp.planned_end_date < CURRENT_DATE AND cp.status != 'COMPLETED' 
        THEN CURRENT_DATE - cp.planned_end_date
        ELSE 0
    END as days_delayed,
    CASE
        WHEN cp.phase_budget > 0 AND cp.physical_progress_percentage > 0
        THEN (cp.phase_budget * cp.physical_progress_percentage / 100) / NULLIF(cp.actual_cost, 0)
        ELSE NULL
    END as cost_performance_index,
    CASE
        WHEN cp.planned_start_date IS NOT NULL AND cp.planned_end_date IS NOT NULL
        AND cp.physical_progress_percentage IS NOT NULL
        THEN 
            CASE
                WHEN CURRENT_DATE < cp.planned_start_date THEN 1.0
                ELSE cp.physical_progress_percentage / 
                     NULLIF(EXTRACT(DAYS FROM (CURRENT_DATE - cp.planned_start_date)) * 100.0 / 
                            NULLIF(EXTRACT(DAYS FROM (cp.planned_end_date - cp.planned_start_date)), 0), 0)
            END
        ELSE NULL
    END as schedule_performance_index
FROM construction_phases cp;

CREATE OR REPLACE VIEW v_project_construction_summary AS
SELECT 
    p.id as project_id,
    p.name as project_name,
    p.project_code,
    COUNT(cp.id) as total_phases,
    COUNT(CASE WHEN cp.status = 'COMPLETED' THEN 1 END) as completed_phases,
    COUNT(CASE WHEN cp.status = 'IN_PROGRESS' THEN 1 END) as active_phases,
    COUNT(CASE WHEN cp.planned_end_date < CURRENT_DATE AND cp.status != 'COMPLETED' THEN 1 END) as delayed_phases,
    AVG(cp.physical_progress_percentage) as avg_physical_progress,
    AVG(cp.financial_progress_percentage) as avg_financial_progress,
    SUM(cp.phase_budget) as total_construction_budget,
    SUM(cp.actual_cost) as total_construction_cost,
    COUNT(cm.id) as total_milestones,
    COUNT(CASE WHEN cm.status = 'COMPLETED' THEN 1 END) as completed_milestones,
    COUNT(CASE WHEN cm.planned_date < CURRENT_DATE AND cm.status != 'COMPLETED' THEN 1 END) as overdue_milestones,
    COUNT(ct.id) as total_tests,
    COUNT(CASE WHEN ct.test_result = 'PASSED' THEN 1 END) as passed_tests,
    COUNT(CASE WHEN ct.test_result = 'FAILED' THEN 1 END) as failed_tests
FROM projects p
LEFT JOIN construction_phases cp ON p.id = cp.project_id
LEFT JOIN construction_milestones cm ON p.id = cm.project_id
LEFT JOIN construction_testing ct ON p.id = ct.project_id
GROUP BY p.id, p.name, p.project_code;

