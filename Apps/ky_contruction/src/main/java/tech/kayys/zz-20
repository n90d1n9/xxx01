    @Path("/{id}/optimize")
    public Response optimizeResources(@PathParam("id") Long phaseId) {
        ConstructionPhaseService.PhaseResourceOptimization optimization = 
                phaseService.optimizeResourceAllocation(phaseId);
        if (optimization == null) {
            return Response.status(404).build();
        }
        return Response.ok(optimization).build();
    }
    
    @GET
    @Path("/projects/{projectId}/delayed")
    public Response getDelayedPhases(@PathParam("projectId") Long projectId) {
        List<ConstructionPhase> delayed = phaseRepository.findDelayedPhases(projectId);
        return Response.ok(delayed).build();
    }
    
    @GET
    @Path("/{id}/performance")
    public Response getPhasePerformance(@PathParam("id") Long id) {
        ConstructionPhase phase = phaseRepository.findById(id);
        if (phase == null) {
            return Response.status(404).build();
        }
        
        Map<String, Object> performance = new HashMap<>();
        performance.put("schedulePerformanceIndex", phase.getSchedulePerformanceIndex());
        performance.put("costPerformanceIndex", phase.getCostPerformanceIndex());
        performance.put("isDelayed", phase.isDelayed());
        performance.put("daysDelayed", phase.getDaysDelayed());
        performance.put("physicalProgress", phase.physicalProgressPercentage);
        performance.put("financialProgress", phase.financialProgressPercentage);
        
        return Response.ok(performance).build();
    }
