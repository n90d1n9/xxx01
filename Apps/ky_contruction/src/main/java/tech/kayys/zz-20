        try {
            test.testResult = ConstructionTesting.TestResult.valueOf(result.toUpperCase());
            test.numericalResult = numericalResult;
            test.remarks = remarks;
            
            // Check if retest is required for failed tests
            if (test.testResult == ConstructionTesting.TestResult.FAILED) {
                test.retestRequired = true;
                test.correctiveActionRequired = true;
            }
            
            test.persist();
            return Response.ok(test).build();
            
        } catch (IllegalArgumentException e) {
            return Response.status(400).entity("Invalid test result: " + result).build();
        }
    }
    
    @GET
    @Path("/failed-tests")
    public Response getFailedTests(@QueryParam("project") Long projectId) {
        List<ConstructionTesting> failedTests;
        
        if (projectId != null) {
            failedTests = ConstructionTesting.list(
                    "project.id = ?1 and testResult = 'FAILED' ORDER BY testDate DESC", projectId);
        } else {
            failedTests = ConstructionTesting.list(
                    "testResult = 'FAILED' ORDER BY testDate DESC");
        }
        
        return Response.ok(failedTests).build();
    }
    
    @GET
    @Path("/retest-required")
    public Response getRetestRequired(@QueryParam("project") Long projectId) {
        List<ConstructionTesting> retestRequired;
        
        if (projectId != null) {
            retestRequired = ConstructionTesting.list(
                    "project.id = ?1 and retestRequired = true ORDER BY testDate DESC", projectId);
        } else {
            retestRequired = ConstructionTesting.list(
                    "retestRequired = true ORDER BY testDate DESC");
        }
        
        return Response.ok(retestRequired).build();
    }
    
    @GET
    @Path("/statistics")
    public Response getTestStatistics(@QueryParam("project") Long projectId) {
        Map<String, Object> stats = new HashMap<>();
        
        String baseQuery = projectId != null ? 
                "project.id = " + projectId + " and " : "";
        
        // Overall test statistics
        long totalTests = ConstructionTesting.count(
                (baseQuery + "1=1").replace(" and 1=1", ""));
        long passedTests = ConstructionTesting.count(
                baseQuery + "testResult = 'PASSED'");
        long failedTests = ConstructionTesting.count(
                baseQuery + "testResult = 'FAILED'");
        long pendingTests = ConstructionTesting.count(
                baseQuery + "testResult = 'PENDING'");
        
