    private void detectScheduleAnomalies(Project project) {
        // Detect activities significantly behind schedule
        List<ScheduleActivity> behindSchedule = ScheduleActivity
                .list("schedule.project = ?1 and actualStart > lateStart", project);
        
        if (!behindSchedule.isEmpty()) {
            BigDecimal anomalyScore = new BigDecimal(behindSchedule.size() * 20);
            createAnomaly(project, AnomalyDetection.AnomalyType.SCHEDULE_ANOMALY,
                    anomalyScore,
                    String.format("%d activities are behind their late start dates", behindSchedule.size()),
                    "Reassign resources and review critical path activities");
        }
    }
    
    private void detectProductivityAnomalies(Project project) {
        LocalDate weekAgo = LocalDate.now().minusWeeks(1);
        List<LaborProductivity> recentProductivity = LaborProductivity
                .list("project = ?1 and date >= ?2", project, weekAgo);
        
        if (!recentProductivity.isEmpty()) {
            double avgEfficiency = recentProductivity.stream()
                    .filter(p -> p.efficiencyPercentage != null)
                    .mapToDouble(p -> p.efficiencyPercentage.doubleValue())
                    .average()
                    .orElse(100.0);
            
            if (avgEfficiency < 60.0) { // Below 60% efficiency
                BigDecimal anomalyScore = new BigDecimal((100 - avgEfficiency) / 2);
                createAnomaly(project, AnomalyDetection.AnomalyType.PRODUCTIVITY_ANOMALY,
                        anomalyScore,
                        String.format("Average productivity efficiency: %.1f%%", avgEfficiency),
                        "Investigate work methods, provide training, or review resource allocation");
            }
        }
    }
    
    private void detectInvoiceAnomalies(Project project) {
        // Detect suspicious invoice patterns
        LocalDate monthAgo = LocalDate.now().minusMonths(1);
        
        List<Object[]> vendorInvoices = MaterialTransaction.find(
                "SELECT vendor, COUNT(*), SUM(totalCost) " +
                "FROM MaterialTransaction " +
                "WHERE project = ?1 and transactionDate >= ?2 and transactionType = 'PURCHASE' " +
                "GROUP BY vendor " +
                "HAVING COUNT(*) > 20 OR SUM(totalCost) > 1000000000", // > 1B IDR
                project, monthAgo.atStartOfDay()
        ).project(Object[].class).list();
        
        for (Object[] vendorData : vendorInvoices) {
            String vendor = (String) vendorData[0];
            Long invoiceCount = (Long) vendorData[1];
            BigDecimal totalAmount = (BigDecimal) vendorData[2];
            
            if (invoiceCount > 50 || totalAmount.compareTo(new BigDecimal("5000000000")) > 0) {
                createAnomaly(project, AnomalyDetection.AnomalyType.INVOICE_ANOMALY,
                        new BigDecimal("75"),
                        String.format("Vendor %s: %d invoices, total: Rp %,.0f", 
                                vendor, invoiceCount, totalAmount),
                        "Review vendor invoices for potential fraud or pricing issues");
            }
        }
    }
    
    private BigDecimal calculateAverageWeeklyCost(Project project) {
        LocalDate monthAgo = LocalDate.now().minusMonths(1);
        LocalDate weekAgo = LocalDate.now().minusWeeks(1);
        
        List<MaterialTransaction> historicalTransactions = MaterialTransaction
                .list("project = ?1 and transactionDate BETWEEN ?2 AND ?3", 
                        project, monthAgo.atStartOfDay(), weekAgo.atStartOfDay());
        
        if (historicalTransactions.isEmpty()) return BigDecimal.ZERO;
        
        BigDecimal totalCost = historicalTransactions.stream()
                .map(t -> t.totalCost != null ? t.totalCost : BigDecimal.ZERO)
                .reduce(BigDecimal.ZERO, BigDecimal::add);
        
        long weekCount = monthAgo.until(weekAgo).getDays() / 7;
        if (weekCount == 0) weekCount = 1;
        
        return totalCost.divide(new BigDecimal(weekCount), 2, java.math.RoundingMode.HALF_UP);
    }
    
    private void createAnomaly(Project project, AnomalyDetection.AnomalyType type, 
                             BigDecimal score, String description, String recommendation) {
        AnomalyDetection anomaly = new AnomalyDetection();
        anomaly.project = project;
        anomaly.detectionDate = LocalDateTime.now();
        anomaly.anomalyType = type;
        anomaly.anomalyScore = score;
        anomaly.description = description;
        anomaly.recommendation = recommendation;
        anomaly.persist();
    }
