class FormBuilderDesigner extends ConsumerStatefulWidget {
  const FormBuilderDesigner({Key? key}) : super(key: key);

  @override
  ConsumerState<FormBuilderDesigner> createState() => _FormBuilderDesignerState();
}

class _FormBuilderDesignerState extends ConsumerState<FormBuilderDesigner> {
  bool _checkedAutoSave = false;

  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addPostFrameCallback((_) {
      _checkAutoSave();
    });
  }

  Future<void> _checkAutoSave() async {
    if (_checkedAutoSave) return;
    _checkedAutoSave = true;

    final autoSaveData = await StorageManager.loadAutoSave();
    if (autoSaveData != null && mounted) {
      _showRecoveryDialog(autoSaveData);
    }
  }

  void _showRecoveryDialog(Map<String, dynamic> autoSaveData) {
    final timestamp = DateTime.parse(autoSaveData['timestamp'] as String);
    final timeDiff = DateTime.now().difference(timestamp);
    
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (context) => AlertDialog(
        backgroundColor: const Color(0xFF2D2D2D),
        title: Row(
          children: [
            const Icon(Icons.restore, color: Colors.blue),
            const SizedBox(width: 12),
            const Text('Recover Auto-Saved Form?', style: TextStyle(color: Colors.white)),
          ],
        ),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(
              'An auto-saved version was found from ${_formatTimeDiff(timeDiff)} ago.',
              style: const TextStyle(color: Colors.white70),
            ),
            const SizedBox(height: 16),
            Container(
              padding: const EdgeInsets.all(12),
              decoration: BoxDecoration(
                color: Colors.blue.withOpacity(0.1),
                borderRadius: BorderRadius.circular(8),
                border: Border.all(color: Colors.blue.withOpacity(0.3)),
              ),
              child: Row(
                children: [
                  const Icon(Icons.info_outline, color: Colors.blue, size: 20),
                  const SizedBox(width: 12),
                  Expanded(
                    child: Text(
                      'Contains ${(autoSaveData['fields'] as List).length} fields',
                      style: const TextStyle(color: Colors.blue),
                    ),
                  ),
                ],
              ),
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () {
              StorageManager.clearAutoSave();
              Navigator.pop(context);
            },
            child: const Text('Discard'),
          ),
          ElevatedButton.icon(
            icon: const Icon(Icons.restore),
            label: const Text('Recover'),
            onPressed: () {
              _recoverFromAutoSave(autoSaveData);
              Navigator.pop(context);
            },
          ),
        ],
      ),
    );
  }

  void _recoverFromAutoSave(Map<String, dynamic> data) {
    final fieldsJson = data['fields'] as List;
    final fields = fieldsJson.map((json) => FieldConfig.fromJson(json as Map<String, dynamic>)).toList();
    
    // Clear current state and load recovered data
    ref.read(formFieldsProvider.notifier).loadFields(fields);
    ref.read(autoSaveManagerProvider.notifier).markSaved();
    
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(
        content: Text('✅ Form recovered from auto-save'),
        backgroundColor: Colors.green,
      ),
    );
  }

  String _formatTimeDiff(Duration diff) {
    if (diff.inMinutes < 1) return 'less than a minute';
    if (diff.inMinutes < 60) return '${diff.inMinutes} minute${diff.inMinutes > 1 ? 's' : ''}';
    if (diff.inHours < 24) return '${diff.inHours} hour${diff.inHours > 1 ? 's' : ''}';
    return '${diff.inDays} day${diff.inDays > 1 ? 's' : ''}';
  }

  @override
  Widget build(BuildContext context) {
    final historyState = ref.watch(historyManagerProvider);
    final canUndo = historyState.currentIndex >= 0;
    final canRedo = historyState.currentIndex < historyState.history.length - 1;
    final selectionState = ref.watch(selectionManagerProvider);
    final clipboard = ref.watch(clipboardProvider);
    final showSearch = ref.watch(showSearchProvider);
    final showFilterPanel = ref.watch(showFilterPanelProvider);
    final filterManager = ref.watch(filterManagerProvider.notifier);
    final autoSaveState = ref.watch(autoSaveManagerProvider);

    // Mark as dirty when fields change
    ref.listen(formFieldsProvider, (_, __) {
      ref.read(autoSaveManagerProvider.notifier).markDirty();
    });

    return Scaffold(
      backgroundColor: const Color(0xFF1E1E1E),
      appBar: AppBar(
        title: const Text('🎨 Form Builder - Phase 1 Complete: Auto-Save & Recovery'),
        backgroundColor: const Color(0xFF2D2D2D),
        actions: [
          
      
        ],
      ),
      body: Column(
        children: [
          if (showSearch) const AdvancedSearchBar(),
          if (showFilterPanel) const FilterPanel(),
          if (selectionState.hasSelection) const BulkOperationsPanel(),
          const StatsBar(),
          Expanded(
            child: Focus(
              autofocus: true,
              onKey: (node, event) => _handleKeyEvent(event, ref),
              child: Row(
                children: [
                  const ComponentPalette(),
                  const Expanded(child: FormCanvas()),
                  const PropertiesPanel(),
                ],
              ),
            ),
          ),
        ],
      ),
    );
  }

}

