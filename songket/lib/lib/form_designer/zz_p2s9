            Icon(icon, size: 18, color: Colors.blue),
            const SizedBox(width: 12),
            Text(label, style: const TextStyle(color: Colors.white, fontSize: 13)),
          ],
        ),
      ),
    );
  }

  void _addField(WidgetRef ref, String type, String? label, {bool isContainer = false, Map<String, dynamic>? options}) {
    final field = FieldConfig(
      id: 'field_${DateTime.now().millisecondsSinceEpoch}',
      type: type,
      name: isContainer ? null : '${type}_${DateTime.now().millisecondsSinceEpoch}',
      label: label,
      children: isContainer ? [] : null,
      options: options,
    );

    ref.read(formFieldsProvider.notifier).addField(field);
  }
}

// ============================================================================
// FORM CANVAS (Simplified)
// ============================================================================

class FormCanvas extends ConsumerWidget {
  const FormCanvas({Key? key}) : super(key: key);

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final fields = ref.watch(formFieldsProvider);

    if (fields.isEmpty) {
      return Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            
          ],
        ),
      );
    }

    return SingleChildScrollView(
      padding: const EdgeInsets.all(24),
      child: Center(
        child: Container(
          constraints: const BoxConstraints(maxWidth: 800),
          child: Column(
            children: fields.asMap().entries.map((entry) {
              return FieldCard(field: entry.value, index: entry.key);
            }).toList(),
          ),
        ),
      ),
    );
  }
}

// ============================================================================
// FIELD CARD (Simplified)
// ============================================================================

class FieldCard extends ConsumerWidget {
  final FieldConfig field;
  final int index;

  const FieldCard({Key? key, required this.field, required this.index}) : super(key: key);

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final selectedField = ref.watch(selectedFieldProvider);
    final isSelected = selectedField?.id == field.id;

    return Container(
      margin: const EdgeInsets.only(bottom: 12),
      decoration: BoxDecoration(
        color: const Color(0xFF2D2D2D),
        border: Border.all(
          color: isSelected ? Colors.blue : const Color(0xFF3D3D3D),
          width: isSelected ? 2 : 1,
        ),
        borderRadius: BorderRadius.circular(8),
      ),
      child: InkWell(
        onTap: () => ref.read(selectedFieldProvider.notifier).state = field,
        child: Padding(
          padding: const EdgeInsets.all(16),
          child: Row(
            children: [
              Icon(Icons.drag_indicator, color: Colors.white.withOpacity(0.3), size: 20),
              const SizedBox(width: 12),
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    if (field.label != null)
                      Text(
                        field.label!,
                        style: const TextStyle(color: Colors.white, fontWeight: FontWeight.w500),
                      ),
                    const SizedBox(height: 8),
                    Container(
                      padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 10),
                      decoration: BoxDecoration(
                        color: const Color(0xFF1E1E1E),
                        border: Border.all(color: const Color(0xFF3D3D3D)),
                        borderRadius: BorderRadius.circular(6),
                      ),
                      child: Text(
                        field.hint ?? 'Field preview',
                        style: TextStyle(color: Colors.white.withOpacity(0.5)),
                      ),
                    ),
                  ],
                ),
              ),
              const SizedBox(width: 12),
              Column(
                children: [
                  IconButton(
                    icon: const Icon(Icons.content_copy, size: 18),
                    color: Colors.white70,
                    onPressed: () => ref.read(formFieldsProvider.notifier).duplicateField(field),
                  ),
                  IconButton(
                    icon: const Icon(Icons.delete, size: 18),
                    color: Colors.red,
                    onPressed: () => ref.read(formFieldsProvider.notifier).deleteField(field.id),
                  ),
                ],
              ),
            ],
          ),
        ),
      ),
    );
  }
}

// ============================================================================
// PROPERTIES PANEL (Simplified)
// ============================================================================

class PropertiesPanel extends ConsumerWidget {
  const PropertiesPanel({Key? key}) : super(key: key);

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final selectedField = ref.watch(selectedFieldProvider);

    if (selectedField == null) {
      return Container(
        width: 300,
        color: const Color(0xFF252526),
        child: const Center(
          child: Text('No field selected', style: TextStyle(color: Colors.white54)),
        ),
      );
    }

    return Container(
      width: 300,
      color: const Color(0xFF252526),
      padding: const EdgeInsets.all(16),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text(
            'PROPERTIES',
            style: TextStyle(
              color: Colors.white70,
              fontSize: 12,
              fontWeight: FontWeight.bold,
            ),
          ),
          const SizedBox(height: 16),
          const Text('Label', style: TextStyle(color: Colors.white)),
          const SizedBox(height: 8),
          TextField(
            controller: TextEditingController(text: selectedField.label ?? ''),
            style: const TextStyle(color: Colors.white),
            decoration: InputDecoration(
              filled: true,
              fillColor: const Color(0xFF1E1E1E),
              border: OutlineInputBorder(borderRadius: BorderRadius.circular(6)),
            ),
            onChanged: (value) {
              ref.read(formFieldsProvider.notifier).updateField(
                    selectedField.id,
                    selectedField.copyWith(label: value),
                  );
            },
          ),
        ],
      ),
    );
  }
}

