              ],
            ),
          ),
          // Bulk operations panel
          if (showBulkPanel) BulkOperationsPanel(),
          // Main content
          Expanded(
            child: Focus(
              autofocus: true,
              onKey: (node, event) => _handleKeyEvent(event, ref),
              child: Row(
                children: [
                  const ComponentPalette(),
                  const Expanded(child: FormCanvas()),
                  const PropertiesPanel(),
                ],
              ),
            ),
          ),
        ],
      ),
