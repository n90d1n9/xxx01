              _handleCopy(ref);
            } : null,
          ),
          // Paste
          IconButton(
            icon: const Icon(Icons.content_paste),
            tooltip: 'Paste (Ctrl+V)',
            onPressed: clipboard.isNotEmpty ? () {
              _handlePaste(ref);
            } : null,
          ),
          // Delete
          IconButton(
            icon: const Icon(Icons.delete),
            tooltip: 'Delete (Del)',
            onPressed: (selectedField != null || selectedFields.isNotEmpty) ? () {
              _handleDelete(ref);
            } : null,
