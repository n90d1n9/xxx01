class FieldCard extends ConsumerWidget {
  final FieldConfig field;
  final int index;

  const FieldCard({Key? key, required this.field, required this.index}) : super(key: key);

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final selectedField = ref.watch(selectedFieldProvider);
    final selectedFields = ref.watch(selectedFieldsProvider);
    final isSelected = selectedField?.id == field.id;
    final isMultiSelected = selectedFields.contains(field.id);

    return GestureDetector(
      onTap: () {
        if (RawKeyboard.instance.keysPressed.contains(LogicalKeyboardKey.controlLeft) ||
            RawKeyboard.instance.keysPressed.contains(LogicalKeyboardKey.controlRight)) {
          // Ctrl+Click - Toggle multi-select
          final newSet = Set<String>.from(selectedFields);
          if (isMultiSelected) {
            newSet.remove(field.id);
          } else {
            newSet.add(field.id);
          }
          ref.read(selectedFieldsProvider.notifier).state = newSet;
        } else {
          // Regular click - Select single
          ref.read(selectedFieldProvider.notifier).state = field;
          ref.read(selectedFieldsProvider.notifier).state = {};
        }
      },
      child: Container(
        margin: const EdgeInsets.only(bottom: 12),
        decoration: BoxDecoration(
          color: const Color(0xFF2D2D2D),
          border: Border.all(
            color: (isSelected || isMultiSelected) ? Colors.blue : const Color(0xFF3D3D3D),
            width: (isSelected || isMultiSelected) ? 2 : 1,
          ),
          borderRadius: BorderRadius.circular(8),
        ),
        child: Padding(
          padding: const EdgeInsets.all(16),
          child: Row(
            children: [
              // Multi-select checkbox
              if (selectedFields.isNotEmpty || isMultiSelected)
                Padding(
                  padding: const EdgeInsets.only(right: 12),
                  child: Icon(
                    isMultiSelected ? Icons.check_box : Icons.check_box_outline_blank,
                    color: isMultiSelected ? Colors.blue : Colors.white54,
                    size: 20,
                  ),
                ),
              Icon(Icons.drag_indicator, color: Colors.white.withOpacity(0.3), size: 20),
              const SizedBox(width: 12),
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Row(
                      children: [
                        if (field.label != null)
                          Text(
                            field.label!,
                            style: const TextStyle(color: Colors.white, fontWeight: FontWeight.w500),
                          ),
                        const Spacer(),
                        Container(
                          padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 2),
                          decoration: BoxDecoration(
                            color: Colors.blue.withOpacity(0.2),
                            borderRadius: BorderRadius.circular(4),
                          ),
                          child: Text(
                            field.type,
                            style: const TextStyle(color: Colors.blue, fontSize: 10),
                          ),
                        ),
                      ],
                    ),
                    const SizedBox(height: 8),
                    Container(
                      padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 10),
                      decoration: BoxDecoration(
                        color: const Color(0xFF1E1E1E),
                        border: Border.all(color: const Color(0xFF3D3D3D)),
                        borderRadius: BorderRadius.circular(6),
                      ),
                      child: Text(
                        field.hint ?? 'Field preview',
                        style: TextStyle(color: Colors.white.withOpacity(0.5)),
                      ),
                    ),
                  ],
                ),
              ),
              const SizedBox(width: 12),
              Column(
                children: [
                  IconButton(
                    icon: const Icon(Icons.content_copy, size: 18),
                    color: Colors.white70,
                    tooltip: 'Duplicate (Ctrl+D)',
                    onPressed: () => ref.read(formFieldsProvider.notifier).duplicateField(field),
                  ),
                  IconButton(
                    icon: const Icon(Icons.delete, size: 18),
                    color: Colors.red,
                    tooltip: 'Delete (Del)',
                    onPressed: () => ref.read(formFieldsProvider.notifier).deleteField(field.id),
                  ),
                ],
              ),
            ],
          ),
        ),
      ),
    );
  }
