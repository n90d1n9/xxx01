class ComponentPaletteWidget extends ConsumerWidget {
  final FormTheme theme;
  const ComponentPaletteWidget({Key? key, required this.theme}) : super(key: key);

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    return Container(
      width: 250,
      color: theme.colors.surface,
      child: ListView(
        padding: const EdgeInsets.all(16),
        children: [
          Text(
            'ADVANCED LAYOUTS',
            style: TextStyle(
              color: theme.colors.textSecondary,
              fontSize: 12,
              fontWeight: FontWeight.bold,
            ),
          ),
          const SizedBox(height: 12),
          ...advancedLayoutFieldTypes.map((fieldType) {
            return _ComponentButton(
              theme: theme,
              label: fieldType.label,
              icon: fieldType.icon,
              onTap: () => _addAdvancedLayout(ref, fieldType.type),
            );
          }),
        ],
      ),
    );
  }

  void _addAdvancedLayout(WidgetRef ref, String type) {
    final field = FieldConfig(
      id: 'field_${DateTime.now().millisecondsSinceEpoch}',
      type: type,
      name: '${type}_${DateTime.now().millisecondsSinceEpoch}',
      label: null,
      options: _getDefaultLayoutOptions(type),
    );

    ref.read(formFieldsProvider.notifier).addField(field);
    ref.read(selectedFieldProvider.notifier).state = field;
  }

  Map<String, dynamic> _getDefaultLayoutOptions(String type) {
    switch (type) {
      case 'tabs':
        return {
          'tabs': [
            TabConfig(id: 'tab1', label: 'Tab 1', fields: []).toJson(),
            TabConfig(id: 'tab2', label: 'Tab 2', fields: []).toJson(),
          ],
        };
      case 'stepper':
        return {
          'steps': [
            StepConfig(id: 'step1', title: 'Step 1', fields: []).toJson(),
            StepConfig(id: 'step2', title: 'Step 2', fields: []).toJson(),
          ],
        };
      case 'accordion':
        return {
          'panels': [
            AccordionPanelConfig(id: 'panel1', header: 'Panel 1', fields: []).toJson(),
            AccordionPanelConfig(id: 'panel2', header: 'Panel 2', fields: []).toJson(),
          ],
        };
      default:
        return {};
    }
  }
}

