class FormBuilderDesigner extends ConsumerStatefulWidget {
  const FormBuilderDesigner({Key? key}) : super(key: key);

  @override
  ConsumerState<FormBuilderDesigner> createState() => _FormBuilderDesignerState();
}

class _FormBuilderDesignerState extends ConsumerState<FormBuilderDesigner> {
  bool _checkedAutoSave = false;

  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addPostFrameCallback((_) {
      _checkAutoSave();
    });
  }

  Future<void> _checkAutoSave() async {
    if (_checkedAutoSave) return;
    _checkedAutoSave = true;
    final autoSaveData = await StorageManager.loadAutoSave();
    if (autoSaveData != null && mounted) {
      _showRecoveryDialog(autoSaveData);
    }
  }

  void _showRecoveryDialog(Map<String, dynamic> autoSaveData) {
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (context) => AlertDialog(
        backgroundColor: const Color(0xFF2D2D2D),
        title: const Row(
          children: [
            Icon(Icons.restore, color: Colors.blue),
            SizedBox(width: 12),
            Text('Recover Auto-Saved Form?', style: TextStyle(color: Colors.white)),
          ],
        ),
        content: const Text('An auto-saved version was found.', style: TextStyle(color: Colors.white70)),
        actions: [
          TextButton(
            onPressed: () {
              StorageManager.clearAutoSave();
              Navigator.pop(context);
            },
            child: const Text('Discard'),
          ),
          ElevatedButton(
            onPressed: () {
              final fieldsJson = autoSaveData['fields'] as List;
              final fields = fieldsJson.map((json) => FieldConfigExtension.fromJson(json as Map<String, dynamic>)).toList();
              ref.read(formFieldsProvider.notifier).loadFields(fields);
              Navigator.pop(context);
            },
            child: const Text('Recover'),
          ),
        ],
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    final theme = ref.watch(themeManagerProvider);
    final showGrid = ref.watch(showGridProvider);
    final snapToGrid = ref.watch(snapToGridProvider);
    final dragDropState = ref.watch(dragDropManagerProvider);

    return Scaffold(
      backgroundColor: theme.colors.background,
      appBar: AppBar(
        title: const Text('🎨 Form Builder - Phase 2: Step 9 - Drag & Drop'),
        backgroundColor: theme.colors.surface,
        foregroundColor: theme.colors.text,
        actions: [
          // Drag & Drop controls
          PopupMenuButton(
            icon: Icon(Icons.grid_on, color: theme.colors.text),
            tooltip: 'View Options',
            itemBuilder: (context) => [
              CheckedPopupMenuItem(
                checked: showGrid,
                value: 'grid',
                child: const Text('Show Grid'),
              ),
              CheckedPopupMenuItem(
                checked: snapToGrid,
                value: 'snap',
                child: const Text('Snap to Grid'),
              ),
            ],
            onSelected: (value) {
              if (value == 'grid') {
                ref.read(showGridProvider.notifier).state = !showGrid;
              } else if (value == 'snap') {
                ref.read(snapToGridProvider.notifier).state = !snapToGrid;
              }
            },
          ),
          
          // Drag status indicator
          if (dragDropState.isDragging)
            Container(
              margin: const EdgeInsets.symmetric(horizontal: 8, vertical: 12),
              padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
              decoration: BoxDecoration(
                color: theme.colors.primary.withOpacity(0.2),
                borderRadius: BorderRadius.circular(12),
              ),
              child: Row(
                children: [
                  Icon(Icons.open_with, size: 16, color: theme.colors.primary),
                  const SizedBox(width: 6),
                  Text(
                    'Dragging...',
                    style: TextStyle(color: theme.colors.primary, fontSize: 11),
                  ),
                ],
              ),
            ),
          
          const VerticalDivider(),
          IconButton(
            icon: Icon(Icons.code, color: theme.colors.text),
            tooltip: 'Export',
            onPressed: () => _showExportDialog(),
          ),
        ],
      ),
      body: Row(
        children: [
          ComponentPaletteWidget(theme: theme),
          Expanded(child: FormCanvasWidget(theme: theme)),
          EnhancedPropertiesPanel(
            theme: theme,
            selectedField: ref.watch(selectedFieldProvider),
          ),
        ],
      ),
    );
  }

  void _showExportDialog() {
    final config = ref.read(formFieldsProvider.notifier).exportConfig();
    final theme = ref.read(themeManagerProvider);

    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        backgroundColor: theme.colors.surface,
        title: Text('Export Config', style: TextStyle(color: theme.colors.text)),
        content: SizedBox(
          width: 600,
          height: 400,
          child: SingleChildScrollView(
            child: SelectableText(config, style: TextStyle(color: theme.colors.primary, fontFamily: 'monospace', fontSize: 12)),
          ),
        ),
        actions: [
          TextButton(onPressed: () => Navigator.pop(context), child: const Text('Close')),
          ElevatedButton.icon(
            icon: const Icon(Icons.copy),
            label: const Text('Copy'),
            onPressed: () {
              Clipboard.setData(ClipboardData(text: config));
              Navigator.pop(context);
            },
          ),
