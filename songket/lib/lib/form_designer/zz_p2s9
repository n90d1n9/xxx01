extension FieldConfigExtension on FieldConfig {
  static FieldConfig fromJson(Map<String, dynamic> json) {
    return FieldConfig(
      id: json['id'] as String? ?? 'field_${DateTime.now().millisecondsSinceEpoch}',
      type: json['type'] as String,
      name: json['name'] as String?,
      label: json['label'] as String?,
      title: json['title'] as String?,
      description: json['description'] as String?,
      hint: json['hint'] as String?,
      required: json['required'] as bool? ?? false,
      children: json['children'] != null
          ? (json['children'] as List).map((c) => FieldConfigExtension.fromJson(c as Map<String, dynamic>)).toList()
          : null,
      options: json['options'] as Map<String, dynamic>?,
      visibleIf: json['visibleIf'] as String?,
    );
  }
}

