    return GestureDetector(
      onTap: () => _handleTap(ref),
      onSecondaryTapDown: (details) => _showContextMenu(context, ref, details.globalPosition),
      child: Container(
        margin: const EdgeInsets.only(bottom: 12),
        decoration: BoxDecoration(
          color: const Color(0xFF2D2D2D),
          border: Border.all(
            color: (isSelected || isMultiSelected) ? Colors.blue : const Color(0xFF3D3D3D),
            width: (isSelected || isMultiSelected) ? 2 : 1,
          ),
          borderRadius: BorderRadius.circular(8),
          boxShadow: isMultiSelected ? [
            BoxShadow(
              color: Colors.blue.withOpacity(0.3),
              blurRadius: 8,
              spreadRadius: 1,
            ),
          ] : null,
        ),
        child: Padding(
          padding: const EdgeInsets.all(16),
          child: Row(
            children: [
              // Multi-select checkbox
              if (selectionState.hasSelection || isMultiSelected)
                Padding(
                  padding: const EdgeInsets.only(right: 12),
                  child: Icon(
                    isMultiSelected ? Icons.check_box : Icons.check_box_outline_blank,
                    color: isMultiSelected ? Colors.blue : Colors.white54,
                    size: 20,
                  ),
                ),
              Icon(Icons.drag_indicator, color: Colors.white.withOpacity(0.3), size: 20),
              const SizedBox(width: 12),
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Row(
                      children: [
                        if (field.label != null)
                          Expanded(
                            child: Text(
                              field.label!,
                              style: const TextStyle(color: Colors.white, fontWeight: FontWeight.w500),
                            ),
                          ),
                        if (field.required)
                          const Icon(Icons.star, size: 14, color: Colors.red),
                        const SizedBox(width: 8),
                        Container(
                          padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 2),
                          decoration: BoxDecoration(
                            color: Colors.blue.withOpacity(0.2),
                            borderRadius: BorderRadius.circular(4),
                          ),
                          child: Text(
                            field.type,
                            style: const TextStyle(color: Colors.blue, fontSize: 10),
                          ),
                        ),
                      ],
                    ),
                    const SizedBox(height: 8),
                    Container(
                      padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 10),
                      decoration: BoxDecoration(
                        color: const Color(0xFF1E1E1E),
                        border: Border.all(color: const Color(0xFF3D3D3D)),
                        borderRadius: BorderRadius.circular(6),
                      ),
                      child: Text(
                        field.hint ?? 'Field preview',
                        style: TextStyle(color: Colors.white.withOpacity(0.5)),
                      ),
                    ),
                  ],
                ),
              ),
              if (!selectionState.hasSelection) ...[
                const SizedBox(width: 12),
                Column(
                  children: [
                    IconButton(
                      icon: const Icon(Icons.content_copy, size: 18),
                      color: Colors.white70,
                      tooltip: 'Duplicate',
                      onPressed: () => ref.read(formFieldsProvider.notifier).duplicateField(field),
                    ),
                    IconButton(
                      icon: const Icon(Icons.delete, size: 18),
                      color: Colors.red,
                      tooltip: 'Delete',
                      onPressed: () => ref.read(formFieldsProvider.notifier).deleteField(field.id),
                    ),
                  ],
                ),
              ],
            ],
          ),
        ),
      ),
    );
  }

  void _handleTap(WidgetRef ref) {
    final isCtrl = RawKeyboard.instance.keysPressed.contains(LogicalKeyboardKey.controlLeft) ||
                   RawKeyboard.instance.keysPressed.contains(LogicalKeyboardKey.controlRight);
    final isShift = RawKeyboard.instance.keysPressed.contains(LogicalKeyboardKey.shiftLeft) ||
                    RawKeyboard.instance.keysPressed.contains(LogicalKeyboardKey.shiftRight);
    
    final selectionState = ref.read(selectionManagerProvider);

    if (isShift && selectionState.lastSelectedId != null) {
      // Shift+Click - Range selection
      final fields = ref.read(formFieldsProvider);
      ref.read(selectionManagerProvider.notifier).rangeSelect(
        fields,
        selectionState.lastSelectedId!,
        field.id,
      );
    } else if (isCtrl) {
      // Ctrl+Click - Toggle selection
      ref.read(selectionManagerProvider.notifier).toggleSelection(field.id);
    } else {
      // Regular click - Single selection
      ref.read(selectedFieldProvider.notifier).state = field;
      ref.read(selectionManagerProvider.notifier).clearSelection();
    }
  }

  void _showContextMenu(BuildContext context, WidgetRef ref, Offset position) {
    showMenu(
      context: context,
      position: RelativeRect.fromLTRB(position.dx, position.dy, position.dx, position.dy),
      items: [
        const PopupMenuItem(
          value: 'copy',
          child: Row(
            children: [
              Icon(Icons.content_copy, size: 16),
              SizedBox(width: 8),
              Text('Copy'),
            ],
          ),
        ),
        const PopupMenuItem(
          value: 'duplicate',
          child: Row(
            children: [
              Icon(Icons.file_copy, size: 16),
              SizedBox(width: 8),
              Text('Duplicate'),
            ],
          ),
        ),
        const PopupMenuItem(
          value: 'delete',
          child: Row(
            children: [
              Icon(Icons.delete, size: 16, color: Colors.red),
              SizedBox(width: 8),
              Text('Delete', style: TextStyle(color: Colors.red)),
            ],
          ),
        ),
        const PopupMenuDivider(),
        const PopupMenuItem(
          value: 'select_type',
          child: Row(
            children: [
              Icon(Icons.select_all, size: 16),
              SizedBox(width: 8),
              Text('Select all of type'),
            ],
          ),
        ),
      ],
    ).then((value) {
      if (value != null) {
        switch (value) {
          case 'copy':
            ref.read(clipboardProvider.notifier).copy([field]);
            break;
          case 'duplicate':
            ref.read(formFieldsProvider.notifier).duplicateField(field);
            break;
          case 'delete':
            ref.read(formFieldsProvider.notifier).deleteField(field.id);
            break;
          case 'select_type':
            final fields = ref.read(formFieldsProvider);
            ref.read(selectionManagerProvider.notifier).selectByType(fields, field.type);
            break;
        }
      }
    });
  }
}


