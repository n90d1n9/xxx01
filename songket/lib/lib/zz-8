  final String? transformation; // e.g., "UPPER", "TRIM", "FORMAT"
  final Map<String, dynamic>? validationRules;
  final List<ConditionalFormat>? conditionalFormats;
  final String? hyperlink; // Link pattern
  final bool isCalculated;
  final bool isDerived; // Derived from other columns
  final String? aiSuggestion; // AI-suggested configuration
  
  AdvancedReportColumn({
    required this.id,
    required this.fieldName,
    required this.displayName,
    required this.dataType,
    this.sortable = true,
    this.filterable = true,
    this.aggregatable = false,
    this.groupable = false,
    this.visible = true,
    this.width = 150,
    this.minWidth,
    this.maxWidth,
    this.resizable = true,
    this.frozen = false,
    this.tooltip,
    this.formula,
    this.dependencies,
    this.transformation,
    this.validationRules,
    this.conditionalFormats,
    this.hyperlink,
    this.isCalculated = false,
    this.isDerived = false,
    this.aiSuggestion,
  });

  Map<String, dynamic> toJson() => {
    'id': id,
    'fieldName': fieldName,
    'displayName': displayName,
    'dataType': dataType.name,
    'sortable': sortable,
    'filterable': filterable,
    'aggregatable': aggregatable,
    'groupable': groupable,
    'visible': visible,
    'width': width,
    'minWidth': minWidth,
    'maxWidth': maxWidth,
    'resizable': resizable,
    'frozen': frozen,
    'tooltip': tooltip,
    'formula': formula,
    'dependencies': dependencies,
    'transformation': transformation,
    'validationRules': validationRules,
    'conditionalFormats': conditionalFormats?.map((c) => c.toJson()).toList(),
    'hyperlink': hyperlink,
